// ══════════════════════════════════════════════════════════════════════
// config_inc.iqx — Shared configuration for the Undo Threshold experiment
//
// Defines: defaults, parameters, values, expressions, data columns,
//          shared stimuli (fixation cross, dot-pattern pictures),
//          and the instruct navigation element.
//
// Must be included FIRST in main.iqx.
// All element names use the "ut_" prefix to avoid namespace conflicts.
// ══════════════════════════════════════════════════════════════════════

// ── Display Defaults ──────────────────────────────────────────────────
<defaults>
/ canvasaspectratio = (4, 3)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ screencolor = white
/ txcolor = black
/ inputdevice = keyboard
</defaults>

// ── Timing and Design Parameters ──────────────────────────────────────
<parameters>
// Timing (all in ms)
/ ut_fixation_duration = 500
/ ut_response_timeout = 2000
/ ut_correction_window = 500
/ ut_feedback_duration = 500
/ ut_post_trial_pause = 500

// Response keys
/ ut_left_key = "d"
/ ut_right_key = "k"

// Practice settings
/ ut_practice_trials_per_block = 12
/ ut_min_practice_acc = 75
/ ut_max_practice_repeats = 3
</parameters>

// ── Runtime Values ────────────────────────────────────────────────────
// These track trial-level state and are updated in ontrialbegin/ontrialend.
<values>
// Condition tracking
/ ut_condition = ""
/ ut_trial_num = 0

// Stimulus properties (set in ontrialbegin from list index)
/ ut_stim_index = 0
/ ut_direction = 0
/ ut_coherence = 0
/ ut_correct_key = ""

// Initial response data
/ ut_initial_response = ""
/ ut_initial_rt = 0
/ ut_initial_correct = 0

// Correction data (Block B only; stays 0 in Block A)
/ ut_correction_made = 0
/ ut_correction_response = ""
/ ut_correction_rt = 0

// Final response (= initial if no correction, = corrected if corrected)
/ ut_final_response = ""
/ ut_final_rt = 0
/ ut_final_correct = 0

// Helper for coherence decoding
/ ut_coh_offset = 0

// Practice tracking
/ ut_practice_repeat_count = 0
/ ut_practice_acc = 0
/ ut_practice_failed = 0

// Completion code: 3 random digits (1-6), prefixed with 9 if practice failed
/ ut_code_digit1 = 0
/ ut_code_digit2 = 0
/ ut_code_digit3 = 0
/ ut_completion_code = ""
</values>

// ── Expressions ───────────────────────────────────────────────────────
// Computed values for data analysis convenience.
<expressions>
// Direction as text (1=left, 2=right)
/ ut_direction_label = if (values.ut_direction == 1) "left" else "right"
// Coherence as text (1=high, 2=medium, 3=low)
/ ut_coherence_label = if (values.ut_coherence == 1) "high" else if (values.ut_coherence == 2) "medium" else "low"
</expressions>

// ── Data Export ───────────────────────────────────────────────────────
// All custom values must be listed here or they won't appear in .iqdat.
<data>
/ columns = [date time subject group blocknum blockcode trialnum trialcode
             latency response correct
             values.ut_condition
             values.ut_stim_index
             values.ut_direction
             values.ut_coherence
             expressions.ut_direction_label
             expressions.ut_coherence_label
             values.ut_correct_key
             values.ut_initial_response
             values.ut_initial_rt
             values.ut_initial_correct
             values.ut_correction_made
             values.ut_correction_response
             values.ut_correction_rt
             values.ut_final_response
             values.ut_final_rt
             values.ut_final_correct
             values.ut_practice_failed
             values.ut_completion_code]
/ separatefiles = true
</data>

// ── Instruction Navigation ────────────────────────────────────────────
<instruct>
/ nextkey = (" ")
/ prevkey = (noresponse)
/ nextlabel = "Press SPACE to continue"
/ prevlabel = ""
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</instruct>

// ── Shared Stimuli ────────────────────────────────────────────────────

// Fixation cross: small black "+" centered on screen
<text ut_fixation>
/ items = ("+")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ txcolor = black
</text>

// Dot-motion stimulus images (90 images loaded from file list)
// Items 1-15: left_high, 16-30: left_medium, 31-45: left_low
// Items 46-60: right_high, 61-75: right_medium, 76-90: right_low
