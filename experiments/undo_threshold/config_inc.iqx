<picture ut_dot_stimulus>
/ items = ut_all_dots
/ select = values.ut_stim_index
/ size = (30%, 40%)
/ position = (50%, 50%)
</picture>

// Response key labels shown at bottom of screen during trials
<text ut_key_labels>
/ items = ("D = Left                                          K = Right")
/ position = (50%, 92%)
/ fontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ txcolor = gray
</text>

// ── Completion Code Random Digit Lists ────────────────────────────────
// Three separate lists for 3 independent random draws (digits 1-6)
<list ut_code_list1>
/ items = (1, 2, 3, 4, 5, 6)
/ selectionmode = random
/ replace = true
</list>

<list ut_code_list2>
/ items = (1, 2, 3, 4, 5, 6)
/ selectionmode = random
/ replace = true
</list>

<list ut_code_list3>
/ items = (1, 2, 3, 4, 5, 6)
/ selectionmode = random
/ replace = true
</list>
