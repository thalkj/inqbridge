**************************************************************************************************************
**************************************************************************************************************
	PRACTICE TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial go_practice>
/ ontrialbegin = [
	trial.go_practice.insertStimulusTime(clearScreen, parameters.stimDuration);	
]
/ stimulustimes = [0 = practice]
/ validresponse = (parameters.goKey)
/ correctresponse = (parameters.goKey)
/ beginresponsetime = 0
/ responseinterrupt = frames
/ timeout = parameters.responseDuration
/ ontrialend = [
	trial.go_practice.resetStimulusFrames();
	values.respRT = trial.go_practice.latency;
	
	values.word = text.practice.currentItem;

	if (trial.go_practice.correct){
		values.responseCategory = "HIT";
	} else {
		values.responseCategory = "MISS";
		values.respRT = "";
	}
]
/ branch = [
	if (values.responseCategory == "HIT"){
		return trial.correctfeedback;
	} else {
		return trial.errorfeedback;
	}
]
</trial>
		
<trial nogo_practice>
/ ontrialbegin = [
	trial.nogo_practice.insertStimulusTime(clearScreen, parameters.stimDuration);	
]
/ stimulustimes = [0 = practice_comp]
/ validresponse = (parameters.goKey)
/ correctresponse = (0)
/ beginresponsetime = 0
/ responseinterrupt = frames
/ timeout = parameters.responseDuration
/ ontrialend = [
	trial.nogo_practice.resetStimulusFrames();
	values.respRT = trial.nogo_practice.latency;

	values.word = text.practice_comp.currentItem;

	if (trial.nogo_practice.correct){
		values.responseCategory = "CR";
		values.respRT = "";
	} else {
		values.responseCategory = "FA";
	}
]
/ branch = [
	if (values.responseCategory == "CR"){
		return trial.correctfeedback;
	} else {
		return trial.errorfeedback;
	}
]
</trial>	


<trial correctfeedback>
/ stimulusframes = [1 = correctFeedback]
//for touchscreens: present inactive response button
/ validresponse = (parameters.goKey)
/ isvalidresponse = [
	return false;
]
/timeout = parameters.practiceFeedbackDuration
/ posttrialpause = 500
/ recorddata = true
</trial>


<trial errorfeedback>
/ ontrialbegin = [
	if (values.responseCategory == "FA"){
		text.MissFeedback.skip	= true;
		text.FAFeedback.skip = false;		
	} else {
		text.MissFeedback.skip	= false;
		text.FAFeedback.skip = true;		
	}

]
/ stimulusframes = [1 = MissFeedback, FAFeedback]
/ validresponse = (" ")
/ posttrialpause = 500
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial start>
/ ontrialbegin = [
	text.fixation.textColor = white;
]
/ stimulusframes = [1 = fixation]

//for touchscreens: present inactive response button
/ validresponse = (parameters.goKey)
/ isvalidresponse = [
	return false;
]

/ trialduration = parameters.startFixation
/ recorddata = false
</trial>

<trial end>
/ ontrialbegin = [
	text.fixation.textColor = red;
]
/ stimulusframes = [1 = fixation]

//for touchscreens: present inactive response button
/ validresponse = (parameters.goKey)
/ isvalidresponse = [
	return false;
]

/ trialduration = parameters.endFixation
/ recorddata = false
</trial>
	
<trial go>
/ ontrialbegin = [

	//select the appropriate go stim that should be dynamically presented at the start of the trial depending on which block is currently run
	if (values.condition == "NH"){
		trial.go.insertStimulusTime(text.neutral, 0);
	} else if (values.condition == "NS"){
		trial.go.insertStimulusTime(text.neutral, 0);
	} else if (values.condition == "HS"){
		trial.go.insertStimulusTime(text.positive, 0);
	} else if (values.condition == "HN"){
		trial.go.insertStimulusTime(text.positive, 0);
	} else if (values.condition == "SH"){
		trial.go.insertStimulusTime(text.negative, 0);
	} else if (values.condition == "SN"){
		trial.go.insertStimulusTime(text.negative, 0);
	}
	
	//remove the presented stim after stimDuration
	trial.go.insertStimulusTime(clearScreen, parameters.stimDuration);
	
	//select the duration of the inter trial interval to be run after this trial
	values.iti = list.iti.nextValue;
]
/ validresponse = (parameters.goKey)
/ correctresponse = (parameters.goKey)
/ beginresponsetime = 0
/ responseinterrupt = frames
/ timeout = parameters.responseDuration
/ ontrialend = [
	trial.go.resetStimulusFrames();//due the use of dynamic stimulus presentation, the trials needs to be reset for future uses
	values.respRT = trial.go.latency;
	
	//Summary Variables:
	
	//add 1 (correct = Hit) or 0 (incorrect = Miss) to the list that collects responses in go trials (those are either hits or misses)
	//and store correct response latencies
	
	//across all different blocks
	list.Hits.appendItem(trial.go.correct);
	if (trial.go.correct){
		list.hitRT.appendItem(trial.go.latency);
	}

	//separately for each experimental block	
	if (values.condition == "NH"){
		values.word = text.neutral.currentItem;
		list.Hits_NH.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_NH.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";
		}
		
	} else if (values.condition == "HN"){
		values.word = text.positive.currentItem;
		list.Hits_HN.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_HN.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";
		}
		
	} else if (values.condition == "NS"){
		values.word = text.neutral.currentItem;
		list.Hits_NS.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_NS.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";
		}
		
	}  else if (values.condition == "HS"){
		values.word = text.positive.currentItem;
		list.Hits_HS.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_HS.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";
		}
		
	}  else if (values.condition == "SH"){
		values.word = text.negative.currentItem;
		list.Hits_SH.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_SH.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";		}
		
	}  else if (values.condition == "SN"){
		values.word = text.negative.currentItem;
		list.Hits_SN.appendItem(trial.go.correct);
		if (trial.go.correct){
			values.responseCategory = "HIT";
			list.hitRT_SN.appendItem(trial.go.latency);
		} else {
			values.responseCategory = "MISS";
			values.respRT = "";
		}
		
	}
]
/ posttrialpause = values.iti
</trial>
	
<trial nogo>
/ ontrialbegin = [
	//select the appropriate NOGO stim that should be dynamically presented at the start of the trial depending on which block is currently run
	if (values.condition == "HN"){
		trial.nogo.insertStimulusTime(text.neutral, 0);
	} else if (values.condition == "NH"){
		trial.nogo.insertStimulusTime(text.positive, 0);
	} else if (values.condition == "HS"){
		trial.nogo.insertStimulusTime(text.negative, 0);
	} else if (values.condition == "SH"){
		trial.nogo.insertStimulusTime(text.positive, 0);
	} else if (values.condition == "SN"){
		trial.nogo.insertStimulusTime(text.neutral, 0);
	} else if (values.condition == "NS"){
		trial.nogo.insertStimulusTime(text.negative, 0);
	}
		
	trial.nogo.insertStimulusTime(clearScreen, parameters.stimDuration);	
	values.iti = list.iti.nextValue;	
]
/ validresponse = (parameters.goKey)
/ correctresponse = (0)
/ beginresponsetime = 0
/ responseinterrupt = frames
/ timeout = parameters.responseDuration
/ ontrialend = [
	trial.nogo.resetStimulusFrames();
	values.respRT = trial.nogo.latency;

	//Summary Variables:
	//because it's a nogo trial, correct responses are correct rejections (CR) and incorrect responses are false alarms (FA)
	
	//across all blocks:
	list.FAs.appendItem(trial.nogo.error);
	
	//separately by block:
	if (values.condition == "HN"){
		values.word = text.neutral.currentItem;
		list.FAs_HN.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
		
	} else if (values.condition == "NH"){
		values.word = text.positive.currentItem;
		list.FAs_NH.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
	} else if (values.condition == "HS"){
		values.word = text.negative.currentItem;
		list.FAs_HS.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
	}  else if (values.condition == "SH"){
		values.word = text.positive.currentItem;
		list.FAs_SH.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
	} else if (values.condition == "SN"){
		values.word = text.neutral.currentItem;
		list.FAs_SN.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
	}  else if (values.condition == "NS"){
		values.word = text.negative.currentItem;
		list.FAs_NS.appendItem(trial.nogo.error);
		if (trial.nogo.correct){
			values.responseCategory = "CR";
			values.respRT = "";
		} else {
			values.responseCategory = "FA";
		}
	}
]
/ posttrialpause = values.iti;
</trial>	
		
**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block intro>
/ onblockbegin = [
	values.GoStim = "";
	values.NoGoStim = "";
]
/ trials = [1-2 = instructions]
</block>

<block practice>
/ skip = [
	parameters.runPractice == false;
]
/ onblockbegin = [
	values.GoStim = item.practiceGo_catLABEL.item(1); //selects the appropriate label for the practice GO category
	values.NoGoStim = item.practiceNoGo_catLABEL.item(1); //selects the appropriate label for the practice NOGO category
	values.condition = "practice";
]
/ trials = [
	1 = blockInstructions; 
	2 = getReady; 
	3 = start; 
	4-13 = noreplace(go_practice, nogo_practice); //calls 10 practice trials: 5 go and 5 nogo trials
	14 = end;
]
</block>

<block testInstructions>
/ trials = [1 = testInstructions]
</block>


//HN = positive go, neutral nogo
<block HN>
/ onblockbegin = [
	values.condition = "HN";
	values.GoStim = item.positive_catLABEL.item(1); //selects the appropriate label (positive) for the HN GO category
	values.NoGoStim = item.neutral_catLABEL.item(1); //selects the appropriate label (neutral) for the HN NOGO category
	text.instructions.textColor = turquoise;
	list.iti.reset();
	text.neutral.resetSelection();//resets the lists of positive words, so that all positive words are available for selection again
	text.positive.resetSelection(); //resets the lists of neutral words, so that all neutral words are available for selection again
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>
//Note: to change the ratio to 2 Go: 1 Nogo trial use: / trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-33 = noreplace(go, go, nogo); 34 = end]


//NH = neutral go, positive nogo
<block NH>
/ onblockbegin = [
	values.condition = "NH";
	values.GoStim = item.neutral_catLABEL.item(1);
	values.NoGoStim = item.positive_catLABEL.item(1);
	text.instructions.textColor = yellow;
	list.iti.reset();
	text.neutral.resetSelection();
	text.positive.resetSelection();
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>

//HS = positive go and negative nogo
<block HS>
/ onblockbegin = [
	values.condition = "HS";
	values.GoStim = item.positive_catLABEL.item(1);
	values.NoGoStim =item.negative_catLABEL.item(1);
	text.instructions.textColor = turquoise;
	list.iti.reset();
	text.positive.resetSelection();
	text.negative.resetSelection();
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>

//SH = negative go and positive nogo
<block SH>
/ onblockbegin = [
	values.condition = "SH";
	values.GoStim =item.negative_catLABEL.item(1);
	values.NoGoStim = item.positive_catLABEL.item(1);
	text.instructions.textColor = red;
	list.iti.reset();
	text.positive.resetSelection();
	text.negative.resetSelection();
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>

//SN: negative go and neutral nogo
<block SN>
/ onblockbegin = [
	values.condition = "SN";
	values.GoStim = item.negative_catLABEL.item(1);
	values.NoGoStim = item.neutral_catLABEL.item(1);
	text.instructions.textColor = turquoise;
	list.iti.reset();
	text.neutral.resetSelection();
	text.negative.resetSelection();
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>

//NS: neutral go and negative nogo
<block NS>
/ onblockbegin = [
	values.condition = "NS";
	values.GoStim = item.neutral_catLABEL.item(1);
	values.NoGoStim = item.negative_catLABEL.item(1);
	text.instructions.textColor = red;
	list.iti.reset();
	text.neutral.resetSelection();
	text.negative.resetSelection();
]
/ trials = [1 = blockInstructions; 2 = getReady; 3 = start; 4-23 = noreplace(go, nogo); 24 = end]
</block>

<block finish>
/ trials = [1 = finish]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ blocks = [
	1 = intro;
	2 = practice;
	3 = testInstructions;
	
				//3 rounds of testing: each round calls each of the 6 experimental condition blocks in random order
	
	4-9 = noreplace(block.HN, block.NH, block.HS, block.SH, block.SN, block.NS);
	10-15 = noreplace(block.HN, block.NH, block.HS, block.SH, block.SN, block.NS);	
	16-21 = noreplace(block.HN, block.NH, block.HS, block.SH, block.SN, block.NS);
	
	22 = finish;
]
</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************