expressions.hitRT_NS)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/index:					helper variable to access the current trialinformation
/iti:					current intertrial interval

/respRT:				response time (in ms), measured from onset of word (Note: if no response, values.respRT is empty)
/responseCategory:		go trials: HIT, MISS; nogo trials: FA (false alarm), CR (correct rejection)

/GoStim:				"neutral" vs. "SAD" vs. "happy"

<values>
/index = 1
/iti = 1000

/respRT = 0
/responseCategory = ""

/GoStim = "neutral"
/NoGoStim = ""
/condition = ""
/word = ""
/feedback = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

Note: the following expressions calculate z-scores based on hit and FA rate.(see Gregg & Sedikides, 2010, p.148)
If the hitrate / FA rate is 0 => 0.005 is used instead
IF the hitrate / FA rate is 1.0 => 0.995 is used instead

Gregg, A. & Sedikides, C. (2010). Narcissistic Fragility:
Rethinking Its Links to Explicit and Implicit Self-esteem, Self and Identity, 9:2, 142-161 (p.148)

/hitrate:				the overall hitrate across all blocks
/z_hitrate:				the z-score of the overall hitrate
/FArate:				the overall False Alarm rate across all blocks
/z_FA:					the z-score of the overall FA rate
/dprime:				difference btw. (z_hitrate - z_FA): measure of Sensitivity
/mean_hitRT:			the overall mean hit response time (in ms)
/SD_hitRT:				standard deviation of the hit response times across blocks (in ms)
/SD_FAs:				standard deviation of the false alarm rates

/hitrate_NF:			the hitrate in NF block  (NF = neutral go, fear nogo)
/z_hitrate_NF:			the z-score of the NF hitrate
/FArate_NF:				the false alarm rate in NF block
/z_FA_NF:				the z-score of the NF FA-rate
/dprime_NF:				difference btw. (z_hitrate - z_FA) in NF block: measure of Sensitivity
/hitRT_NF:				mean hit response time (in ms) in NF block
/z_hitRT_NF:			standardized mean hit response time using the overall mean hit response time and standard deviation
/z_FA_NF_2:				standardized FA rate using the overall FA rate and its standard deviation

/hitrate_FN:			the hitrate in FN block (FN = fear go, neutral nogo)
/z_hitrate_FN:			the z-score of the FN hitrate
/FArate_FN:				the false alarm rate in FN block
/z_FA_FN:				the z-score of the FN FA-rate
/dprime_FN:				difference btw. (z_hitrate - z_FA) in FN block: measure of Sensitivity
/hitRT_FN:				mean hit response time (in ms) in FN block

(same for all other conditions)


<expressions>
/hitrate = return list.Hits.mean
/missrate = return (1-expressions.hitrate)
/FArate = return list.FAs.mean
/CRrate = return (1-expressions.FArate)
/z_hitrate = {
	if (expressions.hitrate == 0){
		return zofp(expressions.hitrate + 0.005)		
	} else if (expressions.hitrate == 1){
		return zofp(expressions.hitrate - 0.005)
	} else {
		return zofp(expressions.hitrate)	
	}
}
/z_FA = {
	if (expressions.FArate == 0){
		return zofp(expressions.FArate + 0.005)		
	} else if (expressions.FArate == 1){
		return zofp(expressions.FArate - 0.005)
	} else {
		return zofp(expressions.FArate)	
	}	
}
/dprime = expressions.z_hitrate - expressions.z_FA
/c = return (-1*((expressions.z_hitrate + expressions.z_FA)/2))
/mean_hitRT = list.hitRT.mean
/SD_hitRT = list.hitRT.standarddeviation
/SD_FAs = list.FAs.standarddeviation


/hitrate_HN = list.Hits_HN.mean
/missrate_HN = (1-expressions.hitrate_HN)
/FArate_HN = list.FAs_HN.mean
/CRrate_HN = (1-expressions.FArate_HN)
/z_hitrate_HN = {
	if (expressions.hitrate_HN == 0){
		zofp(expressions.hitrate_HN + 0.005)		
	} else if (expressions.hitrate_HN == 1){
		zofp(expressions.hitrate_HN - 0.005)
	} else {
		zofp(expressions.hitrate_HN)	
	}
}
/z_FA_HN = {
	if (expressions.FArate_HN == 0){
		zofp(expressions.FArate_HN + 0.005)		
	} else if (expressions.FArate_HN == 1){
		zofp(expressions.FArate_HN - 0.005)
	} else {
		zofp(expressions.FArate_HN)	
	}	
}
/dprime_HN = expressions.z_hitrate_HN - expressions.z_FA_HN
/c_HN = return (-1*((expressions.z_hitrate_HN + expressions.z_FA_HN)/2))
/hitRT_HN = list.hitRT_HN.mean
/z_hitRT_HN = (expressions.hitRT_HN - expressions.mean_hitRT)/expressions.SD_hitRT
/z_FA_HN_2 = (expressions.FArate_HN - expressions.FArate)/expressions.SD_FAs

/hitrate_NH = list.Hits_NH.mean
/missrate_NH = (1-expressions.hitrate_NH)
/FArate_NH = list.FAs_NH.mean
/CRrate_NH = (1-expressions.FArate_NH)
/z_hitrate_NH = {
	if (expressions.hitrate_NH == 0){
		zofp(expressions.hitrate_NH + 0.005)		
	} else if (expressions.hitrate_NH == 1){
		zofp(expressions.hitrate_NH - 0.005)
	} else {
		zofp(expressions.hitrate_NH)	
	}
}
/z_FA_NH = {
	if (expressions.FArate_NH == 0){
		zofp(expressions.FArate_NH + 0.005)		
	} else if (expressions.FArate_NH == 1){
		zofp(expressions.FArate_NH - 0.005)
	} else {
		zofp(expressions.FArate_NH)	
	}	
}
/dprime_NH = expressions.z_hitrate_NH - expressions.z_FA_NH
/c_NH = return (-1*((expressions.z_hitrate_NH + expressions.z_FA_NH)/2))
/hitRT_NH = list.hitRT_NH.mean

/hitrate_HS = list.Hits_HS.mean
/missrate_HS = (1-expressions.hitrate_HS)
/FArate_HS = list.FAs_HS.mean
/CRrate_HS = (1-expressions.FArate_HS)
/z_hitrate_HS = {
	if (expressions.hitrate_HS == 0){
		zofp(expressions.hitrate_HS + 0.005)		
	} else if (expressions.hitrate_HS == 1){
		zofp(expressions.hitrate_HS - 0.005)
	} else {
		zofp(expressions.hitrate_HS)	
	}
}
/z_FA_HS = {
	if (expressions.FArate_HS == 0){
		zofp(expressions.FArate_HS + 0.005)		
	} else if (expressions.FArate_HS == 1){
		zofp(expressions.FArate_HS - 0.005)
	} else {
		zofp(expressions.FArate_HS)	
	}	
}
/dprime_HS = expressions.z_hitrate_HS - expressions.z_FA_HS
/c_HS = return (-1*((expressions.z_hitrate_HS + expressions.z_FA_HS)/2))
/hitRT_HS = list.hitRT_HS.mean
/z_hitRT_HS = (expressions.hitRT_HS - expressions.mean_hitRT)/expressions.SD_hitRT
/z_FA_HS_2 = (expressions.FArate_HS - expressions.FArate)/expressions.SD_FAs

/hitrate_SH = list.Hits_SH.mean
/missrate_SH = (1-expressions.hitrate_SH)
/FArate_SH = list.FAs_SH.mean
/CRrate_SH = (1-expressions.FArate_SH)
/z_hitrate_SH = {
	if (expressions.hitrate_SH == 0){
		zofp(expressions.hitrate_SH + 0.005)		
	} else if (expressions.hitrate_SH == 1){
		zofp(expressions.hitrate_SH - 0.005)
	} else {
		zofp(expressions.hitrate_SH)	
	}
}
/z_FA_SH = {
	if (expressions.FArate_SH == 0){
		zofp(expressions.FArate_SH + 0.005)		
	} else if (expressions.FArate_SH == 1){
		zofp(expressions.FArate_SH - 0.005)
	} else {
		zofp(expressions.FArate_SH)	
	}	
}
/dprime_SH = expressions.z_hitrate_SH - expressions.z_FA_SH
/c_SH = return (-1*((expressions.z_hitrate_SH + expressions.z_FA_SH)/2))
/hitRT_SH = list.hitRT_SH.mean

/hitrate_SN = list.Hits_SN.mean
/missrate_SN = (1-expressions.hitrate_SN)
/FArate_SN = list.FAs_SN.mean
/CRrate_SN = (1-expressions.FArate_SN)
/z_hitrate_SN = {
	if (expressions.hitrate_SN == 0){
		zofp(expressions.hitrate_SN + 0.005)		
	} else if (expressions.hitrate_SN == 1){
		zofp(expressions.hitrate_SN - 0.005)
	} else {
		zofp(expressions.hitrate_SN)	
	}
}
/z_FA_SN = {
	if (expressions.FArate_SN == 0){
		zofp(expressions.FArate_SN + 0.005)		
	} else if (expressions.FArate_SN == 1){
		zofp(expressions.FArate_SN - 0.005)
	} else {
		zofp(expressions.FArate_SN)	
	}	
}
/dprime_SN = expressions.z_hitrate_SN - expressions.z_FA_SN
/c_SN = return (-1*((expressions.z_hitrate_SN + expressions.z_FA_SN)/2))
/hitRT_SN = list.hitRT_SN.mean
/z_hitRT_SN = (expressions.hitRT_SN - expressions.mean_hitRT)/expressions.SD_hitRT
/z_FA_SN_2 = (expressions.FArate_SN - expressions.FArate)/expressions.SD_FAs

/hitrate_NS = list.Hits_NS.mean
/missrate_NS = (1-expressions.hitrate_NS)
/FArate_NS = list.FAs_NS.mean
/CRrate_NS = (1-expressions.FArate_NS)
/z_hitrate_NS = {
	if (expressions.hitrate_NS == 0){
		zofp(expressions.hitrate_NS + 0.005)		
	} else if (expressions.hitrate_NS == 1){
		zofp(expressions.hitrate_NS - 0.005)
	} else {
		zofp(expressions.hitrate_NS)	
	}
}
/z_FA_NS = {
	if (expressions.FArate_NS == 0){
		zofp(expressions.FArate_NS + 0.005)		
	} else if (expressions.FArate_NS == 1){
		zofp(expressions.FArate_NS - 0.005)
	} else {
		zofp(expressions.FArate_NS)	
	}	
}
/dprime_NS = expressions.z_hitrate_NS - expressions.z_FA_NS
/c_NS = return (-1*((expressions.z_hitrate_NS + expressions.z_FA_NS)/2))
/hitRT_NS = list.hitRT_NS.mean
</expressions>


