<block TargetAattributeB_responsetimeout3>
/ bgstim = (TargetAremind, attributeBremind)
/ onblockbegin = [
	values.targettype = "A";
	values.pairing = "AB";
	values.responsetimeout_target = parameters.responsetimeout3_signal;
	values.responsetimeout_noise = parameters.responsetimeout3_noise;
]
/ trials = [1 = reminder;
			2-17 = random(TargetA_true, NoiseA_false, attributeA_false, attributeB_true);
			18 = testTrialStart;
