</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

/phase:							"training" vs. "test"
/responsetimeout_target:		time in ms that is allowed for response in the current target trial
/responsetimeout_noise:			time in ms that is allowed for response in the current noise trial
/signal:						1 = signal trial (spacebar response is correct); 0 = noisetrial (no response is correct)

/targettype:					"A" (here: A-alcoholic drinks)
/pairing:						"AA" -> targetA-attributeA (here: alcoholic drinks and good)
								"AB" -> targetA-attributeB (here: alcoholic drinks and bad)
/trialtype:						"practice" vs. "test"

<values>
/ phase = "training"
/ responsetimeout_target = 0
/ responsetimeout_noise = 0
/ signal = 0
/ targettype = ""
/ pairing = ""
/ trialtype = "training"
/ selectReminders = 1
</values>

******************************
Summary values
******************************

/count_signalAA:			counts signal trials for pairing targetA-attributeA (here: alcoholic drinks-good) - across all responsetimeouts
/count_NoiseAA:				counts noise trials for pairing targetA-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalAB:			counts signal trials for pairing targetA-attributeB (here: alcoholic drinks-bad) - across all responsetimeouts
/count_NoiseAB:				counts noise trials for pairing targetA-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBA:			counts signal trials for pairing targetB-attributeA (here: non-alcoholic drink-good) - across all responsetimeouts
/count_NoiseBA:				counts noise trials for pairing targetB-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBB:			counts signal trials for pairing targetB-attributeB (here: non-alcoholic drink-bad) - across all responsetimeouts
/count_NoiseBB:				counts noise trials for pairing targetB-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AA:					counts hits for pairing targetA-attributeA (here: alcoholic drinks-good) - across all responsetimeouts
/FA_AA:						counts false alarms for pairing targetA-attributeA (here: alcoholic drinks-good) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AB:					counts hits for pairing targetA-attributeB (here: alcoholic drinks-bad) - across all responsetimeouts
/FA_AB:						counts false alarms for pairing targetA-attributeA (here: alcoholic drinks-bad) - across all responsetimeouts
(and separately for responsetimeouts)


<values>
/ count_signalAA = 0
/ count_NoiseAA = 0
/ count_signalAA1 = 0
/ count_NoiseAA1 = 0
/ count_signalAA2 = 0
/ count_NoiseAA2 = 0
/ count_signalAA3 = 0
/ count_NoiseAA3 = 0
/ count_signalAA4 = 0
/ count_NoiseAA4 = 0

/ count_signalAB = 0
/ count_NoiseAB = 0
/ count_signalAB1 = 0
/ count_NoiseAB1 = 0
/ count_signalAB2 = 0
/ count_NoiseAB2 = 0
/ count_signalAB3 = 0
/ count_NoiseAB3 = 0
/ count_signalAB4 = 0
/ count_NoiseAB4 = 0


/ hits_AA = 0
/ FA_AA = 0
/ hits_AA1 = 0
/ FA_AA1 = 0
/ hits_AA2 = 0
/ FA_AA2 = 0
/ hits_AA3 = 0
/ FA_AA3 = 0
/ hits_AA4 = 0
/ FA_AA4 = 0

/ hits_AB = 0
/ FA_AB = 0
/ hits_AB1 = 0
/ FA_AB1 = 0
/ hits_AB2 = 0
/ FA_AB2 = 0
/ hits_AB3 = 0
/ FA_AB3 = 0
/ hits_AB4 = 0
/ FA_AB4 = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/ propCorrect_AA = return ((values.hits_AA + (values.count_noiseAA - values.fa_AA)) / (values.count_signalAA + values.count_noiseAA))
/ propCorrect_AB = return ((values.hits_AB + (values.count_noiseAB - values.fa_AB)) / (values.count_signalAB + values.count_noiseAB))

/ rHit_AA = return (values.hits_AA/values.count_signalAA)
/ rMiss_AA = return (1-expressions.rHit_AA)
/ rFa_AA = return (values.fa_AA/values.count_noiseAA)
/ rCr_AA = return (1-expressions.rFa_AA)

/ zHit_AA = {
	if (expressions.rHit_AA == 0){
		return zOfP(expressions.rHit_AA + 0.005)		
	} else if (expressions.rHit_AA == 1){
		return zOfP(expressions.rHit_AA - 0.005)
	} else {
		return zOfP(expressions.rHit_AA)	
	}
}

/ zFa_AA = {
	if (expressions.rFa_AA == 0){
		return zOfP(expressions.rFa_AA + 0.005)		
	} else if (expressions.rFa_AA == 1){
		return zOfP(expressions.rFa_AA - 0.005)
	} else {
		return zOfP(expressions.rFa_AA)	
	}
}
/ dPrime_AA = return (expressions.zHit_AA-expressions.zFa_AA)
/ c_AA = return (-1*((expressions.zHit_AA + expressions.zFa_AA)/2))

/ rHit_AB = return (values.hits_AB/values.count_signalAB)
/ rMiss_AB = return (1-expressions.rHit_AB)
/ rFa_AB = return (values.fa_AB/values.count_noiseAB)
/ rCr_AB = return (1-expressions.rFa_AB)

/ zHit_AB = {
	if (expressions.rHit_AB == 0){
		return zOfP(expressions.rHit_AB + 0.005)		
	} else if (expressions.rHit_AB == 1){
		return zOfP(expressions.rHit_AB - 0.005)
	} else {
		return zOfP(expressions.rHit_AB)	
	}
}

/ zFa_AB = {
	if (expressions.rFa_AB == 0){
		return zOfP(expressions.rFa_AB + 0.005)		
	} else if (expressions.rFa_AB == 1){
		return zOfP(expressions.rFa_AB - 0.005)
	} else {
		return zOfP(expressions.rFa_AB)	
	}
}
/ dPrime_AB = return (expressions.zHit_AB-expressions.zFa_AB)
/ c_AB = return (-1*((expressions.zHit_AB + expressions.zFa_AB)/2))

/ dPrimeDiff = return (expressions.dPrime_AA - expressions.dPrime_AB)
</expressions>



**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************



<text NoiseA>
/ items = NoiseA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
</text>

<text TargetA>
/ items = TargetA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
</text>


<text attributeA>
/ items = attributeA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = (0, 255, 255) 
</text>

<text attributeB>
/ items = attributeB 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = (0, 255, 255) 
</text>

********************* Reminder Stimuli *********************

<text TargetAremind>
/ items = ("<%item.targetAlabel.item(1)%>") 
/ color = white 
/ position = (30,15) 
</text>

<text attributeAremind>
/ items = ("<%item.attributealabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70,15) 
</text>

<text attributeBremind>
/ items = ("<%item.attributeBlabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70, 15) 
</text>

<text error>
/ items = ("X") 
/ position = (50,65) 
/ color = red 
</text>

<text correctresp>
/ items = ("O") 
/ position = (50,65) 
/ color = green 
</text>

<text remind>
/ items = reminders
/ select = values.selectReminders
/ position = (50%, 65%) 
/ size = (80%, 50%)
/ txcolor = white 
/ fontstyle = ("Arial", 2.67%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
</text>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS
**************************************************************************************************************
**************************************************************************************************************

<trial TargetA_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100) 
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=TargetA] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeA_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeA] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeB_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeB] 
/ posttrialpause = parameters.isi
</trial>

<trial NoiseA_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise 
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=NoiseA] 
/ posttrialpause = parameters.isi
</trial>


<trial attributeB_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeB] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeA_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise 
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeA]
/ posttrialpause = parameters.isi
</trial>

<trial reminder>
/ validresponse = (" ")
/ correctresponse = (" ") 
/ stimulusFrames = [1=remind] 
/ response = correct 
/ recorddata = false
/ posttrialpause = 1000
</trial> 

<trial speedup>
/ correctresponse = (" ") 
/ stimulusFrames = [1=speedup] 
/ response = correct 
/ recorddata = false
</trial> 

<trial trainingStart>
/ ontrialbegin = [
	values.phase = "training";
	values.selectReminders = 1;
]
/ trialduration = 0
/ recorddata = false
</trial>

<trial testStart>
/ ontrialbegin = [
	values.phase = "test";
	values.selectReminders = 3;
]
/ trialduration = 0
/ recorddata = false
</trial>

<trial testTrialStart>
/ correctresponse = (" ") 
/ stimulusFrames = [1=testTrialStart] 
/ response = correct 
/ recorddata = false
/ posttrialpause = 1000
</trial> 

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

*********************************************************************
Training Blocks: separate presentation of attributes and targets
*********************************************************************

Note: this block presents Attribute trials for which attribute A (good) is the correct response 
with responsetimeout1
<block attributeA_responsetimeout1>
/ bgstim = (attributeAremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [1 = reminder; 2-21 = random(attributeA_true, attributeB_false)] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

Note: this block presents Attribute trials for which attribute B (bad) is the correct response 
with responsetimeout1
<block attributeB_responsetimeout1>
/ bgstim = (attributeBremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [1 = reminder; 2-21 = random(attributeB_true, attributeA_false)] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

Note: this block presents TargetA and NoiseA trials
with responsetimeout1
<block TargetA_responsetimeout1>
/ bgstim = (TargetAremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [1 = reminder; 2-21 = random(TargetA_true, NoiseA_false)] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

*********************************************************************
Test Blocks: simultaneous presentation of attributes and targets
*********************************************************************

NOTE:
The following blocks present target and attribute categories simultaneously:
blocks
- run 16 'practice' trials; randomly sampled from target (either A or B) and respective noise and attributeA and attributeB trials
signal : noise = 1 : 1
- run 60 trials; randomly sampled from target (either A or B) and respective noise and attributeA and attributeB trials
signal : noise = 1 : 1

Example: 
signal:noise = 1:1 (minimum number of trials possible: 4)
/ trials = [1-4 = random(TargetB_true, NoiseB_false, attributeA_true, attributeB_false)]
signal:noise = 2:1 (minimum number of trials possible: 6)
/ trials = [1-6 = random(TargetB_true, TargetB_true, NoiseB_false, attributeA_true, attributeA_true, attributeB_false)]
signal:noise = 4:3 (minimum number of trials possible: 14)
/ trials = [1-14 = random(TargetB_true, TargetB_true, TargetB_true, TargetB_true, NoiseB_false, NoiseB_false, NoiseB_false, 
attributeA_true, attributeA_true, attributeA_true, attributeA_true, attributeB_false, attributeB_false, attributeB_false)]


****************************************************************************
responsetimeout2:
****************************************************************************

Note: this block pairs targetA (bug) with attributeA (good) with responsetimeout2
<block TargetAattributeA_responsetimeout2>
/ bgstim = (TargetAremind, attributeAremind)
/ onblockbegin = [
	values.targettype = "A";
	values.pairing = "AA";
	values.responsetimeout_target = parameters.responsetimeout2_signal;
	values.responsetimeout_noise = parameters.responsetimeout2_noise;
]
/ trials = [
            1 = reminder;
			2-17 = random(TargetA_true, NoiseA_false, attributeA_true, attributeB_false);
			18 = testTrialStart;
            19-78 = random(TargetA_true, NoiseA_false, attributeA_true, attributeB_false)] 

/ ontrialend = [
	if (block.TargetAattributeA_responsetimeout2.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1){
			values.hits_AA += block.TargetAattributeA_responsetimeout2.correct;
			values.hits_AA2 += block.TargetAattributeA_responsetimeout2.correct;
			values.count_signalAA += 1;
			values.count_signalAA2 += 1;
		} else if (values.signal == 0){
			values.FA_AA += block.TargetAattributeA_responsetimeout2.error;
			values.FA_AA2 += block.TargetAattributeA_responsetimeout2.error;
			values.count_noiseAA += 1;
			values.count_noiseAA2 += 1;
		}
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]
</block>

Note: this block pairs targetA (bug) with attributeB (bad) with responsetimeout2
<block TargetAattributeB_responsetimeout2>
/ bgstim = (TargetAremind, attributeBremind)
/ onblockbegin = [
	values.targettype = "A";
	values.pairing = "AB";
	values.responsetimeout_target = parameters.responsetimeout2_signal;
	values.responsetimeout_noise = parameters.responsetimeout2_noise;
]
/ trials = [1 = reminder;
			2-17 = random(TargetA_true, NoiseA_false, attributeA_false, attributeB_true);
			18 = testTrialStart;
            19-78 = random(TargetA_true, NoiseA_false, attributeA_false, attributeB_true)] 

/ ontrialend = [
	if (block.TargetAattributeB_responsetimeout2.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1){
			values.hits_AB += block.TargetAattributeB_responsetimeout2.correct;
			values.hits_AB2 += block.TargetAattributeB_responsetimeout2.correct;
			values.count_signalAB += 1;
			values.count_signalAB2 += 1;
		} else if (values.signal == 0){
			values.FA_AB += block.TargetAattributeB_responsetimeout2.error;
			values.FA_AB2 += block.TargetAattributeB_responsetimeout2.error;
			values.count_noiseAB += 1;
			values.count_noiseAB2 += 1;
		}
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]
</block>

