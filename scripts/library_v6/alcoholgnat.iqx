			values.hits_AB += block.TargetAattributeB_responsetimeout3.correct;
			values.hits_AB3 += block.TargetAattributeB_responsetimeout3.correct;
			values.count_signalAB += 1;
			values.count_signalAB3 += 1;
		} else if (values.signal == 0){
			values.FA_AB += block.TargetAattributeB_responsetimeout3.error;
			values.FA_AB3 += block.TargetAattributeB_responsetimeout3.error;
			values.count_noiseAB += 1;
			values.count_noiseAB3 += 1;
