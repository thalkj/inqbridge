**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

the following expressions calculate the correct trialstart times for the stims presented
during trial.listPresentation

<expressions>
/trialstart_word1 = parameters.attnDuration
/trialstart_isi2 = expressions.trialstart_word1 + parameters.listwordPresentationDuration
/trialstart_word2 = expressions.trialstart_isi2 + parameters.listPresentation_isi
/trialstart_isi3 = expressions.trialstart_word2 + parameters.listwordPresentationDuration
/trialstart_word3 = expressions.trialstart_isi3 + parameters.listPresentation_isi
/trialstart_isi4 = expressions.trialstart_word3 + parameters.listwordPresentationDuration
/trialstart_word4 = expressions.trialstart_isi4 + parameters.listPresentation_isi
/trialstart_isi5 = expressions.trialstart_word4 + parameters.listwordPresentationDuration
/trialstart_word5 = expressions.trialstart_isi5 + parameters.listPresentation_isi
/trialstart_isi6 = expressions.trialstart_word5 + parameters.listwordPresentationDuration
/trialduration = expressions.trialstart_isi6 + parameters.listPresentation_isi
</expressions>



/propCorrect_recall:  			proportion correct recall performance
/meanRT_recall:					mean latency (in ms) of correct recall responses
/propCorrect_comp_primed:		proportion correct of answering comparison test questions of primed items
/meanRT_comp_primed:			mean latency (in ms)of making correct comparisons of primed test items
/uncorrmeanRT_comp_primed:		mean latency (in ms) of making comparisons of primed test items for both correct and incorrect responses
/speed_comp_primed:				relationship btw. proportion correct of answering comparison test questions of primed items to 
								the mean (uncorrected) response time (in min) of comparison trials of primed items
								=> number of correct responses per minute

/propCorrect_comp_unprimed:		proportion correct of answering comparison test questions of unprimed items
/meanRT_comp_unprimed:			mean latency (in ms)of making correct comparisons of unprimed test items
/uncorrmeanRT_comp_unprimed:	mean latency (in ms) of making comparisons of unprimed test items for both correct and incorrect responses
/speed_comp_unprimed:			relationship btw. proportion correct of answering comparison test questions of unprimed items to 
								the mean (uncorrected) response time (in min) of comparison trials of unprimed items
								=> number of correct responses per minute

/ResponseSpeedChange:			Difference in response speed btw. unprimed and primed word comparisons
								=> positive: unprimed word comparisons take longer (Priming Effect)
								=> negative: primed word comparisons take longer
								Note: Was & Woltz (2007) use residual change scores (from regression analysis)
								rather than difference scores to measure the Priming Effect (see discussion on p.93)
								

<expressions>
/propCorrect_recall = list.ACC_recall.mean
/meanRT_recall = list.RT_recall.mean
/propCorrect_comp_primed = list.compACC_primed.mean
/meanRT_comp_primed = list.compRT_primed.mean
/uncorrmeanRT_comp_primed = list.compRT_primed_uncorrected.mean
/speed_comp_primed = expressions.propCorrect_comp_primed/(expressions.uncorrmeanRT_comp_primed/1000/60)
/propCorrect_comp_unprimed = list.compACC_unprimed.mean
/meanRT_comp_unprimed = list.compRT_unprimed.mean
/uncorrmeanRT_comp_unprimed = list.compRT_unprimed_uncorrected.mean
/speed_comp_unprimed = expressions.propCorrect_comp_unprimed/(expressions.uncorrmeanRT_comp_unprimed/1000/60)
/ResponseSpeedChange = expressions.speed_comp_unprimed - expressions.speed_comp_primed
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text instructions>
/ items = instructions
/ select = values.selectInstructions
/ resetinterval = 0
/ vjustify = center
/ hjustify = left
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
</text>

<trial instruction>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ stimulusframes = [1 = instructions]
/ validresponse = (" ")
</trial>

<trial instruction_sameExample>
/ ontrialbegin = [
	values.selectInstructions = 5;
]
/ stimulusframes = [1 = instructions]

//for touchscreens: show both response buttons but make differentKey nonresponsive
/ validresponse = (parameters.differentKey, parameters.sameKey)
/ correctresponse = (parameters.sameKey)
/response = correct
</trial>

<trial instruction_differentExample>
/ ontrialbegin = [
	values.selectInstructions = 6;
]
/ stimulusframes = [1 = instructions]

//for touchscreens: show both response buttons but make sameKey nonresponsive
/ validresponse = (parameters.differentKey, parameters.sameKey)
/ correctresponse = (parameters.differentKey)
/response = correct
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>


