**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC_recall>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list RT_recall>
</list>

Note: list stores 1 = correct comparison response; 0 = otherwise for each test comparison trial for primed Sets
<list compACC_primed>
</list>

Note: list stores the latency of correct responses for each test comparison trial for primed Sets
<list compRT_primed>
</list>

Note: list stores the response latency for each test comparison trial for primed Sets
<list compRT_primed_uncorrected>
</list>

Note: list stores 1 = correct comparison response; 0 = otherwise for each test comparison trial for primed Sets
<list compACC_unprimed>
</list>

Note: list stores the latency of correct responses for each test comparison trial for primed Sets
<list compRT_unprimed>
</list>

Note: list stores the response latency for each test comparison trial for unprimed Sets
<list compRT_unprimed_uncorrected>
</list>

*******************************
used for comparison feedback
*******************************

Note: list stores 1 = correct response; 0 = incorrect response for each comparison run within one round
<list compACC_round>
</list>

Note: list stores the latency of all comparison responses (warmup + test) for each comparison run within one round
<list compRT_round>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

*******************************************
List Presentation
*******************************************

//Preparation Trial:
<trial getReadyWordlist>
/ stimulusframes = [1 = getReadyWordList]

/ timeout = parameters.getReadyWordlist
/ recorddata = false
/ posttrialpause = parameters.wordList_delay
/ ontrialend = [
//check whether this trial was called during practice or a test block:
	if (values.practice == false){
	//when the script ends up here, the trial was called from a test block
	
	//select the next concept presentation Order of the five recall words:
		values.presentationOrder = list.presentationOrder.nextValue;
		
	//select the next set#:
		values.setNr = list.setNr.nextValue;
		
	//reset the variable that will store the presented words""		
		values.presentedStim = "";
	
	//store the relevant concepts tested/set type/individual words for recall and comparison trials 
	//based on the select set#:
		values.Fconcept = item.FConcept.item(values.setNr);
		values.Iconcept = item.IConcept.item(values.setNr);
		values.Nconcept = item.NConcept.item(values.setNr);	
		
		values.setTypeNr = item.setTypeNr.item(values.setNr);
		if (contains(values.setTypeNr, "Unprimed")){
			values.setType = "unprimed";
		} else {
			values.setType = "primed";
		}
		values.FMem1 = item.FMemStim1.item(values.setNr);
		values.FMem2 = item.FMemStim2.item(values.setNr);
		values.FMem3 = item.FMemStim3.item(values.setNr);
		values.IMem1 = item.IMemStim1.item(values.setNr);
		values.IMem2 = item.IMemStim2.item(values.setNr);
	
		values.WrmD1wrd1 = item.WrmD1wrd1.item(values.setNr);
		values.WrmD1wrd2 = item.WrmD1wrd2.item(values.setNr);
		values.WrmD2wrd1 = item.WrmD2wrd1.item(values.setNr);
		values.WrmD2wrd2 = item.WrmD2wrd2.item(values.setNr);
		values.WrmL1wrd1 = item.WrmL1wrd1.item(values.setNr);
		values.WrmL1wrd2 = item.WrmL1wrd2.item(values.setNr);
		values.WrmL2wrd1 = item.WrmL2wrd1.item(values.setNr);
		values.WrmL2wrd2 = item.WrmL2wrd2.item(values.setNr);	
	
		values.compWord1_1 = item.comp1_wrd1.item(values.setNr);
		values.compWord1_2 = item.comp1_wrd2.item(values.setNr);
		values.compWord2_1 = item.comp2_wrd1.item(values.setNr);
		values.compWord2_2 = item.comp2_wrd2.item(values.setNr);
		values.compWord3_1 = item.comp3_wrd1.item(values.setNr);
		values.compWord3_2 = item.comp3_wrd2.item(values.setNr);
		values.compWord4_1 = item.comp4_wrd1.item(values.setNr);
		values.compWord4_2 = item.comp4_wrd2.item(values.setNr);
		values.compWord5_1 = item.comp5_wrd1.item(values.setNr);
		values.compWord5_2 = item.comp5_wrd2.item(values.setNr);
		values.compWord6_1 = item.comp6_wrd1.item(values.setNr);
		values.compWord6_2 = item.comp6_wrd2.item(values.setNr);		
		values.compWord7_1 = item.comp7_wrd1.item(values.setNr);
		values.compWord7_2 = item.comp7_wrd2.item(values.setNr);	
		values.compWord8_1 = item.comp8_wrd1.item(values.setNr);
		values.compWord8_2 = item.comp8_wrd2.item(values.setNr);	
	
		values.compWord1_compAns = item.comp1_compAns.item(values.setNr);
		values.compWord2_compAns = item.comp2_compAns.item(values.setNr);
		values.compWord3_compAns = item.comp3_compAns.item(values.setNr);
		values.compWord4_compAns = item.comp4_compAns.item(values.setNr);	
		values.compWord5_compAns = item.comp5_compAns.item(values.setNr);		
		values.compWord6_compAns = item.comp6_compAns.item(values.setNr);		
		values.compWord7_compAns = item.comp7_compAns.item(values.setNr);		
		values.compWord8_compAns = item.comp8_compAns.item(values.setNr);		
		
		values.compWord1_compType = item.comp1_compType.item(values.setNr);
		values.compWord2_compType = item.comp2_compType.item(values.setNr);
		values.compWord3_compType = item.comp3_compType.item(values.setNr);
		values.compWord4_compType = item.comp4_compType.item(values.setNr);	
		values.compWord5_compType = item.comp5_compType.item(values.setNr);		
		values.compWord6_compType = item.comp6_compType.item(values.setNr);		
		values.compWord7_compType = item.comp7_compType.item(values.setNr);		
		values.compWord8_compType = item.comp8_compType.item(values.setNr);	
				
	} else {
	//when the script ends up here, the trial was called from a practice block
	//and practice material has to be accessed instead of test material
	
		values.presentationOrder = list.presentationOrder.nextValue;
		values.setNr = list.setNr_practice.nextValue;
		values.presentedStim = "";
		
		values.Fconcept = item.FConcept_practice.item(values.setNr);
		values.Iconcept = item.IConcept_practice.item(values.setNr);
		values.Nconcept = "NA";	
		
		values.setTypeNr = item.setTypeNr_practice.item(values.setNr);
		values.FMem1 = item.FMemStim1_practice.item(values.setNr);
		values.FMem2 = item.FMemStim2_practice.item(values.setNr);
		values.FMem3 = item.FMemStim3_practice.item(values.setNr);
		values.IMem1 = item.IMemStim1_practice.item(values.setNr);
		values.IMem2 = item.IMemStim2_practice.item(values.setNr);	
		
		values.WrmD1wrd1 = item.WrmD1wrd1_practice.item(values.setNr);
		values.WrmD1wrd2 = item.WrmD1wrd2_practice.item(values.setNr);
		values.WrmD2wrd1 = item.WrmD2wrd1_practice.item(values.setNr);
