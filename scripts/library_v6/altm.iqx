/ validresponse = (parameters.differentKey, parameters.sameKey)
/ beginresponsetime = parameters.comp_attn_isi1 + parameters.comp_attnPriming + parameters.comp_attn_isi2
/ correctresponse = (parameters.sameKey)
/ ontrialend = [
	trial.warmUp_same2.resetStimulusFrames();
	list.compACC_round.appendItem(trial.warmUp_same2.correct);
	list.compRT_round.appendItem(trial.warmUp_same2.latency);
	values.compStem = text.WrmL2wrd1.currentItem;
	values.compAlt = text.WrmL2wrd2.currentItem;
	
	if (trial.warmUp_same2.responseText == parameters.differentKey){
		values.responseCategory = "d";
	} else {
		values.responseCategory = "l";
	}		
]
</trial>

