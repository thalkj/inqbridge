		values.compWord8_compType = item.comp8_compType_practice.item(values.setNr);			
			
	}	
]
</trial>

//present the selected five words:
<trial listPresentation>
/ ontrialbegin = [	
//depending on the selected concept presentation order (values.presentationOrder in trial.getReadyWordlist), 
//the script prepares the order of the five words:	
	if (values.presentationOrder == "IFIFF"){
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);
		
	//this code assembles values.presentedStim using the order in which the ignored and focused words are to be presented:
		values.presentedStim = concat(values.IMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);	
		
	} else if (values.presentationOrder == "FIFIF"){
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);

		values.presentedStim = concat(values.FMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);			
	} else if (values.presentationOrder == "FIFFI"){
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);

		values.presentedStim = concat(values.FMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);			
	} else if (values.presentationOrder == "IFFIF"){
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);

		values.presentedStim = concat(values.IMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);			
	} else if (values.presentationOrder == "FIIFF"){
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);

		values.presentedStim = concat(values.FMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);			
	} else if (values.presentationOrder == "IFFFI"){
		trial.listPresentation.insertStimulusTime(text.IMem1, expressions.trialstart_word1);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi2);
		trial.listPresentation.insertStimulusTime(text.FMem1, expressions.trialstart_word2);
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi3);
		trial.listPresentation.insertStimulusTime(text.FMem2, expressions.trialstart_word3);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi4);
		trial.listPresentation.insertStimulusTime(text.FMem3, expressions.trialstart_word4);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi5);
		trial.listPresentation.insertStimulusTime(text.IMem2, expressions.trialstart_word5);		
		trial.listPresentation.insertStimulusTime(clearScreen, expressions.trialstart_isi6);


		values.presentedStim = concat(values.IMem1, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem1);		
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem2);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.FMem3);
		values.presentedStim = concat(values.presentedStim, "|");
		values.presentedStim = concat(values.presentedStim, values.IMem2);			
	}
]
/ stimulustimes = [0 = attnMem]
/ ontrialend = [
//The trial uses dynamic stimulus insertation and thus needs to reset the stimulus frames at the end of the trial
	trial.listPresentation.resetStimulusFrames();
]
/ timeout = expressions.trialduration
/ posttrialpause = parameters.listPresentation_iti
/ recorddata = false
</trial>

***********************************************************
Recall
***********************************************************

ISI500 btwn last ISI1000 (list word presentation) = parameters.recall_delay and is implemented as the
pretrialpause to the recall trial

recallleft/recallright is selected by list.recallQuestion

<trial recall>
/ pretrialpause = parameters.recall_delay
/ ontrialbegin = [
//the script samples whether the 'focused category' will be the left or the right category
	values.recallQuestion = list.recallQuestion.nextValue;
	if (values.recallQuestion == 1){
		values.leftCategory = values.Fconcept;
		values.rightCategory = values.Iconcept;
	} else {
		values.leftCategory = values.Iconcept;
		values.rightCategory = values.Fconcept;
	}
	
	values.correctResponse = values.Fconcept;
	
]	
/ stimulustimes = [0 = recallQuestion, left, right]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	if (values.recallQuestion == 1){
	//the focused category was presented on the left:
		if (trial.recall.responseText == parameters.leftKey){
		//if the script ends up here: the left key was pressed and thus the response is correct (true)
			return true;
		} else {
		//if the script ends up here: the left key was not pressed and thus the response is not correct (false)
			return false;
		}
	} else {
	//the focused category was not presented on the left (=> it was presented on the right)
		if (trial.recall.responseText == parameters.rightKey){
			return true;
		} else {
			return false;
		}
	}
]
/ ontrialend = [
	if (trial.recall.correct){
		text.correctFeedback.skip = false;
		text.errorFeedback.skip = true;
	} else {
		text.correctFeedback.skip = true;
		text.errorFeedback.skip = false;		
	}
	
	if (trial.recall.responseText == parameters.leftKey){
		values.responseCategory = values.leftCategory;
	} else {
		values.responseCategory = values.rightCategory;
	}
	
	list.ACC_recall.appendItem(trial.recall.correct);
	if (trial.recall.correct){
		list.RT_recall.appendItem(trial.recall.latency);
	}
]
/ beginresponsetime = 0
/ responseinterrupt = immediate
/ posttrialpause = parameters.recall_isi
/ branch = [
	return trial.recallFeedback;
]
</trial>

<trial recallFeedback>
/ stimulusframes = [1 = correctFeedback, errorFeedback, recallfeedback, recallContinue]
/ validresponse = (" ")
/ recorddata = false
/ posttrialpause = parameters.recall_iti
</trial>

*****************************************************************
Comparison Warm Up Trials: order is randomly selected 
*****************************************************************

<trial getReadyComparison>
/ pretrialpause = parameters.comparison_delay
/ stimulusframes = [1 = getReadyComparison]

//for touchscreens: present the inactive response buttons
/ validresponse = (parameters.differentKey, parameters.sameKey)
/ isvalidresponse = [
	return false;
]

/ timeout = parameters.warmUpGetReady
/ recorddata = false
</trial>


<trial warmUp_different1>
/ ontrialbegin = [
	values.primeType = "warmUp";
	values.correctResponse = "d";
	trial.warmUp_different1.insertStimulusTime(text.compFixation1, parameters.comp_attn_isi1);
	trial.warmUp_different1.insertStimulusTime(text.compFixation2, parameters.comp_attn_isi1);	
	trial.warmUp_different1.insertStimulusTime(shape.eraser, (parameters.comp_attn_isi1 + parameters.comp_attnPriming));
	trial.warmUp_different1.insertStimulusTime(text.WrmD1wrd1, (parameters.comp_attn_isi1 + parameters.comp_attnPriming + parameters.comp_attn_isi2));
	trial.warmUp_different1.insertStimulusTime(text.WrmD1wrd2, (parameters.comp_attn_isi1 + parameters.comp_attnPriming + parameters.comp_attn_isi2));
]
/ stimulustimes = [0 = different, same]
/ validresponse = (parameters.differentKey, parameters.sameKey)
/ beginresponsetime = parameters.comp_attn_isi1 + parameters.comp_attnPriming + parameters.comp_attn_isi2
/ correctresponse = (parameters.differentKey)
/ ontrialend = [
	trial.warmUp_different1.resetStimulusFrames();
	list.compACC_round.appendItem(trial.warmUp_different1.correct);
	list.compRT_round.appendItem(trial.warmUp_different1.latency);
	values.compStem = text.WrmD1wrd1.currentItem;
	values.compAlt = text.WrmD1wrd2.currentItem;	
	
	if (trial.warmUp_different1.responseText == parameters.differentKey){
		values.responseCategory = "d";
	} else {
		values.responseCategory = "l";
	}
]
</trial>

