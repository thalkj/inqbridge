*****************************************************************
Comparison Test Trials: miscellaneous trials
*****************************************************************

<trial ComparisonFeedbackDelay>
/ stimulusframes = [1 = clearScreen]

/ trialduration = parameters.comparisonFeedback_delay
/ recorddata = false
</trial>

<trial ComparisonFeedback>
/ stimulusframes = [1 = comparisonFeedback]
/ validresponse = (" ")
/ recorddata = false
</trial>

<trial performanceGoalsReminder>
/ stimulusframes = [1= performanceGoals]
/ validresponse = (" ")
/ recorddata = false
/ posttrialpause = parameters.comparison_iti
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************
<block instructions>
/ onblockbegin = [
	values.selectInstructions = 0;
]
/ trials = [
	1-4 = instruction; 
	5 = instruction_sameExample; 
	6 = instruction_differentExample; 
	7-8 = instruction;
]
/ onblockend = [
	values.practice = 1;
]
</block>

<block testInstructions>
/ onblockbegin = [
	values.practice = 0;
	values.round = 0;
	values.selectInstructions = 8;
	list.presentationOrder.reset();
	list.recallQuestion.reset();
	list.ACC_recall.reset();
	list.RT_recall.reset();
	list.compACC_primed.reset();
	list.compRT_primed.reset();
	list.compRT_primed_uncorrected.reset();
	list.compACC_unprimed.reset();
	list.compRT_unprimed.reset();
	list.compRT_unprimed_uncorrected.reset();	
]
/ trials = [1-2 = instruction]
</block>

<block listPresentation>
/ onblockbegin = [
	values.compStem = "";
	values.compAlt = "";
	values.primeType = "";
	values.leftCategory = "";
	values.rightCategory = "";
	values.responseCategory = "";
	values.correctResponse = "";
	values.round += 1;
]
/ trials = [
	1 = getReadyWordlist; 
	2 = listPresentation;
]
</block>

<block recall>
/ trials = [1 = recall]
</block>

<block comparison>
/ onblockbegin = [
	list.compACC_round.reset();
	list.compRT_round.reset();
	values.responseCategory = "";
]
/ trials = [
	1 = getReadyComparison;
	2-5 = noreplace(warmUp_different1, warmUp_different2, warmUp_same1, warmUp_same2);
	6 = sequence(comp1, comp2, comp3, comp4, comp5, comp6, comp7, comp8);
	7 = ComparisonFeedbackDelay;
	8 = ComparisonFeedback;
	9 = performanceGoalsReminder;
]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ blocks = [
	1 = instructions;
	2-3 = sequence(listPresentation, recall, comparison); 	
	4 = testInstructions;
	5-22 =sequence(listPresentation, recall, comparison);
	23 = finish;
]
</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************