		values.WrmL1wrd2 = item.WrmL1wrd2_practice.item(values.setNr);
		values.WrmL2wrd1 = item.WrmL2wrd1_practice.item(values.setNr);
		values.WrmL2wrd2 = item.WrmL2wrd2_practice.item(values.setNr);	
	
		values.compWord1_1 = item.comp1_wrd1_practice.item(values.setNr);
		values.compWord1_2 = item.comp1_wrd2_practice.item(values.setNr);
		values.compWord2_1 = item.comp2_wrd1_practice.item(values.setNr);
		values.compWord2_2 = item.comp2_wrd2_practice.item(values.setNr);
		values.compWord3_1 = item.comp3_wrd1_practice.item(values.setNr);
		values.compWord3_2 = item.comp3_wrd2_practice.item(values.setNr);
		values.compWord4_1 = item.comp4_wrd1_practice.item(values.setNr);
		values.compWord4_2 = item.comp4_wrd2_practice.item(values.setNr);
		values.compWord5_1 = item.comp5_wrd1_practice.item(values.setNr);
		values.compWord5_2 = item.comp5_wrd2_practice.item(values.setNr);
		values.compWord6_1 = item.comp6_wrd1_practice.item(values.setNr);
		values.compWord6_2 = item.comp6_wrd2_practice.item(values.setNr);		
		values.compWord7_1 = item.comp7_wrd1_practice.item(values.setNr);
		values.compWord7_2 = item.comp7_wrd2_practice.item(values.setNr);	
		values.compWord8_1 = item.comp8_wrd1_practice.item(values.setNr);
		values.compWord8_2 = item.comp8_wrd2_practice.item(values.setNr);
		
		values.compWord1_compAns = item.comp1_compAns_practice.item(values.setNr);
		values.compWord2_compAns = item.comp2_compAns_practice.item(values.setNr);
		values.compWord3_compAns = item.comp3_compAns_practice.item(values.setNr);
		values.compWord4_compAns = item.comp4_compAns_practice.item(values.setNr);	
		values.compWord5_compAns = item.comp5_compAns_practice.item(values.setNr);		
		values.compWord6_compAns = item.comp6_compAns_practice.item(values.setNr);		
		values.compWord7_compAns = item.comp7_compAns_practice.item(values.setNr);		
		values.compWord8_compAns = item.comp8_compAns_practice.item(values.setNr);		
		
		values.compWord1_compType = item.comp1_compType_practice.item(values.setNr);
		values.compWord2_compType = item.comp2_compType_practice.item(values.setNr);
		values.compWord3_compType = item.comp3_compType_practice.item(values.setNr);
		values.compWord4_compType = item.comp4_compType_practice.item(values.setNr);	
