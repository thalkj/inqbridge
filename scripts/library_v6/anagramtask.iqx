/2 = "BLAL"
/3 = "NORB"
/4 = "BLUC"
/5 = "NAIR"
</item>

<list easyAnagramsItemnumbers>
/ items = (1, 2, 3, 4, 5)
/ replace = false
</list>

<item easyAnagramsSolutions>
/1 = "HAND"
/2 = "BALL"
/3 = "BORN"
/4 = "CLUB"
/5 = "RAIN"
</item>

<item difficultAnagrams>
/1 = "DIYAMG"
/2 = "WOPNEG"
/3 = "HAMYAP"
/4 = "CYTEPL"
/5 = "KAMASD"
</item>

<list difficultAnagramsItemnumbers>
/ items = (1, 2, 3, 4, 5)
/ replace = false
</list>

<item difficultAnagramsSolutions>
/1 = "DIGAMY"
/2 = "GOWPEN"
/3 = "MAYHAP"
/4 = "YCLEPT"
/5 = "DAMASK"
</item>

