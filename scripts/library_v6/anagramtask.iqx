values.countSkips_easy, expressions.meanAttempts_easy, expressions.propCorrect_easy, expressions.meanRT_easy, expressions.meanCorrRT_easy,
values.countSkips_difficult, expressions.meanAttempts_difficult, expressions.propCorrect_difficult, expressions.meanRT_difficult, expressions.meanCorrRT_difficult)

</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

<values>
/anagramCondition = ""
/anagramOffsettime = ""
/countAttempts = 0
/timeout = 0
/correctSolution = ""
/lastSuggestedSolution = ""
/suggestedSolutions = ""
/anagram = ""
/anagramRT = ""
/anagramACC = ""
/anagramIndex = ""
/skip = 0
/selectFeedback = ""
/defaultResponse = ""
/nextAnagram = ""
/countSkips_easy = 0
/countSkips_difficult = 0
</values>

**************************************************************************************************************
