/meanCorrRT_easy = list.corrRT_easyAnagrams.mean

/meanAttempts_difficult = list.attemtps_difficult.mean
/propCorrect_difficult = list.ACC_difficultAnagrams.mean
/meanRT_difficult = list.RT_difficultAnagrams.mean
/meanCorrRT_difficult = list.corrRT_difficultAnagrams.mean
</expressions>

