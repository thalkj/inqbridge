/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text easyAnagram>
/ items = easyAnagrams
/ select = values.anagramIndex
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ position = (50%, 35%)
/ size = (80%, 10%)
/ vjustify = center
</text>

<text difficultAnagram>
/ items = difficultAnagrams
/ select = values.anagramIndex
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ position = (50%, 35%)
/ size = (80%, 10%)
/ vjustify = center
</text>

<text feedback>
/ onprepare = [
	if (values.selectFeedback == 1){
		text.feedback.textColor = green;
	} else if (values.selectFeedback == 2){
		text.feedback.textColor = red;
	} else {
		text.feedback.textColor = black;		
	}
]
/ items = feedback
/ select = values.selectFeedback
/ fontstyle = ("Arial", 7%, true, false, false, false, 5, 1)
/ position = (50%, 70%)
/ size = (80%, 8%)
/ vjustify = center
</text>

<text feedbackEraser>
/ items = ("")
/ fontstyle = ("Arial", 7%, false, false, false, false, 5, 1)
/ position = (50%, 70%)
/ txcolor = red
/ size = (80%, 8%)
/ vjustify = center
/ txbgcolor = white
</text>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************


*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC_easyAnagrams>
</list>

Note: list stores the response latencies for each relevant trial
<list RT_easyAnagrams>
</list>

Note: list stores the correct response latencies for each relevant trial
<list corrRT_easyAnagrams>
</list>

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC_difficultAnagrams>
</list>

Note: list stores the response latencies for each relevant trial
<list RT_difficultAnagrams>
</list>

Note: list stores the correct response latencies for each relevant trial
<list corrRT_difficultAnagrams>
</list>

<list attempts_easy>
</list>

<list attemtps_difficult>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

*******************************
easy Anagrams
*******************************

<trial easyAnagramStart>
/ ontrialend = [
	values.anagramCondition = "easy";
	values.anagramIndex = list.easyAnagramsItemnumbers.nextValue;
	values.correctSolution = item.easyAnagramsSolutions.item(values.anagramIndex);
	values.anagram = item.easyAnagrams.item(values.anagramIndex);
	values.anagramACC = 0;
	values.anagramRT = "";
	values.skip = 0;
	values.defaultResponse = "";
	values.nextAnagram = 0;
	values.countAttempts = 0;	
	values.suggestedSolutions = "";
	values.lastSuggestedSolution = "";
	
]
/ trialduration = 0
/ branch = [
	values.anagramOffsettime = script.elapsedTime + parameters.anagramTimeout;//set the timeout for the current anagram
	return openended.easyAnagram;
]
/ recorddata = false
</trial>


<openended easyAnagram>
/ ontrialbegin = [
	values.timeout = values.anagramOffsettime - script.elapsedTime;
	
	//determine whether a feedback stim should be presented
	if (values.selectFeedback != 0){
		openended.easyAnagram.insertStimulusTime(text.feedback, 0);	
		openended.easyAnagram.insertStimulusTime(text.feedbackEraser, parameters.feedbackDuration);
	}
]
/ stimulustimes = [0 = easyAnagram, instruct]
/ monkeyresponse = ("HAND", "BALL", "BORN", "CLUB", "RAIN", "DIGAMY", "GOWPEN", "MAYHAP", "YCLEPT", "DAMASK", "SKIP")
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ required = true
/ beginresponsetime = 0
/ responseinterrupt = immediate
/ buttonlabel = "Next"
/ iscorrectresponse = [
	toupper(openended.easyAnagram.response) == values.correctSolution;
]
/ ontrialend = [
	openended.easyAnagram.resetStimulusFrames();
	
	//update variables as long as participants are still trying to solve the current anagram
	if (values.nextAnagram == 0){
	
		values.anagramRT += openended.easyAnagram.latency;
			
		if (contains(toupper(openended.easyAnagram.response), "SKIP")){
			values.skip = 1;
			values.countSkips_easy += 1;
			values.nextAnagram = 1;
			list.ACC_easyAnagrams.appendItem(0);
			list.RT_easyAnagrams.appendItem(values.anagramRT);
			values.selectFeedback = 0;
			values.lastSuggestedSolution = "";
		} else if (openended.easyAnagram.correct){
			values.anagramACC = 1;
			values.selectFeedback = 1;
			list.ACC_easyAnagrams.appendItem(1);
			list.corrRT_easyAnagrams.appendItem(values.anagramRT);
			list.RT_easyAnagrams.appendItem(values.anagramRT);
			values.lastSuggestedSolution = openended.easyAnagram.response;
			values.suggestedSolutions = concat(values.suggestedSolutions, openended.easyAnagram.response);
			values.suggestedSolutions = concat(values.suggestedSolutions, ",");
			values.countAttempts += 1;		
		} else if (openended.easyAnagram.response != ""){
			values.anagramACC = 0;
			values.selectFeedback = 2;
			values.suggestedSolutions = concat(values.suggestedSolutions, openended.easyAnagram.response);
			values.suggestedSolutions = concat(values.suggestedSolutions, ",");	
			values.countAttempts += 1;
		} else {//in case of a no response => ran out of time
			values.selectFeedback = 3;
			values.nextAnagram = 1;
			list.ACC_easyAnagrams.appendItem(0);
			list.RT_easyAnagrams.appendItem(values.anagramRT);			
		}				
	}	
]
/ defaultresponse = values.defaultResponse
/ timeout = values.timeout
/ branch = [
	if (values.nextAnagram == 1){//participant is done with the current anagram and should move on to the next
		if (values.selectFeedback != 3){
			values.selectFeedback = 0
		}
		return trial.easyAnagramData;
	} else if (values.selectFeedback == 1){
		values.nextAnagram = 1;//the openended trial should only be presented once more for the Correct Feedback stim
		values.defaultResponse = openended.easyAnagram.response;
		values.anagramOffsettime = script.elapsedTime + parameters.feedbackDuration;//the next openended trial only runs for the duration of the feedback trial
		return openended.easyAnagram;
	} else {
		return openended.easyAnagram;
	}
]
/ recorddata = false
</openended>

//Note: this trial saves the relevant anagram data to the data file
<trial easyAnagramData>
/ ontrialbegin = [
	list.attempts_easy.appendItem(values.countAttempts);
]
/ stimulusframes = [1 = clearScreen]
/ trialduration = 0
/ recorddata = true
</trial>

*******************************
difficult Anagrams
*******************************

<trial difficultAnagramStart>
/ ontrialend = [
	values.anagramCondition = "difficult";
	values.anagramIndex = list.difficultAnagramsItemnumbers.nextValue;
	values.correctSolution = item.difficultAnagramsSolutions.item(values.anagramIndex);
	values.anagram = item.difficultAnagrams.item(values.anagramIndex);
	values.anagramACC = 0;
	values.anagramRT = "";
	values.skip = 0;
	values.defaultResponse = "";
	values.nextAnagram = 0;
	values.countAttempts = 0;	
	values.suggestedSolutions = "";
	values.lastSuggestedSolution = "";
	
]
/ trialduration = 0
/ branch = [
	values.anagramOffsettime = script.elapsedTime + parameters.anagramTimeout;//set the timeout for the current anagram
	return openended.difficultAnagram;
]
/ recorddata = false
</trial>

<openended difficultAnagram>
/ ontrialbegin = [
	values.timeout = values.anagramOffsettime - script.elapsedTime;
	
	//determine whether a feedback stim should be presented
	if (values.selectFeedback != 0){
		openended.difficultAnagram.insertStimulusTime(text.feedback, 0);	
		openended.difficultAnagram.insertStimulusTime(text.feedbackEraser, parameters.feedbackDuration);
	}
]
/ monkeyresponse = ("HAND", "BALL", "BORN", "CLUB", "RAIN", "DIGAMY", "GOWPEN", "MAYHAP", "YCLEPT", "DAMASK", "SKIP")
/ stimulustimes = [0 = difficultAnagram, instruct]
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ beginresponsetime = 0
/ required = true
/ responseinterrupt = immediate
/ buttonlabel = "Next"
/ iscorrectresponse = [
	toupper(openended.difficultAnagram.response) == values.correctSolution;
]
/ ontrialend = [
	openended.difficultAnagram.resetStimulusFrames();
	
	//update variables as long as participants are still trying to solve the current anagram
	if (values.nextAnagram == 0){
	
		values.anagramRT += openended.difficultAnagram.latency;
			
		if (contains(toupper(openended.difficultAnagram.response), "SKIP")){
			values.skip = 1;
			values.countSkips_difficult += 1;
			values.nextAnagram = 1;
			list.ACC_difficultAnagrams.appendItem(0);
			list.RT_difficultAnagrams.appendItem(values.anagramRT);
			values.selectFeedback = 0;
			values.lastSuggestedSolution = "";
		} else if (openended.difficultAnagram.correct){
			values.anagramACC = 1;
			values.selectFeedback = 1;
			list.ACC_difficultAnagrams.appendItem(1);
			list.corrRT_difficultAnagrams.appendItem(values.anagramRT);
			list.RT_difficultAnagrams.appendItem(values.anagramRT);
			values.lastSuggestedSolution = openended.difficultAnagram.response;
			values.suggestedSolutions = concat(values.suggestedSolutions, openended.difficultAnagram.response);
			values.suggestedSolutions = concat(values.suggestedSolutions, ",");
			values.countAttempts += 1;		
		} else if (openended.difficultAnagram.response != ""){
			values.anagramACC = 0;
			values.selectFeedback = 2;
			values.suggestedSolutions = concat(values.suggestedSolutions, openended.difficultAnagram.response);
			values.suggestedSolutions = concat(values.suggestedSolutions, ",");	
			values.countAttempts += 1;
		} else {//in case of a no response => ran out of time
			values.selectFeedback = 3;
			values.nextAnagram = 1;
			list.ACC_difficultAnagrams.appendItem(0);
			list.RT_difficultAnagrams.appendItem(values.anagramRT);			
		}				
	}	
]
/ defaultresponse = values.defaultResponse
/ timeout = values.timeout
/ branch = [
	if (values.nextAnagram == 1){//participant is done with the current anagram and should move on to the next
		if (values.selectFeedback != 3){
			values.selectFeedback = 0
		}
		return trial.difficultAnagramData;
	} else if (values.selectFeedback == 1){
		values.nextAnagram = 1;//the openended trial should only be presented once more for the Correct Feedback stim
		values.defaultResponse = openended.difficultAnagram.response;
		values.anagramOffsettime = script.elapsedTime + parameters.feedbackDuration;//the next openended trial only runs for the duration of the feedback trial
		return openended.difficultAnagram;
	} else {
		return openended.difficultAnagram;
	}
]
/ recorddata = false
</openended>

//Note: this trial saves the relevant anagram data to the data file
<trial difficultAnagramData>
/ ontrialbegin = [
	list.attemtps_difficult.appendItem(values.countAttempts);
]
/ stimulusframes = [1 = clearScreen]
/ trialduration = 0
/ recorddata = true
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block finish>
/ trials = [
	1 = finish;
]
</block>

<block test>
/ preinstructions = (intro1, intro2)
/ onblockbegin = [
	values.selectFeedback = 0;
]
/ trials = [
	1,2,5,8,10 = easyAnagramStart;
	3,4,6,7,9 = difficultAnagramStart;
]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ blocks = [
	1 = test;
	2 = finish;
]
</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************