</radiobuttons>

<radiobuttons q4_H_GD_kurz>
/caption = "4. Die meisten Männer sind eigentlich wie Kinder."
/ options = ("lehne~nvollkommen ab", "lehne ab", "lehne eher ab", "stimme~neher zu", "stimme zu", "stimme~nvollkommen zu")
