<radiobuttons q3_H_P_kurz>
/caption = "3. Männer reden über Gleichberechtigung, können aber nicht damit umgehen."
/ options = ("lehne~nvollkommen ab", "lehne ab", "lehne eher ab", "stimme~neher zu", "stimme zu", "stimme~nvollkommen zu")
/ optionvalues = ("1", "2", "3", "5", "6", "7")
