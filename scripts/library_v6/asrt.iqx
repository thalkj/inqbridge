<expt asrt>
/ onexptbegin = [
	values.sequence = concat(values.sequence, list.patternPosition.item(1));
	values.sequence = concat(values.sequence, list.patternPosition.item(2));
	values.sequence = concat(values.sequence, list.patternPosition.item(3));
	values.sequence = concat(values.sequence, list.patternPosition.item(4));	
]
/ blocks = [
	1 = intro;
	2 = ASRT;
	3 = finish;
]
</expt>

