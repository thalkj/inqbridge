**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text box1>
/ items = ("")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos1_x
/ vposition = 50%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = gray
/ erase = false
</text>

<text box2>
/ items = ("")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos2_x
/ vposition = 50%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = gray
