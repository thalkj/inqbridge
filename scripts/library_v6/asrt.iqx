**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/FeedbackACC:				overall proportion correct (pattern and random trials)
/FeedbackRT:				overall (pattern and random trials) median response time of correct responses
Note: start trials are not considered; the lists are reset every other block
and the values are simply used for feedback

/ACC_P:							the mean of all block proportion corrects for pattern trials
/RT_P:							the mean of all block median correct latencies (in ms) for pattern trials						

/ACC_R:							the mean of all block proportion corrects for random trials (start trials excluded)
/RT_R:							the mean of all block median correct latencies (in ms) for random trials (start trials excluded)

		 
<expressions>
/FeedbackACC = list.accuracy.mean
/FeedbackRT = list.latencies.median

/ACC_P = list.propCorrect_P.mean
/RT_P = list.medianRTs_P.mean

/ACC_R = list.propCorrect_R.mean
/RT_R = list.medianRTs_R.mean
</expressions>


**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text box1_key>
/ items = ("<%parameters.responsekey1%>")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos1_x
/ vposition = 60%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = black
/ txcolor = white
</text>

<text box2_key>
/ items = ("<%parameters.responsekey2%>")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos2_x
/ vposition = 60%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = black
/ txcolor = white
</text>

<text box3_key>
/ items = ("<%parameters.responsekey3%>")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos3_x
/ vposition = 60%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = black
/ txcolor = red
</text>

<text box4_key>
/ items = ("<%parameters.responsekey4%>")
/ fontstyle = ("Arial", parameters.stimHeight, false, false, false, false, 5, 1)
/ hposition = parameters.pos4_x
/ vposition = 60%
/ size = (parameters.stimHeight*0.75, parameters.stimHeight)
/ txbgcolor = black
/ txcolor = white
</text>


<text instructions>
/ items = instructions
/ select = 1
/ position = (10%, 25%)
/ halign = left
/ valign = top
/ hjustify = left
/ size = (80%, 80%)
</text>


<trial instructions>
/ stimulusframes = [1 = instructions, box1, box2, box3, box4, box1_key, box2_key, box3_key, box4_key]
/ validresponse = (" ")
/ recorddata = false
</trial>


<clock timer>
/ mode = timer
/ resetrate = block
/ erase = false
/ txcolor = yellow
/ txbgcolor = black
/ timeout = parameters.breakDuration
/ position = (50%, 30%)
/ format = "mm:ss"
</clock> 

<text breakInstructions>
/ items = miscellaneousInstructions
/ select = 1
/ position = (50%, 20%)
/ size = (60%, 10%)
/ vjustify = center
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
</text>

<text Feedback>
/ items = miscellaneousInstructions
/ select = 2
/ position = (50%, 50%)
/ size = (80%, 40%)
/ vjustify = center
/ fontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
</text>

<text Feedback2>
/ items = miscellaneousInstructions
/ select = 3
/ position = (50%, 65%)
/ size = (80%, 10%)
/ vjustify = center
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ txcolor = red
</text>

<trial break>
/ skip = [
	values.skipBreak == true;
]
/ stimulusframes = [1 = breakInstructions, timer, Feedback, blockInfo, Feedback2]
/ timeout = parameters.breakDuration
/ recorddata = false
</trial>


<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

*************************************
General Helper Instruction Trials
*************************************

This trial is used when participants are asked to place their fingers on specific response
buttons. On the touchscreen, this trial presents the (inactive) response buttons to the participants.
<trial getReady>
/ stimulusframes = [1 = getReady]
/ trialduration = parameters.readyDuration
/ validresponse = (parameters.responsekey1, parameters.responsekey2, parameters.responsekey3, parameters.responsekey4)
/ beginresponsetime = parameters.readyDuration
/ errormessage = false
/ recorddata = false
</trial>

