		values.top = 26.7;
		values.bottom_percentile = 15;
		values.top_percentile = 20;		
	} else if (expressions.Craving <= 30.9) {
		values.bottom = 26.7;
		values.top = 30.9;	
		values.bottom_percentile = 20;
		values.top_percentile = 25;		
	} else if (expressions.Craving <= 33.6) {
		values.bottom = 30.9;
		values.top = 33.6;	
		values.bottom_percentile = 25;
		values.top_percentile = 30;		
	} else if (expressions.Craving <= 37.5) {
		values.bottom = 33.6;
		values.top = 37.5;
		values.bottom_percentile = 30;
		values.top_percentile = 35;		
	} else if (expressions.Craving <= 39.2) {
