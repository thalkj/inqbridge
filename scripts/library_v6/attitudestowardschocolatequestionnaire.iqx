		values.top = 13.0;
		values.bottom_percentile = 35;
		values.top_percentile = 49;		
	} else if (expressions.Guilt <= 16.6) {
		values.bottom = 13.0;
		values.top = 16.6;
		values.bottom_percentile = 40;
		values.top_percentile = 45;		
	} else if (expressions.Guilt <= 18.3) {
		values.bottom = 16.6;
		values.top = 18.3;	
		values.bottom_percentile = 45;
		values.top_percentile = 50;		
	} else if (expressions.Guilt <= 19.7) {
