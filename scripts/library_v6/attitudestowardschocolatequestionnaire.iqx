/Guilt_percentile_M = {
	if (expressions.Guilt <= 2.9) {
		values.bottom = 0;
		values.top = 2.9;
		values.bottom_percentile = 0;
		values.top_percentile = 5;
	} else if (expressions.Guilt <= 6.4){
		values.bottom = 2.9;
		values.top = 6.4;
		values.bottom_percentile = 5;
		values.top_percentile = 10;		
	} else if (expressions.Guilt <= 7.7){
		values.bottom = 6.4;
		values.top = 7.7;
		values.bottom_percentile = 10;
		values.top_percentile = 15;		
	} else if (expressions.Guilt <= 9.9) {
		values.bottom = 7.7;
		values.top = 9.9;
		values.bottom_percentile = 15;
		values.top_percentile = 20;		
	} else if (expressions.Guilt <= 10.1) {
		values.bottom = 9.9;
