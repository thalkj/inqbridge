		values.bottom_percentile = 20;
		values.top_percentile = 25;		
	} else if (expressions.Guilt <= 10.9) {
		values.bottom = 10.1;
		values.top = 10.9;	
		values.bottom_percentile = 25;
		values.top_percentile = 30;		
	} else if (expressions.Guilt <= 11.9) {
		values.bottom = 10.9;
		values.top = 11.9;
		values.bottom_percentile = 30;
		values.top_percentile = 35;		
	} else if (expressions.Guilt <= 13.0) {
