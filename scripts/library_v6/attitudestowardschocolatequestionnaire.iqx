	SURVEY
*******************************************************************************************************************
*******************************************************************************************************************
Notes:
- presents the surveypages
- to take pictures of each screen set /screencapture = true

<survey attitudestowardschocolatequestionnaire>
/pages = [
	1 = ATCQ1; 
	2 = ATCQ2; 
	3 = ATCQ3; 
	4 = ATCQ4; 
	5 = ATCQ5; 
	6 = ATCQ6;
	7 = ATCQ7;
	8 = ATCQ8;
	9 = ATCQ9;
]
/screencapture = false
/ onblockend = [
	expressions.determinePercentiles;
]
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/subcaptionfontstyle = ("Arial", 2%, false, false, false, false, 5, 1)
/itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
/showpagenumbers = false
/showquestionnumbers = false
/ itemspacing = 6%
/ finishlabel = "Finish"
/ nextbuttonposition = (65%, 90%)
/ backbuttonposition = (20%, 90%)
/ navigationbuttonfontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
</survey>

