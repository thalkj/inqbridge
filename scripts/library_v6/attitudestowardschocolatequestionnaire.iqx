/determinePercentiles = {
	if (dropdown.gender.response == "Male"){
		values.Craving_percentile = expressions.Craving_percentile_M;
		values.Guilt_percentile = expressions.Guilt_percentile_M;
		values.Functional_percentile = expressions.Functional_percentile_M;
	} else {
		values.Craving_percentile = expressions.Craving_percentile_F;
		values.Guilt_percentile = expressions.Guilt_percentile_F;
		values.Functional_percentile = expressions.Functional_percentile_F;		
	}
}

