		values.top_percentile = 49;		
	} else if (expressions.Craving <= 42.6) {
		values.bottom = 39.2;
		values.top = 42.6;
		values.bottom_percentile = 40;
		values.top_percentile = 45;		
	} else if (expressions.Craving <= 45.5) {
		values.bottom = 42.6;
		values.top = 45.5;	
		values.bottom_percentile = 45;
		values.top_percentile = 50;		
	} else if (expressions.Craving <= 49.4) {
		values.bottom = 45.5;
		values.top = 49.4;	
		values.bottom_percentile = 50;
		values.top_percentile = 55;		
	} else if (expressions.Craving <= 53.6) {
		values.bottom = 49.4;
		values.top = 53.6;	
		values.bottom_percentile = 55;
		values.top_percentile = 60;		
	} else if (expressions.Craving <= 56.0) {
		values.bottom = 53.6;
		values.top = 56.0;
		values.bottom_percentile = 60;
		values.top_percentile = 65;			
	} else if (expressions.Craving <= 58.9) {
		values.bottom = 56.0;
		values.top = 58.9;
		values.bottom_percentile = 65;
		values.top_percentile = 70;		
	} else if (expressions.Craving <= 65.5) {
		values.bottom = 58.9;
		values.top = 65.5;
		values.bottom_percentile = 70;
		values.top_percentile = 75;		
	} else if (expressions.Craving <= 67.9) {
		values.bottom = 65.5;
		values.top = 67.9;
		values.bottom_percentile = 75;
		values.top_percentile = 80;			
	} else if (expressions.Craving <= 71.1) {
		values.bottom = 67.9;
		values.top = 71.1;	
		values.bottom_percentile = 80;
		values.top_percentile = 85;	
	} else if (expressions.Craving <= 77.3) {
		values.bottom = 71.1;
		values.top = 77.3;
		values.bottom_percentile = 85;
		values.top_percentile = 90;		
	} else if (expressions.Craving <= 83.8) {
		values.bottom = 77.3;
		values.top = 83.8;
		values.bottom_percentile = 90;
		values.top_percentile = 95;			
	} else {
		values.bottom = 83.8;
		values.top = 100;	
		values.bottom_percentile = 95;
		values.top_percentile = 100;			
	}
	
	values.bottom_percentile + (expressions.Craving - values.bottom)*expressions.calculateStep;
}

