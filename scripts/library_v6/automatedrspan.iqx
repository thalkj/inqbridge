<list PracSentenceCorrect>
/ items = (
	"FALSE", "TRUE", "TRUE", "FALSE", "TRUE", "TRUE", "TRUE", "FALSE", 
	"FALSE", "FALSE", "TRUE", "TRUE", "FALSE", "FALSE", "FALSE")
/ selectionmode = text.PracSentenceProblem.currentIndex
</list>


