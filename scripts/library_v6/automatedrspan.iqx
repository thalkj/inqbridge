**************************************************************************************************************

***************************
Visual Letters: 
***************************
<item letters_visual>
/ 1 = "T"
/ 2 = "L"
/ 3 = "Q"
/ 4 = "N"
/ 5 = "F"
/ 6 = "H"
/ 7 = "Y"
/ 8 = "S"
/ 9 = "P"
/ 10 = "K"
/ 11 = "R" 
/ 12 = "J"
