*************

<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed, 
expressions.totalCorrectCount)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	Instructions and stimulus text
**************************************************************************************************************
**************************************************************************************************************

<text true>
/ items = true
/ txcolor = darkGray
/ txbgcolor = white
/ position = (40%, 60%)
/ fontstyle = ("Arial", 7%, false, false, false, false, 5, 1)
</text>

<text false>
/ items = false
/ txcolor = darkGray
/ txbgcolor = white
/ position = (60%, 60%)
/ fontstyle = ("Arial", 7%, false, false, false, false, 5, 1)
</text>

<text continue>
/ items = continue
/ txcolor = blue
/ position = (50%, 66%)
/ fontstyle = ("Arial", 4%, false, false, true, false, 5, 1)
</text>

<text instructions>
/ items = instructions
/ txcolor = darkGray
/ txbgcolor = white
/ position = (50%, 33%)
/ size = (66%, 50%)
/ hjustify = left
/ vjustify = center
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ select = sequence
</text>

<text examples>
/ items = examples
/ fontstyle = ("Arial", 3.91%, false, false, false, false, 5, 1)
/ txcolor = black
/ select = sequence
/ position = (50%, 40%)
</text>

<text test>
/ items = test
/ fontstyle = ("Arial", 3.91%, false, false, false, false, 5, 1)
/ txcolor = black
/ select = noreplace
/ position = (50%, 40%)
</text>

<text correctmessage>
/ items = correctmessage
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ txcolor = green
</text>

<text errormessage>
/ items = error
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ txcolor = red
</text>

