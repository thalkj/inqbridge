**************************************************************************************************************
**************************************************************************************************************
	Trial Definitions
**************************************************************************************************************
**************************************************************************************************************

<trial examples>
/ stimulusframes = [1=examples, true, false]
/ validresponse = (true, false)
/ correctmessage = true(correctmessage, 500)
/ errormessage = true(errormessage, 500)
/ iscorrectresponse = [
	return (trial.examples.response == item.exampleanswers.item(text.examples.nextIndex));
]
</trial>

<trial test>
/ stimulusframes = [1=test, true, false]
/ validresponse = (true, false)
/ iscorrectresponse = [
	return (trial.test.response == item.testanswers.item(text.test.nextIndex));
]
</trial>

<trial instructions>
/ stimulustimes = [1=instructions, continue]
/ validresponse = (continue)
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	Block Definitions
**************************************************************************************************************
**************************************************************************************************************

<block test>
/ trials = [1-64=test]
/ timeout = parameters.testduration
</block>

<block instructions>
/ trials = [1-2=instructions; 3-6=examples;7=instructions]
</block>

**************************************************************************************************************
**************************************************************************************************************
	Experiment Definition
**************************************************************************************************************
**************************************************************************************************************
<expt baddeley>
/ blocks = [
	1=instructions; 
	2=test;
]
</expt>

