</text>

*******************************************************************************************************************
*******************************************************************************************************************
	LISTS
*******************************************************************************************************************
*******************************************************************************************************************
Note: list randomly samples the first letter to be presented in a block
1 = X
2 = Y

<list firsttarget>
/items = (1, 2)
/replace = true
</list>

*******************************************************************************************************************
*******************************************************************************************************************
	TRIALS
*******************************************************************************************************************
*******************************************************************************************************************

*********************************************************************************************************
-all response latencies are measured from onset of target stimulus until the next target is presented
-response does not interrupt trial

Target (800ms) -> Fixation (200ms) -> Target (800ms) .....
SOA: 1000ms (=> 1 Hz): participants have the entire 1000ms to respond to the presented target
*********************************************************************************************************


Note:
* first trial needs to be a Go trial
* randomly selects the first target
<trial startGO>
/ontrialbegin = [
	values.trialtype = "Go";
	values.selecttarget = list.firsttarget.nextValue;
	if (values.blocktype == "SL") values.count_go_SL += 1 else values.count_go_dl += 1;

	trial.startgo.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.startgo.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.startgo.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]

/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (" ")
/ontrialend = [
	trial.startgo.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.startgo.response != 0) values.rt = trial.startgo.latency else values.rt = "";
	if (values.rt !=""){
		if (values.rt >= parameters.anticipatoryresponse){
			values.responsetype = "Go Success";
		} else {
			values.responsetype = "Go Anticipatory";
		}
	} else {
		values.responsetype = "Go Omission";
	}

	if (values.responsetype == "Go Omission"){
		if (values.blocktype == "SL") {
			values.count_omissions_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_omissions_DL += 1;
		}
	} else if (values.responsetype == "Go Anticipatory"){
		if (values.blocktype == "SL") {
			values.count_anticipatory_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_anticipatory_DL += 1;
		}		
	}
]
/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
</trial>


Note:
* Go trial that follows a Go trial
* reverses the target
<trial GO>
/ontrialbegin = [
	values.trialtype = "Go";
	if (values.blocktype == "SL") values.count_go_SL += 1 else values.count_go_dl += 1;
	if (values.selecttarget == 1) values.selecttarget = 2 else values.selecttarget = 1;

	trial.GO.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.GO.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.GO.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/ validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (" ")
/ontrialend = [
	trial.GO.resetStimulusFrames();
	values.stimulus = text.target.currentItem;
	
	if (trial.GO.response != 0) values.rt = trial.GO.latency else values.rt = "";
	if (values.rt !=""){
		if (values.rt >= parameters.anticipatoryresponse){
			values.responsetype = "Go Success";
		} else {
			values.responsetype = "Go Anticipatory";
		}
	} else {
		values.responsetype = "Go Omission";
	}

	if (values.responsetype == "Go Omission"){
		if (values.blocktype == "SL") {
			values.count_omissions_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_omissions_DL += 1;
		}
	} else if (values.responsetype == "Go Anticipatory"){
		if (values.blocktype == "SL") {
			values.count_anticipatory_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_anticipatory_DL += 1;
		}		
	}	
]
/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
</trial>


Note:
* no target reversal
* NoGo trial that is followed by a second NoGo trial (->NOGO_DL2)
<trial NOGO_DL1>
/ontrialbegin = [
	values.trialtype = "NoGo";
	if (values.blocktype == "SL") values.count_nogo_SL += 1 else values.count_NOGO_DL += 1;

	trial.NOGO_DL1.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.NOGO_DL1.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.NOGO_DL1.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (0)
/ontrialend = [
	trial.NOGO_DL1.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.NOGO_DL1.response != 0) values.rt = trial.NOGO_DL1.latency else values.rt = "";
	if (trial.NOGO_DL1.error) {
		values.responsetype = "NoGo Failure";
		values.count_failedsuppressions_DL += 1;	
	} else {
		values.responsetype = "NoGo Success";
	}
]
/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
/branch = [return trial.NOGO_DL2;]
</trial>

Note:
* follows a NoGo trial (-> NoGo_DL1)
* calls a Go trial (->GO_DL)
<trial NOGO_DL2>
/ontrialbegin = [
	values.trialtype = "NoGo";
	if (values.blocktype == "SL") values.count_NOGO_SL += 1 else values.count_nogo_dl += 1;

	trial.NOGO_DL2.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.NOGO_DL2.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.NOGO_DL2.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (0)
/ontrialend = [
	trial.NOGO_DL2.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.NOGO_DL2.response != 0) values.rt = trial.NOGO_DL2.latency else values.rt = "";
	if (trial.NOGO_DL2.error) {
		values.responsetype = "NoGo Failure";
		values.count_failedsuppressions_DL += 1;		
	} else {
		values.responsetype = "NoGo Success";
	}
]
/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
/branch = [return trial.GO_DL;]
</trial>

Note:
* Go trial that follows a NOGO_DL trial
* target reversal
<trial GO_DL>
/ontrialbegin = [
	values.trialtype = "Go";
	if (values.blocktype == "SL") values.count_go_SL += 1 else values.count_go_dl += 1;
	if (values.selecttarget == 1) values.selecttarget = 2 else values.selecttarget = 1;

	trial.GO_DL.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.GO_DL.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.GO_DL.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (" ")
/ontrialend = [
	trial.GO_DL.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.GO_DL.response != 0) values.rt = trial.GO_DL.latency else values.rt = "";
	if (values.rt !=""){
		if (values.rt >= parameters.anticipatoryresponse){
			values.responsetype = "Go Success";
		} else {
			values.responsetype = "Go Anticipatory";
		}
	} else {
		values.responsetype = "Go Omission";
	}

	if (values.responsetype == "Go Omission"){
		if (values.blocktype == "SL") {
			values.count_omissions_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_omissions_DL += 1;
		}
	} else if (values.responsetype == "Go Anticipatory"){
		if (values.blocktype == "SL") {
			values.count_anticipatory_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_anticipatory_DL += 1;
		}		
	}	
]

/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
</trial>


Note:
* a nogo trial that follows a go trial
* no target reversal
* is followed by a Go trial (-> GO_SL)
<trial NOGO_SL>
/ontrialbegin = [
	values.trialtype = "NoGo";
	if (values.blocktype == "SL") values.count_nogo_SL += 1 else values.count_nogo_dl += 1;

	trial.NOGO_SL.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.NOGO_SL.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.NOGO_SL.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (0)
/ontrialend = [
	trial.NOGO_SL.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.NOGO_SL.response != 0) values.rt = trial.NOGO_SL.latency else values.rt = "";
	if (trial.NOGO_SL.error) {
		values.responsetype = "NoGo Failure";
	} else {
		values.responsetype = "NoGo Success";
	}

	if (trial.NOGO_SL.error){
		if (values.blocktype == "SL"){
			values.count_failedsuppressions_SL += 1;		
		} else if (values.blocktype == "DL"){
			values.count_failedsuppressions_DL += 1;		
		}
	} 
]
/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
/branch = [return trial.GO_SL;]
</trial>

Note:*TARGET TRIAL for Behavioral Adaptation*
* Go trial that follows a NOGO_SL trial
* target reversal
* latencies of correct responses that follow correct suppression of the preceding NoGo trial are tracked in 
summary variables 
<trial GO_SL>
/ontrialbegin = [
	values.trialtype = "Go";
	if (values.blocktype == "SL") values.count_go_SL += 1 else values.count_go_dl += 1;
	if (values.selecttarget == 1) values.selecttarget = 2 else values.selecttarget = 1;
	values.previousresponsetype = values.responsetype;

	trial.GO_SL.insertStimulusTime(clearScreen, parameters.stimulusduration);
	trial.GO_SL.insertStimulusTime(text.fixationcross, parameters.stimulusduration);
	trial.GO_SL.insertStimulusTime(clearScreen, (parameters.fixationduration + parameters.stimulusduration));
]
/stimulustimes = [0 = target]
/responseinterrupt = frames
/beginresponsetime = 0
/validresponse = (" ")
/monkeyresponse = (" ", noresponse)
/correctresponse = (" ")
/ontrialend = [
	trial.GO_SL.resetStimulusFrames();
	values.stimulus = text.target.currentItem;

	if (trial.GO_SL.response != 0) values.rt = trial.GO_SL.latency else values.rt = "";
	if (values.rt !=""){
		if (values.rt >= parameters.anticipatoryresponse){
			values.responsetype = "Go Success";
		} else {
			values.responsetype = "Go Anticipatory";
		}
	} else {
		values.responsetype = "Go Omission";
	}

	if (values.responsetype == "Go Omission"){
		if (values.blocktype == "SL") {
			values.count_omissions_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_omissions_DL += 1;
		}
	} else if (values.responsetype == "Go Anticipatory"){
		if (values.blocktype == "SL") {
			values.count_anticipatory_SL += 1;			
		} else if (values.blocktype == "DL"){
			values.count_anticipatory_DL += 1;
		}		
	}		

	if (values.blocktype == "DL"){
		if (values.responsetype == "Go Success"){
			if (values.previousresponsetype == "NoGo Success"){
				values.count_go_sldl += 1; 
				values.sumrt_go_sldl += trial.go_sl.latency;			
			}
		}
	} else if (values.blocktype == "SL"){
		if (values.responsetype == "Go Success"){
			if (values.previousresponsetype ==  "NoGo Success"){
				values.count_go_slsl += 1; 
				values.sumrt_go_slsl += trial.go_sl.latency;			
			}
		}
	}
]

/trialduration = (parameters.stimulusduration + parameters.fixationduration)
/recorddata = true
</trial>

