</radiobuttons>

<radiobuttons q8_R>
/caption = "8. I am not a safe driver when I exceed the speed limit."
/ options = ("1~nNot true", "2", "3", "4~nSomewhat~ntrue", "5", "6", "7~nVery true")
/ optionvalues = ("1","1", "0", "0", "0", "0", "0")
