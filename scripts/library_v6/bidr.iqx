<radiobuttons q12_R>
/caption = "12. I sometimes lose out on things because I can’t make up my mind soon enough."
/ options = ("1~nNot true", "2", "3", "4~nSomewhat~ntrue", "5", "6", "7~nVery true")
/ optionvalues = ("1","1", "0", "0", "0", "0", "0")
