/ optionvalues = ("0","0", "0", "0", "0", "1", "1")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q10_R>
/caption = "10. It’s hard for me to shut off a disturbing thought."
/ options = ("1~nNot true", "2", "3", "4~nSomewhat~ntrue", "5", "6", "7~nVery true")
/ optionvalues = ("1","1", "0", "0", "0", "0", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q11>
/caption = "11. I never regret my decisions."
/ options = ("1~nNot true", "2", "3", "4~nSomewhat~ntrue", "5", "6", "7~nVery true")
/ optionvalues = ("0","0", "0", "0", "0", "1", "1")
