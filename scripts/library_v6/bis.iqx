**************************************************************************************************************
**************************************************************************************************************

********************
raw data
********************

The raw questionnaire data are saved under "BIS.IQDAT"

********************
summary data
********************

<summarydata>
/columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.elapsedTime, script.completed,  
expressions.A_Attention, expressions.A_CogInstabile, expressions.M_Motor, expressions.M_Perserverance, expressions.NP_SelfControl, 
expressions.NP_CogComplex, expressions.totalscore,

radiobuttons.q1_R.response,
radiobuttons.q2.response,
radiobuttons.q3.response,
radiobuttons.q4.response,
radiobuttons.q5.response,
radiobuttons.q6.response,
radiobuttons.q7_R.response,
radiobuttons.q8_R.response,
radiobuttons.q9_R.response,
radiobuttons.q10_R.response,
radiobuttons.q11.response,
radiobuttons.q12_R.response,
radiobuttons.q13_R.response,
radiobuttons.q14.response,
radiobuttons.q15_R.response,
radiobuttons.q16.response,
radiobuttons.q17.response,
radiobuttons.q18.response,
radiobuttons.q19.response,
radiobuttons.q20_R.response,
radiobuttons.q21.response,
radiobuttons.q22.response,
radiobuttons.q23.response,
radiobuttons.q24.response,
radiobuttons.q25.response,
radiobuttons.q26.response,
radiobuttons.q27.response,
radiobuttons.q28.response,
radiobuttons.q29_R.response,
radiobuttons.q30_R.response


)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************
totalscore:								holds the total of all scores 
A_Attention-NP_CogComplex:				adds up all the scores for each individual subscale

<expressions>

/A_Attention = radiobuttons.q5.response + radiobuttons.q9_R.response + radiobuttons.q11.response + 
radiobuttons.q20_R.response + radiobuttons.q28.response

/A_CogInstabile = radiobuttons.q6.response + radiobuttons.q24.response + radiobuttons.q26.response

/M_Motor = radiobuttons.q2.response + radiobuttons.q3.response + radiobuttons.q4.response +
radiobuttons.q17.response + radiobuttons.q19.response + radiobuttons.q22.response + radiobuttons.q25.response

/M_Perserverance = radiobuttons.q16.response + radiobuttons.q21.response + radiobuttons.q23.response + radiobuttons.q30_R.response

/NP_SelfControl = radiobuttons.q1_R.response + radiobuttons.q7_R.response + radiobuttons.q8_R.response +
radiobuttons.q12_R.response + radiobuttons.q13_R.response + radiobuttons.q14.response

/NP_CogComplex = radiobuttons.q10_R.response + radiobuttons.q15_R.response + radiobuttons.q18.response +
radiobuttons.q27.response + radiobuttons.q29_R.response

/totalscore = expressions.A_Attention + expressions.A_CogInstabile+expressions.M_Motor+
expressions.M_Perserverance+expressions.NP_SelfControl+expressions.NP_CogComplex
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	QUESTIONS
**************************************************************************************************************
**************************************************************************************************************
NOTE: 
*by default each question is required, to change: set
/required = false for each of the 30 questions

*the R indicates reversed scoring

<radiobuttons q1_R>
/caption = "1. I plan tasks carefully"
/ options = ("Rarely/Never", "Occasionally", "Often", "Almost Always/Always")
/orientation = horizontalequal
/ optionvalues = ("4", "3", "2", "1")
/required = true
</radiobuttons>

<radiobuttons q2>
/caption = "2. I do things without thinking"
/ options = ("Rarely/Never", "Occasionally", "Often", "Almost Always/Always")
/ optionvalues = ("1", "2", "3", "4")
