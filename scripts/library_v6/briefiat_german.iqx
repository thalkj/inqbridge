************************************
Short Blocks
************************************

Note:
Short Blocks are simply shorter versions (only 4 prefatory trial + 8 trials) of the longer Experimental Blocks. 
They are intended as practice blocks as participants tend to be slower 
during the first two blocks of an BIAT. They are not included into further data analyses.

<block short_a>
/ onblockbegin = [
	values.currentTarget = item.targetALabel.1; 
	text.topFocusInstruct.1 = item.targetAFocusInstruct.1;
]
/ trials = [
	1=testInstructions; 
	2=showLabels;
  3-6 = noreplace(targetARight, targetBLeft);
  8,10,12,14 = noreplace(targetARight, targetBLeft);
  7,9,11,13 = noreplace(attributeA, attributeB);
 ]
/ errormessage = true(error,200)
/ response = correct
</block>

<block short_b>
/ onblockbegin = [
	values.currentTarget = item.targetBLabel.1; 
	text.topFocusInstruct.1 = item.targetBFocusInstruct.1;
]
/ trials = [
	1=testInstructions; 
	2=showLabels;
  3-6 = noreplace(targetBRight, targetALeft);
  8,10,12,14 = noreplace(targetBRight, targetALeft);
  7,9,11,13 = noreplace(attributeA, attributeB);
 ]
/ errormessage = true(error,200)
/ response = correct
</block>

************************************
Experimental Blocks
************************************
Note:
* experimental blocks run 20 trials by default
* the first 4 trials = prefatory trials that are not included into subsequent analyses

<block A>
/ skip = [parameters.extended == false && block.A.totalcount >=1]
/ onblockbegin = [
	values.currentTarget = item.targetALabel.1; 
	text.topFocusInstruct.1 = item.targetAFocusInstruct.1;
]
/ trials = [1=testInstructions; 2=showLabels;
  3-6 = noreplace(targetARight, targetBLeft);
  8,10,12,14,16,18,20,22 = noreplace(targetARight, targetBLeft);
  7,9,11,13,15,17,19,21 = noreplace(attributeA, attributeB)]
/ errormessage = true(error,200)
/ response = correct
/ ontrialend = [

	if (block.A.latency  <= 10000 && block.A.currenttrialnumber >= 7 ) {
		list.ACC.appendItem(block.A.correct);
		if (block.A.totalcount == 0){
			list.corrRT_A1.appendItem(block.A.latency);
			list.corrRT_1.appendItem(block.A.latency);
		} else if (block.A.totalcount == 1) {
			list.corrRT_A2.appendItem(block.A.latency);
			list.corrRT_2.appendItem(block.A.latency);
		}
	}	
	
	
	if (block.A.currenttrialnumber >= 7){
		if(block.A.latency  < 300) {
			list.RT300.appendItem(1);
		} else {
			list.RT300.appendItem(0);
		}		
	}	
]
</block>

<block B>
/ skip = [parameters.extended == false && block.B.totalcount >=1]
/ onblockbegin = [
	values.currentTarget = item.targetBLabel.1; 
	text.topFocusInstruct.1 = item.targetBFocusInstruct.1;
]
/ trials = [1=testInstructions;2=showLabels;
  3-6 = noreplace(targetBRight, targetALeft);
  8,10,12,14,16,18,20,22= noreplace(targetBRight, targetALeft);
  7,9,11,13,15,17,19,21= noreplace(attributeA, attributeB)]
/ errormessage = true(error,200)
/ response = correct
/ ontrialend = [

	if (block.B.latency  <= 10000 && block.B.currenttrialnumber >= 7 ) {
		list.ACC.appendItem(block.B.correct);
		if (block.B.totalcount == 0){
			list.corrRT_B1.appendItem(block.B.latency);
			list.corrRT_1.appendItem(block.B.latency);
		} else if (block.B.totalcount == 1) {
			list.corrRT_B2.appendItem(block.B.latency);
			list.corrRT_2.appendItem(block.B.latency);
		}
	}	
	
	if (block.B.currenttrialnumber >= 7){
		if(block.B.latency  < 300) {
			list.RT300.appendItem(1);
		} else {
			list.RT300.appendItem(0);
		}		
	}
]
</block>

<block summary>
/ trials = [1=summary]
/ recorddata = false
</block>

<block end>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

Note: 
* counterbalanced by groupnumber
* if a participant goes through a sequence of BIATs the short blocks 
short_a & short_b only need to be run for the very first BIAT in the sequence

<expt a>
/ groups = (1 of 2)
/ onblockbegin = [
	values.blockcount += 1;
]
/ blocks = [
	1 = intro; 
	2 = short_a; 
	3 = short_b; 
	4 = A; 
	5 = B; 
	6 = A; 
	7 = B; 
	8 = summary;
	9 = end;
]
</expt>

<expt b>
/ groups = (2 of 2)
/ onblockbegin = [
	values.blockcount += 1;
]
/ blocks = [
	1 = intro; 
	2 = short_b; 
	3 = short_a; 
	4 = B; 
	5 = A; 
	6 = B; 
	7 = A; 
	8 = summary;
	9 = end;
]
</expt>

***********************************************************************
Test Monkey
***********************************************************************

<monkey>
/ latencydistribution = normal(500, 100)
/ percentcorrect = 90
</monkey>

**************************************************************************************************************
												End of File
**************************************************************************************************************