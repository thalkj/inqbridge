/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q15>
/caption = "15. I love to talk with others who admire <%textbox.favoritecelebrity.response%>"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q16>
/caption = "16. Keeping up with news about <%textbox.favoritecelebrity.response%> is an entertaining pastime."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q17>
/caption = "17. It is enjoyable just to be with others who like <%textbox.favoritecelebrity.response%>"
