/required = true
</radiobuttons>

<radiobuttons q31>
/caption = "31. News about <%textbox.favoritecelebrity.response%> is a pleasant break from a harsh world"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
