</radiobuttons>

<radiobuttons q25>
/caption = "25. I have frequent thoughts about <%textbox.favoritecelebrity.response%>, even when I don’t want to"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
