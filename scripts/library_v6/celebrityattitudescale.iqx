	SURVEY
*******************************************************************************************************************
*******************************************************************************************************************
Notes:
- presents the surveypages
- to take pictures of each screen set /screencapture = true


<survey CelebrityAttitudeScale>
/pages = [
	1 = CAS1; 
	2 = CAS2; 
	3 = CAS3; 
	4 = CAS4; 
	5 = CAS5; 
	6 = CAS6; 
	7 = CAS7; 
	8 = CAS8;
	9 = CAS9;
	10 = CAS10;
	11 = CAS11;
	12 = CAS12;
	13 = CAS13;
	14 = CAS14;
]
/screencapture = false
/ fontstyle = ("Arial", 3%, false, true, false, false, 5, 1)
/subcaptionfontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ txcolor = black
/showpagenumbers = false
/showquestionnumbers = false
