/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************
<surveypage CAS1>
/caption ="THE CELEBRITY ATTITUDE SCALE"
/subcaption = "The purpose of this survey is to identify your views about famous persons. The responses you give are confidential. There are no right or wrong answers, so please answer as openly and thoughtfully as you can. 

For purposes of the survey we are defining the term “celebrity” as a famous living person (or one who died during your lifetime) that you greatly admire.

"
/questions = [1 = favoritecelebrity]
</surveypage>

<surveypage CAS2>
/caption ="THE CELEBRITY ATTITUDE SCALE
"
/questions = [1 = celebritytype]
</surveypage>


<surveypage CAS3>
/caption ="THE CELEBRITY ATTITUDE SCALE
"
/questions = [1 = q1, q2, q3]
</surveypage>

