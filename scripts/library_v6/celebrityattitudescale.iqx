/required = true
</radiobuttons>

<radiobuttons q21>
/caption = "21. My friends and I like to discuss what <%textbox.favoritecelebrity.response%> has done"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q22>
/caption = "22. I would gladly die in order to save the life of <%textbox.favoritecelebrity.response%>"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q23>
/caption = "23. If I were lucky enough to meet <%textbox.favoritecelebrity.response%>, and he/she asked me to do something illegal as a favor, I would probably do it."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
