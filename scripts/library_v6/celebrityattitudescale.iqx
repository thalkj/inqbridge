*******************************************************************************************************************
*******************************************************************************************************************
	DEFAULTS:
*******************************************************************************************************************
*******************************************************************************************************************
requires Inquisit 6.5.2.0

<defaults>
/minimumversion = "6.5.2.0"
/canvasaspectratio = (4,3)
/ quitcommand = (Alt+18)
</defaults>

*******************************************************************************************************************
*******************************************************************************************************************
	DATA: this section contains data file information
*******************************************************************************************************************
*******************************************************************************************************************

********************
raw data: CAS.iqdat
********************

********************
Summary data
********************

<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed, 
expressions.IntensePersonal, expressions.z_score_IP, expressions.p_IP,
expressions.EntertainmentSocial, expressions.z_score_ES, expressions.p_ES,
expressions.BorderlinePathological, expressions.z_score_BP, expressions.p_BP,
textbox.favoritecelebrity.response, checkboxes.celebritytype.response,
radiobuttons.q1.response, radiobuttons.q2.response, radiobuttons.q3.response, radiobuttons.q4.response, radiobuttons.q5.response, 
radiobuttons.q6.response, radiobuttons.q7.response, radiobuttons.q8.response, radiobuttons.q9.response, radiobuttons.q10.response, 
radiobuttons.q11.response, radiobuttons.q12.response, radiobuttons.q13.response, radiobuttons.q14.response, radiobuttons.q15.response, 
radiobuttons.q16.response, radiobuttons.q17.response, radiobuttons.q18.response, radiobuttons.q19.response, radiobuttons.q20.response, 
radiobuttons.q21.response, radiobuttons.q22.response, radiobuttons.q23.response, radiobuttons.q24.response, radiobuttons.q25.response, 
radiobuttons.q26.response, radiobuttons.q27.response, radiobuttons.q28.response, radiobuttons.q29.response, radiobuttons.q30.response, 
radiobuttons.q31.response, radiobuttons.q32.response, radiobuttons.q33.response, radiobuttons.q34.response)
</summarydata>


*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

Intense personal 1+ 8 + 11 + 2 + 33 + 18 + 24 + 12 + 14 + 16 + 28 +6 + 3
(Max = 13*5 = 65; Min = 13*1 = 13)
Entertainment Social 17+ 31 + 23 + 13 + 19+ 29 +5
(Max = 7 * 5 = 35; Min = 7)
Borderline Pathological 4 + 22 + 25 + 15 + 20 + 7
(Max = 6 * 5 = 30; Min = 6)
The rest of the items can be considered as filler items

<expressions>
/IntensePersonal = radiobuttons.q1.response + radiobuttons.q8.response + radiobuttons.q11.response + 
radiobuttons.q2.response + radiobuttons.q33.response + radiobuttons.q18.response + radiobuttons.q24.response +
radiobuttons.q12.response + radiobuttons.q14.response + radiobuttons.q16.response + radiobuttons.q28.response +
radiobuttons.q6.response + radiobuttons.q3.response

/EntertainmentSocial = radiobuttons.q17.response + radiobuttons.q31.response + radiobuttons.q23.response +
radiobuttons.q13.response + radiobuttons.q19.response + radiobuttons.q29.response + radiobuttons.q5.response

/BorderlinePathological = radiobuttons.q4.response + radiobuttons.q22.response + radiobuttons.q25.response + 
radiobuttons.q15.response + radiobuttons.q20.response + radiobuttons.q7.response
</expressions>

Norms (based on means and standard deviations published by Maltby et al, 2006, p. 278.
No gender differences found by Maltby et al)
<expressions>
/z_score_IP = (expressions.IntensePersonal - 17.86)/6.5
/z_score_ES = (expressions.EntertainmentSocial - 24.48)/9.5
/z_score_BP = (expressions.BorderlinePathological - 11.34)/3.4

/p_IP = pofz(expressions.z_score_IP)
/p_ES = pofz(expressions.z_score_ES)
/p_BP = pofz(expressions.z_score_BP)
</expressions>



*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<textbox favoritecelebrity>
/caption = "Who is your favorite celebrity? (Please choose one famous person, as defined above)" 
/required = true
/ textboxsize = (40%, 5%)
</textbox>

<checkboxes celebritytype>
/caption = "Just in case your favorite celebrity is unknown to us, please select one or more of the following to describe why your favorite celebrity is famous:"
/options = ("Acting", "Author", "Artist", "Medicine", "Modeling", "Music", "News", "Politics", "Religion",
"Royalty", "Radio or TV Talk Show", "Science", "Sports")
/other =  "Other (please describe)"
/orientation = vertical
/required = true
</checkboxes>

<radiobuttons q1>
/caption = "1. If I were to meet <%textbox.favoritecelebrity.response%> in person, he/she would already somehow know that I am his/her biggest fan"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q2>
/caption = "2. One of the main reasons I maintain an interest in <%textbox.favoritecelebrity.response%> is that doing so gives me a temporary escape from life’s problems."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q3>
/caption = "3. <%textbox.favoritecelebrity.response%> is practically perfect in every way."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q4>
/caption = "4. I share with <%textbox.favoritecelebrity.response%> a special bond that cannot be described in words."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q5>
/caption = "5. To know <%textbox.favoritecelebrity.response%> is to love him/her"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q6>
/caption = "6. When something bad happens to <%textbox.favoritecelebrity.response%> I feel like it happened to me"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q7>
/caption = "7. When <%textbox.favoritecelebrity.response%> fails or loses at something I feel like a failure myself."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q8>
/caption = "8. The successes of <%textbox.favoritecelebrity.response%> are my successes too."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q9>
/caption = "9. I consider <%textbox.favoritecelebrity.response%> to be my soul mate."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q10>
/caption = "10. When <%textbox.favoritecelebrity.response%> dies (or died) I will feel (or I felt) like dying too."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q11>
/caption = "11. If someone gave me several thousand dollars to do with as I please, I would consider spending it on a personal possession (like a napkin or paper plate) once used by <%textbox.favoritecelebrity.response%>."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q12>
/caption = "12. When something good happens to <%textbox.favoritecelebrity.response%> I feel like it happened to me."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q13>
/caption = "13. I am obsessed by details of <%textbox.favoritecelebrity.response%>’s life."
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q14>
/caption = "14. I have pictures and/or souvenirs of <%textbox.favoritecelebrity.response%> which I always keep in exactly the same place."
