</radiobuttons>

<radiobuttons q18>
/caption = "18. I enjoy watching, reading, or listening to <%textbox.favoritecelebrity.response%> because it means a good time"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q19>
/caption = "19. Learning the life story of <%textbox.favoritecelebrity.response%> is a lot of fun"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
/optionvalues = ("5"; "4"; "3"; "2"; "1")
/orientation = horizontalequal
/required = true
</radiobuttons>

<radiobuttons q20>
/caption = "20. I like watching and hearing about <%textbox.favoritecelebrity.response%> when I am with a large group of people"
/options = ("Strongly Agree"; "Agree"; "Uncertain or ~nneutral"; "Disagree"; "Strongly Disagree")
