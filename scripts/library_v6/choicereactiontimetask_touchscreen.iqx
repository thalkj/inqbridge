**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text choiceRT_intro>
/ items = choiceRT_intro
/ select = sequence
/ resetinterval = 0
/ vjustify = center
/ hjustify = left
/ position = (50%, 50%)
/ size = (80%, 80%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ erase = false
</text>

<trial choiceRT_HBdemo>
/ stimulusframes = [1 = choiceRT_intro, welcome, header, showHB]
/ validresponse = (showHB)
/ responseinterrupt = immediate
/ recorddata = true
/ branch = [
	trial.choiceRT_HBdemo2;
]
</trial>

<trial choiceRT_HBdemo2>
/ ontrialbegin = [	
	values.isi = 4000;
	values.rt = "";
]
/ stimulusframes = [1 = choiceRT_intro, welcome, header, HomeButton_choiceRT, HomeButtonLabel_choiceRT, introInstructions]
/ validresponse = (homeButton_choiceRT)
/ responseinterrupt = immediate
/ recorddata = true
/ ontrialend = [
	text.instructionReminder.textcolorblue = 166;
	text.instructionReminder.textcolorgreen = 166;
	text.instructionReminder.textcolorred = 166;
]
/ branch = [
	trial.choiceRTpractice_HB;
]
/ responsemessage = (anyresponse, clearScreen, 0)
</trial>

<trial choiceRT_intro>
/ inputdevice = mouse
/ stimulusframes = [1 = clearScreen, choiceRT_intro, choiceRT_continue]
/ validresponse = (choiceRT_continue)
/ recorddata = false
</trial>


<trial finish>
/ stimulusframes = [1 = clearScreen, finish, finalFeedback]
/ timeout = 2000
/ recorddata = false
</trial>

<trial choiceRT_monitorSizeCheck>
/ stimulusframes = [1 = monitorSizeFail, exit]
/ validresponse = (exit)
</trial>

