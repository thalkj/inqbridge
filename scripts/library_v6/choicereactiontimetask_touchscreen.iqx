	TRIALS : Choice Reaction Time Task
**************************************************************************************************************
**************************************************************************************************************

Note: trial.assembleTargetButtonList_choiceRT

- creates list.targetbuttons_choiceRT based on the active circle response rectangles
- set the color of the active response rectangles gray; white otherwise
- calculates the needed poolSize of list.targetbuttons_choiceRT (for 5 response boxes => 5 * 9 = 45)
- calculates the number of active response rectangles

<trial assembleTargetButtonList_choiceRT>
/ ontrialbegin = [
	values.nr_stims = parameters.button1_choiceRT + parameters.button2_choiceRT + 
	parameters.button3_choiceRT + parameters.button4_choiceRT + parameters.button5_choiceRT;
]
/ trialduration = 0
/ branch = [
	return trial.assembleTargetButtonList_choiceRT_B;
]
/ recorddata = true
</trial>

<trial assembleTargetButtonList_choiceRT_B>
/ ontrialbegin = [
	if (parameters.button1_choiceRT == true){
		list.targetbuttons_choiceRT.insertItem(1, 1);
		shape.1.color = lightGray;
	} else {	
		shape.1.colorblue = 166;
		shape.1.colorgreen = 166;
		shape.1.colorred = 166;
	}
	if (parameters.button2_choiceRT == true){
		list.targetbuttons_choiceRT.insertItem(2, 1);
		shape.2.color = lightGray;
	} else {
		shape.2.colorblue = 166;
		shape.2.colorgreen = 166;
		shape.2.colorred = 166;
	}
	if (parameters.button3_choiceRT == true){
		list.targetbuttons_choiceRT.insertItem(3, 1);
		shape.3.color = lightGray;
	} else {
		shape.3.colorblue = 166;
		shape.3.colorgreen = 166;
		shape.3.colorred = 166;
	}	
	if (parameters.button4_choiceRT == true){
		list.targetbuttons_choiceRT.insertItem(4, 1);
		shape.4.color = lightGray;
	} else {
		shape.4.colorblue = 166;
		shape.4.colorgreen = 166;
		shape.4.colorred = 166;
	}	
	if (parameters.button5_choiceRT == true){
		list.targetbuttons_choiceRT.insertItem(5, 1);
		shape.5.color = lightGray;
	} else {
		shape.5.colorblue = 166;
		shape.5.colorgreen = 166;
		shape.5.colorred = 166;
	}
]
/ trialduration = 0
/ branch = [
	if (trial.assembleTargetButtonList_choiceRT_B.trialcount < parameters.numberTestTrials/values.nr_stims){
			return trial.assembleTargetButtonList_choiceRT_B;
	} else {
		values.nr_stims = list.targetbuttons_choiceRT.poolSize;
	}
	return null;
]
/ recorddata = true
</trial>



Note:
- trial presents HomeButton and response buttons and stores script.elapsedTime as the time the finger touches down on HomeButton
- the trial concludes with pressing down on the HomeButton and calls trial.ChoiceRT_HB

Note: 
* after a predetermined time frame, a reminder to press on home button is flashed onto the screen
* trial is only run once at the start of the test sequence to collect the very first up response

<trial ChoiceRT_start>
/ontrialbegin = [	
	values.repeat = 0;
	values.selectFeedback = 4;
	trial.ChoiceRT_start.insertStimulusTime(text.choiceRT_feedback, parameters.homeButton_RW);
]
/ stimulusframes = [1 = clearScreen, ChoiceRT_feedbackEraser,homeButton_ChoiceRT, 
HomeButtonLabel_ChoiceRT, 1, 2, 3, 4, 5, instructionReminder]
/ beginresponsetime = -1
/ validresponse = (homeButton_choiceRT)
/ isvalidresponse = [
	if (trial.ChoiceRT_start.response == "homeButton_ChoiceRT") {
		values.rt_down1 = script.elapsedTime;
		values.rt_down3 = values.rt_down1;
	}
	return (trial.ChoiceRT_start.response == "homeButton_ChoiceRT");
]
/ responseinterrupt = immediate
/ ontrialend = [
		trial.ChoiceRT_start.resetStimulusFrames();
		
		text.instructionReminder.textcolorblue = 166;
		text.instructionReminder.textcolorgreen = 166;
		text.instructionReminder.textcolorred = 166;
]
/ branch = [
		return trial.ChoiceRT_HB;
]
/ recorddata = false
/ responsemessage = ("homeButton_ChoiceRT", text.CHoiceRT_feedbackEraser, 0)
</trial>

Note: trial.choiceRT_HB introduces a buffer time after pressing down on the HomeButton
to ensure that Stimulus is not presented unless the finger has rested on the Homebutton for 
values.isi 
* HB label changes color to blue
* if the finger stays on HomeButton (no 'up' response detected) for values.isi time
then trial.choiceRTpractice2 is called
* if the finger is lifted off too early from HomeButton, trial.choiceRT_HBdown_repeat is called

<trial ChoiceRT_HB>
/ ontrialbegin = [
	if (values.repeat == 0){
		values.responseArea = "";
		values.trialcount += 1;
		values.valid = 1;
		values.stimPresentTime = "";
		values.isi = list.isi_choiceRT.nextValue;
		values.countUp = 0;
		values.count_earlyResponses = 0;
		values.rt = "";	
		values.rt_down1 = values.rt_down3;
		values.rt_down3 = "";
		values.rt_down2 = "";
		values.rt_up1 = "";
		values.rt_up2 = "";	
	
		values.targetPosition = list.targetbuttons_choiceRT.nextValue;
		if (values.targetPosition == 1) {
			shape.target.hposition = shape.1.hposition;
			shape.target.vposition = shape.1.vposition;			
		} else if (values.targetPosition == 2){
			shape.target.hposition = shape.2.hposition;
			shape.target.vposition = shape.2.vposition;		
		} else if (values.targetPosition == 3){
			shape.target.hposition = shape.3.hposition;
			shape.target.vposition = shape.3.vposition;				
		} else if (values.targetPosition == 4){
			shape.target.hposition = shape.4.hposition;
			shape.target.vposition = shape.4.vposition;			
		} else if (values.targetPosition == 5){
			shape.target.hposition = shape.5.hposition;
			shape.target.vposition = shape.5.vposition;				
		}	
	}	
]	
/ stimulustimes = [0 = HomeButton_choiceRT, HomeButtonLabel2_choiceRT]
/ validresponse = (lbuttonup)
/ responseinterrupt = immediate
/ beginresponsetime = -1
/ timeout = values.isi
/ ontrialend = [
	trial.choiceRT_HB.resetStimulusFrames();	
]
/ branch = [
	if (trial.choiceRT_HB.response == 0 || monkey.monkeyMode){
		return trial.choiceRT_HBoffSTIMdown;
	} else {
		return trial.choiceRT_HBdown_repeat;
	}
]
/ recorddata = false
/ responsemessage = ("lbuttonup", HomeButtonLabel_choiceRT, 0)
/ responsemessage = (0,	choiceRT_feedbackEraser, 0)
</trial>

Note: trial.choiceRT_HBdown_repeat waits once more for a HomeButton touchdown
- home button label changes back to white
- values.rt_down1 is updated to reflect the new HomeButton touchdown 
- if no touchdown occurs within 5000ms, a reminder/error message is presented
- once the touchdown occurs, trial.choiceRT_HB is called once more

<trial choiceRT_HBdown_repeat>
/ ontrialbegin = [
	values.repeat = 1;
	values.selectFeedback = 4;
	trial.choiceRT_HBdown_repeat.insertStimulusTime(text.choiceRT_feedback, parameters.homeButton_RW);
]
/ stimulusframes = [1 = choiceRT_feedbackEraser, choiceRT_HBfeedback, homeButton_choiceRT, HomeButtonLabel_choiceRT]
/ validresponse = (homeButton_choiceRT)
/ responseinterrupt = immediate
/ beginresponsetime = -1
/ ontrialend = [
		trial.choiceRT_HBdown_repeat.resetStimulusFrames();
		
		if (trial.choiceRT_HBdown_repeat.response == "homeButton_choiceRT"){
				values.rt_down1 = script.elapsedTime;
				values.count_earlyResponses += 1;
				values.total_earlyResponses += 1;
				values.total_earlyResponses_choiceRT += 1;
		}
]
/ branch = [
	return trial.choiceRT_HB;
]	
/ recorddata = false
/ responsemessage = ("homeButton_choiceRT", text.choiceRT_feedbackEraser, 0)
</trial>


Note: trial.choiceRT is called after the homebutton is pressed for values.isi
- the Stim button appears
- collects script.elapsedTime when finger lifts off HomeButton after Stim presentation 
and turns the Home Button label back to white
- collects script.elapsedTime when finger touches down on Stim Button 
- values.finalACC stores whether the response was actually correct (=Stim Button was pressed within predetermined time frame and finger wasn't lifted of Home Button); 0 = finger went down elsewhere

<trial choiceRT_HBoffSTIMdown>
/ ontrialbegin = [
	values.valid = 1;
	values.ACC = 0;
	values.finalACC = 0;
]
/ stimulustimes = [0 = target]
/ validresponse = (lbuttonup, lbuttondown)
/ beginresponsetime = -1
/timeout = parameters.stim_RW
/ isvalidresponse = [
	if (trial.choiceRT_HBoffSTIMdown.response == "lbuttonup"){
			values.countUP += 1;
			values.rt_up1 = script.elapsedTime;
			values.rt_releaseHB = values.rt_up1 - shape.target.timestamp;				
			
	} else if (trial.choiceRT_HBoffSTIMdown.response == "lbuttondown"){
		values.valid = 1;
	
		values.rt_down2 = script.elapsedTime;
		if (mouse.y >= expressions.targetStimButton_top && mouse.y <= expressions.targetStimButton_bottom && 
			mouse.x >= expressions.targetStimButton_left && mouse.x <= expressions.targetStimButton_right){

			values.responseArea = "Target";
			values.finalACC = 1;
			values.ACC = 1;

		} else {
			values.ACC = 2;
			values.responseArea = "elsewhere";
		}		
	}
	
	return (values.valid == 1);
]
/ correctresponse = (lbuttondown)
/ response = correct
/ errormessage = true(HomeButtonLabel_choiceRT, 0)
/ responsemessage = (lbuttondown, eraseButton_choiceRT, 0)

/ ontrialend = [
	trial.choiceRT_HBoffSTIMdown.resetStimulusFrames();
	values.stimPresentTime = shape.target.timestamp;
	if (values.finalACC == 1){
		values.rt = expressions.A + expressions.B;			
	}
		
	if (values.ACC == 1){
		list.latencies_choiceRT.appendItem(values.rt);
	
	}	
	list.ACC_choiceRT.appendItem(values.finalACC);
	
	if (values.responseArea == ""){
		values.ACC = 3;
	}

]
/ branch = [
	if (values.responseArea == ""){
		values.selectFeedback = 3;
		return trial.choiceRT_feedback;
	} else {
		return trial.choiceRT_StimOFF;
	}
]
/ recorddata = false
</trial>

Note: trial
- collects second UP response (ideally finger lifts off the Stim button)
- if something other than the Stim button was pressed, trial.choiceRT_feedback is called
<trial choiceRT_STIMoff>
/ validresponse = (lbuttonup)
/ beginresponsetime = -1
/ isvalidresponse = [
	values.rt_up2 = script.elapsedTime;
	trial.choiceRT_StimOFF.response == "lbuttonup";
]
/ ontrialend = [
	values.countUP += 1;
]
/ branch = [
	if (values.responseArea == "elsewhere"){
		values.selectFeedback = 1;
		return trial.choiceRT_feedback;
	} else {
		return trial.choiceRT_HBdown;
	}
]
/ recorddata = false
</trial>


<trial choiceRT_feedback>
/ stimulusframes = [1 = clearScreen, choiceRT_feedback]
/ trialduration = parameters.feedback
/ recorddata = false
/ branch = [
	return (trial.choiceRT_HBdown);
]
</trial>

Note: this trial collects the down response on the homebutton after the finger is lifted off the stim button;
if more trials need to be run it calls trial.choiceRT_HB;
<trial choiceRT_HBdown>
/ontrialbegin = [
	values.repeat = 0;
	values.selectFeedback = 4;
	trial.choiceRT_HBdown.insertStimulusTime(text.choiceRT_feedback, parameters.homeButton_RW);
]
/ stimulusframes = [1 = choiceRT_feedbackEraser,homeButton_choiceRT, HomeButtonLabel_choiceRT, 1, 2, 3, 4, 5, instructionReminder]
/ beginresponsetime = -1
/ validresponse = (homeButton_choiceRT)
/ isvalidresponse = [
	if (trial.choiceRT_HBdown.response == "homeButton_choiceRT") {
		values.rt_down3 = script.elapsedTime;
	}
	return (trial.choiceRT_HBdown.response == "homeButton_choiceRT");
]
/ responseinterrupt = immediate
/ ontrialend = [
	trial.choiceRT_HBdown.resetStimulusFrames();
		
	text.instructionReminder.textcolorblue = 166;
	text.instructionReminder.textcolorgreen = 166;
	text.instructionReminder.textcolorred = 166;
	
	if (values.finalACC == 1){
		if (expressions.A != ""){
			list.durationsA.appendItem(expressions.A);		
		}
		if (expressions.B != ""){
			list.durationsB.appendItem(expressions.B);		
		}
		if (expressions.C != ""){
			list.durationsC.appendItem(expressions.C);		
		}	
		if (expressions.D != ""){
			list.durationsD.appendItem(expressions.D);		
		}	
		if (expressions.duration_HomeButton != ""){
			list.homeButton_durations.appendItem(expressions.duration_HomeButton);		
		}		
	}
]
/ branch = [
	if (values.trialcount < parameters.numberTestTrials){
		return trial.choiceRT_HB;	
	}
	return null;
]
/ recorddata = true
/ responsemessage = ("homeButton_choiceRT", text.choiceRT_feedbackEraser, 0)
</trial>

