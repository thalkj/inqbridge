<shape 1>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ hposition = 1px * (expressions.centerx - expressions.widthchange_angle0)
/ vposition = 1px * (expressions.centery + expressions.heightchange_angle0)
/erase = false
/ color = lightGray
</shape>

<shape 2>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ hposition = 1px * (expressions.centerx - expressions.widthchange_angle45)
/ vposition = 1px * (expressions.centery - expressions.heightchange_angle45)
/erase = false
/ color = lightGray
</shape>

<shape 3>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ hposition = 1px * (expressions.centerx + expressions.widthchange_angle90)
/ vposition = 1px * (expressions.centery - expressions.heightchange_angle90)
/erase = false
/ color = lightGray
</shape>

<shape 4>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ hposition = 1px * (expressions.centerx + expressions.widthchange_angle45)
/ vposition = 1px * (expressions.centery - expressions.heightchange_angle45)
/erase = false
/ color = lightGray
</shape>

<shape 5>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ hposition = 1px * (expressions.centerx + expressions.widthchange_angle0)
/ vposition = 1px * (expressions.centery - expressions.heightchange_angle0)
/erase = false
/ color = lightGray
</shape>

<shape target>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ erase = false
/ color = yellow
</shape>

<shape HomeButton_choiceRT>
/ shape = circle
/ color = black
/ position = (50%, parameters.HomeButton_choiceRT_y)
/ size = (parameters.homeButtonSize*0.75, parameters.homeButtonSize)
/ erase = false
</shape>

<text HomeButtonLabel_choiceRT>
/ items = ("HOME")
/ txcolor = white
/ size = (10%, 7%)
/ position = (50%, 50%)
/ erase = false
/ txbgcolor = black
/ vjustify = center
</text>

<text HomeButtonLabel2_choiceRT>
/ items = ("HOME")
/ txcolor = blue
/ size = (10%, 7%)
/ position = (50%, 50%)
/ erase = false
/ txbgcolor = black
/ vjustify = center
</text>

<text choiceRT_feedback>
/items = choiceRT_feedback
/ select = values.selectFeedback
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ position = (50%, 75%)
/ size = (80%, 15%)
/ txbgcolor = transparent
/erase = false
</text>

<text choiceRT_HBfeedback>
/ items = choiceRT_feedback
/ select = 2
/ size = (80%, 15%)
/ position = (50%, 80%)
/ txcolor = red
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</text>

<text choiceRT_feedbackEraser>
/items = ("")
/ vjustify = center
/ hjustify = left
/ position = (50%, 75%)
/ size = (80%, 15%)
/ erase = false
</text>

<shape eraseButton_choiceRT>
/ shape = rectangle
/ size = (parameters.responsebuttonSize * 0.75%, parameters.responsebuttonSize)
/ erase = false
/ color = lightGray
/ hposition = shape.target.hposition
/ vposition = shape.target.vposition
</shape>



<text instructionReminder>
/ items = instructionReminder
/ select = 1
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ size = (80%, 20%)
/ position = (50%, 90%)
/ hjustify = center
/ vjustify = center
/txcolor = black
</text>

