**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block cft_untimed>
/ skip = [
	parameters.runTimedTest == true;
]
/ trials = [1 = problemPage]
/ onblockend = [
	values.testDuration_s = (script.elapsedTime - block.cft_untimed.timestamp)/1000;
]
</block>

<block cft_timed>
/ skip = [
	parameters.runTimedTest == false;
]
/ timeout = parameters.timeLimit
/ trials = [1 = problemPage]
/ onblockend = [
	values.testDuration_s = (script.elapsedTime - block.cft_timed.timestamp)/1000;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ preinstructions = (intro)
/ blocks = [
	1 = cft_untimed;
	2 = cft_timed;
]
</expt>

