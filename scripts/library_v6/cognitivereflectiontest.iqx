**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************
concat(values.helperFoil1Response, subString(parameters.problem1FoilAnswer, i, 1));
		values.helperFoil1Response = concat(values.helperFoil1Response, "|");
<expressions>
/countCorrect = values.problem1Correct + values.problem2Correct + values.problem3Correct

//generate the Foil Responses that might be contained in the string variables that collect all responses for each problem:
/Foil1Response = {

	var Foil1Response = "|";
	Foil1Response = concat(Foil1Response, parameters.problem1FoilAnswer);
	Foil1Response = concat(Foil1Response, "|");

	return (Foil1Response);
}
/Foil2Response = {
	var Foil2Response = "|";
	Foil2Response = concat(Foil2Response, parameters.problem2FoilAnswer);
	Foil2Response = concat(Foil2Response, "|");

	return (Foil2Response);
}
/Foil3Response = {
	var Foil3Response = "|";
	Foil3Response = concat(Foil3Response, parameters.problem3FoilAnswer);
	Foil3Response = concat(Foil3Response, "|");

	return (Foil3Response);
}
</expressions>



