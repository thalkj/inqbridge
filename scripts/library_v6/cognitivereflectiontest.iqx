**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

//trial presents all three problems on the same page
//all problems and response boxes are presented in black font
//participants can choose to select to respond to an individual question by pressing the corresponding response box
//or participants can choose to submit their response
<trial problemPage>
/ ontrialbegin = [
	text.problem1.textColor = black;
	text.problem2.textColor = black;	
	text.problem3.textColor = black;
	shape.problem1ResponseFrame.color = black;
	shape.problem2ResponseFrame.color = black;
	shape.problem3ResponseFrame.color = black;

	values.problem1Correct = (values.problem1Response == parameters.problem1CorrectAnswer);
	values.problem2Correct = (values.problem2Response == parameters.problem2CorrectAnswer);	
	values.problem3Correct = (values.problem3Response == parameters.problem3CorrectAnswer);	
	
	values.problem1Foil = (values.problem1Response == parameters.problem1FoilAnswer);
	values.problem2Foil = (values.problem2Response == parameters.problem2FoilAnswer);
	values.problem3Foil = (values.problem3Response == parameters.problem3FoilAnswer);	
	
	//check if the Foil responses have been made:
	if (values.problem1FoilDetected == 0){
		if (contains(values.problem1_allResponses, expressions.Foil1Response)){
			values.problem1FoilDetected = 1;
		}		
	}

	if (values.problem2FoilDetected == 0){
		if (contains(values.problem2_allResponses, expressions.Foil2Response)){
			values.problem2FoilDetected = 1;
		}		
	}

	if (values.problem3FoilDetected == 0){
		if (contains(values.problem3_allResponses, expressions.Foil3Response)){
			values.problem3FoilDetected = 1;
		}		
	}	
]

/ stimulusframes = [1 = clearScreen, AnswerHeader, problem1, problem2, problem3,
problem1ResponseFrame, problem1response, 
problem2ResponseFrame, problem2response,
problem3ResponseFrame, problem3response,
submit, ResponseInstruct]
/ validresponse = (problem1ResponseFrame, problem2ResponseFrame, problem3ResponseFrame, submit)
//submit is only active if all three questions have an answer
/ isvalidresponse = [
	if (trial.problemPage.response != "submit"){
		return true;
	} else {
		return (trial.problemPage.response == "submit" && values.problem1Response != "" && 
		values.problem2Response != "" && values.problem3Response != "")
	}
]
/ branch = [
	if (trial.problemPage.response == "problem1ResponseFrame"){
		return trial.problem1;
	} else if (trial.problemPage.response == "problem2ResponseFrame"){
		return trial.problem2;
	} else if (trial.problemPage.response == "problem3ResponseFrame"){
		return trial.problem3;
	} else {
		return trial.finish;
	}
]
</trial>


<trial problem1>
/ ontrialbegin = [
	text.problem1.textColor = blue;//active
	text.problem2.textColor = gray;	//inactive
	text.problem3.textColor = gray;	//inactive
	
	shape.problem1ResponseFrame.color = blue;//active
	shape.problem2ResponseFrame.color = gray;//inactive
	shape.problem3ResponseFrame.color = gray;//inactive	

]
/ stimulusframes = [1 = clearScreen,AnswerHeader, problem1, problem2, problem3,
problem1ResponseFrame, problem1response, 
problem2ResponseFrame, problem2response,
problem3ResponseFrame, problem3response,
00, 1, 2, 3, 4, 5, 6, 7, 8, 9, done, correction]
/ validresponse = (00, 1, 2, 3, 4, 5, 6, 7, 8, 9, done, correction)
/ ontrialend = [
	if (trial.problem1.response !="correction" && trial.problem1.response !="done"){	
		values.problem1_allResponses = concat(values.problem1_allResponses, evaluate(trial.problem1.response));					
	} else {
		values.problem1_allResponses = concat(values.problem1_allResponses, "|");
		values.problem1_allResponses = concat(values.problem1_allResponses, trial.problem1.response);
		values.problem1_allResponses = concat(values.problem1_allResponses, "|");		
	}

	if (trial.problem1.response == "correction"){
		values.problem1Response = "";
		values.problem1_countCorrections += 1;
	} else if (trial.problem1.response != "done"){
		values.problem1Response = concat(values.problem1Response, evaluate(trial.problem1.response));
	}
	
	values.problem1_duration += trial.problem1.latency;
]
/ branch = [
	if (trial.problem1.response == "done"){
		return trial.problemPage;
	} else {
		return trial.problem1;
	}
]

</trial>

