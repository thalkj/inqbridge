**************************************************************************************************************
**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/problem1CorrectAnswer = "5" //stores the officially correct response to problem1
/problem2CorrectAnswer = "5" //stores the officially correct response to problem2
/problem3CorrectAnswer = "47" //stores the officially correct response to problem3

/problem1FoilAnswer = "10" //stores the foil response to problem1
/problem2FoilAnswer = "100" //stores the foil response to problem2
/problem3FoilAnswer = "24" //stores the foil response to problem3

/runTimedTest = false //true = the test is timed; false = the test is not timed
/timeLimit = 300000 //the time limit (in ms) if parameters.runTimedTest = true (default: 5 minutes)
</parameters>

**************************************************************************************************************
**************************************************************************************************************
	EDITABLE STIMULI
**************************************************************************************************************
**************************************************************************************************************

<item problems>
/1 = "1. A bat and a ball cost $1.10 in total. The bat costs $1.00 more than the ball. How much does the ball cost? ____ cents"
/2 = "2. If it takes 5 machines 5 minutes to make 5 widgets, how long would it take 100 machines to make 100 widgets?____ minutes"
/3 = "3. In a lake, there is a patch of lily pads. Every day, the patch doubles in size. If it takes 48 days for the patch to cover the entire lake, how long would it take for the patch to cover half of the lake?____ days"
</item>

<text AnswerHeader>
/ items = ("Answer")
/ fontstyle = ("Arial", 3%, true, false, true, false, 5, 1)
/ hposition = shape.problem1ResponseFrame.hposition
/ vposition = shape.problem1ResponseFrame.vposition - 7%
/ halign = left
/ valign = top
/ width = shape.problem1ResponseFrame.width
/height = 5%
/ txbgcolor = white
/ vjustify = center
/ erase = false
</text>

<button done>
/ erase = false
/ caption = "done"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 0)
/ position = (75%, 93%)
/ size = (30%, 8%)
</button>

<button correction>
/ erase = false
/ caption = "correction"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 0)
/ position = (25%, 93%)
/ size = (30%, 8%)
</button>

<button submit>
/ erase = false
/ caption = "submit"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 0)
/ position = (50%, 90%)
/ size = (30%, 8%)
</button>

<text ResponseInstruct>
/ items = ("Press the answer boxes to respond or edit your responses.
Press 'submit' when you have answered all three problems.")
/ hposition = 50%
/ vposition = 80%
/ size = (80%, 10%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ txbgcolor = white
/ txcolor = blue
</text>

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<button exitbutton>
/ caption = "EXIT"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (30%, 8%)
/ valign = center
/ halign = center
</button>

