<parameters>
/getReadyDuration = 3000 				//the duration (in ms) of the get-ready-trial (default: 3000)

/instructDuration = 1000				//the duration (in ms) the aloud/silent instructions are presented during the test (default: 1000)
										//Note: the duration during the demo trials is significantly longer (-> 10s)
										
/stimPresentationDuration = 1000		//the duration (in ms) of the individual words (default: 1000)

/distractorTaskDuration = 1000			//the duration (in ms) of each distractor (magnitude estimation) task (default: 1000)
										//Note: the duration during the demo trials is significantly longer (-> 10s)

/cuedRecallTimeout = 5000				//the max. duration (in ms) for the recall trial (default: 5000ms)
										//Note: the duration during the demo trials is significantly longer (-> 20s)


/ wordSize = 8%							//the proportional sizing (relative to active canvas height) of the presented words (default: 8%)


/key_smaller = "S"						//the key used for 'smaller than 50' judgments (default: S)
/key_larger = "L"						//the key used for 'larger than 50' judgments (default: L)
										//Note: 'key_smaller' key should be located to the left of 'key_larger'
</parameters>

