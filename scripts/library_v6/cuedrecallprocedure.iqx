/ items = words_foilBlock
/ select = values.word3
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
</text>

<text word4_foilBlock>
/ items = words_foilBlock
/ select = values.word4
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
</text>

<text word1_targetBlock>
/ items = words_targetBlock
/ select = values.word1
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
</text>

<text word2_targetBlock>
/ items = words_targetBlock
/ select = values.word2
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
</text>

<text word3_targetBlock>
/ items = words_targetBlock
/ select = values.word3
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
