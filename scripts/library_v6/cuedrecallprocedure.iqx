<text getReady>
/ items = ("Get Ready!")
/ fontstyle = ("Arial", 10.00%, true, false, false, false, 5, 1)
/ size = (80%, 80%)
/ vjustify = center
/ position = (50%, 50%)
</text>

<text getReady2>
/ items = ("<%expressions.buttoninstruct1%>")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
/ position = (50%, 70%)
/ vjustify = center
</text>

<text getReady_demo>
/ items = ("You will need these <%expressions.buttoninstruct2%>s to work on the number categorization task.")
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
/ position = (50%, 80%)
/ vjustify = center
/ txcolor = blue
</text>

<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {
	"put your index fingers over the <%parameters.key_smaller%> and <%parameters.key_larger%> buttons below";} 
else {"place your index fingers on the <%parameters.key_smaller%> and <%parameters.key_larger%> keys";}
/buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {
	"button";} 
else {"key";}
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	EDITABLE LISTS: change editable lists here
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
				!!!REMAINING CODE: Customize after careful consideration only!!!
**************************************************************************************************************


**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = black
/ screencolor = white
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 

values.trialCount, values.trialCategory,
values.target, values.targetCategory, 
values.foil, values.foilBlockWords, values.targetBlockWords,
values.2digitNumber,
response, values.recallResponse, correct, latency)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,

expressions.propCorrect_overall,
expressions.meanCorrRT_overall,
expressions.propCorrect_2block_target,
expressions.meanCorrRT_2block_target,
expressions.propCorrect_2block_control,
expressions.meanCorrRT_2block_control,
expressions.propCorrect_1block,
expressions.meanCorrRT_1block,

expressions.propCorrect_DistractorTask_overall,
expressions.meanCorrRT_DistractorTask_overall,
expressions.propCorrect_DistractorTask_2block_target,
expressions.meanCorrRT_DistractorTask_2block_target,
expressions.propCorrect_DistractorTask_2block_control,
expressions.meanCorrRT_DistractorTask_2block_control,
expressions.propCorrect_DistractorTask_1block,
expressions.meanCorrRT_DistractorTask_1block)

</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

<values>
/phase = ""								//"practice" vs. "test"
/trialCategory = ""						//1 = 2blocks foil/target; 2 = 2blocks control; 3 = 1block
/target = ""							//stores the target word
/targetCategory = ""					//stores the target category
/foil = ""								//stores the foil word - if applicable
/foilBlockWords = ""					//stores all the words presented during the 'foil' block (1st block for 2block trials)
/targetBlockWords = ""					//stores all the words presented during the 'target' block		
/word1 = ""								//stores the selected itemnumbers for word1 to word4 selected from temporary item lists
/word2 = ""
/word3 = ""
/word4 = ""

/distractorNumberCount = 0				//counts the number of distractor numbers run for each trial
/2digitNumber = ""						//stores the selected 2digit number

/instructDuration = 0					//stores the duration allowed for instructions
/distractorDuration = 0					//stores the duration allowed for distractor presentation
/cuedRecallDuration = 0					//stores the duration allowed for cuedRecall

/trialCount = 0							//counts the number of trials run during each phase
/recallResponse = ""					//the recall response in lower case letters only
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/propCorrect_overall = list.ACC_overall.mean
/meanCorrRT_overall = list.corrRT_overall.mean
/propCorrect_2block_target = list.2block_target_ACC.mean
/meanCorrRT_2block_target = list.2block_target_RT.mean
/propCorrect_2block_control = list.2block_control_ACC.mean
/meanCorrRT_2block_control = list.2block_control_RT.mean
/propCorrect_1block = list.1block_ACC.mean
/meanCorrRT_1block = list.1block_RT.mean

/propCorrect_DistractorTask_overall = list.distractorACC_overall.mean
/meanCorrRT_DistractorTask_overall = list.distractorRT_overall.mean
/propCorrect_DistractorTask_2block_target = list.distractorACC_2block_target.mean
/meanCorrRT_DistractorTask_2block_target = list.distractorRT_2block_target.mean
/propCorrect_DistractorTask_2block_control = list.distractorACC_2block_control.mean
/meanCorrRT_DistractorTask_2block_control = list.distractorRT_2block_control.mean
/propCorrect_DistractorTask_1block = list.distractorACC_1block.mean
/meanCorrRT_DistractorTask_1block = list.distractorRT_1block.mean
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
finish trial
**************************************************************************************************************

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

//filled during runtime for each trial
//for 2-block trials (target trials): first item will the foil
<item words_foilBlock>
</item>

//filled during runtime for each trial
//first item will the target
<item words_targetBlock>
</item>

<text word1_foilBlock>
/ items = words_foilBlock
/ select = values.word1
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
</text>

<text word2_foilBlock>
/ items = words_foilBlock
/ select = values.word2
/ vjustify = center
/ size = (80%, parameters.wordSize*1.1)
