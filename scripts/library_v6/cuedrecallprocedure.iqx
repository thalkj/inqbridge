**************************************************************************************************************
**************************************************************************************************************
	TRIALS: 
**************************************************************************************************************
**************************************************************************************************************


<trial 2block_demo>
/ ontrialbegin = [
	values.trialCategory = 0;
	values.foilBlockWords = "";
	values.targetBlockWords = "";
	values.distractorNumberCount = 0;
	list.2digitNumbers.reset();
	values.2digitNumber = "";
	values.recallResponse = "";
	
	//timeouts for demo trial is slightly longer than for the test trials
	values.instructDuration = 10000;
	values.distractorDuration = 10000;
	values.cuedRecallDuration = 20000;
	
	//clear the block lists for new items:
	item.words_foilBlock.clearItems();
	item.words_targetBlock.clearItems();
	
	//add the 4 items to targetBlock
	item.words_targetBlock.appendItem(item.practiceTargetsWords.item(list.practiceTargetItemnumbers.nextIndex));	
	values.target = item.words_targetBlock.item(1);
	values.foil = "NA";
	values.targetCategory = item.practiceTargetCategories.item(list.practiceTargetItemnumbers.currentIndex);
	
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));	
	
	//add the 4 items to fillerBlock	
	item.words_foilBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));	

	//dynamic stimulus insertion:	
	trial.2block_demo.insertStimulusTime(clearScreen, 5000);
	trial.2block_demo.insertStimulusTime(text.instruct1, 5000);
	trial.2block_demo.insertStimulusTime(text.instruct1_demo, 5000);
]
/ stimulusframes = [1 = clearScreen, getReady, getReady2, getReady_demo]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = (parameters.getReadyDuration + values.instructDuration)
/ ontrialend = [
	trial.2block_demo.resetStimulusFrames();
]
/ branch = [
	return trial.foilBlock;
]
/ recorddata = false
</trial>


<trial 1block_demo>
/ ontrialbegin = [
	values.trialCategory = 0;
	values.foilBlockWords = "";
	values.targetBlockWords = "";
	values.distractorNumberCount = 0;
	list.2digitNumbers.reset();
	values.2digitNumber = "";
	values.recallResponse = "";
	
	//timeouts for demo trial is slightly longer than for the test trials
	values.instructDuration = 10000;
	values.distractorDuration = 10000;
	values.cuedRecallDuration = 20000;

	//clear the block lists for new items:
	item.words_foilBlock.clearItems();
	item.words_targetBlock.clearItems();
	
	//add the 4 items to targetBlock (this trial does not use foilBlock):
	item.words_targetBlock.appendItem(item.practiceTargetsWords.item(list.practiceTargetItemnumbers.nextIndex));	
	values.target = item.words_targetBlock.item(1);
	values.foil = "NA";
	values.targetCategory = item.practiceTargetCategories.item(list.practiceTargetItemnumbers.currentIndex);
	
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.practiceFillerWords.item(list.practiceFillerItemnumbers.nextIndex));
	
	//dynamic stimulus insertion:
	trial.1block_demo.insertStimulusTime(clearScreen, 10000);
	trial.1block_demo.insertStimulusTime(text.instruct1, 10000);
	trial.1block_demo.insertStimulusTime(text.instruct1_demo, 10000);
]
/ stimulusframes = [1 = clearScreen, getReady, getReady2, getReady_demo]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = (parameters.getReadyDuration + values.instructDuration)
/ ontrialend = [
	trial.1block_demo.resetStimulusFrames();
]
/ branch = [
	return trial.targetBlock;
]
/ recorddata = false
</trial>


<trial 2block_target_instruct1>
/ ontrialbegin = [
	values.trialCount += 1;
	values.trialCategory = 1;
	values.foilBlockWords = "";
	values.targetBlockWords = "";
	values.distractorNumberCount = 0;
	list.2digitNumbers.reset();
	values.2digitNumber = "";
	values.recallResponse = "";
	values.instructDuration = parameters.instructDuration;
	values.distractorDuration = parameters.distractorTaskDuration;
	values.cuedRecallDuration = parameters.cuedRecallTimeout;
	text.instruct2_demo.skip = true;
	text.distractor_demo.skip = true;
	
	//clear the block lists for new items:
	item.words_foilBlock.clearItems();
	item.words_targetBlock.clearItems();
	
	//add the new items to foilBlock/targetBlock:	
	//add foils/targets to index positions '1':
	item.words_targetBlock.appendItem(item.targets.item(list.targetItemnumbers.nextIndex));	
	item.words_foilBlock.appendItem(item.foils.item(list.targetItemnumbers.currentIndex));
	values.target = item.words_targetBlock.item(1);
	values.foil = item.words_foilBlock.item(1);
	values.targetCategory = item.targetCategories.item(list.targetItemnumbers.currentIndex);
	
	//add the remaining 3 filler items to foilBlock:
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	
	//add the remaining 3 filler items to targetBlock:
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	
	//dynamic stimulus insertion:
	trial.2block_target_instruct1.insertStimulusTime(clearScreen, parameters.getReadyDuration);
	trial.2block_target_instruct1.insertStimulusTime(text.instruct1, parameters.getReadyDuration);
]
/ stimulusframes = [1 = clearScreen, getReady, getReady2]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = (parameters.getReadyDuration + values.instructDuration)
/ ontrialend = [
	trial.2block_target_instruct1.resetStimulusFrames();
]
/ branch = [
	return trial.foilBlock;
]
/ recorddata = false
</trial>

<trial 2block_control_instruct1>
/ ontrialbegin = [
	values.trialCount += 1;
	values.trialCategory = 2;
	values.foilBlockWords = "";
	values.targetBlockWords = "";
	values.distractorNumberCount = 0;
	list.2digitNumbers.reset();
	values.2digitNumber = "";
	values.recallResponse = "";
	values.instructDuration = parameters.instructDuration;
	values.distractorDuration = parameters.distractorTaskDuration;
	values.cuedRecallDuration = parameters.cuedRecallTimeout;
	text.instruct2_demo.skip = true;
	text.distractor_demo.skip = true;
	
	//clear the block lists for new items:
	item.words_foilBlock.clearItems();
	item.words_targetBlock.clearItems();
	
	//add the new items to foilBlock/targetBlock:	
	//add foils/targets to index positions '1':
	item.words_targetBlock.appendItem(item.targets.item(list.targetItemnumbers.nextIndex));	
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	values.target = item.words_targetBlock.item(1);
	values.foil = "NA";
	values.targetCategory = item.targetCategories.item(list.targetItemnumbers.currentIndex);
	
	//add the remaining 3 filler items to foilBlock:
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_foilBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	
	//add the remaining 3 filler items to targetBlock:
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	
	//dynamic stimulus insertion:
	trial.2block_control_instruct1.insertStimulusTime(clearScreen, parameters.getReadyDuration);
	trial.2block_control_instruct1.insertStimulusTime(text.instruct1, parameters.getReadyDuration);
]
/ stimulusframes = [1 = clearScreen, getReady, getReady2]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = (parameters.getReadyDuration + values.instructDuration)
/ ontrialend = [
	trial.2block_control_instruct1.resetStimulusFrames();
]
/ branch = [
	return trial.foilBlock;
]
/ recorddata = false

</trial>

//assembles the item lists for targetBlock words (Note: targetBlock acts as foilBlock for 1block trials)
//presents 'aloud' instructions
<trial 1block_instruct>
/ ontrialbegin = [
	values.trialCount += 1;
	values.trialCategory = 3;
	values.foilBlockWords = "";
	values.targetBlockWords = "";
	values.distractorNumberCount = 0;
	list.2digitNumbers.reset();
	values.2digitNumber = "";
	values.recallResponse = "";
	values.instructDuration = parameters.instructDuration;
	values.distractorDuration = parameters.distractorTaskDuration;
	values.cuedRecallDuration = parameters.cuedRecallTimeout;
	text.instruct2_demo.skip = true;
	text.distractor_demo.skip = true;
	
	//clear the block lists for new items:
	item.words_foilBlock.clearItems();
	item.words_targetBlock.clearItems();
	
	//add the 4 items to targetBlock (this trial does not use foilBlock):
	item.words_targetBlock.appendItem(item.targets.item(list.targetItemnumbers.nextIndex));	
	values.target = item.words_targetBlock.item(1);
	values.foil = "NA";
	values.targetCategory = item.targetCategories.item(list.targetItemnumbers.currentIndex);
	
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	item.words_targetBlock.appendItem(item.fillers.item(list.fillerItemnumbers.nextIndex));
	
	//dynamic stimulus insertion:	
	trial.1block_instruct.insertStimulusTime(clearScreen, parameters.getReadyDuration);
	trial.1block_instruct.insertStimulusTime(text.instruct1, parameters.getReadyDuration);
]
/ stimulusframes = [1 = clearScreen, getReady, getReady2]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = (parameters.getReadyDuration + values.instructDuration)
/ ontrialend = [
	trial.1block_instruct.resetStimulusFrames();
]
/ branch = [
	return trial.targetBlock;
]
/ recorddata = false

</trial>


//for 2blocktrials: presents block 1 words 
//for 1block trials: this trial is skipped
<trial foilBlock>
/ ontrialbegin = [
	values.word1 = list.blockitemnumbers.nextValue;
	values.word2 = list.blockitemnumbers.nextValue;
	values.word3 = list.blockitemnumbers.nextValue;
	values.word4 = list.blockitemnumbers.nextValue;
	trial.foilBlock.insertStimulusTime(text.word2_foilBlock, parameters.stimPresentationDuration);
	trial.foilBlock.insertStimulusTime(text.word3_foilBlock, 2*parameters.stimPresentationDuration);
	trial.foilBlock.insertStimulusTime(text.word4_foilBlock, 3*parameters.stimPresentationDuration);
]
/ stimulustimes = [0 = clearScreen, word1_foilBlock]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ ontrialend = [
	trial.foilBlock.resetStimulusFrames();
	values.foilBlockWords = concat(values.foilBlockWords, text.word1_foilBlock.currentItem);
	values.foilBlockWords = concat(values.foilBlockWords, ",");
	values.foilBlockWords = concat(values.foilBlockWords, text.word2_foilBlock.currentItem);
	values.foilBlockWords = concat(values.foilBlockWords, ",");
	values.foilBlockWords = concat(values.foilBlockWords, text.word3_foilBlock.currentItem);
	values.foilBlockWords = concat(values.foilBlockWords, ",");
	values.foilBlockWords = concat(values.foilBlockWords, text.word4_foilBlock.currentItem);
	values.foilBlockWords = concat(values.foilBlockWords, ",");
]
/ trialduration = (4*parameters.stimPresentationDuration)
/ branch = [
	return trial.instruct2;
]
/ recorddata = false
</trial>

<trial instruct2>
/ stimulusframes = [1 = clearScreen, instruct2, instruct2_demo]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ trialduration = values.instructDuration

/ branch = [
	return trial.targetBlock;
]
/ recorddata = false
</trial>

//for 2blocktrials: presents block 2 words
//for 1block trials: this trial presents the only block of 4 words run
<trial targetBlock>
/ ontrialbegin = [
	values.word1 = list.blockitemnumbers.nextValue;
	values.word2 = list.blockitemnumbers.nextValue;
	values.word3 = list.blockitemnumbers.nextValue;
	values.word4 = list.blockitemnumbers.nextValue;
	trial.targetBlock.insertStimulusTime(text.word2_targetBlock, parameters.stimPresentationDuration);
	trial.targetBlock.insertStimulusTime(text.word3_targetBlock, 2*parameters.stimPresentationDuration);
	trial.targetBlock.insertStimulusTime(text.word4_targetBlock, 3*parameters.stimPresentationDuration);
]
/ stimulustimes = [0 = clearScreen, word1_targetBlock]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ isvalidresponse = [
	return false; //present inactive magnitude response keys on touchscreen devices
]

/ ontrialend = [
	trial.targetBlock.resetStimulusFrames();
	values.targetBlockWords = concat(values.targetBlockWords, text.word1_targetBlock.currentItem);
	values.targetBlockWords = concat(values.targetBlockWords, ",");
	values.targetBlockWords = concat(values.targetBlockWords, text.word2_targetBlock.currentItem);
	values.targetBlockWords = concat(values.targetBlockWords, ",");
	values.targetBlockWords = concat(values.targetBlockWords, text.word3_targetBlock.currentItem);
	values.targetBlockWords = concat(values.targetBlockWords, ",");
	values.targetBlockWords = concat(values.targetBlockWords, text.word4_targetBlock.currentItem);
	values.targetBlockWords = concat(values.targetBlockWords, ",");
]
/ trialduration = (4*parameters.stimPresentationDuration)
/ recorddata = false
/ branch = [
	return trial.distractortask;
]
</trial>

<trial distractortask>
/ ontrialbegin = [
	values.distractorNumberCount += 1;
	values.2digitNumber = list.2digitNumbers.nextValue;
	mouse.x = 50%;
	mouse.y = 50%;
]
/ stimulusframes = [1 = clearScreen, 2digitNumber, distractor_demo, smaller, bigger]

/ validresponse = (parameters.key_smaller, parameters.key_larger)
/ timeout = values.distractorDuration
/ iscorrectresponse = [
	return ((values.2digitNumber < 50 && trial.distractortask.responseText == parameters.key_smaller) ||
(values.2digitNumber > 50 && trial.distractortask.responseText == parameters.key_larger))
]
/ ontrialend = [
	if (values.phase == "test"){
		list.distractorACC_overall.appendItem(trial.distractortask.correct);
		if (trial.distractortask.correct){
			list.distractorRT_overall.appendItem(trial.distractortask.latency);
		}
		
		if (values.trialCategory == 1){
			list.distractorACC_2block_target.appendItem(trial.distractortask.correct);
			if (trial.distractortask.correct){
				list.distractorRT_2block_target.appendItem(trial.distractortask.latency);
			}			
		} else if (values.trialCategory == 2){
			list.distractorACC_2block_control.appendItem(trial.distractortask.correct);
			if (trial.distractortask.correct){
				list.distractorRT_2block_control.appendItem(trial.distractortask.latency);
			}			
		} else if (values.trialCategory == 3){
			list.distractorACC_1block.appendItem(trial.distractortask.correct);
			if (trial.distractortask.correct){
				list.distractorRT_1block.appendItem(trial.distractortask.latency);
			}			
		} 
	}
]

/ branch = [
	if (values.distractorNumberCount < 8) {
		return trial.distractortask;
	} else {
		return openended.cuedRecall;
	}
]
/ recorddata = true
</trial>

<openended cuedRecall>
/ ontrialbegin = [
	values.2digitNumber = "";
]

/ stimulusframes = [1 = clearScreen, cue, cue_instructions, cue_instructionsDemo]
/ fontstyle = ("Arial", parameters.wordSize, false, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ timeout = values.cuedRecallDuration
/ iscorrectresponse = [
	values.recallResponse = tolower(openended.cuedRecall.response);
	return (values.recallResponse == values.target);
]
/ monkeyresponse = (values.target, "monkey")
/ ontrialend = [
	
	//Summary Variables:	
	if (values.phase == "test"){
		list.ACC_overall.appendItem(openended.cuedRecall.correct);
		if (openended.cuedRecall.correct){
			list.corrRT_overall.appendItem(openended.cuedRecall.latency);
		}
	
		if (values.trialCategory == 1) {
			list.2block_target_ACC.appendItem(openended.cuedRecall.correct);
			if (openended.cuedRecall.correct) {
				list.2block_target_RT.appendItem(openended.cuedRecall.latency);
			}
		} else if (values.trialCategory == 2) {
			list.2block_control_ACC.appendItem(openended.cuedRecall.correct);
			if (openended.cuedRecall.correct) {
				list.2block_control_RT.appendItem(openended.cuedRecall.latency);
			}
		} else if (values.trialCategory == 3) {
			list.1block_ACC.appendItem(openended.cuedRecall.correct);
			if (openended.cuedRecall.correct) {
				list.1block_RT.appendItem(openended.cuedRecall.latency);
			}
		}		
	}
]
/ buttonlabel = "Enter"
/ recorddata = true
</openended>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block practice>
/ onblockbegin = [
	values.phase = "practice";
]

/ trials = [
	1 = 1block_demo;
	2 = 2block_demo;
]
</block>

//this list controls the sequence of the test trials
//by default the trials are selected sequentially (Note: the order of the current trial sequence was randomly determined)
//=> all participant run with the task with the same sequence
//to change to a random selection: replace /selectionmode = sequence with /replace = false. 
<list testtrials>
/items = (
trial.2block_control_instruct1,trial.2block_target_instruct1,trial.2block_control_instruct1,trial.1block_instruct,
trial.1block_instruct,trial.2block_control_instruct1,trial.2block_target_instruct1,trial.1block_instruct,
trial.2block_control_instruct1,trial.2block_control_instruct1,trial.2block_control_instruct1,trial.2block_control_instruct1,
trial.2block_target_instruct1,trial.2block_control_instruct1,trial.2block_target_instruct1,trial.2block_target_instruct1,
trial.2block_target_instruct1,trial.1block_instruct,trial.1block_instruct,trial.1block_instruct,
trial.2block_target_instruct1,trial.2block_target_instruct1,trial.1block_instruct,trial.2block_control_instruct1,
trial.2block_target_instruct1,trial.1block_instruct,trial.2block_target_instruct1,trial.1block_instruct,
trial.2block_target_instruct1,trial.2block_target_instruct1,trial.2block_control_instruct1,trial.1block_instruct,
trial.2block_control_instruct1,trial.1block_instruct,trial.2block_control_instruct1,trial.1block_instruct,
)
/ selectionmode = sequence
</list>

<block test>
/ preinstructions = (test)
/ onblockbegin = [
	values.phase = "test";
	values.trialCount = 0;
	text.cue_instructionsDemo.skip = true;
]
/ trials = [1-36 = list.testtrials]
</block>

<block finish>
/ trials = [
	1 = finish;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt cuedrecall>
/ preinstructions = (intro)
/ blocks = [
	1 = practice;
	2 = test;
	3 = finish;
]
</expt>

