	VALUES: automatically updated
*******************************************************************************************************************
*******************************************************************************************************************


*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************
SUBSCALE SCORING**: The measure yields a total score (SUM) as well as scores on six sub-scales:
1. Nonacceptance of emotional responses (NONACCEPT): 11, 12, 21, 23, 25, 29
2. Difficulty engaging in Goal-directed behavior (GOALS): 13, 18, 20R, 26, 33
3. Impulse control difficulties (IMPULSE): 3, 14, 19, 24R, 27, 32
4. Lack of emotional awareness (AWARENESS): 2R, 6R, 8R, 10R, 17R, 34R
5. Limited access to emotion regulation strategies (STRATEGIES): 15, 16, 22R, 28, 30, 31, 35, 36
6. Lack of emotional clarity (CLARITY): 1R, 4, 5, 7R, 9
Total score: sum of all subscales
**”R” indicates reverse scored item

<expressions>
/NONACCEPT = radiobuttons.q11.response + radiobuttons.q12.response + radiobuttons.q21.response + radiobuttons.q23.response +
radiobuttons.q25.response + radiobuttons.q29.response
/GOALS = radiobuttons.q13.response + radiobuttons.q18.response + radiobuttons.q20R.response + 
radiobuttons.q26.response + radiobuttons.q33.response
/IMPULSE = radiobuttons.q3.response + radiobuttons.q14.response + radiobuttons.q19.response +
radiobuttons.q24R.response + radiobuttons.q27.response + radiobuttons.q32.response
/AWARENESS = radiobuttons.q2R.response + radiobuttons.q6R.response + radiobuttons.q8R.response +
radiobuttons.q10R.response + radiobuttons.q17R.response + radiobuttons.q34R.response
/STRATEGIES = radiobuttons.q15.response + radiobuttons.q16.response + radiobuttons.q22R.response +
radiobuttons.q28.response + radiobuttons.q30.response + radiobuttons.q31.response +
radiobuttons.q35.response + radiobuttons.q36.response
/CLARITY = radiobuttons.q1R.response + radiobuttons.q4.response + radiobuttons.q5.response + 
radiobuttons.q7R.response + radiobuttons.q9.response
/TOTAL = expressions.NONACCEPT + expressions.GOALS + expressions.IMPULSE + expressions.AWARENESS +
expressions.STRATEGIES + expressions.CLARITY
</expressions>



*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<radiobuttons q1R>
/caption = "I am clear about my feelings."
/ options = ("1~nalmost never~n(0-10%)", "2~nsometimes~n(11-35%)", 
"3~nabout half the time~n(36-65%)", "4~nmost of the time~n(66-90%)", "5~nalmost always~n(91-100%)")
/ optionvalues = ("5", "4", "3", "2", "1")
/required = true
/orientation = horizontalequal
</radiobuttons>

