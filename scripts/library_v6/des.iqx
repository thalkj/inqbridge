*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<slider example>
/caption = "Example Scale:
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = false
</slider>

<slider q1>
/caption = "1. Some people have the experience of driving a car and suddenly realizing that they don't remember what has happened during all or part of the trip.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q2>
/caption = "2. Some people find that sometimes they are listening to someone talk and they suddenly realize that they did not hear all or part of what was said.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q3>
/caption = "3. Some people have the experience of finding themselves in a place and having no idea how they got there.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q4>
/caption = "4. Some people have the experience of finding themselves dressed in clothes that they don't remember putting on.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q5>
/caption = "5. Some people have the experience of finding new things among their belongings that they do not remember buying.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q6>
/caption = "6. Some people sometimes find that they are approached by people that they do not know who call them by another name or insist that they have met them before.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q7>
/caption = "7. Some people sometimes have the experience of feeling as though they are standing next to themselves or watching themselves do something as if they were looking at another person.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q8>
/caption = "8. Some people are told that they sometimes do not recognize friends or family members.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q9>
/caption = "9. Some people find that they have no memory for some important events in their lives (for example, a wedding or graduation).
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q10>
/caption = "10. Some people have the experience of being accused of lying when they do not think that they have lied.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q11>
/caption = "11. Some people have the experience of looking in a mirror and not recognizing themselves.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q12>
/caption = "12. Some people sometimes have the experience of feeling that other people, objects, and the world around them are not real.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q13>
/caption = "13. Some people sometimes have the experience of feeling that their body does not belong to them.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q14>
/caption = "14. Some people have the experience of sometimes remembering a past event so vividly that they feel as if they were reliving that event.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q15>
/caption = "15. Some people have the experience of not being sure whether things that they remember happening really did happen or whether they just dreamed them.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q16>
/caption = "16. Some people have the experience of being in a familiar place but finding it strange and unfamiliar.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q17>
/caption = "17. Some people find that when they are watching television or a movie they become so absorbed in the story that they are unaware of other events happening around them.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q18>
/caption = "18. Some people sometimes find that they become so involved in a fantasy or daydream that it feels as though it were really happening to them.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q19>
/caption = "19. Some people find that they are sometimes able to ignore pain.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q20>
/caption = "20. Some people find that they sometimes sit staring off into space, thinking of nothing, and are not aware of the passage of time.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q21>
/caption = "21. Some people sometimes find that when they are alone they talk out loud to themselves.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q22>
/caption = "22. Some people find that in one situation they may act so differently compared with another situation that they feel almost as if they were different people.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q23>
/caption = "23. Some people sometimes find that in certain situations they are able to do things with amazing ease and spontaneity that would usually be difficult for them (for example, sports, work, social situations, etc.).
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q24>
/caption = "24. Some people sometimes find that they cannot remember whether they have done something or have just thought about doing that thing (for example, not knowing whether they have just mailed a letter or have just thought about mailing it).
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
</slider>

<slider q25>
/caption = "25. Some people find evidence that they have done things that they do not remember doing.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q26>
/caption = "26. Some people sometimes find writings, drawings, or notes among their belongings that they must have done but cannot remember doing.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q27>
/caption = "27. Some people find that they sometimes hear voices inside their head that tell them to do things or comment on things that they are doing.
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

<slider q28>
/caption = "28. Some people sometimes feel as if they are looking at the world through a fog so that people or objects appear far away or unclear
"
/ labels=("Never~n0%", "Always~n100%")
/ range = (0, 100)
/ increment = 1
/ showticks = false

/ slidersize = (50%, 3%)
/ required = true
</slider>

*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************

<surveypage DES1>
/ caption ="This questionnaire consists of twenty‐eight questions about experiences that you may have in your daily life. 

We are interested in how often you have these experiences. It is important, however, that your answers show how often these experiences happen to you when you are not under the influence of alcohol or drugs. 

To answer the questions, please determine to what degree the experience described in the question applies to you and move the slider to the position on each scale that reflects what percentage of the time you have the experience: 100% means ‘always’, 0% means ‘never’ with 1% increments in between. 
"
/ questions = [1 = example]
</surveypage>

<surveypage DES2>
/ caption ="Move the slider to show what percentage of the time this happens to you:
"
/ subcaption = "Note: you always have to move the slider at least once.
"
/ questions = [1 = q1, q2]
</surveypage>

<surveypage DES3>
/ caption ="Move the slider to show what percentage of the time this happens to you:
"
/ questions = [1 = q3, q4]
</surveypage>

