<values>
/numberOfEndorsedItems = 0
/round = 0
</values>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

<expressions>
/DES_total = slider.q1.response + slider.q2.response + slider.q3.response + slider.q4.response + 
slider.q5.response + slider.q6.response + slider.q7.response + slider.q8.response +
slider.q9.response + slider.q10.response + slider.q11.response + slider.q12.response + 
slider.q13.response + slider.q14.response + slider.q15.response + slider.q16.response +
slider.q17.response + slider.q18.response + slider.q19.response + slider.q20.response + 
slider.q21.response + slider.q22.response + slider.q23.response + slider.q24.response +
slider.q25.response + slider.q26.response + slider.q27.response + slider.q28.response

/DESscore = expressions.DES_total/28

/numberOfEndorsedItems = {
if (values.round == 0){
	

if (slider.q1.response != 0){
	values.numberOfEndorsedItems += 1;
}
if (slider.q2.response != 0){
