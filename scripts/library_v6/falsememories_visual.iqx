**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/wordcountEstimate: 	algorithm to estimate the number of words recalled
						-> algorithm replaces 7 possible word separators (" ", ;, etc) with "," in values.Recall
						-> algorithm adds a comma before the first word
						-> algoritm replaces multiple consecutive "," (up to 5) with a single one in values.Recall
						-> algorithm adds a comma at the end of the string
							-> values.Recall is as cleaned up as possible of random word separators
						-> algorithm removes all "," from values.Recall and stores the resulting reduced string in values.reducedRecall
						-> algorithm compares the length of values.reducedRecall to that of values.Recall
						and uses the reduced length to estimate the number of words in between the separators
						NOTE: values.recall will ideally contain only lower letter words separated by a single comma each at
						the end of this function + a start and an ending comma

/removeConsecutiveCommas:	recursive helper function to remove instances of consecutive commas from values.Recall						

/lurePosition_Recall:	recursive algorithm to find the position of the lure in a list of recalled words (algorithm is only called for recall lists that contain the lure)
						-> algorithm takes advantage of the comma separators in values.recall
						-> finds the comma after which the word is equal to the lure
						-> values.lure_listPosition = number of commas checked + 1;
			
<expressions>
/wordcountEstimate = {
	
	
	values.Recall = replaceAll(values.Recall, "\", ",");
	values.Recall = replaceAll(values.Recall, "|", ",");	
	values.Recall = replaceAll(values.Recall, "/", ",");	
	values.Recall = replaceAll(values.Recall, ";", ",");	
	values.Recall = replaceAll(values.Recall, " ", ",");	
	values.Recall = replaceAll(values.Recall, ":", ",");
	values.Recall = replaceAll(values.Recall, ".", ",");
	if (computer.platform == "win"){
values.Recall = replaceAll(values.Recall, "
", ",");			
	} else if (computer.platform == "mac"){
		values.Recall = replaceAll(values.Recall, "
", ",");
	}	
	values.Recall = concat(",", values.Recall);
	expressions.removeConsecutiveCommas;
		
	if (!endswith(values.Recall, ",")){
		values.Recall = concat(values.Recall, ",");	
	}

	values.RecallLength = length(values.Recall);
	values.reducedRecall = replaceAll(values.Recall, ",", "");	
	values.RecallWordEstimate= values.RecallLength - length(values.reducedRecall) - 1;
}
/removeConsecutiveCommas = {
	values.Recall = replaceAll(values.Recall, ",,", ",");
	if (contains(values.Recall, ",,")){
		expressions.removeConsecutiveCommas;
	}
}
/lurePosition_Recall = {
	values.countSeparator += 1;
	if (startswith(values.helperRecall, values.lureHelper)){
			values.positionLure_Recall = values.countSeparator;
	} else {
			values.helperRecall = trimleft(values.helperRecall, ",");
			values.index = search(values.helperRecall, ",");
			
			if (values.index >= 0){
				values.helperRecall = subString(values.helperRecall, values.index, length(values.helperRecall)-values.index);
				if (length(values.helperRecall) > 1){
					expressions.lurePosition_Recall;			
				}				
			}
	} 	
}	
/otherWordIntrusions = {
	
	values.helperRecall = values.Recall;
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(1), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(2), "");	
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(3), "");	
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(4), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(5), "");	
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(6), "");		
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(7), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(8), "");	
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(9), "");		
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(10), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(11), "");	
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(12), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(13), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(14), "");
	values.helperRecall = replaceAll(values.helperRecall, item.studyWords_currentList.item(15), "");		
	values.helperRecall = replaceAll(values.helperRecall, values.lure, "");
	
	if (length(replaceAll(values.helperRecall, ",", "")) > 0){
		values.intrusionOther = values.helperRecall;		
	} else {
		values.intrusionOther = "";
	}
}
</expressions>


Recall:
/mean_WordRecall:				mean of the estimated number of words recalled
/SD_WordRecall:					standard deviation of the estimated number of words recalled

/prop_word1Recall-
/prop_word15Recall:				stores the recall proportion of words in study positions 1 - 15 (Max: 8/8 for each item)
/prop_lureRecall:				stores recall proportion of the lure (=a specific highly related item that was NOT a study item) based on the number of recall trials (Max: 8/8)

/mean_LurePosition:				calculates the mean lure Position in the list of recalled items across all lists
/SD_LurePosition:				standard deviation of the lure positions in the list of recalled items across all lists 

/mean_IntrusionsOther:			calculates the mean number of other word intrusions on recall
									!Note: a value > 0 could be a flag to manually check in the raw data file whether misspellings of study list words 
									occurred as these misspelled word would be counted as 'intrusions'
/propCorrect_Math:				proportion correct math problems
/nr_MathProblems:				number of math problems attempted 
									
Recognition:									
									
/propHits:						hit rate (across all studied words)
/propHits_recallWords:			hit rate for study words used in recall blocks
/propHits_mathWords:			hit rate for study words used in math blocks
/propFA:						false alarm rate (across all non-studied words)
/propFA_recallLures:			false alarm rate for lures tied to study words in recall blocks
/propFA_mathLures:				false alarm rate for lures tied to study words in math blocks
/propFA_newWords:				false alarm rate for study words from lists that were not studied
/propFA_newLures:				false alarm rate for lures tied to study words from lists that were not studied

/propRemember_recallWords:		proportion remember judgments for hits for study words used in recall blocks
/propRemember_recallLures:		proportion remember judgments for false alarms  for recall study word lures

/propRemember_mathWords:		proportion remember judgments for hits for study words used in math blocks
/propRemember_mathLures:		proportion remember judgments for false alarms  for math study word lures

/propRemember_newWords:			proportion remember judgments for false alarms for study words from lists that were not studied
/propRemember_newLures:			proportion remember judgments for false alarms for lures of non-studied lists			
								
									
<expressions>
/mean_WordRecall = list.wordCountEstimates.mean
/SD_WordRecall = list.wordCountEstimates.standarddeviation

/prop_word1Recall = values.word1_recall/list.recallLists.itemCount
/prop_word2Recall = values.word2_recall/list.recallLists.itemCount
/prop_word3Recall = values.word3_recall/list.recallLists.itemCount
/prop_word4Recall = values.word4_recall/list.recallLists.itemCount
/prop_word5Recall = values.word5_recall/list.recallLists.itemCount
/prop_word6Recall = values.word6_recall/list.recallLists.itemCount
/prop_word7Recall = values.word7_recall/list.recallLists.itemCount
/prop_word8Recall = values.word8_recall/list.recallLists.itemCount
/prop_word9Recall = values.word9_recall/list.recallLists.itemCount
/prop_word10Recall = values.word10_recall/list.recallLists.itemCount
/prop_word11Recall = values.word11_recall/list.recallLists.itemCount
/prop_word12Recall = values.word12_recall/list.recallLists.itemCount
/prop_word13Recall = values.word13_recall/list.recallLists.itemCount
/prop_word14Recall = values.word14_recall/list.recallLists.itemCount
/prop_word15Recall = values.word15_recall/list.recallLists.itemCount

/prop_lureRecall = values.lure_recall/list.recallLists.itemCount

/mean_LurePosition = list.lurePositions.mean
/SD_LurePosition = list.lurePositions.standarddeviation

/mean_IntrusionsOther = list.intrusions.mean

/propCorrect_Math = list.mathAccuracy.mean
/nr_MathProblems = list.mathAccuracy.itemCount

/propHits = (list.recognition_recallWords.mean*list.recognition_recallWords.itemCount + list.recognition_mathWords.mean*list.recognition_mathWords.itemCount)/
(list.recognition_recallWords.itemCount + list.recognition_mathWords.itemCount)
/propHits_recallWords = list.recognition_recallWords.mean
/propHits_mathWords = list.recognition_mathWords.mean

/propFA = 1 - ((list.recognition_mathLures.mean*list.recognition_mathLures.itemCount + list.recognition_newLures.mean*list.recognition_newLures.itemCount +
list.recognition_newWords.mean*list.recognition_newWords.itemCount + list.recognition_recallLures.mean*list.recognition_recallLures.itemCount)/
(list.recognition_mathLures.itemCount + list.recognition_newLures.itemCount + list.recognition_newWords.itemCount + list.recognition_recallLures.itemCount))
/propFA_recallLures = 1 - list.recognition_recallLures.mean
/propFA_mathLures = 1 - list.recognition_mathLures.mean
/propFA_newWords = 1 - list.recognition_newWords.mean
/propFA_newLures = 1 - list.recognition_newLures.mean

/propRemember_recallWords = list.knowRemember_recallWords.mean
/propRemember_recallLures = list.knowRemember_recallLures.mean

/propRemember_mathWords = list.knowRemember_mathWords.mean
/propRemember_mathLures = list.knowRemember_mathLures.mean

/propRemember_newWords = list.knowRemember_newWords.mean
/propRemember_newLures = list.knowRemember_newLures.mean
</expressions>


