<trial recognition_mathLure>
/ ontrialbegin = [
	values.wordCategory = "math-lure";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_mathLure, old, new]
/ validresponse = (old, new)
/ correctresponse = (new)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_mathLure.response;
	values.stim = text.recognition_mathLure.currentItem;
	list.recognition_mathLures.insertItem(trial.recognition_mathLure.correct, 1);
]
/ branch = [
	if (values.recognitionResponse == "old"){
		return trial.KnowRememberJudgment;
	}
]
</trial>


<trial KnowRememberJudgment>
/ stimulusframes = [1=rememberknowInstructions, stim, remember, know]
/ validresponse = (remember, know)
/ ontrialend = [
	if (trial.KnowRememberJudgment.response == "remember"){
		values.rememberResponse = 1;
	} else {
		values.rememberResponse = 0;
	}
	
	if (values.wordCategory == "new"){
		list.knowRemember_newWords.insertItem(values.rememberResponse, 1);
	} else if (values.wordCategory == "new-lure"){
		list.knowRemember_newLures.insertItem(values.rememberResponse, 1);
	} else if (values.wordCategory == "recall"){
		list.knowRemember_recallWords.insertItem(values.rememberResponse, 1);
	} else if (values.wordCategory == "recall-lure"){
		list.knowRemember_recallLures.insertItem(values.rememberResponse, 1);
	} else if (values.wordCategory == "math"){
		list.knowRemember_mathWords.insertItem(values.rememberResponse, 1);
	} else if (values.wordCategory == "math-lure"){
		list.knowRemember_mathLures.insertItem(values.rememberResponse, 1);
	}
]
</trial>

