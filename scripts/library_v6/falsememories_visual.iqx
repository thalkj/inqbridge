**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

**************************
currentList
**************************

Note: trial adds a delay before the presentation of the first list word
<trial studyPhaseDelay>
/ trialduration = parameters.wordpresentationSOA
/ recorddata = false
</trial>

Note: trial.studyList_list
* presents the next (randomly selected) study list word of the currently presented list for a predetermined amount of time
* the first item of the current study list as well as a randomly selected item from positions 2-6
are stored in item.old (specific to list) which will store the two 'old' items used for the recognition phase
(Note: this step is coded under block level as it's specific to the list)

<trial studyList_currentList>
/ ontrialbegin = [
	values.phase = "study";
	values.lure = item.lure_currentList.item(1);
	values.lureHelper = ",";
	values.lureHelper = concat(values.lureHelper, values.lure);
	values.lureHelper = concat(values.lureHelper, ",");	
]
/ stimulusframes = [1 = studyWord_currentList]
/ trialduration = parameters.wordpresentationSOA
</trial>

************************
immediate Recall
************************

Note: openended.recall_currentList 
* presents a textbox to collect all recalled items
(each of these items should ideally be put on a new line in the textbox)
* trial estimates the number of estimated words (whether or not they really are words)
* trial checks which study words (including the lure) have been mentioned 
and counts the number of correctly recalled items. Note: script tests ",studyword," to ensure that the entire word is contained
* recall is time-limited
<openended recall_currentList>
/ stimulusframes = [1 = recallInstructions]
/ pretrialpause = parameters.recallDelay
/ ontrialbegin = [
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.phase = "recall";
]
/ size = (20%, 30%)
/ multiline = true
/ charlimit = 5000
/ position = (50%, 50%)
/ monkeyresponse = ("mad, ;wrath, enrage,butter,flour,toast,table,sofa,bench,hot,chilly,frost", "mad, ;wrath, enrage,butter,flour,toast,table,sofa,bench,hot,chilly,frost,anger,sleep,chair")
/ ontrialend = [
	values.Recall = tolower(openended.recall_currentList.response);
	expressions.wordcountEstimate;
	list.wordCountEstimates.insertItem(values.RecallWordEstimate, 1);	
		
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(1));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word1_recall += 1;
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(2));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word2_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(3));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word3_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(4));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word4_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(5));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word5_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(6));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word6_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(7));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word7_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(8));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;	
		values.word8_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(9));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word9_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(10));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word10_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(11));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word11_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(12));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word12_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(13));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word13_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(14));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word14_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.studyWords_currentList.item(15));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word15_recall += 1;		
	}	
	
	
	if (contains(values.Recall, values.lureHelper)){
		values.lure_recall += 1;	
		values.countSeparator = 0;
		values.helperRecall = values.Recall;
		values.index = 0;
		expressions.lurePosition_Recall;
		list.lurePositions.insertItem(values.positionLure_Recall, 1);
	}	
	
	
	values.nr_otherRecalledWords = values.RecallWordEstimate - values.countCorrect_Recall - (values.positionLure_Recall > 0);
	list.intrusions.insertItem(values.nr_otherRecalledWords, 1);	
	expressions.otherWordIntrusions;

	list.accuracy_recall.insertItem(values.countCorrect_Recall, 1);

]
/ timeout = parameters.maxRecallDuration
</openended>

<openended math>
/ ontrialbegin = [
	values.phase = "math";
	values.mathProblem = "";
	values.number1 = list.digits.nextValue;
	values.number2 = list.digits.nextValue;
	values.mathProblem = concat(values.mathProblem, values.number1);
	values.mathProblem = concat(values.mathProblem, " ");	
	
	if (replace(0,1) == 1){
		values.mathProblem = concat(values.mathProblem, "*");
	} else {
		values.mathProblem = concat(values.mathProblem, "+");
	}
	
	values.mathProblem = concat(values.mathProblem, " ");	
	values.mathProblem = concat(values.mathProblem, values.number2);
]
/ stimulusframes = [1 = mathProblem]
/ monkeyresponse = ("1", "2", "5", "12", "24", "10")
/ iscorrectresponse = [
	return (openended.math.response == evaluate(values.mathProblem));
]
/ ontrialend = [
	list.mathAccuracy.insertItem(openended.math.correct, 1);
]
/ branch = [
		return openended.math;		
]
/ buttonlabel = "submit"
/ mask = integer
</openended>

<trial break>
/ stimulusframes = [1 = break]
/ recorddata = false
/ trialduration = parameters.MinRecognitionDelay;
</trial>


*******************************************
Recognition Trials
*******************************************

<trial recognition_newWord>
/ ontrialbegin = [
	values.wordCategory = "new";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_newWord, old, new]
/ validresponse = (old, new)
/ correctresponse = (new)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_newWord.response;
	values.stim = text.recognition_newWord.currentItem;
	list.recognition_newWords.insertItem(trial.recognition_newWord.correct, 1);
]
/ branch = [
	if (values.recognitionResponse == "old"){
		return trial.KnowRememberJudgment;
	}
]
</trial>

<trial recognition_newLure>
/ ontrialbegin = [
	values.wordCategory = "new-lure";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_newLure, old, new]
/ validresponse = (old, new)
/ correctresponse = (new)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_newLure.response;
	values.stim = text.recognition_newLure.currentItem;
	list.recognition_newLures.insertItem(trial.recognition_newLure.correct, 1);
]
/ branch = [
	if (values.recognitionResponse == "old"){
		return trial.KnowRememberJudgment;
	}
]
</trial>


<trial recognition_recallWord>
/ ontrialbegin = [
	values.wordCategory = "recall";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_recallWord, old, new]
/ validresponse = (old, new)
/ correctresponse = (old)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_recallWord.response;
	values.stim = text.recognition_recallWord.currentItem;
	list.recognition_recallWords.insertItem(trial.recognition_recallWord.correct, 1);
]
/ branch = [
	if (values.recognitionResponse == "old"){
		return trial.KnowRememberJudgment;
	}
]	
</trial>

<trial recognition_recallLure>
/ ontrialbegin = [
	values.wordCategory = "recall-lure";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_recallLure, old, new]
/ validresponse = (old, new)
/ correctresponse = (new)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_recallLure.response;
	values.stim = text.recognition_recallLure.currentItem;
	list.recognition_recallLures.insertItem(trial.recognition_recallLure.correct, 1);
]
/ branch = [
	if (values.recognitionResponse == "old"){
		return trial.KnowRememberJudgment;
	}
]
</trial>

<trial recognition_mathWord>
/ ontrialbegin = [
	values.wordCategory = "math";
]
/ stimulusframes = [1 = recognitionInstructions, recognition_mathWord, old, new]
/ validresponse = (old, new)
/ correctresponse = (old)
/ ontrialend = [
	values.recognitionResponse = trial.recognition_mathWord.response;
	values.stim = text.recognition_mathWord.currentItem;
	list.recognition_mathWords.insertItem(trial.recognition_mathWord.correct, 1);
]
/ branch = [
