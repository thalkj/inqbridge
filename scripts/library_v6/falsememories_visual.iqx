]	
/ trials = [1 = studyPhaseDelay; 2-16 = studyList_currentList]
/ branch = [
	return block.mathProblems;
]
</block>

<block mathProblems>
/ timeout = parameters.maxRecallDuration
/ trials = [1 = math]
</block>


Note: block.break
- dynamically creates the item lists used for the new items for the recognition task
- resets all recall variables
<block break>
/ onblockbegin = [
	values.RecallWordEstimate = "";
	values.positionLure_Recall = "";
	values.Recall = "";
	values.nr_otherRecalledWords = "";
	values.countCorrect_Recall = "";
	values.intrusionOther = "";
	values.lure = "";
]
/ trials = [1-8 = newWordsCreation; 9 = break]
/ onblockend = [
	values.nextList = "";
]
</block>

Note: block.recognition
* presents 96 trials (48 new, 48 old) in random order
<block recognition>
/ preinstructions = (recognitionPhase, recognitionPhase2)
/ trials = [1-96 = noreplace(trial.recognition_newWord, trial.recognition_newWord, trial.recognition_newWord, trial.recognition_newLure,
trial.recognition_recallWord, trial.recognition_recallWord, trial.recognition_recallWord, trial.recognition_recallLure,
trial.recognition_mathWord, trial.recognition_mathWord, trial.recognition_mathWord, trial.recognition_mathLure)]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ preinstructions = (Intro, Intro2, Intro3)

/ onexptbegin = [
	var i = 0;
	while (i < 8){
		list.recallLists.appendItem(list.listAssignment.nextValue);
		i += 1;
	}

	i = 0;
	while (i < 8){
		list.mathLists.appendItem(list.listAssignment.nextValue);
		i += 1;
	}
	
	i = 0;
	while (i < 8){
		list.newLists.appendItem(list.listAssignment.nextValue);
		i += 1;
	}
]

/blocks = [
	1-16 = noreplace(block.recall, block.math);
	17 = break;
	18 = recognition;
]		
</expt>
	
