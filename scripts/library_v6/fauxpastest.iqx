<button yes>
/ caption = "YES"
/ position = (75%, 90%)
/ size = (20%, 10%)
/ fontStyle = ("Arial", 5%, false, false, false, false, 5, 1)
</button>

<button no>
/ caption = "NO"
/ position = (25%, 90%)
/ size = (20%, 10%)
/ fontStyle = ("Arial", 5%, false, false, false, false, 5, 1)
</button>

<text scenarioHeader>
/ items = ("Story <%values.scenarioCounter%> of <%item.scenarios.itemCount%>")
/ position = (50%, 5%)
/ txcolor = gray
/ erase = false
</text>

**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************
<instruct>
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ finishLabel = "START"
</instruct>

<page intro>
<h1>The Faux Pas Test</h1><hr><br>
In a moment, you’ll be presented with 20 short stories about social situations.<br><br>
Read the stories <u>carefully</u>. You'll be asked questions following each story.<br><br>
Please answer each question as best as you can using your <%expressions.buttonInstruct%> to select your answers.<br><br><br>
When you are ready, press START to continue to the first story.
</page>

<expressions>
/ buttonInstruct = if (computer.touch){
	return "fingers";
} else {
	return "mouse";
}
</expressions>


**************************************************************************************************************
finish trial
**************************************************************************************************************

<text finish>
/ items = ("<center><h1>Thank you!</h1></center>")
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ position = (50%, 50%)
</text>

<button exit>
/ caption = "exit"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (30%, 8%)
</button>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = true
</trial>


**************************************************************************************************************
								!!!REMAINING CODE: Customize after careful consideration only!!!
**************************************************************************************************************

**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.6.1.0 or higher

<defaults>
/ canvasaspectratio = (4,3)
/ minimumversion = "6.6.1.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txbgcolor = white
/ txcolor = black
/ inputDevice = mouse
</defaults>

*******************************************************************************************************************
*******************************************************************************************************************
	DATA
*******************************************************************************************************************
*******************************************************************************************************************

Note: data file explanations under User Manual Information at the top

********************
raw data
********************

<data>
/ columns = (build, computer.platform, date, time, subject, group, session,  
blockcode, blocknum, trialcode, trialnum,

values.scenarioCounter, values.scenarioIndex, values.scenario, values.category, 
values.fpACC, values.compACC, values.scenarioACC, 
values.countCatFCorr, values.countCatCCorr, expressions.fauxpasDetectionScore,
values.q1CorrAnswer, values.q1Resp, values.q1ACC, 
values.q2CorrAnswers, values.q2Resp, values.q2ACC,
values.q3Resp, values.q4Resp, values.q5Resp, values.q6Resp,
values.q7CorrAnswer,values.q7Resp, values.q7ACC,
values.q8CorrAnswer,values.q8Resp, values.q8ACC,

response, correct, latency)	
</data>

********************
summary data
********************

<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed, values.scenarioCounter,
values.countCatFCorr, values.countCatCCorr, expressions.fauxpasDetectionScore,)
</summarydata>
	
*******************************************************************************************************************
*******************************************************************************************************************
	VALUES: automatically updated
*******************************************************************************************************************
*******************************************************************************************************************

<values>
/ scenarioCounter = 0
/ scenarioIndex = 0
/ scenario = ""
/ category = ""
/ q1CorrAnswer = ""
/ q2CorrAnswers = ""
/ q7CorrAnswer = ""
/ q8CorrAnswer = ""

/ q1Resp = ""
/ q2Resp = ""
/ q3Resp = ""
/ q4Resp = ""
/ q5Resp = ""
/ q6Resp = ""
/ q7Resp = ""
/ q8Resp = ""

/ q1ACC = ""
/ q2ACC = ""
/ q7ACC = ""
/ q8ACC = ""

/ fpACC = 0
/ compACC = 0
/ scenarioACC = 0

/ countCatFCorr= 0
/ countCatCCorr = 0
</values>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

<expressions>
/ fauxpasDetectionScore = return (values.countCatFCorr/values.countCatCCorr)
</expressions>

*******************************************************************************************************************
*******************************************************************************************************************
	LISTS
*******************************************************************************************************************
*******************************************************************************************************************

******************************************************
Data Lists

accuracy: store 1 for each correct trial; 0 = otherwise
latency: store the latency of correct responses
******************************************************


*******************************************************************************************************************
*******************************************************************************************************************
	STIMULI
*******************************************************************************************************************
*******************************************************************************************************************

<shape outerframe>
/ shape = rectangle
/ color = black
/ size = (80%, 60%)
/ position = (50%,37%)
/ erase = false
</shape>

<text scenario>
/ items = scenarios
/ select = values.scenarioIndex
/ size = (79%, 59%)
/ hPosition = shape.outerframe.hPosition
/ vPosition = shape.outerframe.vPosition
/ vJustify = center
/ fontStyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ txBgColor = white
/ erase = false
</text>

*******************************************************************************************************************
*******************************************************************************************************************
	TRIALS
*******************************************************************************************************************
*******************************************************************************************************************

<trial q1>
/ onTrialBegin = [
	values.q1Resp = "";
	values.q2Resp = "";
	values.q3Resp = "";
	values.q4Resp = "";
	values.q5Resp = "";
	values.q6Resp = "";
	values.q7Resp = "";
	values.q8Resp = "";
	values.q1ACC = null;
	values.q2ACC = null;
	values.q7ACC = null;
	values.q8ACC = null;
	values.fpACC = null;
	values.compACC = null;
	values.scenarioACC = null;
	
	values.scenarioCounter += 1;
	values.scenarioIndex = list.scenarios.nextIndex;
	values.scenario = item.scenarios.item(values.scenarioIndex);
	values.category = item.categories.item(values.scenarioIndex);
	if (values.category == "F"){
		values.q1CorrAnswer = "yes";	//Note: for translations, keep 'yes' as it refers to the button called 'yes'
	} else {
		values.q1CorrAnswer = "no"; //Note: for translations, keep 'no' as it refers to the button called 'no'
	}
	values.q2CorrAnswers = toLower(item.q2CorrAnswers.item(values.scenarioIndex));	
	
	//dynamic stimuli insertions (due to parameterized duration of scenario)
	trial.q1.insertStimulusTime(text.fauxPasQuestion1, parameters.scenarioDuration_inms);
	trial.q1.insertStimulusTime(button.yes, parameters.scenarioDuration_inms);	
	trial.q1.insertStimulusTime(button.no, parameters.scenarioDuration_inms);		
]
/ stimulusTimes = [0 = clearScreen, outerFrame, scenario, scenarioHeader]
/ beginResponseTime = parameters.scenarioDuration_inms
/ validResponse = (yes, no)
/ correctResponse = (values.q1CorrAnswer)
/ onTrialEnd = [
	trial.q1.resetStimulusFrames();
	values.q1Resp = trial.q1.response;
	values.q1ACC = trial.q1.correct;
	if (values.category == "C"){//correct non-faux pas responses do automatically get q2 'correct'
		if (values.q1ACC){
			values.q2ACC = 1;
		}
	}
]
/ branch = [
	if (trial.q1.response == "yes"){
		return openended.q2;
	} else {
		return surveypage.q7;
	}
]
</trial>

<openended q2>
/ stimulusTimes = [0 = clearScreen, outerFrame, scenario, fauxPasQuestion2, scenarioHeader]
/ position = (50%,90%)
/ size = (40%,6%)
/ multiline = true
/ responseFontStyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ navigationButtonFontStyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ isCorrectResponse = [
	var resp = toLower(openended.q2.response);
	resp = replaceAll(resp, " ", ""); //remove any empty spaces
	resp = concat(resp, ",");	
	return (contains(values.q2CorrAnswers, resp));//checks if response is contained in values.q2CorrAnswers
]
/ required = true
/ onTrialEnd = [
	values.q2ACC = openended.q2.correct;
	values.q2Resp = openended.q2.response;
]
/ branch = [
	return surveypage.q3To6;
]
</openended>

<surveyPage q3To6>
/ questions = [1 = fauxPasQuestion3, fauxPasQuestion4, fauxPasQuestion5, fauxPasQuestion6]
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ subcaptionfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ showpagenumbers = false
/ showquestionnumbers = false
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ navigationbuttonsize = (15%, 5%)
/ backbuttonposition = (20%, 90%)
/ nextbuttonposition = (70%, 90%)
/ onTrialEnd = [
	values.q3Resp = textbox.fauxPasQuestion3.response;
	values.q4Resp = textbox.fauxPasQuestion4.response;
	values.q5Resp = textbox.fauxPasQuestion5.response;
	values.q6Resp = textbox.fauxPasQuestion6.response;
]
/ branch = [
	return surveypage.q7;
]
</surveyPage>

<surveyPage q7>
/ questions = [1 = fauxPasQuestion7]
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ subcaptionfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ showpagenumbers = false
/ showquestionnumbers = false
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ navigationbuttonsize = (15%, 5%)
/ backbuttonposition = (20%, 90%)
/ nextbuttonposition = (70%, 90%)
/ onTrialEnd = [
	values.q7CorrAnswer = item.fauxPasQuestions7AnswersA.item(values.scenarioIndex);
	values.q7Resp = radiobuttons.fauxPasQuestion7.response;
	values.q7ACC = (values.q7Resp == values.q7CorrAnswer);
]
/ branch = [
	return surveyPage.q8;
]
</surveyPage>

<surveyPage q8>
/ questions = [1 = fauxPasQuestion8]
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ subcaptionfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ showpagenumbers = false
/ showquestionnumbers = false
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ navigationbuttonsize = (15%, 5%)
/ backbuttonposition = (20%, 90%)
/ nextbuttonposition = (70%, 90%)
/ onTrialEnd = [
	values.q8CorrAnswer = item.fauxPasQuestions8AnswersA.item(values.scenarioIndex);
	values.q8Resp = radiobuttons.fauxPasQuestion8.response;
	values.q8ACC = (values.q8Resp == values.q8CorrAnswer);
]
/ branch = [
	return trial.scenarioEnd;
]
</surveyPage>

//records one line of data per scenario
<trial scenarioEnd>
/ onTrialBegin = [
	values.fpACC = values.q1ACC * values.q2ACC;
	values.compACC = values.q7ACC * values.q8ACC;
	values.scenarioACC = values.fpACC * values.compACC;
	
	if (values.category == "F"){
		values.countCatFCorr += values.scenarioACC;
	} else {
		values.countCatCCorr += values.scenarioACC;
	}
]
/ isCorrectResponse = [
	return (values.scenarioACC);
]
/ stimulusFrames = [1 = clearScreen]
/ trialDuration = parameters.iti_inms
/ recordData = true
</trial>


*******************************************************************************************************************
*******************************************************************************************************************
	BLOCKS
*******************************************************************************************************************
*******************************************************************************************************************

<block test>
/ trials = [1-20 = q1] //q1 automatically branches to other questions
</block>


<block finish>
/ trials = [1 = finish]
</block>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPERIMENT
*******************************************************************************************************************
*******************************************************************************************************************

<expt a>
/ preInstructions = (intro)
/ blocks = [
	1 = test;
	2 = finish;
]
</expt>

<monkey>
/ latencydistribution=normal(100, 80)
</monkey>


*******************************************************************************************************************
												End of File
*******************************************************************************************************************