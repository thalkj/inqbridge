<text fauxPasQuestion1>
/ items = ("<center><b><u>Question:</u><br>
Did anyone say something they shouldn't have said or something awkward?</b><br><br>
Press the<br>corresponding button</center>")
/ vJustify = center
/ fontStyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ position = (50%,80%)
</text>

<text fauxPasQuestion2>
/ items = ("Who said something they shouldn't have said or something awkward?")
/ vJustify = center
/ fontStyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ position = (50%,75%)
/ erase = false
</text>

<textbox fauxPasQuestion3>
/ caption = "Why shouldn't he/she have said it or why was it awkward?"
/ textboxSize = (80%,10%)
/ multiline = true
</textbox>

<textbox fauxPasQuestion4>
/ caption = "Why do you think he/she said it?"
/ textboxSize = (80%,10%)
/ multiline = true
</textbox>

<item fauxPasQuestions5>
/ 1 = "Did Vicky and Maria know each other?"
/ 2 = "Did Sarah remember that the party was a surprise party?"
/ 3 = "When he tried on the shirt, did Jim know they didn’t have it in his size?"
/ 4 = "Did Lisa know who had bought the curtains?"
/ 5 = "While he was getting the haircut, did Bob know the barber was cutting it too short?"
/ 6 = "When he handed his card to the cashier, did John know the machine wouldn’t take his card?"
/ 7 = "Did Mary know that Sally was a girl?"
/ 8 = "When she invited her, did Pam know that Joan wouldn’t be able to walk home with her?"
/ 9 = "When he first ran into her in the hall, did Joanne’s boyfriend know that she hadn’t gotten the role?"
/ 10 = "When Joe went into the library, did he realize he didn’t have his library card?"
/ 11 = "When he came in, did Robert know that the accountant was sick with cancer?"
/ 12 = "When Joe was talking to Peter, did he know that Mike was in one of the cubicles?"
/ 13 = "When he smelled the pie, did Scott know it was an apple pie?"
/ 14 = "Did Anne remember that Jeannette had given her the bowl?"
/ 15 = "Did Jake know that Christine had entered a story in the contest?"
/ 16 = "Did Tim know that Jack was another customer?"
/ 17 = "When Eleanor got on the bus, did Paul know how long she had been waiting?"
/ 18 = "Did Claire know that Roger’s wife was a lawyer?"
/ 19 = "Did Richard know what his neighbor Ted’s reaction would be?"
/ 20 = "When he started wrapping up a chicken for Louise, did the butcher know that she wanted a freerange chicken?"
</item>

