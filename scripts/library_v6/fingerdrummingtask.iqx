	values.currentButton = list.tapsequenceV3.nextValue; /*sample the next target button */
	
	/* set the color of the current button to be yellow */
	if (values.currentButton == 1){
		text.1.textBgColor = yellow;
	} else if (values.currentButton == 2){
		text.2.textBgColor = yellow;	
	} else if (values.currentButton == 3){
		text.3.textBgColor = yellow;	
	} else if (values.currentButton == 4){
		text.4.textBgColor = yellow;	
	}		
]
/ stimulustimes = [0 = 1, 2, 3, 4, errorAlertEraser]
/ validresponse = (1, 2, 3, 4)
/ iscorrectresponse = [
	return (trial.drummingV3.response == values.currentButton);
]
/ response = correct /* terminate the trial with a correct response (unless timeout limit is reached) */
/ beginresponsetime = 0
/ ontrialend = [
	
	/* add accuracy/latency to summary data lists */
	list.accuracy.insertItem(trial.drummingV3.correct, 1);
	if (trial.drummingV3.correct){
		list.latencies.insertItem(trial.drummingV3.latency, 1);
	}

	
	/* reset all buttons back to gray */
	text.1.textBgColor = gray;
	text.2.textBgColor = gray;		
	text.3.textBgColor = gray;		
	text.4.textBgColor = gray;		
	
	/* in case, the trial terminated with a response, update tap counter and check whether one sequence has been completed */
	if (trial.drummingV3.response !=0){
		values.countTaps += 1;
		
		if (mod(values.countTaps, 4)==0){
			values.countCompletedSequences += 1;
		}
	}	

	/* check stop condition */
	if (script.elapsedTime > values.startTime + parameters.timeoutV3){
		values.stop = 1;
	}	
]
/ branch = [
	return trial.drummingV3;
]
