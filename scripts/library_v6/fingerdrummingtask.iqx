<block version1>
/ onblockbegin = [
	values.version = 1;
	values.nextIndex = 0;
	values.countCompletedSequences = 0;
	values.countTaps = 0;
	list.accuracy.reset();
	list.latencies.reset();
	text.errorAlert.textColor = black;
	values.correctSequence = parameters.correctSequenceV1;
	text.1.textBgColor = gray;
	text.2.textBgColor = gray;
	text.3.textBgColor = gray;
	text.4.textBgColor = gray;	
	text.1_HL.textBgColor = yellow;
	text.2_HL.textBgColor = yellow;
	text.3_HL.textBgColor = yellow;
	text.4_HL.textBgColor = yellow;	
	values.stop = 0;
	values.test = 0;
]
/ stop = [
	values.stop == 1;
]
/ trials = [1 = taskIntro; 2 = drummingV12_practice]
/ onblockend = [
	if (values.hand == 1){
		values.LH_completedSequences_V1 = values.countCompletedSequences;
		values.LH_ACC_V1 = list.accuracy.mean;
		values.LH_meanRT_V1 = list.latencies.mean;
	} else {
		values.RH_completedSequences_V1 = values.countCompletedSequences;
		values.RH_ACC_V1 = list.accuracy.mean;
		values.RH_meanRT_V1 = list.latencies.mean;		
	}
]
/ branch = [
	return block.blockfeedback;
]
</block>

