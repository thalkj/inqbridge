version 1/2
*********************************************

<trial drummingV12_practice>
/ ontrialbegin = [

	values.index = values.nextIndex;
	values.currentButton = subString(values.correctSequence, values.index, 1);
	
	if (values.currentButton == 1){
		text.button_HL.vposition = text.1.vposition;
		text.button_HL.hposition = text.1.hposition;
		values.buttonLabel = "index";
	} else if (values.currentButton == 2){
		text.button_HL.vposition = text.2.vposition;
		text.button_HL.hposition = text.2.hposition;
		values.buttonLabel = "middle";
	} else if (values.currentButton == 3){
		text.button_HL.vposition = text.3.vposition;
		text.button_HL.hposition = text.3.hposition;
		values.buttonLabel = "ring";
	} else if (values.currentButton == 4){
		text.button_HL.vposition = text.4.vposition;
		text.button_HL.hposition = text.4.hposition;
		values.buttonLabel = "pinky";
	}
]
/ stimulusframes = [1 = 1, 2, 3, 4]
/ validresponse = (1, 2, 3, 4)
/ iscorrectresponse = [
	return (trial.drummingV12_practice.response == values.currentButton);
]
/ response = correct
/ beginresponsetime = 0
/ ontrialend = [
	trial.drummingV12_practice.resetStimulusFrames();
	
	if (trial.drummingV12_practice.response !=0){
		values.countTaps += 1;	
		values.nextIndex = values.index + 1;
		if (values.nextIndex == length(values.correctSequence)){
			values.countCompletedSequences += 1;
			values.nextIndex = 0;
		}
	}			
	
	text.1.textBgColor = gray;		
	text.2.textBgColor = gray;
	text.3.textBgColor = gray;		
	text.4.textBgColor = gray;		
		
	if (trial.drummingV12_practice.response == 1){
		text.1.textBgColor = lightGray;
	} else if (trial.drummingV12_practice.response == 2){
		text.2.textBgColor = lightGray;		
	} else if (trial.drummingV12_practice.response == 3){
		text.3.textBgColor = lightGray;		
	} else if (trial.drummingV12_practice.response == 4){
		text.4.textBgColor = lightGray;		
	}	
]
/ branch = [
	if (values.countCompletedSequences < 3){	
		return trial.drummingV12_practice;		
	} else {
		values.nextIndex = 0;
		values.countCompletedSequences = 0;
		values.countTaps = 0;
		text.errorAlert.textColor = black;
		text.1_HL.textBgColor = yellow;
		text.2_HL.textBgColor = yellow;
		text.3_HL.textBgColor = yellow;
		text.4_HL.textBgColor = yellow;	
		values.test = 1;
		values.startTime = script.elapsedTime;
		return trial.drummingV12;
	}
]
/ errormessage = true(text.button_HL, 0)
</trial>


Note: trial.drummigV12
<trial drummingV12>
/ ontrialbegin = [

	values.index = values.nextIndex;
	values.currentButton = subString(values.correctSequence, values.index, 1);
	
	if (values.currentButton == 1){
		text.button_HL.vposition = text.1.vposition;
		text.button_HL.hposition = text.1.hposition;
		values.buttonLabel = "index";
	} else if (values.currentButton == 2){
		text.button_HL.vposition = text.2.vposition;
		text.button_HL.hposition = text.2.hposition;
		values.buttonLabel = "middle";
	} else if (values.currentButton == 3){
		text.button_HL.vposition = text.3.vposition;
		text.button_HL.hposition = text.3.hposition;
		values.buttonLabel = "ring";
	} else if (values.currentButton == 4){
		text.button_HL.vposition = text.4.vposition;
		text.button_HL.hposition = text.4.hposition;
		values.buttonLabel = "pinky";
	}
]
/ stimulusframes = [1 = 1, 2, 3, 4, timerV1]
/ validresponse = (1, 2, 3, 4)
/ iscorrectresponse = [
	return (trial.drummingV12.response == values.currentButton);
]
/ response = correct
/ beginresponsetime = 0
/ ontrialend = [
	trial.drummingV12.resetStimulusFrames();
	list.accuracy.insertItem(trial.drummingV12.correct, 1);
	if (trial.drummingV12.correct){
		list.latencies.insertItem(trial.drummingV12.latency, 1);
	}
	
	if (trial.drummingV12.response !=0){
		values.countTaps += 1;	
		values.nextIndex = values.index + 1;
		if (values.nextIndex == length(values.correctSequence)){
			values.countCompletedSequences += 1;
			values.nextIndex = 0;
		}
	}			
	
	text.1.textBgColor = gray;		
	text.2.textBgColor = gray;
	text.3.textBgColor = gray;		
	text.4.textBgColor = gray;		
		
	if (trial.drummingV12.response == 1){
		text.1.textBgColor = lightGray;
	} else if (trial.drummingV12.response == 2){
		text.2.textBgColor = lightGray;		
	} else if (trial.drummingV12.response == 3){
		text.3.textBgColor = lightGray;		
	} else if (trial.drummingV12.response == 4){
		text.4.textBgColor = lightGray;		
	}	
	
	if (values.version == 1){
		if (script.elapsedTime > values.startTime + parameters.timeoutV1){
			values.stop = 1;
		}		
	} else {
		if (script.elapsedTime > values.startTime + parameters.timeoutV2){
			values.stop = 1;
		}			
	}
;
]
/ branch = [
	return trial.drummingV12;
]
/ errormessage = true(text.button_HL, 0)
</trial>

Comments: 
trial drummingV12>
/ ontrialbegin = [

	values.index = values.nextIndex; /*sample next button index*/
	values.currentButton = subString(values.correctSequence, values.index, 1); /*translate index into button*/
	
	/*prepare text.button_HL (feedback button): assign screen positions of current button*/
	if (values.currentButton == 1){
		text.button_HL.vposition = text.1.vposition;
		text.button_HL.hposition = text.1.hposition;
		values.buttonLabel = "index";
	} else if (values.currentButton == 2){
		text.button_HL.vposition = text.2.vposition;
		text.button_HL.hposition = text.2.hposition;
		values.buttonLabel = "middle";
	} else if (values.currentButton == 3){
		text.button_HL.vposition = text.3.vposition;
		text.button_HL.hposition = text.3.hposition;
		values.buttonLabel = "ring";
	} else if (values.currentButton == 4){
		text.button_HL.vposition = text.4.vposition;
		text.button_HL.hposition = text.4.hposition;
		values.buttonLabel = "pinky";
	}
]
/ stimulusframes = [1 = 1, 2, 3, 4]
/ validresponse = (1, 2, 3, 4)
/ iscorrectresponse = [
	return (trial.drummingV12.response == values.currentButton);
]
/ response = correct /*terminate trial only with a correct response (until timeout limit is reached)*/
/ beginresponsetime = 0 /*continuous responses
/ ontrialend = [
	trial.drummingV12.resetStimulusFrames();
	list.accuracy.insertItem(trial.drummingV12.correct, 1); /*stores the initial accuracy*/
	if (trial.drummingV12.correct){ /* in case of an initially correct respons, store latency
		list.latencies.insertItem(trial.drummingV12.latency, 1);
	}
	
	/*check whether the trial terminated with a response to update tapcount and move ahead*/
	if (trial.drummingV12.response !=0){
		values.countTaps += 1;	
		values.nextIndex = values.index + 1;
		if (values.nextIndex == length(values.correctSequence)){
			values.countCompletedSequences += 1;
			values.nextIndex = 0;
		}
	}			
	
	/*reset all buttons back to a gray background*/
	text.1.textBgColor = gray;		
	text.2.textBgColor = gray;
	text.3.textBgColor = gray;		
	text.4.textBgColor = gray;		
	
	/*the currently pressed button is highlighted in lightGray */
	if (trial.drummingV12.response == 1){
		text.1.textBgColor = lightGray;
	} else if (trial.drummingV12.response == 2){
		text.2.textBgColor = lightGray;		
	} else if (trial.drummingV12.response == 3){
		text.3.textBgColor = lightGray;		
	} else if (trial.drummingV12.response == 4){
		text.4.textBgColor = lightGray;		
	}	
	
	/*check whether the block should be stopped:
	if (values.version == 1){
		if (script.elapsedTime > values.startTime + parameters.timeoutV1){
			values.stop = 1;
		}		
	} else {
		if (script.elapsedTime > values.startTime + parameters.timeoutV2){
			values.stop = 1;
		}			
	}
]
/ branch = [
	return trial.drummingV12;
]
/ errormessage = true(text.button_HL, 0) /*if current response is incorrect, present the highlighted button */
</trial>

