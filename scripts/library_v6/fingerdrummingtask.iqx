<block version3>
/ onblockbegin = [
	values.version = 3;
	values.countCompletedSequences = 0;
	values.countTaps = 0;
	text.errorAlert.textColor = red;
	text.1.textBgColor = gray;
	text.2.textBgColor = gray;
	text.3.textBgColor = gray;
	text.4.textBgColor = gray;		
	text.1_HL.textBgColor = white;
	text.2_HL.textBgColor = white;
	text.3_HL.textBgColor = white;
	text.4_HL.textBgColor = white;		
	values.stop = 0;
	list.accuracy.reset();
	list.latencies.reset();
	values.test = 0;
]
/ stop = [
	values.stop == 1;
]
/ trials = [1 = taskIntro; 2 = drummingV3_practice]
/ onblockend = [
	if (values.hand == 1){
		values.LH_completedSequences_V3 = values.countCompletedSequences;
		values.LH_ACC_V3 = list.accuracy.mean;
		values.LH_meanRT_V3 = list.latencies.mean;
	} else {
		values.RH_completedSequences_V3 = values.countCompletedSequences;
		values.RH_ACC_V3 = list.accuracy.mean;
		values.RH_meanRT_V3 = list.latencies.mean;		
	}
]
/ branch = [
	return block.blockfeedback;
]
</block>

<block blockfeedback>
/ trials = [1 = blockfeedback]
</block>

<block finish>
/ trials = [1 = finish]
</block>

