<block touchscreenCheck>
/ skip = [
	computer.touch;
]
/ trials = [1 = touchscreenCheck]
</block>

<block generalIntro>
/ trials = [1 = generalIntro; 2 = buttonSizeAdjust]
</block>


<block setUp_LH>
/ onblockbegin = [
	values.hand = 1;
	values.currentHand = "LEFT";
	text.4_adjustbutton.hposition = 1px * display.getPixelsX(20);
	text.3_adjustbutton.hposition = 1px * display.getPixelsX(40);
	text.2_adjustbutton.hposition = 1px * display.getPixelsX(60);
	text.1_adjustbutton.hposition = 1px * display.getPixelsX(80);
]
/ trials = [1 = adjustIntro; 2 = choosePositions]
/ onblockend = [
	text.1.hposition = text.1_adjustbutton.hposition;
	text.2.hposition = text.2_adjustbutton.hposition;
	text.3.hposition = text.3_adjustbutton.hposition;
	text.4.hposition = text.4_adjustbutton.hposition;
	
	text.1.vposition = text.1_adjustbutton.vposition;
	text.2.vposition = text.2_adjustbutton.vposition;
	text.3.vposition = text.3_adjustbutton.vposition;
	text.4.vposition = text.4_adjustbutton.vposition;	
	
	text.1_HL.hposition = text.1_adjustbutton.hposition;
	text.2_HL.hposition = text.2_adjustbutton.hposition;
	text.3_HL.hposition = text.3_adjustbutton.hposition;
	text.4_HL.hposition = text.4_adjustbutton.hposition;
	
	text.1_HL.vposition = text.1_adjustbutton.vposition;
	text.2_HL.vposition = text.2_adjustbutton.vposition;
	text.3_HL.vposition = text.3_adjustbutton.vposition;
	text.4_HL.vposition = text.4_adjustbutton.vposition;		

]
</block>

