<expt a>
/ groups = (1 of 2)
/ onexptbegin = [
	values.buttonSize = parameters.buttonSize;
]
/ blocks = [
	1 = touchscreenCheck;
	2 = generalIntro;
	3 = setUp_RH;
	4-6 = noreplace(version1, version2, version3);	
	7 = setUp_LH;
	8-10 = noreplace(version1, version2, version3);
	11 = finish;
]
</expt>


<expt b>
