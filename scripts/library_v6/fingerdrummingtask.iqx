script.subjectId, script.groupId, script.sessionId, script.elapsedTime, 
script.completed,
values.LH_completedSequences_V1, values.LH_ACC_V1, values.LH_meanRT_V1, 
values.RH_completedSequences_V1, values.RH_ACC_V1, values.RH_meanRT_V1,
values.LH_completedSequences_V2, values.LH_ACC_V2, values.LH_meanRT_V2, 
values.RH_completedSequences_V2, values.RH_ACC_V2, values.RH_meanRT_V2,
values.LH_completedSequences_V3, values.LH_ACC_V3, values.LH_meanRT_V3, 
values.RH_completedSequences_V3, values.RH_ACC_V3, values.RH_meanRT_V3)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
/version:				3 versions: 1 vs. 2 vs. 3
/hand:					1 = Left Hand (LH); 2 = Right Hand (RH)
/test:					1 = timed test; 0 = untimed practice (first 3 sequences)

/validPosition:			helper variable to detect problems with the layout of the buttons
/correctSequence:		V1/V2: stores the correct tap sequence
/index:					helper variable to determine the current tap in the sequence (index of the current tapsequence list)
/nextIndex:				helper variable to determine the next tap in the sequence
/countTaps:				a tap counter
/currentButton:			stores the number of the current button in the sequence:
						4 = pinky
						3 = ring
						2 = middle
						1 = index
						
/countCompletedSequences: a counter of how many sequences were completed
/buttonLabel:			helper variable; stores the label of the highlighted button for version 1 and version 2


/currentHand:			helper variable that stores the label of the current hand
/selectInstructions:	helper variable that helps select the appropriate instructins
/buttonSize:			helper variable that stores the current button size (in percentage)
/startTime:				helper variable that stores the script.elapsedTime of the last started test
/stop:					helper variable: 1 = current task has reached timelimit and should stop; 0 = otherwise

<values>
/version = ""
/hand = 0
/test = 0

/validPosition = 0
/correctSequence = ""
/index = 0
/nextIndex= 0
/countTaps = 0
/currentButton = ""

/countCompletedSequences = 0

/buttonLabel = ""
/currentHand = "right"
/selectInstructions = 1

/buttonSize = ""
/startTime = ""
/stop = 0

</values>


Summary Variables:

Version1:
/LH_ACC_V1:						stores the proportion correct taps for left hand version1
/LH_meanRT_V1:					stores the mean latency (in ms) of correct taps for left hand version1
/RH_ACC_V1:						stores the proportion correct taps for right hand version1
/RH_meanRT_V1:					stores the mean latency (in ms) of correct taps for right hand version1
/LH_completedSequences_V1: 		stores the number of completed sequences for left hand version1
/RH_completedSequences_V1: 		stores the number of completed sequences for right hand version1

Version2:
/LH_ACC_V2:						stores the proportion correct taps for left hand version2
/LH_meanRT_V2:					stores the mean latency (in ms) of correct taps for left hand version2
/RH_ACC_V2:						stores the proportion correct taps for right hand vversion2
/RH_meanRT_V2:					stores the mean latency (in ms) of correct taps for right hand version2
/LH_completedSequences_V2: 		stores the number of completed sequences for left hand version2
/RH_completedSequences_V2: 		stores the number of completed sequences for right hand version2


<values>
