<text intro>
/ items = instructions
/ select = 1
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ vjustify = center
/ hjustify = left
</text>

<text adjustmentIntro>
/ items = instructions
/ select = 2
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ vjustify = center
/ hjustify = left
</text>

<text taskIntro>
/ items = instructions
/ select = values.selectInstructions
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ vjustify = center
/ hjustify = left
</text>

<button continueButton>
/ caption = "<%item.continuebuttons.item(values.selectInstructions)%>"
/size = (20%, 8%)
/ position = (50%, 90%)
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
</button>

<text sizeAdjustInstruct>
/ items = misc
/ select = 1
/size = (80%, 20%)
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ erase = false
</text>


<text moveInstructions>
/ items = misc
/ select = 2
/size = (80%, 20%)
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
</text>

<text adjustInstructions>
/ items = misc
/ select = 3
/size = (80%, 20%)
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
</text>


<trial generalIntro>
/ ontrialbegin = [
	values.selectInstructions = 1;
]
/ stimulusframes = [1 = intro, continueButton]
/ validresponse = (continueButton)
/ recorddata = false
</trial>

<trial adjustIntro>
/ ontrialbegin = [
	values.selectInstructions = 2;
]
/ stimulusframes = [1 = adjustmentIntro, HandAlert, continueButton]
/ validresponse = (continueButton)
/ branch = [
	return trial.helperTrial;
]
/ recorddata = false
</trial>

Note: catches the up-response before the drag/drop trial starts
<trial helperTrial>
/ validresponse = (lbuttonup)
/ trialduration = 100
/ recorddata = false
</trial>

<trial taskIntro>
/ ontrialbegin = [
	values.selectInstructions = values.version + 2;
]
/ stimulusframes = [1 = taskIntro, newTask, continueButton]
/ validresponse = (continueButton)
/ recorddata = false
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

