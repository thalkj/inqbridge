/ onblockbegin = [
	values.hand = 2;
	values.currentHand = "RIGHT";
	text.4_adjustbutton.hposition = 1px * display.getPixelsX(80);
	text.3_adjustbutton.hposition = 1px * display.getPixelsX(60);
	text.2_adjustbutton.hposition = 1px * display.getPixelsX(40);
	text.1_adjustbutton.hposition = 1px * display.getPixelsX(20);
]
