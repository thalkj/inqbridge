/ hposition = 1px * display.getPixelsX(40)
/ vposition = 1px * display.getPixelsY(50)
/ txbgcolor = gray
/ fontstyle = ("Arial", 2%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ dropsource = true
</text>

<text 2_adjustbutton>
/ items = ("middle")
/size = (values.buttonSize * 0.75, values.buttonSize)
/ hposition = 1px * display.getPixelsX(60)
/ vposition = 1px * display.getPixelsY(50)
/ txbgcolor = gray
/ fontstyle = ("Arial", 2%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ dropsource = true
</text>


<text 1_adjustbutton>
/ items = ("index")
/size = (values.buttonSize * 0.75, values.buttonSize)
/ hposition = 1px * display.getPixelsX(80)
/ vposition = 1px * display.getPixelsY(50)
/ txbgcolor = gray
/ fontstyle = ("Arial", 2%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ dropsource = true
</text>


<shape dropcanvas>
/ shape = rectangle
/ size = (100%, 100%)
/ color = black
/ position = (50%, 50%)
/ erase = false
/ droptarget = true
/ dropposition = (anywhere, anywhere)
</shape>

<button continue>
/ caption = "continue"
/ position = (50%, 90%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ size = (10%, 5%)
</button>

<button adjust>
/ caption = "adjust"
/ position = (10%, 90%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ size = (10%, 5%)
</button>


<clock timerV1>
/ mode = timer
/ resetrate = block
/ erase = false
/ txcolor = white
/ txbgcolor = black
/ timeout = parameters.timeoutV1
/ position = (50%, 10%)
/ format = "mm:ss"
</clock>

<clock timerV2>
/ mode = timer
/ resetrate = block
/ erase = false
/ txcolor = white
/ txbgcolor = black
/ timeout = parameters.timeoutV1
/ position = (50%, 10%)
/ format = "mm:ss"
</clock>

<clock timerV3>
/ mode = timer
/ resetrate = block
/ erase = false
/ txcolor = white
/ txbgcolor = black
/ timeout = parameters.timeoutV1
/ position = (50%, 10%)
/ format = "mm:ss"
</clock>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = next button in sequence is pressed; 0 = otherwise
<list accuracy>
</list>

Note: list stores latencies of correct button presses
<list latencies>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS: SET UP 	
**************************************************************************************************************
**************************************************************************************************************

Note: trial alerts participant that task only runs on touchscreens
this alert is only presented if no touchscreen is detected.
At the end of this trial, the script is aborted.
<trial touchscreenCheck>
/ stimulusframes = [1 = touchscreenInfo, exit]
/ validresponse = (exit)
/ ontrialend = [
	if (!monkey.monkeyMode){
		script.abort();
	}
]
/ recorddata = false
</trial>

****************************************
Button Size
****************************************

<trial buttonSizeAdjust>
/ stimulusframes = [1 = sizeAdjustInstruct, adjustmentButton, plus, minus, continue]
/ validresponse = (plus, minus, continue)
/ ontrialend = [
	if (trial.buttonSizeAdjust.response == "plus"){
		values.buttonSize += 1%;
	} else if (trial.buttonSizeAdjust.response == "minus"){
		values.buttonSize -= 1%;
	}
	if (values.buttonSize < 5%){
		values.buttonSize = 5%;
	} else if (values.buttonSize*5 > 90%){
		values.buttonSize = 90%/5;
	}
	

]
/ branch = [
	if (trial.buttonSizeAdjust.response != "continue"){
		return trial.buttonSizeAdjust;
	}
]
/ recorddata = false
</trial>

****************************************
Button Positions
****************************************

<trial choosePositions>
/ inputdevice = dragdrop
/ stimulusframes = [1 = dropcanvas, 1_adjustbutton, 2_adjustbutton, 3_adjustbutton, 4_adjustbutton, continue, moveInstructions]
/ validresponse = (continue)
/ branch = [
	return trial.positionCheck;
]
/ recorddata = false
</trial>
 
<trial positionCheck>
/ stimulusframes = [1 = clearScreen, 4_adjustbutton, 3_adjustbutton, 2_adjustbutton, 1_adjustbutton, continue, adjust, adjustInstructions]
/ validresponse = (continue, adjust)
/ ontrialend = [
	if (values.hand == 1){
		if ( 	(text.4_adjustbutton.hposition < text.3_adjustbutton.hposition) && (text.3_adjustbutton.hposition < text.2_adjustbutton.hposition) &&	
				(text.2_adjustbutton.hposition < text.1_adjustbutton.hposition)){
					values.validPosition = 1;
		} else {
			values.validPosition = 0;
		}		
	} else {
		if ( 	(text.1_adjustbutton.hposition < text.2_adjustbutton.hposition) && (text.2_adjustbutton.hposition < text.3_adjustbutton.hposition) &&	
				(text.3_adjustbutton.hposition < text.4_adjustbutton.hposition)){
					values.validPosition = 1;
		} else {
			values.validPosition = 0;
		}				
	}
	
]
/ branch = [
	if (trial.positionCheck.response == "adjust"){
		return trial.choosePositions;
	} else if (values.validPosition == 0){
		return trial.positionCorrectionAlert;
	}
]
/ recorddata = false
</trial>

<trial positionCorrectionAlert>
/ stimulusframes = [1 = positionCorrectionAlert, continue]
/ validresponse = (continue)
/ branch = [
	return trial.choosePositions;
]
/ recorddata = false
</trial>

