*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************
<surveypage FFMRF_1>
/caption ="<%parameters.completeinstructions%>"
/subcaption = "<%parameters.responselegend%>"
/questions = [1 = Neuroticism,
N_AnxiousnessA, N_Anxiousness, N_AnxiousnessB,
N_HostilityA, N_Hostility, N_HostilityB,
N_DepressivenessA, N_Depressiveness,N_DepressivenessB,
N_SelfConsciousnessA, N_SelfConsciousness,N_SelfConsciousnessB,
N_ImpulsivityA, N_Impulsivity,N_ImpulsivityB,
N_VulnerabilityA, N_Vulnerability, N_VulnerabilityB]
</surveypage>

<surveypage FFMRF_2>
/caption ="<%parameters.repeatinstructions%>"
/subcaption = "<%parameters.responselegend%>"
