**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
	Practice Trial
**************************************************************************************************************

<trial practicetrial>
/ ontrialbegin = [
	values.stimcolor=list.practicecolors.nextValue;
	text.stimword.textColor=list.stimcolor.item(values.stimcolor);
	values.stimword=list.practicewords.nextValue;
]
/ stimulustimes = [0=fixation;200=stimword]
/ validresponse = (parameters.keyred, parameters.keygreen, parameters.keyblue, parameters.keyyellow)
/ iscorrectresponse = [
	return (
	(trial.practicetrial.responseText == parameters.keyred && values.stimcolor == 1) || 
	(trial.practicetrial.responseText == parameters.keygreen && values.stimcolor == 2) || 
	(trial.practicetrial.responseText == parameters.keyblue && values.stimcolor == 3) || 	
	(trial.practicetrial.responseText == parameters.keyyellow && values.stimcolor == 4));
]
/ ontrialend = [
	if (trial.practicetrial.responseText == parameters.keyred) {
		values.responseCategory = 1;
	} else if (trial.practicetrial.responseText == parameters.keygreen) {
		values.responseCategory = 2;
	} else if (trial.practicetrial.responseText == parameters.keyblue) {
		values.responseCategory = 3;
	} else if (trial.practicetrial.responseText == parameters.keyyellow) {
		values.responseCategory = 4;
	}
]
</trial>

**************************************************************************************************************
	Congruent Color Trial (CC)
**************************************************************************************************************

<trial CCtrial>
/ ontrialbegin = [
	values.condition = 1;
	values.stimcolor=list.cdcc.nextValue;
	text.stimword.textColor=list.stimcolor.item(values.stimcolor);
	values.stimworditemnumber =  list.cwcc.nextValue;
	values.stimword=item.colorwords.item(values.stimworditemnumber);
]
/ stimulustimes = [0=fixation;200=stimword]
/ validresponse = (parameters.keyred, parameters.keygreen, parameters.keyblue, parameters.keyyellow)
/ iscorrectresponse = [
	return(
	(trial.CCtrial.responseText == parameters.keyred && values.stimcolor == 1) || 
	(trial.CCtrial.responseText == parameters.keygreen && values.stimcolor == 2) || 
	(trial.CCtrial.responseText == parameters.keyblue && values.stimcolor == 3) || 	
	(trial.CCtrial.responseText == parameters.keyyellow && values.stimcolor == 4));
]
/ ontrialend = [
	if (trial.CCtrial.responseText == parameters.keyred) {
		values.responseCategory = 1;
	} else if (trial.CCtrial.responseText == parameters.keygreen) {
		values.responseCategory = 2;
	} else if (trial.CCtrial.responseText == parameters.keyblue) {
		values.responseCategory = 3;
	} else if (trial.CCtrial.responseText == parameters.keyyellow) {
		values.responseCategory = 4;
	}
	//summary data:
	list.accuracy.appendItem(trial.CCtrial.correct);
	list.accuracy_CC.appendItem(trial.CCtrial.correct);
	if (trial.CCtrial.correct) {
		list.latencies.appendItem(trial.CCtrial.latency);
		list.latencies_CC.appendItem(trial.CCtrial.latency);
	}
]
</trial>

**************************************************************************************************************
	Inongruent Color Trial (IC)
**************************************************************************************************************

<trial ICtrial>
/ ontrialbegin = [
	values.condition = 2;
	values.stimcolor=list.cdic.nextValue;
	text.stimword.textColor=list.stimcolor.item(values.stimcolor);
	values.stimworditemnumber = list.cwic.nextValue;
	values.stimword=item.colorwords.item(values.stimworditemnumber);
]
/ stimulustimes = [0=fixation;200=stimword]
/ validresponse = (parameters.keyred, parameters.keygreen, parameters.keyblue, parameters.keyyellow)
/ iscorrectresponse = [
	return(
	(trial.ICtrial.responseText == parameters.keyred && values.stimcolor == 1) || 
	(trial.ICtrial.responseText == parameters.keygreen && values.stimcolor == 2) || 
	(trial.ICtrial.responseText == parameters.keyblue && values.stimcolor == 3) || 	
	(trial.ICtrial.responseText == parameters.keyyellow && values.stimcolor == 4));
]
/ ontrialend = [
	if (trial.ICtrial.responseText == parameters.keyred) {
		values.responseCategory = 1;
	} else if (trial.ICtrial.responseText == parameters.keygreen) {
		values.responseCategory = 2;
	} else if (trial.ICtrial.responseText == parameters.keyblue) {
		values.responseCategory = 3;
	} else if (trial.ICtrial.responseText == parameters.keyyellow) {
		values.responseCategory = 4;
	}
	//summary data:
	list.accuracy.appendItem(trial.ICtrial.correct);
	list.accuracy_IC.appendItem(trial.ICtrial.correct);
	if (trial.ICtrial.correct) {
		list.latencies.appendItem(trial.ICtrial.latency);
		list.latencies_IC.appendItem(trial.ICtrial.latency);
	}
]
</trial>

**************************************************************************************************************
	HPF Trial (HPF)
**************************************************************************************************************

<trial HPFtrial>
/ ontrialbegin = [
	values.condition = 3;
	values.stimcolor=list.cdother.nextValue;
	text.stimword.textColor=list.stimcolor.item(values.stimcolor);
	values.stimworditemnumber =list.cwother.nextValue;
	values.stimword=item.HPF.item(values.stimworditemnumber);
]
/ stimulustimes = [0=fixation;200=stimword]
/ validresponse = (parameters.keyred, parameters.keygreen, parameters.keyblue, parameters.keyyellow)
