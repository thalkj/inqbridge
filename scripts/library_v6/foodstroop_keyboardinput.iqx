	return(
	(trial.HPFtrial.responseText == parameters.keyred && values.stimcolor == 1) || 
	(trial.HPFtrial.responseText == parameters.keygreen && values.stimcolor == 2) || 
	(trial.HPFtrial.responseText == parameters.keyblue && values.stimcolor == 3) || 	
	(trial.HPFtrial.responseText == parameters.keyyellow && values.stimcolor == 4));
]
/ ontrialend = [
	if (trial.HPFtrial.responseText == parameters.keyred) {
		values.responseCategory = 1;
	} else if (trial.HPFtrial.responseText == parameters.keygreen) {
		values.responseCategory = 2;
	} else if (trial.HPFtrial.responseText == parameters.keyblue) {
		values.responseCategory = 3;
	} else if (trial.HPFtrial.responseText == parameters.keyyellow) {
