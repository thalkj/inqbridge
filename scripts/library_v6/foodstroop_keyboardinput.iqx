****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {"button";} else {"key";}
/buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {
						"Place your index and middle fingers over the '<%parameters.keyred%>, '<%parameters.keygreen%>', '<%parameters.keyblue%>', and '<%parameters.keyyellow%>' response buttons.";} 
				   else {
						"Put your index and middle fingers over the '<%parameters.keyred%>, '<%parameters.keygreen%>', '<%parameters.keyblue%>', and '<%parameters.keyyellow%>' keys.";}
</expressions>


