	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/ keyred = "d"
/ keygreen = "f"
/ keyblue = "j"
/ keyyellow = "k"

/ getReadyDuration = 5000
</parameters>

