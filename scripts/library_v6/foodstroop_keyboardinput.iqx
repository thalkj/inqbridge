**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block instructions01>
/ bgstim = (whitebg)
/ trials = [1-3=instructiontrial]
/ recorddata = false
</block>

<block instructions02>
/ bgstim = (whitebg)
/ trials = [
	1=instructiontrial;
]
/ recorddata = false
</block>

<block testStart>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [1 = getReady]
</block>


**************************************************************************************************************
	Practice Block
**************************************************************************************************************

<block practiceblock>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1 = getReady; 
	2-5=practicetrial;
]
/ errormessage = true(text.x, 1)
</block>

**************************************************************************************************************
	Test Blocks
**************************************************************************************************************
	Congruent Color (CC) Block
**************************************************************************************************************

<block CC>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=CCtrial;
]
</block>

**************************************************************************************************************
	Incongruent Color (IC) Block
**************************************************************************************************************

<block IC>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=ICtrial;
]
</block>

**************************************************************************************************************
	HPF (HPF) Block
**************************************************************************************************************

<block HPF>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=HPFtrial;
]
</block>

**************************************************************************************************************
	NTF (NTF) Block
**************************************************************************************************************

<block NTF>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=NTFtrial;
]
</block>

**************************************************************************************************************
	HPF Animal (HPFA) Block
**************************************************************************************************************

<block HPFA>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=HPFAtrial;
]
</block>

**************************************************************************************************************
	NTF Animal (NTFA) Block
**************************************************************************************************************

<block NTFA>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-12=NTFAtrial;
]
</block>


**************************************************************************************************************
	optional Mixed Design Block
**************************************************************************************************************

Note: to run the study with a mixed design:
<block FoodStroop>
/ bgstim = (redreminder, greenreminder, bluereminder, yellowreminder)
/ trials = [
	1-72 = noreplace(CCtrial,ICtrial,HPFtrial,NTFtrial,HPFAtrial,NTFAtrial);
]
</block>

Note: repeated color selections are possible in the Mixed Design


<block finish>
/ trials = [
	1 = finish;
]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt FoodStroop>
/ blocks = [
	1=instructions01; 
	2=practiceblock; 
	3=instructions02;
	4 = testStart;
	5-10=noreplace(CC,IC,HPF,NTF,HPFA,NTFA);
	11 = finish;
]
</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************