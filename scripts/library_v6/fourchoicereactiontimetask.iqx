**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/ pos1_x = 35.5%
/ pos2_x = 45.0%
/ pos3_x = 55.0%
/ pos4_x = 65.0%
/ stimHeight = 7%

/ responsekey1 = "D"
/ responsekey2 = "F"
/ responsekey3 = "J"
/ responsekey4 = "K"

/SOA = 500
/prematureErrorWindow = 100
/timeoutErrorWindow = 1000
/readyDuration = 7000
/feedbackDuration = 1000

/maxTrials = 100
</parameters>

**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************

<item instructions>
/1 = "There are 4 gray boxes arranged in a horizontal line on your screen. 
Any of the 4 gray boxes can turn red.
~n~n~n~n~n~n~n~n~n~n~n
As soon as a box turns red, press the corresponding response button (here highlighted in red) <%expressions.buttoninstruct1%>. Respond as FAST as you can while making as few errors as possible.

When you are ready for a short practice session press <Spacebar> to start."
/2 = "Let's continue the same task without feedback.
~n~nWhen you are ready to continue, press <SPACEBAR>."
</item>

<item feedback>
/1 = "Response was made too early"
/2 = "Response was made too late"
/3 = "Response was incorrect"
/4 = "correct!"
</item>

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<text exit>
/ items = ("<press spacebar to exit>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (80%, 5%)
/ vjustify = center
/ valign = center
/ halign = center
</text>


*******************************
General Helper Instructions
******************************

<text getReady>
/ items = ("Get Ready:
~n<%expressions.buttoninstruct2%>")
/ fontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ size = (80%, 40%)
</text>

****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************

<expressions>
/ buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {
"shown at the bottom";} 
else {
"on your keyboard";}
/ buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {"place your left middle and index finger on the two left buttons and your right index and middle finger on the two right buttons";} else {"place your left middle and index finger on the '<%parameters.responsekey1%>' and '<%parameters.responsekey2%>' 
place your right index and middle finger on the '<%parameters.responsekey3%>' and '<%parameters.responsekey4%>'";}

</expressions>

