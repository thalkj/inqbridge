**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial 4choiceRT>
/ ontrialbegin = [	
	values.prematureError = 0;
	values.timeoutError = 0;
	values.incorrectChoice = 0;
	values.ACC = 0;
	values.position = list.highlightedPosition.nextValue;
	if (values.position == 1) {
		text.redBox.hposition = text.box1.hposition;
		text.redBox.vposition = text.box1.vposition;
	} else if (values.position == 2) {
		text.redBox.hposition = text.box2.hposition;
		text.redBox.vposition = text.box2.vposition;
	} else if (values.position == 3) {
		text.redBox.hposition = text.box3.hposition;
		text.redBox.vposition = text.box3.vposition;
	} else if (values.position == 4) {
		text.redBox.hposition = text.box4.hposition;
		text.redBox.vposition = text.box4.vposition;
	} ;
	
	trial.4choiceRT.insertStimulusTime(text.redBox, parameters.SOA);
]
/ stimulustimes = [0 = box1, box2, box3, box4]
/ beginresponsetime = 0
/ responseinterrupt = immediate
/ validresponse = (parameters.responsekey1, parameters.responsekey2, parameters.responsekey3, parameters.responsekey4)
/ iscorrectresponse = [
	return (
	(values.position == 1 && trial.4choiceRT.responseText == parameters.responsekey1) ||
	(values.position == 2 && trial.4choiceRT.responseText == parameters.responsekey2) ||
	(values.position == 3 && trial.4choiceRT.responseText == parameters.responsekey3) ||	
	(values.position == 4 && trial.4choiceRT.responseText == parameters.responsekey4));	
]
/ ontrialend = [
	trial.4choiceRT.resetStimulusFrames();

	if (trial.4choiceRT.responseText == parameters.responsekey1){
		values.selectedPosition = 1;
	} else if (trial.4choiceRT.responseText == parameters.responsekey2){
		values.selectedPosition = 2;
	} else if (trial.4choiceRT.responseText == parameters.responsekey3){
		values.selectedPosition = 3;
	} else if (trial.4choiceRT.responseText == parameters.responsekey4){
		values.selectedPosition = 4;
	}
	
	values.rt = trial.4choiceRT.latency - parameters.SOA;
	if (values.rt < parameters.prematureErrorWindow){
		values.prematureError = 1;
		values.countPrematureErrors += 1;
	} else if (values.rt > parameters.timeoutErrorWindow){
		values.timeoutError = 1;
		values.countTimeoutErrors += 1;
	} else if (trial.4choiceRT.error){
		values.incorrectChoice = 1;
		values.countIncorrectChoices += 1;
	} else if (trial.4choiceRT.correct){
		values.ACC = 1;
		list.latencies.insertItem(values.rt, 1);
	}
		
	list.accuracy.insertItem(values.ACC, 1);
]
/ branch = [
	return trial.4choiceRT;
]
</trial>
		
	
************************************************
practice trials
************************************************

<trial 4choiceRT_practice>
/ ontrialbegin = [	
	values.prematureError = 0;
	values.timeoutError = 0;
	values.incorrectChoice = 0;
	values.ACC = 0;
	values.position = list.highlightedPosition_practice.nextValue;
	if (values.position == 1) {
		text.redBox.hposition = text.box1.hposition;
		text.redBox.vposition = text.box1.vposition;
	} else if (values.position == 2) {
		text.redBox.hposition = text.box2.hposition;
		text.redBox.vposition = text.box2.vposition;
	} else if (values.position == 3) {
		text.redBox.hposition = text.box3.hposition;
		text.redBox.vposition = text.box3.vposition;
	} else if (values.position == 4) {
		text.redBox.hposition = text.box4.hposition;
		text.redBox.vposition = text.box4.vposition;
	} ;
	
	trial.4choiceRT_practice.insertStimulusTime(text.redBox, parameters.SOA);
]
/ stimulustimes = [0 = box1, box2, box3, box4]
/ beginresponsetime = 0
/ responseinterrupt = immediate
/ validresponse = (parameters.responsekey1, parameters.responsekey2, parameters.responsekey3, parameters.responsekey4)
/ iscorrectresponse = [
	return (
	(values.position == 1 && trial.4choiceRT_practice.responseText == parameters.responsekey1) ||
	(values.position == 2 && trial.4choiceRT_practice.responseText == parameters.responsekey2) ||
	(values.position == 3 && trial.4choiceRT_practice.responseText == parameters.responsekey3) ||	
	(values.position == 4 && trial.4choiceRT_practice.responseText == parameters.responsekey4));
]
/ ontrialend = [
	trial.4choiceRT_practice.resetStimulusFrames();

	if (trial.4choiceRT_practice.responseText == parameters.responsekey1){
		values.selectedPosition = 1;
	} else if (trial.4choiceRT_practice.responseText == parameters.responsekey2){
		values.selectedPosition = 2;
	} else if (trial.4choiceRT_practice.responseText == parameters.responsekey3){
		values.selectedPosition = 3;
	} else if (trial.4choiceRT_practice.responseText == parameters.responsekey4){
		values.selectedPosition = 4;
	}
	
	values.rt = trial.4choiceRT_practice.latency - parameters.SOA;
	if (values.rt < parameters.prematureErrorWindow){
		values.prematureError = 1;
		values.selectFeedback = 1;
		text.feedback.textColor = yellow;
	} else if (values.rt > parameters.timeoutErrorWindow){
		values.timeoutError = 1;
		values.selectFeedback = 2;
		text.feedback.textColor = yellow;		
	} else if (trial.4choiceRT_practice.error){
		values.incorrectChoice = 1;
		values.selectFeedback = 3;
		text.feedback.textColor = red;		
	} else if (trial.4choiceRT_practice.correct){
		values.ACC = 1;
		values.selectFeedback = "";
		text.feedback.textColor = green;
	}
		
]
/branch = [
	if (values.selectFeedback !=""){
		return trial.feedback;
	}
]
</trial>

<trial feedback>
/ stimulusframes = [1 = feedback]
/ trialduration = parameters.feedbackDuration
/ recorddata = false
</trial>
	
	
**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************
<block intro>
/ trials = [1 = intro]
/ onblockend = [
	text.box3.textBgColor = gray;
]
</block>

<block practice>
/ trials = [
	1 = getReady; 
	2-11 = 4choiceRT_practice; 
	12 = testIntro; 
	13 = getReady;
]
</block>

<block 4choiceRTtask>
/ onblockbegin = [
	list.highlightedPosition.reset();
]
/ stop = [
	expressions.totalTrialcount >= parameters.maxTrials;
]
/ trials = [1 = 4choiceRT]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt fourchoice>
/ blocks = [
	1 = intro; 
	2 = practice;
	3 = 4choiceRTtask;
	4 = finish;
]
</expt>

<monkey>
/ latencydistribution = normal(700, 100)
</monkey>


