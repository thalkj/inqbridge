**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/completed:				0 = script was not completed; 1 = script was completed (all conditions run)
/position:				1, 2, 3, or 4 => screen position of the stim from left to right
/selectedPosition:		the selected position based on keyboard press
/rt:					stores the latency measured from onset of red box.
/countPrematureErrors:	counts incorrect premature responses 
						(responses made BEFORE appearance of red box and those made AFTER within the prematureErrorWindow)
/prematureError:		1 = premature error was made; 0 = otherwise
/countTimeoutErrors:	responses made after parameters.timeoutErrorWindow
/timeoutError:			1 = a timeout error was made; 0 = otherwise
/countIncorrectChoices:	counts the number of valid responses (neither premature nor late) that are incorrect response choices
/incorrectChoice:		1 = a valid (neither premature nor late) but incorrect response was made; 0 = otherwise
/correct:				1 = response was correct (no error was made); 0 = otherwise
/selectFeedback:		stores the itemnumber of the selected feedback


<values>
/completed = 0
/position=0
/selectedPosition = 0
/rt = 0
/countPrematureErrors = 0
/prematureError = 0
/countTimeoutErrors = 0
/timeoutError = 0
/countIncorrectChoices = 0
/incorrectChoice = 0
/ACC = 0
/selectFeedback = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/totalTrialcount:			number of test trials run
/propCorrect:			proportion of correct responses
						Notes: all trials with values.Anticipatory = 1 are automatically scored as 0 (incorrect)
						regardless of response key hit
												
/meanRT:				mean correct response latency (in ms; measured from onset of red box)
/SD:					standard deviations of correct latencies

/propPrematureError:	proportion of Premature Errors relative of total number of trials
/propTimeoutErrors:		proportion of Timeout Errors relative of total number of trials
/propIncorrectChoices:	proportion of IncorrectChoices (otherwise valid) relative of total number of trials

<expressions>
/totalTrialcount = list.accuracy.itemCount
/propCorrect = list.accuracy.mean
/meanRT = list.latencies.mean
/SD = list.latencies.standarddeviation

/propPrematureErrors = values.countPrematureErrors/expressions.totalTrialcount
/propTimeoutErrors = values.countTimeoutErrors/expressions.totalTrialcount
/propIncorrectChoices = values.countIncorrectChoices/expressions.totalTrialcount
</expressions>

