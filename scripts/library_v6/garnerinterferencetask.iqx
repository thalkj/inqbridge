"RED line = Press the '<%values.color1key%>' key
BLUE line = Press the '<%values.color2key%>' key")
/ fontstyle = ("Courier New", 5%, false, false, false, false, 5, 1)
/ vjustify = center
/ size = (80%, 15%)
/ position = (50%, 50%)
</text>

<text responsekeys_color_box>
