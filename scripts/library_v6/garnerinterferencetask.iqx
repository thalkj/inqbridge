*****************************
Resttrial
*****************************
<trial resttrial>
/ stimulusframes = [1 = restinstruction, restclock]
/ timeout = values.resttime
/ recorddata = true
</trial>

*****************************
Errorfeedback
*****************************
<trial errorfeedback>
/ stimulusframes = [1 = errorfeedback]

//touchscreens: present inactive response buttons to prevent response button 'flickering'
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ isvalidresponse = [
	return false;
]

/ timeout = 500
/ recorddata = true
/ ontrialend = [
	values.trialcount += 1;
]
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************
*************************
COLOR Blocks: 
*************************

***************
ortho
***************
<block color_ortho_integrated>
/ stop = [
	values.trialcount >= values.nrTrialsPerBlock
]
/ onblockbegin = [
	values.trialcount = 0;
	if (values.group == 1 || values.group == 2) {
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
	} else if (values.group == 3 || values.group == 4) {
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
	}
	values.blockcount += 1;
	values.dimension = 1;
	values.dim_config = 1;
	values.variationtype = 1;
	shape.outerbox.color = parameters.alternativecolor1;
]
/ trials = [1 = intro_color_line; 2-49 = noreplace(color1_tilt1, color1_tilt2, color2_tilt1, color2_tilt2)]
/ ontrialend = [
	if (values.introtrial == 0){
		list.ACC.appendItem(values.correct);
		list.ACC_color_ortho_integrated.appendItem(values.correct);
		if (values.correct == 1) {
			list.RT.appendItem(values.rt);
			list.RT_color_ortho_integrated.appendItem(values.rt);
		}	
	}		
]
/ branch = [block.restblock]
</block>

<block color_ortho_separated>
/ stop = [
	values.trialcount >= values.nrTrialsPerBlock
]
/ onblockbegin = [
	values.trialcount = 0;
	if (values.group == 1 || values.group == 2) {
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
	} else if (values.group == 3 || values.group == 4) {
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
	}
	values.blockcount += 1;
	values.dimension = 1;
	values.dim_config = 2;
	values.variationtype = 1;
	text.line.textColor = parameters.alternativecolor1;
]
/ trials = [1 = intro_color_box; 2-49 = noreplace(color1_tilt1, color1_tilt2, color2_tilt1, color2_tilt2)]

/ ontrialend = [
	if (values.introtrial == 0){
		list.ACC.appendItem(values.correct);
		list.ACC_color_ortho_separated.appendItem(values.correct);
		if (values.correct == 1) {
			list.RT.appendItem(values.rt);
			list.RT_color_ortho_separated.appendItem(values.rt);
		}	
	}		
]

/ branch = [return block.restblock]
</block>

