Note: trial.color1_tilt1
* presents the combination of color 1 (here: red) and tilt 1 (here: right)
* depending on values.dim_config it's either the box that is red (separated) or the line itself (integrated)
* updates summary variables depending on response performance
<trial color1_tilt1>
/ ontrialbegin = [
	values.trialcount += 1;
	values.introtrial = 0;
	values.ITI = list.iti.nextValue;
	values.selectline = 1;
	values.responsekeycongruence = 1;
	if (values.dimension == 1){
		values.target = "color1";
	} else {
		values.target = "tilt1";
	}
	if (values.dim_config == 1){
		text.line.textColor = parameters.color1;
	} else {
		shape.outerbox.color = parameters.color1;
	}
]
/ stimulusframes = [1 = outerbox, innerbox, line]
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ monkeyresponse = (30, 38)
/ correctresponse = (values.key1)
/ ontrialend = [
	if (trial.color1_tilt1.correct){
		values.correct = 1;
	} else {
		values.correct = 0;
		values.iti = 0;		
	}
	values.rt = trial.color1_tilt1.latency;
	
	if (values.practice == 1 && values.correct == 0){
		values.trialcount -= 1;
	}
]
/ branch = [
	if (values.practice == 1 && values.correct == 0) {
		return trial.errorfeedback;
	}
]
/ timeout = parameters.responsetimeout
/ posttrialpause = values.ITI
</trial>



Note: trial.color1_tilt2
* presents the combination of color 1 (here: red) and tilt 2 (here: left)
* depending on values.dim_config it's either the box that is red (separated) or the line itself (integrated)
* updates summary variables depending on response performance
<trial color1_tilt2>
/ ontrialbegin = [
	values.trialcount += 1;
	values.introtrial = 0;
	values.ITI = list.iti.nextValue;
	values.selectline = 2;
	if (values.dimension == 1){
		values.target = "color1";
	} else {
		values.target = "tilt2";
	}
	values.responsekeycongruence = 2;
	if (values.dim_config == 1){
		text.line.textColor = parameters.color1;
	} else {
		shape.outerbox.color = parameters.color1;
	}				
]
/ stimulusframes = [1 = outerbox, innerbox, line]
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ iscorrectresponse = [
	return (
	(values.dimension == 1 && trial.color1_tilt2.responseText == values.key1) || 
	(values.dimension == 2 && trial.color1_tilt2.responseText == values.key2));
]
/ ontrialend = [
	if (trial.color1_tilt2.correct){
		values.correct = 1
	} else {
		values.correct = 0;
		values.iti = 0;		
	}
	
	values.rt = trial.color1_tilt2.latency;
	if (values.practice == 1 && values.correct == 0){
		values.trialcount -= 1;
	}
]
/ branch = [
	if (values.practice == 1 && values.correct == 0) {
		return trial.errorfeedback;
	}
]
/ timeout = parameters.responsetimeout
/ posttrialpause = values.ITI
</trial>



