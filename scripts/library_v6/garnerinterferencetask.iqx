****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {
"Put your index fingers over the response buttons now.

Press one of the response buttons to start.";} else {
"Put your index fingers on the '<%parameters.responsekeyleft%>' and '<%parameters.responsekeyright%>' keys now.

Press one of the keys to start";}
</expressions>


