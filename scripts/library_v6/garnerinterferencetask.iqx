/ monkeyresponse = (30, 38)
/ iscorrectresponse = [
	return (
	(values.dimension == 1 && trial.color2_tilt1.responseText == values.key2) || 
	(values.dimension == 2 && trial.color2_tilt1.responseText == values.key1));
]
/ ontrialend = [
	if (trial.color2_tilt1.correct){
		values.correct = 1
	} else {
		values.correct = 0;
		values.iti = 0;		
	}
	
	values.rt = trial.color2_tilt1.latency;
	if (values.practice == 1 && values.correct == 0){
		values.trialcount -= 1;
	}
]
/ branch = [
	if (values.practice == 1 && values.correct == 0) {
