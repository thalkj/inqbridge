**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/completed:									0 = script was not completed; 1 = script was completed (all conditions run)
/group:										group id (1-4)
/selectline:								determines which of the lines to present
/key1 -									
	/key2	:							sets the response keys (and labels)
/practice:									1 = practice blocks; 0 = experimental blocks
/dimension:									target dimension: 1 = color; 2 = tilt
/variationtype:								1 = orthogonal; 2 = correlated; 3 = control
/dim_config: 								1 = integrated; 2 = separated
/responsekeycongruence:						0 = congruence doesn't apply; 1 = color and tilt response keys congruent; 2 = color and tilt response keys incongruent
/target:									"color1" vs. "color2" vs. "tilt1" vs. "tilt2"
/ITI:										stores the current ITI
/helper:									helper variable to select the appropriate correlated condition
/rt:										current latency
/correct:									1= correct; 0 = incorrect response
/resttime:									current resttime

Summary Values:
/count_color_ortho_integrated (etc):		counts all trials for the varios conditions
/sumcorrect_color_ortho_integrated (etc):	counts how many correct responses are given to the various conditions
											(here: color, ortho, integrated)
/sumRTcorrect_color_ortho_integrated (etc):	sums up the reaction times of the correct responses in a given condition

<values>
/ completed = 0
/ group = 0
/ selectline = 1
/ key1 = "" 
/ key2 = ""
/ practice = 0
/ dimension = 0
/ variationtype = 0
/ dim_config = 0
/ responsekeycongruence = 0
/ target = 0
/ ITI = 0
/ correlated_integrated = 0
/ correlated_separated = 0
/ helper = 0

/ rt = 0
/ correct = 0
/ resttime = 0
/ blockcount = 0

/color1key = ""
/color2key = ""
/tilt1key = ""
/tilt2key = ""

/introtrial = 0
/nrTrialsPerBlock = 24
/trialcount = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/meanrt_color_ortho_integrated (etc):		calculates the mean reaction times to correct responses in a given condition
											(here: color, ortho, integrated)
/propcorrect_color_ortho_integrated (etc):	calculates the proportion correct in a given condition
											(here: color, ortho, integrated)
<expressions>
/overall_PropCorrect = list.ACC.mean
/overall_RT = list.RT.mean

/propCorrect_separated = (
(expressions.propCorrect_color_ortho_separated * list.ACC_color_ortho_separated.itemCount) +
(expressions.propCorrect_color_correlated_separated * list.ACC_color_correlated_separated.itemCount) +
(expressions.propCorrect_color_control_separated * list.ACC_color_control_separated.itemCount) + 
(expressions.propCorrect_tilt_ortho_separated * list.ACC_tilt_ortho_separated.itemCount) +
(expressions.propCorrect_tilt_correlated_separated * list.ACC_tilt_correlated_separated.itemCount) +
(expressions.propCorrect_tilt_control_separated * list.ACC_tilt_control_separated.itemCount))/ 
(list.ACC_color_ortho_separated.itemCount + list.ACC_color_correlated_separated.itemCount + list.ACC_color_control_separated.itemCount +
list.ACC_tilt_ortho_separated.itemCount + list.ACC_tilt_correlated_separated.itemCount + list.ACC_tilt_control_separated.itemCount)

/meanrt_separated = (
(expressions.meanrt_color_ortho_separated * list.RT_color_ortho_separated.itemCount) +
(expressions.meanrt_color_correlated_separated * list.RT_color_correlated_separated.itemCount) +
(expressions.meanrt_color_control_separated * list.RT_color_control_separated.itemCount) + 
(expressions.meanrt_tilt_ortho_separated * list.RT_tilt_ortho_separated.itemCount) +
(expressions.meanrt_tilt_correlated_separated * list.RT_tilt_correlated_separated.itemCount) +
(expressions.meanrt_tilt_control_separated * list.RT_tilt_control_separated.itemCount))/ 
(list.RT_color_ortho_separated.itemCount + list.RT_color_correlated_separated.itemCount + list.RT_color_control_separated.itemCount +
list.RT_tilt_ortho_separated.itemCount + list.RT_tilt_correlated_separated.itemCount + list.RT_tilt_control_separated.itemCount)

/propCorrect_integrated = (
(expressions.propCorrect_color_ortho_integrated * list.ACC_color_ortho_integrated.itemCount) +
(expressions.propCorrect_color_correlated_integrated * list.ACC_color_correlated_integrated.itemCount) +
(expressions.propCorrect_color_control_integrated * list.ACC_color_control_integrated.itemCount) + 
(expressions.propCorrect_tilt_ortho_integrated * list.ACC_tilt_ortho_integrated.itemCount) +
(expressions.propCorrect_tilt_correlated_integrated * list.ACC_tilt_correlated_integrated.itemCount) +
(expressions.propCorrect_tilt_control_integrated * list.ACC_tilt_control_integrated.itemCount))/ 
(list.ACC_color_ortho_integrated.itemCount + list.ACC_color_correlated_integrated.itemCount + list.ACC_color_control_integrated.itemCount +
list.ACC_tilt_ortho_integrated.itemCount + list.ACC_tilt_correlated_integrated.itemCount + list.ACC_tilt_control_integrated.itemCount)

/meanrt_integrated = (
(expressions.meanrt_color_ortho_integrated * list.RT_color_ortho_integrated.itemCount) +
(expressions.meanrt_color_correlated_integrated * list.RT_color_correlated_integrated.itemCount) +
(expressions.meanrt_color_control_integrated * list.RT_color_control_integrated.itemCount) + 
