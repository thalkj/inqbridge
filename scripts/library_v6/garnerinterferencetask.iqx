**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text intro1>
/ items = instructions
/ select = 1
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro1>
/ stimulusframes = [1 = intro1, outerbox, innerbox, line, continue]
/ validresponse = (" ")
/ branch = [
	return trial.intro2;
]
</trial>

<text intro2>
/ items = instructions
/ select = 2
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro2>
/ stimulusframes = [1 = intro2, outerbox, innerbox, line, continue, goback]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro2.responseText == "B" && !monkey.monkeyMode){
		return trial.intro1;
	} else {
		return trial.intro3;
	}
]
</trial>

<text intro3>
/ items = instructions
/ select = 3
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro3>
/ stimulusframes = [1 = intro3, outerbox, innerbox, line, continue, goback]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro3.responseText == "B" && !monkey.monkeyMode){
		return trial.intro2;
	} else {
		return trial.intro4;
	}
]
</trial>

<text intro4>
/ items = instructions
/ select = 4
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro4>
/ stimulusframes = [1 = intro4, outerbox, innerbox, line, continue, goback]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro4.responseText == "B" && !monkey.monkeyMode){
		return trial.intro3;
	} else {
		return trial.intro5;
	}
]
</trial>

<text intro5>
/ items = instructions
/ select = 5
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro5>
/ stimulusframes = [1 = intro5, start, goback]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro5.responseText == "B" && !monkey.monkeyMode){
		return trial.intro4;
	}
]
</trial>

<trial intro_tilt>
/ ontrialbegin = [
	values.introtrial = 1;
]
/ stimulusframes = [1 = attention_tilt, responsekeys_tilt, getReady]
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ recorddata = false
</trial>

<trial intro_color_line>
/ ontrialbegin = [
	values.introtrial = 1;
]
/ stimulusframes = [1 = attention_color_line, responsekeys_color_line, getReady]
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ recorddata = false
</trial>

<trial intro_color_box>
/ ontrialbegin = [
	values.introtrial = 1;
]
/ stimulusframes = [1 = attention_color_box, responsekeys_color_box, getReady]
/ validresponse = (parameters.responsekeyleft, parameters.responsekeyright)
/ recorddata = false
</trial>

<text practiceend>
/ items = instructions
/ select = 6
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial practiceend>
/ stimulusframes = [1 = practiceend, start]
/ validresponse = (" ")
/ recorddata = false
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>
**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text line>
/ items = lines
/ select = values.selectline
/ position = (50%, 50%)
/ fontstyle = ("Arial", parameters.line_fontheight, false, false, false, false, 5, 1)
/ txcolor = black
/ txbgcolor = transparent
</text>

<shape innerbox>
/ shape = rectangle
/ position = (50%, 50%)
/ height = parameters.line_fontheight + 3%
/ width = (parameters.line_fontheight + 3%) * 3/4
/ color = white
</shape>

<shape outerbox>
/ shape = rectangle
/ position = (50%, 50%)
/ height = shape.innerbox.height + 3%
/ width = shape.innerbox.width + 3%*3/4
/ color = red
</shape>

****************************
rest block stimuli
****************************
<text restinstruction>
/ items = restinstructions
/ select = 1
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = black
/ position = (50%, 40%)
</text>

<clock restclock>
/ mode = timer
/ resetrate = block
/ erase = false
/ txcolor = yellow
/ txbgcolor = black
/ timeout = values.resttime
/ position = (50%, 50%)
/ format = "mm:ss"
</clock>

****************************
rest block stimuli
****************************

<text errorfeedback>
/ items = feedback
/ select = 1
/ position = (50%, 50%)
/ txcolor = red
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
</text>

