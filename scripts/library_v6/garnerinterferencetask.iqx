			list.RT_tilt_correlated_separated.appendItem(values.rt);
			list.RT_tilt_correlatedC_separated.appendItem(values.rt);		
		}
	}		
]
/ branch = [return block.restblock]
</block>

<block tilt_correlated_separated_incongruent>
/ stop = [
	values.trialcount >= values.nrTrialsPerBlock
]
/ onblockbegin = [
	values.trialcount = 0;
	if (values.group == 1 || values.group == 3) {
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
	} else if (values.group == 2 || values.group == 4) {
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
	}
	values.blockcount += 1;
	values.dimension = 2;
	values.dim_config = 2;
	values.variationtype = 2;
	text.line.textColor = parameters.alternativecolor1;
]
/ trials = [1 = intro_tilt; 2-49 = noreplace(color1_tilt2, color2_tilt1)]
/ ontrialend = [	
	if (values.introtrial == 0){
		list.ACC.appendItem(values.correct);
		list.ACC_tilt_correlated_separated.appendItem(values.correct);
		list.ACC_tilt_correlatedIC_separated.appendItem(values.correct);
		if (values.correct == 1) {
			list.RT.appendItem(values.rt);
			list.RT_tilt_correlated_separated.appendItem(values.rt);
			list.RT_tilt_correlatedIC_separated.appendItem(values.rt);		
		}
	}		
]
/ branch = [return block.restblock]
</block>

***************
control
***************

<block tilt_control_integrated>
/ stop = [
	values.trialcount >= values.nrTrialsPerBlock
]
/ onblockbegin = [
	values.trialcount = 0;
	if (values.group == 1 || values.group == 3) {
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
	} else if (values.group == 2 || values.group == 4) {
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
	}
	values.blockcount += 1;
	values.dimension = 2;
	values.dim_config = 1;
	values.variationtype = 3;
	shape.outerbox.color = parameters.alternativecolor2;
]
/ trials = [1 = intro_tilt; 2-49 = noreplace(tilt1, tilt2)]
/ ontrialend = [
	if (values.introtrial == 0){
		list.ACC.appendItem(values.correct);
		list.ACC_tilt_control_integrated.appendItem(values.correct);
	
		if (values.correct == 1) {
			list.RT.appendItem(values.rt);
			list.RT_tilt_control_integrated.appendItem(values.rt);
		}
	}	
]
/ branch = [return block.restblock;]
</block>

<block tilt_control_separated>
/ stop = [
	values.trialcount >= values.nrTrialsPerBlock
]
/ onblockbegin = [
	values.trialcount = 0;
	if (values.group == 1 || values.group == 3) {
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
		values.key1 = parameters.responsekeyleft;
		values.key2 = parameters.responsekeyright;
	} else if (values.group == 2 || values.group == 4) {
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
		values.key1 = parameters.responsekeyright;
		values.key2 = parameters.responsekeyleft;
	}
	values.blockcount += 1;
	values.dimension = 2;
	values.dim_config = 2;
	values.variationtype = 3;
	text.line.textColor = parameters.alternativecolor2;
]
/ trials = [1 = intro_tilt; 2-49 = noreplace(tilt1, tilt2)]
/ ontrialend = [
	if (values.introtrial == 0){
		list.ACC.appendItem(values.correct);
		list.ACC_tilt_control_separated.appendItem(values.correct);
	
		if (values.correct == 1) {
			list.RT.appendItem(values.rt);
			list.RT_tilt_control_separated.appendItem(values.rt);
		}
	}
]
/ branch = [return block.restblock;]
</block>

*************************
Practice Blocks
*************************
Note: there is no dedicated practice block. 
There are 4 blocks run for practice followed by block.practiceend that resets
all variable for the experimental blocks and presents the end of practice instructions.

<block practiceend>
/ trials = [1 = practiceend]
/ onblockend = [
	values.blockcount = 0;
	values.nrTrialsPerBlock = parameters.nrTrialsPerTestblock;

	list.RT_color_control_integrated.reset();
	list.RT_color_control_separated.reset();
	list.RT_color_correlated_integrated.reset();
	list.RT_color_correlated_separated.reset();
	list.RT_color_ortho_integrated.reset();
	list.RT_color_ortho_separated.reset();
	list.RT_tilt_control_integrated.reset();
	list.RT_tilt_control_separated.reset();
	list.RT_tilt_correlated_integrated.reset();
	list.RT_tilt_correlated_separated.reset();
	list.RT_tilt_ortho_integrated.reset();
	list.RT_tilt_ortho_separated.reset();
	list.ACC_color_ortho_integrated.reset();
	list.ACC_color_ortho_separated.reset();
	list.ACC_color_control_integrated.reset();
	list.ACC_color_control_separated.reset();
	list.ACC_color_correlated_integrated.reset();
	list.ACC_color_correlated_separated.reset();
	list.ACC_tilt_ortho_integrated.reset();
	list.ACC_tilt_ortho_separated.reset();
	list.ACC_tilt_control_integrated.reset();
	list.ACC_tilt_control_separated.reset();
	list.ACC_tilt_correlated_integrated.reset();
	list.ACC_tilt_correlated_separated.reset();	
	
	list.ACC.reset();
	list.RT.reset();
	list.ACC_color_correlatedC_integrated.reset();
	list.ACC_color_correlatedIC_integrated.reset();	
	list.ACC_color_correlatedC_separated.reset();
	list.ACC_color_correlatedIC_separated.reset();	
	list.ACC_tilt_correlatedC_integrated.reset();
	list.ACC_tilt_correlatedIC_integrated.reset();	
	list.ACC_tilt_correlatedC_separated.reset();
	list.ACC_tilt_correlatedIC_separated.reset();		

	values.practice = 0
]

</block>


*************************
Rest Block
*************************

<block restblock>
/ skip = [values.blockcount == 16]
/ onblockbegin = [
	if (mod(values.blockcount, parameters.prolongedrest) == 0){
		values.resttime = parameters.prolongedresttime;
	} else {
		values.resttime = parameters.regularresttime;
	}
]
/ trials = [1 = resttrial]
</block>


*************************
Intro Block
*************************

<block intro>
/ trials = [1 = intro1]
/ recorddata = false
/ onblockend = [
	values.nrTrialsPerBlock = parameters.nrTrialsPerPracticeblock;
]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

Use of response keys is counterbalanced across participants: 4 conditions;
the assignment to a particular condition is done by groupnumber
(responsekeys are conditional on the assigned script.groupId and are assigned at the beginning of each block)

Note:
color1 (here: red) and tilt1 (here: right) share response keys
color2 (here: blue) and tilt2 (here: left) share response keys
=> trials with those combinations are congruent in their response keys

!If tilt is used as one dimension: the location of the default response keys on the keyboard
might be incompatible with the tilt direction of the line (e.g. left tilt -> L responsekey; right tilt -> A responsekey)
in this condition

<expt a>
/ onexptbegin = [
	values.color1key = parameters.responsekeyleft;
	values.color2key = parameters.responsekeyright;
	values.tilt1key = parameters.responsekeyleft;
	values.tilt2key = parameters.responsekeyright;
	
	//for touch devices the navigation buttons don't have to be provided
	if (computer.touch && !computer.hasKeyboard){
		text.continue.skip = true;
		text.goback.skip = true;
	}
]
/ groups = (1 of 4)
/ onexptbegin = [
	values.practice = 1;
	values.group = 1;
]
/ blocks = [
	1 = intro;
	2-5 = noreplace (color_ortho_integrated, tilt_ortho_separated, color_control_separated, tilt_control_integrated);
	6 = practiceend;
	7-22 = noreplace(color_ortho_integrated, color_ortho_separated, color_correlated_integrated_congruent, color_correlated_integrated_incongruent, 
	color_correlated_separated_congruent, color_correlated_separated_incongruent,color_control_integrated, color_control_separated, 
	tilt_ortho_integrated, tilt_ortho_separated,
	tilt_correlated_integrated_congruent, tilt_correlated_integrated_incongruent, tilt_correlated_separated_congruent, tilt_correlated_separated_incongruent, 
	tilt_control_integrated, tilt_control_separated);
	23 = finish;
]
</expt>

**************************************************
Change the number/types of blocks run:

Example: run only control vs. orthogonal blocks

/ blocks = [
	1 = intro;
	2-5 = noreplace (color_ortho_integrated, tilt_ortho_separated, color_control_separated, tilt_control_integrated);
	6 = practiceend;
	7-14 = noreplace(color_ortho_integrated, color_ortho_separated, color_control_integrated, color_control_separated, 
	tilt_ortho_integrated, tilt_ortho_separated, tilt_control_integrated, tilt_control_separated);
	15 = finish;
]
**************************************************

Note:
color1 (here: red) and tilt2 (here: left) share response keys
color2 (here: blue) and tilt1 (here: right) share response keys
=> trials with those combinations are congruent in their response keys

!If tilt is used as one dimension: the location of the default response keys on the keyboard
might be compatible with the tilt direction of the line (e.g. left tilt -> A responsekey; right tilt -> L responsekey)
in this condition

<expt b>
/ onexptbegin = [
	values.color1key = parameters.responsekeyleft;
	values.color2key = parameters.responsekeyright;
	values.tilt1key = parameters.responsekeyright;
	values.tilt2key = parameters.responsekeyleft;

	//for touch devices the navigation buttons don't have to be provided
	if (computer.touch && !computer.hasKeyboard){
		text.continue.skip = true;
		text.goback.skip = true;
	}
]
/ groups = (2 of 4)
/ onexptbegin = [
	values.practice = 1;
	values.group = 2;
]
/ blocks = [
	1 = intro;
	2-5 = noreplace (color_ortho_integrated, tilt_ortho_separated, color_control_separated, tilt_control_integrated);
	6 = practiceend;
	7-22 = noreplace(color_ortho_integrated, color_ortho_separated, color_correlated_integrated_congruent, color_correlated_integrated_incongruent, 
	color_correlated_separated_congruent, color_correlated_separated_incongruent,color_control_integrated, color_control_separated, 
	tilt_ortho_integrated, tilt_ortho_separated,
	tilt_correlated_integrated_congruent, tilt_correlated_integrated_incongruent, tilt_correlated_separated_congruent, tilt_correlated_separated_incongruent, 
	tilt_control_integrated, tilt_control_separated);
	23 = finish;
]
</expt>

Note:
color1 (here: red) and tilt2 (here: left) share response keys
color2 (here: blue) and tilt1 (here: right) share response keys
=> trials with those combinations are congruent in their response keys

!If tilt is used as one dimension: the location of the default response keys on the keyboard
might be incompatible with the tilt direction of the line (e.g. left tilt -> L responsekey; right tilt -> A responsekey)
in this condition
<expt c>
/ onexptbegin = [
	values.color1key = parameters.responsekeyright;
	values.color2key = parameters.responsekeyleft;
	values.tilt1key = parameters.responsekeyleft;
	values.tilt2key = parameters.responsekeyright;

	
	//for touch devices the navigation buttons don't have to be provided
	if (computer.touch && !computer.hasKeyboard){
		text.continue.skip = true;
		text.goback.skip = true;
	}
]
/ groups = (3 of 4)
/ onexptbegin = [
	values.practice = 1;
	values.group = 3;
]
/ blocks = [
	1 = intro;
	2-5 = noreplace (color_ortho_integrated, tilt_ortho_separated, color_control_separated, tilt_control_integrated);
	6 = practiceend;
	7-22 = noreplace(color_ortho_integrated, color_ortho_separated, color_correlated_integrated_congruent, color_correlated_integrated_incongruent, 
	color_correlated_separated_congruent, color_correlated_separated_incongruent,color_control_integrated, color_control_separated, 
	tilt_ortho_integrated, tilt_ortho_separated,
	tilt_correlated_integrated_congruent, tilt_correlated_integrated_incongruent, tilt_correlated_separated_congruent, tilt_correlated_separated_incongruent, 
	tilt_control_integrated, tilt_control_separated);
	23 = finish;
]

</expt>


Note:
color1 (here: red) and tilt1 (here: right) share response keys
color2 (here: blue) and tilt2 (here: left) share response keys
=> trials with those combinations are congruent in their response keys

!If tilt is used as one dimension: the location of the default response keys on the keyboard
might be  compatible with the tilt direction of the line (e.g. left tilt -> A responsekey; right tilt -> L responsekey)
in this condition
<expt d>
/ onexptbegin = [
	values.color1key = parameters.responsekeyright;
	values.color2key = parameters.responsekeyleft;
	values.tilt1key = parameters.responsekeyright;
	values.tilt2key = parameters.responsekeyleft;

	
	//for touch devices the navigation buttons don't have to be provided
	if (computer.touch && !computer.hasKeyboard){
		text.continue.skip = true;
		text.goback.skip = true;
	}
]
/ groups = (4 of 4)
/ onexptbegin = [
	values.practice = 1;
	values.group = 4;
]
/ blocks = [
	1 = intro;
	2-5 = noreplace (color_ortho_integrated, tilt_ortho_separated, color_control_separated, tilt_control_integrated);
	6 = practiceend;
	7-22 = noreplace(
		color_ortho_integrated, color_ortho_separated, color_correlated_integrated_congruent, color_correlated_integrated_incongruent, 
		color_correlated_separated_congruent, color_correlated_separated_incongruent,color_control_integrated, color_control_separated, 
		tilt_ortho_integrated, tilt_ortho_separated,
		tilt_correlated_integrated_congruent, tilt_correlated_integrated_incongruent, tilt_correlated_separated_congruent, tilt_correlated_separated_incongruent, 
		tilt_control_integrated, tilt_control_separated);
	23 = finish;
]
</expt>

<monkey>
/ latencydistribution = normal(500, 100)
</monkey>


