/ txcolor = white 
/ select = noreplace
</text>

<text TargetB>
/ items = TargetB 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
/ select = noreplace
</text>

<text attributeA>
/ items = attributeA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
