Note: data file explanations under User Manual Information at the top

******************************
raw data
******************************

<data>
/ columns = (build, computer.platform, date, time, subject, group, script.sessionId, blockcode, blocknum, 
trialcode, trialnum, 
values.phase,
item.targetAlabel.items.1, item.targetBlabel.items.1, item.attributeAlabel.items.1, item.attributeBlabel.items.1, 
values.responsetimeout_target, values.responsetimeout_noise, values.signal, 
values.targettype, values.pairing, values.trialtype,
stimulusitem, response, correct, latency)
</data>

******************************
summary data
******************************

<summarydata>
/ columns = (computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, script.elapsedTime, 
script.completed,
parameters.responsetimeout1_signal, parameters.responsetimeout1_noise, parameters.responsetimeout2_signal, parameters.responsetimeout2_noise, parameters.responsetimeout3_signal, parameters.responsetimeout3_noise,
item.targetAlabel.items.1, item.targetBlabel.items.1, item.attributeAlabel.items.1, item.attributeBlabel.items.1, 
expressions.propcorrect_AA, expressions.propcorrect_AB, expressions.propcorrect_BA, expressions.propcorrect_BB,
expressions.rHit_AA, expressions.rMiss_AA, expressions.rFa_AA, expressions.rCr_AA, 
expressions.zHit_AA, expressions.zFa_AA, expressions.dPrime_AA, expressions.c_AA,
expressions.rHit_AB, expressions.rMiss_AB, expressions.rFa_AB, expressions.rCr_AB, 
expressions.zHit_AB, expressions.zFa_AB, expressions.dPrime_AB, expressions.c_AB,
expressions.rHit_BA, expressions.rMiss_BA, expressions.rFa_BA, expressions.rCr_BA, 
expressions.zHit_BA, expressions.zFa_BA, expressions.dPrime_BA, expressions.c_BA,
expressions.rHit_BB, expressions.rMiss_BB, expressions.rFa_BB, expressions.rCr_BB, 
expressions.zHit_BB, expressions.zFa_BB, expressions.dPrime_BB, expressions.c_BB,
expressions.GNATpart1, expressions.GNATpart2, expressions.GNATALL)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

/completed:						0 = script was not completed; 1 = script was completed (all condisions run)
/phase:							"training" vs. "test"
/responsetimeout_target:		time in ms that is allowed for response in the current target trial
/responsetimeout_noise:			time in ms that is allowed for response in the current noise trial
/signal:						1 = signal trial (spacebar response is correct); 0 = noisetrial (no response is correct)

/targettype:					"A" vs. "B" (here: A-women; B-men)
/pairing:						"AA" -> targetA-attributeA 
								"AB" -> targetA-attributeB 
								"BA" -> targetB-attributeA 
								"BB" -> targetB-attributeB 
/trialtype:						"practice" vs. "test"

<values>
/ completed = 0
/ phase = "training"
/ responsetimeout_target = 0
/ responsetimeout_noise = 0
/ signal = 0
/ targettype = ""
/ pairing = ""
/ trialtype = "training"
/ selectReminders = 1
</values>

******************************
Summary values
******************************

/count_signalAA:			counts signal trials for pairing targetA-attributeA (here: women-occupations) - across all responsetimeouts
/count_NoiseAA:				counts noise trials for pairing targetA-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalAB:			counts signal trials for pairing targetA-attributeB (here: women-qualities) - across all responsetimeouts
/count_NoiseAB:				counts noise trials for pairing targetA-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBA:			counts signal trials for pairing targetB-attributeA (here: men-occupations) - across all responsetimeouts
/count_NoiseBA:				counts noise trials for pairing targetB-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBB:			counts signal trials for pairing targetB-attributeB (here: not men-qualities) - across all responsetimeouts
/count_NoiseBB:				counts noise trials for pairing targetB-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AA:					counts hits for pairing targetA-attributeA (here: women-occupations) - across all responsetimeouts
/FA_AA:						counts false alarms for pairing targetA-attributeA (here: women-occupations) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AB:					counts hits for pairing targetA-attributeB (here: women-qualities) - across all responsetimeouts
/FA_AB:						counts false alarms for pairing targetA-attributeA (here: women-qualities) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_BA:					counts hits for pairing targetB-attributeA (here: men-occupations) - across all responsetimeouts
/FA_BA:						counts false alarms for pairing targetA-attributeA (here: men-occupations) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_BB:					counts hits for pairing targetB-attributeB (here: men-qualities) - across all responsetimeouts
/FA_BB:						counts false alarms for pairing targetA-attributeB (here: men-qualities) - across all responsetimeouts
(and separately for responsetimeouts)


<values>
/ count_signalAA = 0
/ count_NoiseAA = 0
