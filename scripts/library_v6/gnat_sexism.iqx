<expt gnat_sexism>
/ blocks = [
	1 = instructions;
	2 = trainingStart;
	3-6   = random (attributeA_responsetimeout1, attributeB_responsetimeout1, TargetA_responsetimeout1, TargetB_responsetimeout1);
    7 = testStart;			
	8-11   = random(TargetBattributeA_responsetimeout2, TargetBattributeB_responsetimeout2, TargetAattributeA_responsetimeout2, TargetAattributeB_responsetimeout2);	
    12 = speedup;
    13-16  = random(TargetBattributeA_responsetimeout3, TargetBattributeB_responsetimeout3, TargetAattributeA_responsetimeout3, TargetAattributeB_responsetimeout3);	
]

</expt>

