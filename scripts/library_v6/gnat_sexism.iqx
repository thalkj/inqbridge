	text.TargetA.resetSelection();
	text.TargetB.resetSelection();
	text.NoiseA.resetSelection();
	text.NoiseB.resetSelection();
	text.attributeA.resetSelection();
	text.attributeB.resetSelection();
]
/ posttrialpause = 1000
</trial> 

