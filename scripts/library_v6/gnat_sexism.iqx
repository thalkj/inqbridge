<text TargetAremind>

/ items = ("<%item.targetAlabel.item(1)%>") 
/ color = white 
/ position = (30,15) 
</text>

<text TargetBremind>

/ items = ("<%item.targetBlabel.item(1)%>") 
/ color = white 
/ position = (30,15) 
</text>

<text attributeAremind>

/ items = ("<%item.attributealabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70,15) 
</text>

<text attributeBremind>

/ items = ("<%item.attributeBlabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70, 15) 
</text>

<text error>

/ items = ("X") 
/ position = (50,65) 
/ color = red 
</text>

<text correctresp>

/ items = ("O") 
/ position = (50,65) 
/ color = green 
</text>

<text remind>
/ items = reminders
/ select = values.selectReminders
/ position = (50%, 65%) 
/ size = (80%, 50%)
/ txcolor = white 
/ fontstyle = ("Arial", 2.67%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
</text>

