**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/rHit_AA:					hit rate for pairing targetA-attributeA (here: women-occupations) across all responsetimeouts
/rHit_AB:					hit rate for pairing targetA-attributeB (here: women-qualities) across all responsetimeouts
/rHit_BA:					hit rate for pairing targetB-attributeA (here: men-occupations) across all responsetimeouts
/rHit_BB:					hit rate for pairing targetB-attributeB (here: men-qualities) across all responsetimeouts

/rFA_AA:					false alarm (FA) rate for pairing targetA-attributeA (here: women-occupations) across all responsetimeouts
/rFA_AB:					false alarm (FA) rate for pairing targetA-attributeB (here: women-qualities) across all responsetimeouts
/rFA_BA:					false alarm (FA) rate for pairing targetB-attributeA (here: men-occupations) across all responsetimeouts
/rFA_BB:					false alarm (FA) rate for pairing targetB-attributeB (here: men-qualities across all responsetimeouts


Note: the following expressions calculate z-scores based on hit and FA rate.(see Gregg & Sedikides, 2010, p.148)
If the hit rate / FA rate is 0 => 0.005 is used instead
IF the hit rate / FA rate is 1.0 => 0.995 is used instead
()

/zhit_AA:					z-score of hit rate for pairings targetA-attributeA (here: women-occupations)
/zhit_AB:					z-score of hit rate for pairings targetA-attributeB (here: women-qualities)
/zhit_BA:					z-score of hit rate for pairings targetB-attributeA (here: men-occupations)
/zhit_BB:					z-score of hit rate for pairings targetB-attributeB (here: men-qualities)

/zFA_AA:					z-score of FA rate for pairings targetA-attributeA (here: women-occupations)
/zFA_AB:					z-score of FA rate for pairings targetA-attributeB (here: women-qualities)
/zFA_BA:					z-score of FA rate for pairings targetB-attributeA (here: men-occuopations)
/zFA_BB:					z-score of FA rate for pairings targetB-attributeB (here: men-qualities)

/AA_dprime:					Computes d' (parametric measure of discriminability) for women-occupations Pairings
/AB_dprime:					Computes d' (parametric measure of discriminability) for women-qualities Pairings
/BA_dprime:					Computes d' (parametric measure of discriminability) for men-occupations Pairings
/BB_dprime:					Computes d' (parametric measure of discriminability) for men-qualities Pairings

/ AA_beta:					Computes ß (beta) (parametric measure of bias) for women-occupations Pairings
/ AB_beta:					Computes ß (beta) (parametric measure of bias) for women-qualities Pairings
/ BA_beta:					Computes ß (beta) (parametric measure of bias) for men-occupations Pairings
/ BB_beta :					Computes ß (beta) (parametric measure of bias) for men-qualities Pairings

/propcorrect_AA:			overall proportion correct for pairing targetA-attributeA (here: women-occupations)
/propcorrect_AB:			overall proportion correct for pairing targetA-attributeB (here: women-qualities)
/propcorrect_BA:			overall proportion correct for pairing targetB-attributeA (here: men-occupations)
/propcorrect_BB:			overall proportion correct for pairing targetB-attributeB (here: men-qualiities)

GNATpart1:					(a) subtracting d' for the Men & Occupations block from d' for the Women & Occupations block;
GNATpart2:					(b) subtracting d' for the Women & Qualities block from d' for the Men & Qualities block;
GNATALL:					=> sum of GNATpart1 and GNATpart2


<expressions>
/propcorrect_AA = (values.hits_AA + (values.count_noiseAA - values.FA_AA)) / (values.count_signalAA + values.count_noiseAA)
/propcorrect_AB = (values.hits_AB + (values.count_noiseAB - values.FA_AB)) / (values.count_signalAB + values.count_noiseAB)
/propcorrect_BA = (values.hits_BA + (values.count_noiseBA - values.FA_BA)) / (values.count_signalBA + values.count_noiseBA)
/propcorrect_BB = (values.hits_BB + (values.count_noiseBB - values.FA_BB)) / (values.count_signalBB + values.count_noiseBB)

/ rHit_AA = return (values.hits_AA/values.count_signalAA)
/ rMiss_AA = return (1-expressions.rHit_AA)
/ rFa_AA = return (values.fa_AA/values.count_noiseAA)
/ rCr_AA = return (1-expressions.rFa_AA)

/ zHit_AA = {
	if (expressions.rHit_AA == 0){
		return zOfP(expressions.rHit_AA + 0.005)		
	} else if (expressions.rHit_AA == 1){
		return zOfP(expressions.rHit_AA - 0.005)
	} else {
		return zOfP(expressions.rHit_AA)	
	}
}

/ zFa_AA = {
	if (expressions.rFa_AA == 0){
		return zOfP(expressions.rFa_AA + 0.005)		
	} else if (expressions.rFa_AA == 1){
		return zOfP(expressions.rFa_AA - 0.005)
	} else {
		return zOfP(expressions.rFa_AA)	
	}
}
/ dPrime_AA = return (expressions.zHit_AA-expressions.zFa_AA)
/ c_AA = return (-1*((expressions.zHit_AA + expressions.zFa_AA)/2))

/ rHit_AB = return (values.hits_AB/values.count_signalAB)
/ rMiss_AB = return (1-expressions.rHit_AB)
/ rFa_AB = return (values.fa_AB/values.count_noiseAB)
/ rCr_AB = return (1-expressions.rFa_AB)

/ zHit_AB = {
	if (expressions.rHit_AB == 0){
		return zOfP(expressions.rHit_AB + 0.005)		
	} else if (expressions.rHit_AB == 1){
		return zOfP(expressions.rHit_AB - 0.005)
	} else {
		return zOfP(expressions.rHit_AB)	
	}
}

/ zFa_AB = {
	if (expressions.rFa_AB == 0){
		return zOfP(expressions.rFa_AB + 0.005)		
	} else if (expressions.rFa_AB == 1){
		return zOfP(expressions.rFa_AB - 0.005)
	} else {
		return zOfP(expressions.rFa_AB)	
	}
}
/ dPrime_AB = return (expressions.zHit_AB-expressions.zFa_AB)
/ c_AB = return (-1*((expressions.zHit_AB + expressions.zFa_AB)/2))

/ rHit_BA = return (values.hits_BA/values.count_signalBA)
/ rMiss_BA = return (1-expressions.rHit_BA)
/ rFa_BA = return (values.fa_BA/values.count_noiseBA)
/ rCr_BA = return (1-expressions.rFa_BA)

/ zHit_BA = {
	if (expressions.rHit_BA == 0){
		return zOfP(expressions.rHit_BA + 0.005)		
	} else if (expressions.rHit_BA == 1){
		return zOfP(expressions.rHit_BA - 0.005)
	} else {
		return zOfP(expressions.rHit_BA)	
	}
}

/ zFa_BA = {
	if (expressions.rFa_BA == 0){
		return zOfP(expressions.rFa_BA + 0.005)		
	} else if (expressions.rFa_BA == 1){
		return zOfP(expressions.rFa_BA - 0.005)
	} else {
		return zOfP(expressions.rFa_BA)	
	}
}
/ dPrime_BA = return (expressions.zHit_BA-expressions.zFa_BA)
/ c_BA = return (-1*((expressions.zHit_BA + expressions.zFa_BA)/2))

/ rHit_BB = return (values.hits_BB/values.count_signalBB)
/ rMiss_BB = return (1-expressions.rHit_BB)
/ rFa_BB = return (values.fa_BB/values.count_noiseBB)
/ rCr_BB = return (1-expressions.rFa_BB)

/ zHit_BB = {
	if (expressions.rHit_BB == 0){
		return zOfP(expressions.rHit_BB + 0.005)		
	} else if (expressions.rHit_BB == 1){
		return zOfP(expressions.rHit_BB - 0.005)
	} else {
		return zOfP(expressions.rHit_BB)	
	}
}

/ zFa_BB = {
	if (expressions.rFa_BB == 0){
		return zOfP(expressions.rFa_BB + 0.005)		
	} else if (expressions.rFa_BB == 1){
		return zOfP(expressions.rFa_BB - 0.005)
	} else {
		return zOfP(expressions.rFa_BB)	
	}
}
/ dPrime_BB = return (expressions.zHit_BB-expressions.zFa_BB)
/ c_BB = return (-1*((expressions.zHit_BB + expressions.zFa_BB)/2))

/ GNATpart1 = expressions.dPrime_AA- expressions.dPrime_BA
/ GNATpart2 = expressions.dPrime_BB- expressions.dPrime_AB
/ GNATALL = expressions.GNATpart1 + expressions.GNATpart2
</expressions>


