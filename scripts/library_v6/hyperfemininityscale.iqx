<surveypage hyperfemininityscale1>
/ caption = "<%parameters.pageinstructions%>"
/ questions = [1 = q1, q2, q3, q4]
</surveypage>

<surveypage hyperfemininityscale2>
/ caption = "<%parameters.pageinstructions%>"
