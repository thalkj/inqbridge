******************************
Test Trials
******************************

<trial AA_attribute>
/ ontrialbegin = [
	values.targetlabelleft=values.attributelabelleft; 
	values.targetlabelright=values.attributelabelright;
]
/ stimulustimes = [0=attributelabelleft,attributelabelright,targetlabelleft,targetlabelright,orleft,orright;
	1000=fixationcross; 1500=attributeA]
/ validresponse = (18,23)
/ correctresponse = (18)
/ posttrialpause = 250
/ ontrialend = [
	if(trial.AA_attribute.latency<=10000) {
		list.ACC.appendItem(trial.AA_attribute.correct);
		list.corrRT.appendItem(trial.AA_attribute.latency);
		list.corrRT_compatible.appendItem(trial.AA_attribute.latency);
	}
	
	if(trial.AA_attribute.latency < 300) {
		list.RT300.appendItem(1);
	} else {
		list.RT300.appendItem(0);
	}
			
	values.item=text.attributeA.currentItem;
]
</trial>

<trial AA_target>
/ ontrialbegin = [
	values.targetlabelleft=values.attributelabelleft; 
	values.targetlabelright=values.attributelabelright;
]
/ stimulustimes = [0=attributelabelleft,attributelabelright,targetlabelleft,targetlabelright,orleft,orright;
	1000=fixationcross; 1500=targetA]
/ validresponse = (18,23)
/ correctresponse = (18)
/ posttrialpause = 250
/ ontrialend = [
	if(trial.AA_target.latency<=10000) {
		list.ACC.appendItem(trial.AA_target.correct);
		list.corrRT.appendItem(trial.AA_target.latency);
		list.corrRT_compatible.appendItem(trial.AA_target.latency);
	}
	
	if(trial.AA_target.latency < 300) {
		list.RT300.appendItem(1);
	} else {
