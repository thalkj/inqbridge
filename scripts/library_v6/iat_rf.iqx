**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block attributeinstructions>
/ onblockbegin = [
	text.targetlabelleft.textColor=black; 
	text.targetlabelright.textColor=black; 
	text.orleft.textColor=black; 
	text.orright.textColor=black;
	
	text.attributelabelleft.vposition=5%;
	text.attributelabelright.vposition=5%;
]
/ trials = [1=instructions]
</block>

<block targetinstructions>
/ onblockbegin = [
	text.targetlabelleft.textColor=white; 
	text.targetlabelright.textColor=white; 
	text.attributelabelleft.textColor=black; 
	text.attributelabelright.textColor=black;
	text.orleft.textColor=black; 
	text.orright.textColor=black;
	
	text.attributelabelleft.vposition=19%;
	text.attributelabelright.vposition=19%;
]
/ trials = [1=instructions]
</block>

<block combinedinstructions>
/ onblockbegin = [
	text.targetlabelleft.textColor=white; 
	text.targetlabelright.textColor=white; 
	text.attributelabelleft.textColor=green; 
	text.attributelabelright.textColor=green;
	text.orleft.textColor=white; 
	text.orright.textColor=white;
	
	text.attributelabelleft.vposition=19%;
	text.attributelabelright.vposition=19%;
]
/ trials = [1=instructions]
</block>

<block attributepractice>
/ onblockbegin = [
	text.attributelabelleft.vposition=5%;
	text.attributelabelright.vposition=5%;
]
/ trials = [1-16=noreplace(attributeApractice,attributeBpractice)]
/ errormessage = true(error,200)
/ response = correct
/ recorddata = true
</block>

<block targetpractice>
/ trials = [1-16=noreplace(targetApractice,targetApracticeswitch,targetBpractice,targetBpracticeswitch)]
/ errormessage = true(error,200)
/ response = correct
/ recorddata = true
</block>

<block combinedpractice>
/ onblockbegin = [
	text.attributelabelleft.vposition=19%;
	text.attributelabelright.vposition=19%;
]
/ trials = [1-32=noreplace(AA_attribute,AA_target,BB_attribute,BB_target,AB_attribute,AB_target,BA_attribute,BA_target)]
/ errormessage = true(error,200)
/ response = correct
/ recorddata = true
</block>

<block combinedtest>
/ onblockbegin = [
	text.attributelabelleft.vposition=19%;
	text.attributelabelright.vposition=19%;
	list.ACC.reset();
	list.corrRT.reset();
	list.corrRT_compatible.reset();
	list.corrRT_incompatible.reset();
]
/ trials = [1-128=noreplace(AA_attribute,AA_target,BB_attribute,BB_target,AB_attribute,AB_target,BA_attribute,BA_target)]
/ errormessage = true(error,200)
/ response = correct
</block>

<block summary>
/skip = [parameters.showsummaryfeedback == false]
/ trials = [1=summary]
/ recorddata = false
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************
<expt iat_rf>
/ blocks = [
	1=attributeinstructions; 
	2=attributepractice; 
	3=targetinstructions; 
	4=targetpractice; 
	5=combinedinstructions; 
	6=combinedpractice; 
	7=combinedtest; 
	8=summary;
]
</expt>

***********************************************************************
Test Monkey
***********************************************************************
<monkey>
/ latencydistribution = normal(500, 100)
/ percentcorrect = 90
</monkey>


**************************************************************************************************************
												End of File
