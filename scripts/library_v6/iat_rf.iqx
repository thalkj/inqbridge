		list.ACC.appendItem(trial.BA_attribute.correct);
		list.corrRT.appendItem(trial.BA_attribute.latency);
		list.corrRT_incompatible.appendItem(trial.BA_attribute.latency);
	}
	
	if(trial.BA_attribute.latency < 300) {
		list.RT300.appendItem(1);
	} else {
		list.RT300.appendItem(0);
	}	
	
	values.item=text.attributeB.currentItem;
]
</trial>

<trial BA_target>
/ ontrialbegin = [
	values.targetlabelleft=values.attributelabelright; 
