/ posttrialpause = 250
/ ontrialend = [
	if(trial.AB_attribute.latency<=10000) {		
		list.ACC.appendItem(trial.AB_attribute.correct);
		list.corrRT.appendItem(trial.AB_attribute.latency);
		list.corrRT_incompatible.appendItem(trial.AB_attribute.latency);
	}
	
	if(trial.AB_attribute.latency < 300) {
		list.RT300.appendItem(1);
	} else {
		list.RT300.appendItem(0);
	}
	
	values.item=text.attributeA.currentItem;
]
</trial>

<trial AB_target>
/ ontrialbegin = [
	values.targetlabelleft=values.attributelabelright; 
	values.targetlabelright=values.attributelabelleft;
]
/ stimulustimes = [0=attributelabelleft,attributelabelright,targetlabelleft,targetlabelright,orleft,orright;
	1000=fixationcross; 1500=targetB]
/ validresponse = (18,23)
/ correctresponse = (18)
/ posttrialpause = 250
/ ontrialend = [
	if(trial.AB_target.latency<=10000) {
		list.ACC.appendItem(trial.AB_target.correct);
		list.corrRT.appendItem(trial.AB_target.latency);
		list.corrRT_incompatible.appendItem(trial.AB_target.latency);
	}
	
	if(trial.AB_target.latency < 300) {
		list.RT300.appendItem(1);
	} else {
		list.RT300.appendItem(0);
	}	
		
	values.item=text.targetB.currentItem;
]
</trial>

<trial BA_attribute>
/ ontrialbegin = [
	values.targetlabelleft=values.attributelabelright; 
	values.targetlabelright=values.attributelabelleft;
]
