********************
Summary data
********************

<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, script.elapsedTime, 
script.completed, 
expressions.PerspectiveTaking, expressions.Fantasy, expressions.EmpathicConcern, expressions.PersonalDistress)
</summarydata>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************
subscales are (taken directly from Davis, 1983):

Perspective Taking – the tendency to spontaneously adopt the psychological point of
view of others
Fantasy – taps respondents' tendencies to transpose themselves imaginatively into
the feelings and actions of fictitious characters in books, movies, and plays
Empathic Concern – assesses "other-oriented" feelings of sympathy and concern for
unfortunate others
Personal Distress – measures "self-oriented" feelings of personal anxiety and unease
in tense interpersonal settings

<expressions>
/PerspectiveTaking = radiobuttons.q3R_PT.response + radiobuttons.q8_PT.response + radiobuttons.q11_PT.response + 
radiobuttons.q15R_PT.response + radiobuttons.q21_PT.response + radiobuttons.q25_PT.response + radiobuttons.q28_PT.response
/Fantasy = radiobuttons.q1_FS.response + radiobuttons.q5_FS.response + radiobuttons.q7R_FS.response + radiobuttons.q12R_FS.response + 
radiobuttons.q16_FS.response + radiobuttons.q23_FS.response + radiobuttons.q26_FS.response
/EmpathicConcern = radiobuttons.q2_EC.response + radiobuttons.q4R_EC.response + radiobuttons.q9_EC.response + radiobuttons.q14R_EC.response + 
radiobuttons.q18R_EC.response + radiobuttons.q20_EC.response + radiobuttons.q22_EC.response
/PersonalDistress = radiobuttons.q6_PD.response + radiobuttons.q10_PD.response + radiobuttons.q13R_PD.response +
radiobuttons.q17_PD.response + radiobuttons.q19R_PD.response + radiobuttons.q24_PD.response + radiobuttons.q27_PD.response
</expressions>


*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<radiobuttons q1_FS>
/caption = "1. I daydream and fantasize, with some regularity, about things that might happen to me."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>


<radiobuttons q2_EC>
/caption = "2. I often have tender, concerned feelings for people less fortunate than me."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q3R_PT>
/caption = "3. I sometimes find it difficult to see things from the ''other guy's'' point of view."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q4R_EC>
/caption = "4. Sometimes I don't feel very sorry for other people when they are having problems."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q5_FS>
/caption = "5. I really get involved with the feelings of the characters in a novel."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q6_PD>
/caption = "6. In emergency situations, I feel apprehensive and ill-at-ease."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q7R_FS>
/caption = "7. I am usually objective when I watch a movie or play, and I don't often get completely caught up in it."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q8_PT>
/caption = "8. I try to look at everybody's side of a disagreement before I make a decision."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q9_EC>
/caption = "9. When I see someone being taken advantage of, I feel kind of protective towards them."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q10_PD>
/caption = "10. I sometimes feel helpless when I am in the middle of a very emotional situation."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q11_PT>
/caption = "11. I sometimes try to understand my friends better by imagining how things look from their perspective."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q12R_FS>
/caption = "12. Becoming extremely involved in a good book or movie is somewhat rare for me."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q13R_PD>
/caption = "13. When I see someone get hurt, I tend to remain calm."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q14R_EC>
/caption = "14. Other people's misfortunes do not usually disturb me a great deal."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q15R_PT>
/caption = "15. If I'm sure I'm right about something, I don't waste much time listening to other people's arguments."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q16_FS>
/caption = "16. After seeing a play or movie, I have felt as though I were one of the characters."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q17_PD>
/caption = "17. Being in a tense emotional situation scares me."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q18R_EC>
/caption = "18. When I see someone being treated unfairly, I sometimes don't feel very much pity for them."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q19R_PD>
/caption = "19. I am usually pretty effective in dealing with emergencies."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("4", "3", "2", "1", "0")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q20_EC>
/caption = "20. I am often quite touched by things that I see happen."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q21_PT>
/caption = "21. I believe that there are two sides to every question and try to look at them both."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q22_EC>
/caption = "22. I would describe myself as a pretty soft-hearted person."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q23_FS>
/caption = "23. When I watch a good movie, I can very easily put myself in the place of a leading character."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q24_PD>
/caption = "24. I tend to lose control during emergencies."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q25_PT>
/caption = "25. When I'm upset at someone, I usually try to ''put myself in his shoes'' for a while."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q26_FS>
/caption = "26. When I am reading an interesting story or novel, I imagine how I would feel if the events in the story were happening to me."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q27_PD>
/caption = "27. When I see someone who badly needs help in an emergency, I go to pieces."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q28_PT>
/caption = "28. Before criticizing somebody, I try to imagine how I would feel if I were in their place."
/ options = ("A~nDoes not~ndescribe me well", "B", "C", "D", "E~nDescribes me~nvery well")
/ optionvalues = ("0", "1", "2", "3", "4")
/required = true
/orientation = horizontalequal
</radiobuttons>

