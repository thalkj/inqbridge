script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = black
/ screencolor = white
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, blockcode, blocknum, 
trialcode, trialnum, values.conditionOrder,
values.countPracticeRounds, values.countTestRounds, values.phase,
values.ruleConsistency, values.targetCat, values.attributeCat,
stimulusitem, stimulusitem, latency, response, values.corrResp, values.corrKey, correct, 
values.responseOptionA, values.responseOptionB,
expressions.ACC_practice, expressions.medianRT_practice, values.practicePass)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, script.elapsedTime, 
script.completed, values.conditionOrder,

values.practicePass, 
values.countPracticeRounds,

values.minTestblockACC, 
expressions.propBelowMinRT,

expressions.D_IRAP_AA,
expressions.D_IRAP_AB,
expressions.D_IRAP_BA,
expressions.D_IRAP_BB,

expressions.D_IRAP_A,
expressions.D_IRAP_B,

expressions.D_IRAP)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/startInstructions:			helper variable to select appropriate instructions
/endInstructions:			helper variable to select appropriate instructions

/responseOptionA_x:			the horizontal screen location of the response Option A key (here: response option A = similar key)
/responseOptionB_x:			the horizontal screen location of the response Option B key (here: response option B = different key)

/responseOptionA_key:		the scancode of the response Option A key
/responseOptionA:	the label that is attached to the response Option A key
/responseOptionB_key:		the scancode of the response Option B key
/responseOptionB:	the label that is attached to the response Option B key
/corrKey:					stores the key of the currently correct key
/corrResp:					the correct response in words "similar" vs. "different"
/targetCat:					the currently tested target category
/attributeCat:				the currently tested attribute category

/trialcount_block:			counts the number of trials (AA, BA, AB, BB) run per block

/ruleConsistency:			1 = block runs the hypothesis-consistent rule
							2 = block runs the hypothesis-inconsistent rule
/instructselect:			helper variable to select instruction text
/selectBlockInstruct:		helper variable to select block instruction text
/phase:						"practice" vs. "test"
/countPracticeRounds:		counts the number of practice rounds (one round = two blocks)
/practicePass:				1 = practice mastery criteria have been met
							0 = practice mastery criteria have not been met 
/minTestblockACC:			tracks the lowest proportion correct in any test block

/countTestRounds:			counts the number of test rounds (one round = two blocks)
/trialcode:					stores the trialcode of the currently run trial

/ACC_practice1:				stores the proportion correct of the first block in a practice round
/RT_practice1:				stores the median latency (in ms) of the first block in a practice round
/ACC_practice2:				stores the proportion correct of the second block in a practice round
/RT_practice2:				stores the median latency (in ms) of the second block in a practice round

/SDpooled_testround1_AA:	stores the standard deviation of the response latencies (in ms) of AA trials in test round 1 (across Consistent and Inconsistent Blocks)
/SDpooled_testround1_AB:	stores the standard deviation of the response latencies (in ms) of AB trials in test round 1
/SDpooled_testround1_AA:	stores the standard deviation of the response latencies (in ms) of BA trials in test round 1
/SDpooled_testround1_BB:	stores the standard deviation of the response latencies (in ms) of BB trials in test round 1
/SDpooled_testround2_AA:	stores the standard deviation of the response latencies (in ms) of AA trials in test round 2
/SDpooled_testround2_AB:	stores the standard deviation of the response latencies (in ms) of AB trials in test round 2
/SDpooled_testround2_AA:	stores the standard deviation of the response latencies (in ms) of BA trials in test round 2
/SDpooled_testround2_BB:	stores the standard deviation of the response latencies (in ms) of BB trials in test round 2
/SDpooled_testround3_AA:	stores the standard deviation of the response latencies (in ms) of AA trials in test round 3
/SDpooled_testround3_AB:	stores the standard deviation of the response latencies (in ms) of AB trials in test round 3
/SDpooled_testround3_AA:	stores the standard deviation of the response latencies (in ms) of BA trials in test round 3
/SDpooled_testround3_BB:	stores the standard deviation of the response latencies (in ms) of BB trials in test round 3

/meanRT_testround1_AA_C:	stores the mean latency (in ms) of AA trials in the Consistent Block of test round 1
/meanRT_testround1_AB_C:	stores the mean latency (in ms) of AB trials in the Consistent Block of test round 1
/meanRT_testround1_BA_C:	stores the mean latency (in ms) of BA trials in the Consistent Block of test round 1
/meanRT_testround1_BB_C:	stores the mean latency (in ms) of BB trials in the Consistent Block of test round 1
/meanRT_testround2_AA_C:	stores the mean latency (in ms) of AA trials in the Consistent Block of test round 2
/meanRT_testround2_AB_C:	stores the mean latency (in ms) of AB trials in the Consistent Block of test round 2
/meanRT_testround2_BA_C:	stores the mean latency (in ms) of BA trials in the Consistent Block of test round 2
/meanRT_testround2_BB_C:	stores the mean latency (in ms) of BB trials in the Consistent Block of test round 2
/meanRT_testround3_AA_C:	stores the mean latency (in ms) of AA trials in the Consistent Block of test round 3
/meanRT_testround3_AB_C:	stores the mean latency (in ms) of AB trials in the Consistent Block of test round 3
/meanRT_testround3_BA_C:	stores the mean latency (in ms) of BA trials in the Consistent Block of test round 3
/meanRT_testround3_BB_C:	stores the mean latency (in ms) of BB trials in the Consistent Block of test round 3

/meanRT_testround1_AA_IC:	stores the mean latency (in ms) of AA trials in the Inconsistent Block of test round 1
/meanRT_testround1_AB_IC:	stores the mean latency (in ms) of AB trials in the Inconsistent Block of test round 1
/meanRT_testround1_BA_IC:	stores the mean latency (in ms) of BA trials in the Inconsistent Block of test round 1
/meanRT_testround1_BB_IC:	stores the mean latency (in ms) of BB trials in the Inconsistent Block of test round 1
/meanRT_testround2_AA_IC:	stores the mean latency (in ms) of AA trials in the Inconsistent Block of test round 2
/meanRT_testround2_AB_IC:	stores the mean latency (in ms) of AB trials in the Inconsistent Block of test round 2
/meanRT_testround2_BA_IC:	stores the mean latency (in ms) of BA trials in the Inconsistent Block of test round 2
/meanRT_testround2_BB_IC:	stores the mean latency (in ms) of BB trials in the Inconsistent Block of test round 2
/meanRT_testround3_AA_IC:	stores the mean latency (in ms) of AA trials in the Inconsistent Block of test round 3
/meanRT_testround3_AB_IC:	stores the mean latency (in ms) of AB trials in the Inconsistent Block of test round 3
/meanRT_testround3_BA_IC:	stores the mean latency (in ms) of BA trials in the Inconsistent Block of test round 3
/meanRT_testround3_BB_IC:	stores the mean latency (in ms) of BB trials in the Inconsistent Block of test round 3

<values>
/startInstructions = 0
/endInstructions = 0

/responseOptionA_x = 25%
/responseOptionB_x = 75%
/responseOptionA = ""
/responseOptionB = ""
/corrKey = ""
/corrResp = ""
/targetCat = ""
/attributeCat = ""

/trialcount_block = 0

/ruleConsistency = 1
/instructselect = 0
/selectBlockInstruct = 0
/phase = ""
/countPracticeRounds = 0
/practicePass = 0
/minTestblockACC = 1

/countTestRounds = 0
/trialcode = ""

/ACC_practice1 = 0
/RT_practice1 = 0
/ACC_practice2 = 0
/RT_practice2 = 0

/SDpooled_testround1_AA = ""
/SDpooled_testround1_AB = ""
/SDpooled_testround1_BA = ""
/SDpooled_testround1_BB = ""
/SDpooled_testround2_AA = ""
/SDpooled_testround2_AB = ""
/SDpooled_testround2_BA = ""
/SDpooled_testround2_BB = ""
/SDpooled_testround3_AA = ""
/SDpooled_testround3_AB = ""
/SDpooled_testround3_BA = ""
/SDpooled_testround3_BB = ""

/meanRT_testround1_AA_C = ""
/meanRT_testround1_AB_C = ""
/meanRT_testround1_BA_C = ""
/meanRT_testround1_BB_C = ""
/meanRT_testround2_AA_C = ""
/meanRT_testround2_AB_C = ""
/meanRT_testround2_BA_C = ""
/meanRT_testround2_BB_C = ""
/meanRT_testround3_AA_C = ""
/meanRT_testround3_AB_C = ""
/meanRT_testround3_BA_C = ""
/meanRT_testround3_BB_C = ""

/meanRT_testround1_AA_IC = ""
/meanRT_testround1_AB_IC = ""
/meanRT_testround1_BA_IC = ""
/meanRT_testround1_BB_IC = ""
/meanRT_testround2_AA_IC = ""
/meanRT_testround2_AB_IC = ""
/meanRT_testround2_BA_IC = ""
/meanRT_testround2_BB_IC = ""
/meanRT_testround3_AA_IC = ""
/meanRT_testround3_AB_IC = ""
/meanRT_testround3_BA_IC = ""
/meanRT_testround3_BB_IC = ""

/conditionOrder = ""
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

Note:
in this script:
AA = attribute A (pleasant), target A (flower)
AB = attribute A (pleasant), target A (insect)
BA = attribute B (unpleasant), target A (flower)
BB = attribute B (unpleasant), target B (insect)

/ACC_practice:			proportion correct during the current practice block (resets after each practice block)
/medianRT_practice:		median response latency during the current practice block (resets after each practice block)
/meanRT_practice:		mean response latency during the current practice block (resets after each practice block)


/ACC_test:				proportion correct during the current testblock (resets after each test block)
/medianRT_test:			median response latency during the current test block (resets after each test block)

/blockACC:				stores percent correct of the current block
/blockRT:				stores the median RT (in ms) of the current block
/propBelowMinRT:		proportion of test trials with response latencies < 300ms
						(Note: Barnes-Holmes et al, 2010, suggest to eliminate the data of participants with propBelowMinRT > 0.1 (10%))

/Diff_AA_1:				Difference score of response latencies in consistent and inconsistent testround 1 for trialtype 'AA' (attributeA, targetA)
/Diff_AB_1:				Difference score of response latencies in consistent and inconsistent testround 1 for trialtype 'AB' (attributeA, targetB)
/Diff_BA_1:				Difference score of response latencies in consistent and inconsistent testround 1 for trialtype 'BA' (attributeB, targetA)
/Diff_BB_1:				Difference score of response latencies in consistent and inconsistent testround 1 for trialtype 'BB' (attributeB, targetB)

/Diff_AA_2:				Difference score of response latencies in consistent and inconsistent testround 2 for trialtype 'AA' (attributeA, targetA)
/Diff_AB_2:				Difference score of response latencies in consistent and inconsistent testround 2 for trialtype 'AB' (attributeA, targetB)
/Diff_BA_2:				Difference score of response latencies in consistent and inconsistent testround 2 for trialtype 'BA' (attributeB, targetA)
/Diff_BB_2:				Difference score of response latencies in consistent and inconsistent testround 2 for trialtype 'BB' (attributeB, targetB)

/Diff_AA_3:				Difference score of response latencies in consistent and inconsistent testround 3 for trialtype 'AA' (attributeA, targetA)
/Diff_AB_3:				Difference score of response latencies in consistent and inconsistent testround 3 for trialtype 'AB' (attributeA, targetB)
/Diff_BA_3:				Difference score of response latencies in consistent and inconsistent testround 3 for trialtype 'BA' (attributeB, targetA)
/Diff_BB_3:				Difference score of response latencies in consistent and inconsistent testround 3 for trialtype 'BB' (attributeB, targetB)

/D_IRAP_AA_1:			IRAP D score for trialtype AA in testround 1 (difference score relative to pooled standard deviation)
/D_IRAP_AB_1:			IRAP D score for trialtype AB in testround 1 (difference score relative to pooled standard deviation)
/D_IRAP_BA_1:			IRAP D score for trialtype BA in testround 1 (difference score relative to pooled standard deviation)
/D_IRAP_BB_1:			IRAP D score for trialtype BB in testround 1 (difference score relative to pooled standard deviation)

/D_IRAP_AA_2:			IRAP D score for trialtype AA in testround 2 (difference score relative to pooled standard deviation)
/D_IRAP_AB_2:			IRAP D score for trialtype AB in testround 2 (difference score relative to pooled standard deviation)
/D_IRAP_BA_2:			IRAP D score for trialtype BA in testround 2 (difference score relative to pooled standard deviation)
/D_IRAP_BB_2:			IRAP D score for trialtype BB in testround 2 (difference score relative to pooled standard deviation)

/D_IRAP_AA_3:			IRAP D score for trialtype AA in testround 3 (difference score relative to pooled standard deviation)
/D_IRAP_AB_3:			IRAP D score for trialtype AB in testround 3 (difference score relative to pooled standard deviation)
/D_IRAP_BA_3:			IRAP D score for trialtype BA in testround 3 (difference score relative to pooled standard deviation)
/D_IRAP_BB_3:			IRAP D score for trialtype BB in testround 3 (difference score relative to pooled standard deviation)

/D_IRAP_AA:				mean of the three IRAP D-scores for trialtype AA (here: pleasant with flowers)
							Note: if fewer than 3 test rounds are run, the score adapts
/D_IRAP_AB:				mean of the three IRAP D-scores for trialtype AB (here: pleasant with insects)
							Note: if fewer than 3 test rounds are run, the score adapts
/D_IRAP_BA:				mean of the three IRAP D-scores for trialtype BA (here: unpleasant with flowers)
							Note: if fewer than 3 test rounds are run, the score adapts
/D_IRAP_BB:				mean of the three IRAP D-scores for trialtype BB (here: unpleasant with insects)
							Note: if fewer than 3 test rounds are run, the score adapts

/D_IRAP_A:		mean of the two IRAP D-scores for target A (here: flowers)
/D_IRAP_B:		mean of the two IRAP D-scores for target A (here: insects)

/D_IRAP:				overall D_IRAP score as the mean of all individual D_IRAPs

<expressions>
/ACC_practice = list.ACC_practice.mean
/medianRT_practice = list.RT_practice.median
/meanRT_practice = list.RT_practice.mean

/propBelowMinRT = 1-list.testRTs.mean

/ACC_test = list.ACC_test.mean
/medianRT_test = list.RT_test.median

/blockACC = 
if (values.phase == "practice"){
	expressions.ACC_practice * 100;
} else {
	expressions.ACC_test * 100;
}

/blockRT = 
if (values.phase == "practice"){
	expressions.medianRT_practice;
} else {
	expressions.medianRT_test;
}

/Diff_AA_1 = values.meanRT_testround1_AA_IC - values.meanRT_testround1_AA_C
/Diff_AB_1 = values.meanRT_testround1_AB_IC - values.meanRT_testround1_AB_C
/Diff_BA_1 = values.meanRT_testround1_BA_IC - values.meanRT_testround1_BA_C
/Diff_BB_1 = values.meanRT_testround1_BB_IC - values.meanRT_testround1_BB_C

/Diff_AA_2 = values.meanRT_testround2_AA_IC - values.meanRT_testround2_AA_C
/Diff_AB_2 = values.meanRT_testround2_AB_IC - values.meanRT_testround2_AB_C
/Diff_BA_2 = values.meanRT_testround2_BA_IC - values.meanRT_testround2_BA_C
/Diff_BB_2 = values.meanRT_testround2_BB_IC - values.meanRT_testround2_BB_C

/Diff_AA_3 = values.meanRT_testround3_AA_IC - values.meanRT_testround3_AA_C
/Diff_AB_3 = values.meanRT_testround3_AB_IC - values.meanRT_testround3_AB_C
/Diff_BA_3 = values.meanRT_testround3_BA_IC - values.meanRT_testround3_BA_C
/Diff_BB_3 = values.meanRT_testround3_BB_IC - values.meanRT_testround3_BB_C

/D_IRAP_AA_1 = expressions.Diff_AA_1/values.SDpooled_testround1_AA
/D_IRAP_AB_1 = expressions.Diff_AB_1/values.SDpooled_testround1_AB
/D_IRAP_BA_1 = expressions.Diff_BA_1/values.SDpooled_testround1_BA
/D_IRAP_BB_1 = expressions.Diff_BB_1/values.SDpooled_testround1_BB

/D_IRAP_AA_2 = expressions.Diff_AA_2/values.SDpooled_testround2_AA
/D_IRAP_AB_2 = expressions.Diff_AB_2/values.SDpooled_testround2_AB
/D_IRAP_BA_2 = expressions.Diff_BA_2/values.SDpooled_testround2_BA
/D_IRAP_BB_2 = expressions.Diff_BB_2/values.SDpooled_testround2_BB

/D_IRAP_AA_3 = expressions.Diff_AA_3/values.SDpooled_testround3_AA
/D_IRAP_AB_3 = expressions.Diff_AB_3/values.SDpooled_testround3_AB
/D_IRAP_BA_3 = expressions.Diff_BA_3/values.SDpooled_testround3_BA
/D_IRAP_BB_3 = expressions.Diff_BB_3/values.SDpooled_testround3_BB

/D_IRAP_AA = 
if (parameters.numberOfTestRounds < 3){
	if (parameters.numberOfTestRounds < 2){
		expressions.D_IRAP_AA_1;
	} else {
		(expressions.D_IRAP_AA_1 + expressions.D_IRAP_AA_2)/2;
	}
} else {
	(expressions.D_IRAP_AA_1 + expressions.D_IRAP_AA_2 + expressions.D_IRAP_AA_3)/3;
}

/D_IRAP_AB = 
if (parameters.numberOfTestRounds < 3){
	if (parameters.numberOfTestRounds < 2){
		expressions.D_IRAP_AB_1;
	} else {
		(expressions.D_IRAP_AB_1 + expressions.D_IRAP_AB_2)/2;
	}
} else {
	(expressions.D_IRAP_AB_1 + expressions.D_IRAP_AB_2 + expressions.D_IRAP_AB_3)/3;
}

/D_IRAP_BA = 
if (parameters.numberOfTestRounds < 3){
	if (parameters.numberOfTestRounds < 2){
		expressions.D_IRAP_BA_1;
	} else {
		(expressions.D_IRAP_BA_1 + expressions.D_IRAP_BA_2)/2;
	}
} else {
	(expressions.D_IRAP_BA_1 + expressions.D_IRAP_BA_2 + expressions.D_IRAP_BA_3)/3;
}

/D_IRAP_BB = 
if (parameters.numberOfTestRounds < 3){
	if (parameters.numberOfTestRounds < 2){
		expressions.D_IRAP_BB_1;
	} else {
		(expressions.D_IRAP_BB_1 + expressions.D_IRAP_BB_2)/2;
	}
} else {
	(expressions.D_IRAP_BB_1 + expressions.D_IRAP_BB_2 + expressions.D_IRAP_BB_3)/3;
}

/D_IRAP_A = (expressions.D_IRAP_AA + expressions.D_IRAP_BA)/2
/D_IRAP_B = (expressions.D_IRAP_AB + expressions.D_IRAP_BB)/2

/D_IRAP = (expressions.D_IRAP_A + expressions.D_IRAP_B)/2
</expressions>


**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************
<text instruction>
/items = instructions
/ select = values.instructselect
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
/ vjustify = center
/ hjustify = left
</text>

<text blockInstruction>
/items = blockInstructions
/ select = values.ruleConsistency
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
/ vjustify = center
/ hjustify = left
</text>

<trial instruction>
/ ontrialbegin = [
	text.start.skip = true;
	text.continue.skip = false;

	if (values.instructselect == 1 || values.instructselect > 4){
		text.goback.skip = true;
	} else {
		text.goback.skip = false;
	}
	
	if (values.instructselect >= 4){
		text.start.skip = false;
		text.continue.skip = true;
	}
	
]
/ stimulusframes = [1 = instruction, continue, start, goback]
/ validresponse = ("B", " ")
/ recorddata = false
/ branch = [
	if (trial.instruction.responseText == "B"){
		if (values.instructselect < 5 && values.instructselect > 1){
			values.instructselect -= 1;
			return trial.instruction;
		} else {
			return trial.instruction;
		}
	} else if (trial.instruction.responseText == " " && values.instructselect < values.endInstructions){
		values.instructselect += 1;
		return trial.instruction;
	}
	return null;
]
</trial>


<trial blockInstruction>
/ stimulusframes = [1 = blockInstruction, ruleChange, start]
/ validresponse = (" ")
/ ontrialend = [
	text.ruleChange.skip = false;
]
/ posttrialpause = parameters.iti
/ recorddata = false
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = true
</trial>

*************************************
General Helper Instruction Trials/Blocks
*************************************

This trial is used when participants are asked to place their fingers on specific response
buttons. On the touchscreen, this trial presents the (inactive) response buttons to the participants.
<trial getReady>
/ stimulusframes = [1 = getReady]
/ timeout = parameters.readyDuration
/ validresponse = (parameters.leftkey, parameters.rightkey)
/ beginresponsetime = parameters.readyDuration
/ errormessage = false
/ recorddata = false
/ posttrialpause = parameters.iti
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************


Note: this text stimulus is used for AA trials that present A attributes (in this script: A attributes = 'pleasant')
<text attributeA_AA>
/ items = attributeA
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ position = (50%, 60%)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for AB trials that present A attributes (in this script: A attributes = 'pleasant')
<text attributeA_AB>
/ items = attributeA
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ position = (50%, 60%)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for BA trials that present B attributes (in this script: B attributes = 'unpleasant')
<text attributeB_BA>
/ items = attributeB
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ position = (50%, 60%)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for BB trials that present B attributes (in this script: B attributes = 'unpleasant')
<text attributeB_BB>
/ items = attributeB
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ position = (50%, 60%)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for AA trials that present A targets (in this script: A targets = 'flowers')
<text targetA_AA>
/ items = targetA
/ select = noreplace
/ position = (50%, 40%)
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for BA trials that present A targets (in this script: A targets = 'flowers')
<text targetA_BA>
/ items = targetA
/ select = noreplace
/ position = (50%, 40%)
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for AB trials that present B targets (in this script: B targets = 'insects')
<text targetB_AB>
/ items = targetB
/ select = noreplace
/ position = (50%, 40%)
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ size = (80%, 15%)
/ vjustify = center
</text>

Note: this text stimulus is used for BB trials that present B targets (in this script: B targets = 'insects')
<text targetB_BB>
/ items = targetB
/ select = noreplace
/ position = (50%, 40%)
/ fontstyle = ("Arial", parameters.stimSize, true, false, false, false, 5, 1)
/ size = (80%, 15%)
/ vjustify = center
</text>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

Note: the following two lists are used to select the horizontal screen location for optionA (here: similar)
and optionB (here: different)
25% = left side of canvas
75% = right side of canvas
(0% = left border of canvas - 100% right border of canvas)
<list responseOptionA_x>
/ items = (25%, 75%)
/ replace = true
/ resetinterval = 0
</list>

<list responseOptionB_x>
/ items = (75%, 25%)
/ selectionMode = list.responseOptionA_x.currentIndex
/ resetinterval = 0
</list>

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = initial correct response; 0 = initial incorrect response for each relevant practice trial
any response coded as an error is automatically coded as 0
<list ACC_practice>
</list>

Note: list stores the latency of responses for each practice trial
(Note: all responses that advance practice trials are correct even if the initial response is incorrect)
<list RT_practice>
</list>

Note: collects test performance for each block
<list ACC_test>
</list>

<list RT_test>
</list>


store 0 = test RT is below 300; 1 = test RT is at or above 300
<list testRTs>
</list>

Note: this list collects all reaction times (within given constraints)
for trial type "AA" per test block (resets after each test block)
<list RT_testround_AA>
</list>

Note: this list collects all reaction times (within given constraints)
for trial type "AA" across a pair of test blocks (one consistent, the other inconsistent)
<list RT_testround_AA_pooled>
</list>

<list RT_testround_AB>
</list>

<list RT_testround_AB_pooled>
</list>

<list RT_testround_BA>
</list>

<list RT_testround_BA_pooled>
</list>

<list RT_testround_BB>
</list>

<list RT_testround_BB_pooled>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS: used for practice and test trials
**************************************************************************************************************
**************************************************************************************************************

Note: trial.AA
- selects the screen position for responseOptionA (here: 'similar') and responseOptionB (here: 'different)
IF parameters.fixedResponseKeyLocation is set to 'false'
(in that case, the script simply uses the randomly assigned locations under the expt-element)
- determines the correct response key depending on ruleConsistency and position of 'similar' and 'different' screen position
AA: for ruleConsistency = 1, the correct response is 'similar'; for ruleConsistency = 2, the correct response is 'different'

<trial AA>
/ ontrialbegin = [
	values.trialcode = "AA";
	values.targetCat = item.targetA_label.item(1);
	values.attributeCat = item.attributeA_label.item(1);

	if (parameters.fixedResponseKeyLocation == false){
		values.responseOptionA_x = list.responseOptionA_x.nextValue;
		values.responseOptionB_x = list.responseOptionB_x.nextValue;		
	}

	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.leftkey;		
		} else {
			values.corrKey = parameters.rightkey;		
		}
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;		
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.rightkey;		
		} else {
			values.corrKey = parameters.leftkey;		
		}		
	}
	
	if (values.ruleConsistency == 1){
		values.corrResp = item.responseCategory1.items.1;
	} else {
		values.corrResp = item.responseCategory2.items.1;
	}
]

/ stimulusframes = [1 = attributeA_AA, targetA_AA, responseOptionA, responseOptionB]
/ validresponse = (parameters.leftkey, parameters.rightkey)
/ correctresponse = (values.corrKey)
/response = correct
/ posttrialpause = parameters.iti
/ errormessage = true(text.errormessage, 0)
</trial>

AB: for ruleConsistency = 1, the correct response is 'different'; for ruleConsistency = 2, the correct response is 'similar'
<trial AB>
/ ontrialbegin = [
	values.trialcode = "AB";
	values.targetCat = item.targetB_label.items.1;
	values.attributeCat = item.attributeA_label.items.1;	
	
	
	if (parameters.fixedResponseKeyLocation == false){
		values.responseOptionA_x = list.responseOptionA_x.nextValue;
		values.responseOptionB_x = list.responseOptionB_x.nextValue;		
	}
	
	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;		
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.rightkey;		
		} else {
			values.corrKey = parameters.leftkey;		
		}
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;			
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.leftkey;		
		} else {
			values.corrKey = parameters.rightkey;		
		}		
	}
	
	if (values.ruleConsistency == 1){
		values.corrResp = item.responseCategory2.items.1;
	} else {
		values.corrResp = item.responseCategory1.items.1;
	}
]
/ stimulusframes = [1 = attributeA_AB, targetB_AB, responseOptionA, responseOptionB]
/ validresponse = (parameters.leftkey, parameters.rightkey)
/ correctresponse = (values.corrKey)
/response = correct
/ posttrialpause = parameters.iti
/ errormessage = true(text.errormessage, 0)
</trial>

BA: for ruleConsistency = 1, the correct response is 'different'; for ruleConsistency = 2, the correct response is 'similar'
<trial BA>
/ ontrialbegin = [
	values.trialcode = "BA";
	values.targetCat = item.targetA_label.items.1;
	values.attributeCat = item.attributeB_label.items.1;	
	
	if (parameters.fixedResponseKeyLocation == false){
		values.responseOptionA_x = list.responseOptionA_x.nextValue;
		values.responseOptionB_x = list.responseOptionB_x.nextValue;		
	}
	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;	
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.rightkey;		
		} else {
			values.corrKey = parameters.leftkey;		
		}
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;		
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.leftkey;		
		} else {
			values.corrKey = parameters.rightkey;		
		}		
	}
	
	if (values.ruleConsistency == 1){
		values.corrResp = item.responseCategory2.items.1;
	} else {
		values.corrResp = item.responseCategory1.items.1;
	}
]
/ stimulusframes = [1 = attributeB_BA, targetA_BA, responseOptionA, responseOptionB]
/ validresponse = (parameters.leftkey, parameters.rightkey)
/ correctresponse = (values.corrKey)
/response = correct
/ posttrialpause = parameters.iti
/ errormessage = true(text.errormessage, 0)
</trial>

BB: for ruleConsistency = 1, the correct response is 'similar'; for ruleConsistency = 2, the correct response is 'different'
<trial BB>
/ ontrialbegin = [
	values.trialcode = "BB";
	values.targetCat = item.targetB_label.items.1;
	values.attributeCat = item.attributeB_label.items.1;	
	
	if (parameters.fixedResponseKeyLocation == false){
		values.responseOptionA_x = list.responseOptionA_x.nextValue;
		values.responseOptionB_x = list.responseOptionB_x.nextValue;		
	}
	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;	
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.leftkey;		
		} else {
			values.corrKey = parameters.rightkey;		
		}
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;			
		if (values.ruleConsistency == 1){
			values.corrKey = parameters.rightkey;		
		} else {
			values.corrKey = parameters.leftkey;		
		}		
	}
	
	if (values.ruleConsistency == 1){
		values.corrResp = item.responseCategory1.items.1;
	} else {
		values.corrResp = item.responseCategory2.items.1;
	}
]
/ stimulusframes = [1 = attributeB_BB, targetB_BB, responseOptionA, responseOptionB]
/ validresponse = (parameters.leftkey, parameters.rightkey)
/ correctresponse = (values.corrKey)
/response = correct
/ posttrialpause = parameters.iti
/ errormessage = true(text.errormessage, 0)
</trial>

<trial feedback>
/ ontrialbegin = [
	text.continue.skip = false;
]
/ stimulusframes = [1 = feedback, continue]
/ validresponse = (" ")
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************


<block instruction>
/ onblockbegin = [
	values.startInstructions = 1;
	values.endInstructions = 4;
	values.instructselect = values.startInstructions
]
/ trials = [1= instruction]
</block>

**************************************************************************************************************
	Practice:
	
	Practice is run as a pair of blocks: practice_part1 and practice_part2.
	Performance and median RT is assessed at the end of each block.
	
	If proportion correct in BOTH blocks >= 80% (see parameters.minPracACC) AND
	median latency in BOTH blocks <= 2000ms (see parameters.maxPracRT)
	then practice is terminated (= practice performance is good enough to advance to the test)
	
	If proportion correct in any of the blocks is below 80% OR median response latency 
	is above 2000ms in one of the two blocks, then the practice block is repeated
	as long as not the maximum number of practice block have been run (default: 4)
	
	
************************************************************************************************************** 

<block practice_part1>
/ onblockbegin = [
	values.phase = "practice";
	values.countPracticeRounds += 1;
	list.ACC_practice.reset();
	list.RT_practice.reset();
	values.trialcount_block = 0;
	
	if (mod(script.groupId, 2) != 0){
		values.ruleConsistency = 1;		
	} else {
		values.ruleConsistency = 2;	
	}		
]
/ trials = [1 = blockInstruction; 2 = getReady; 3-34 = noreplace(AA, AB, BA, BB); 35 = feedback]
/ ontrialend = [
	if (block.practice_part1.currenttrialnumber > 2 && block.practice_part1.currenttrialnumber < 35){
		list.ACC_practice.appendItem(block.practice_part1.correct);
		list.RT_practice.appendItem(block.practice_part1.latency);		
		values.trialcount_block += 1;
	}
]
/ onblockend = [
	values.ACC_practice1 = expressions.ACC_practice;
	values.RT_practice1 = expressions.medianRT_practice;
]
/ branch = [
	return block.practice_part2;
]
</block>

<block practice_part2>
/ onblockbegin = [
	values.phase = "practice";
	list.ACC_practice.reset();
	list.RT_practice.reset();
	values.trialcount_block = 0;
	
	if (mod(script.groupId, 2) != 0){
		values.ruleConsistency = 2;		
	} else {
		values.ruleConsistency = 1;	
	}		
]
/ trials = [1 = blockInstruction; 2 = getReady; 3-34 = noreplace(AA, AB, BA, BB); 35 = feedback]
/ ontrialend = [
	if (block.practice_part2.currenttrialnumber > 2 && block.practice_part2.currenttrialnumber < 35){
		list.ACC_practice.appendItem(block.practice_part2.correct);
		list.RT_practice.appendItem(block.practice_part2.latency);	
		values.trialcount_block += 1;	
	}
]
/ onblockend = [
	values.ACC_practice2 = expressions.ACC_practice;
	values.RT_practice2 = expressions.medianRT_practice;
]
/ branch = [
	if (monkey.monkeyMode){
		values.practicePass = 1;
	} else if (values.countPracticeRounds >= parameters.maxNumberPracticeRounds){
		if (values.ACC_practice1 < parameters.minPracACC || values.ACC_practice2 < parameters.minPracACC ||
		values.RT_practice1 > parameters.maxPracRT || values.RT_practice2 > parameters.maxPracRT){
			return block.prematureEnd;
		} else {
			values.practicePass = 1;
		}
	} else {
		if (values.ACC_practice1 < parameters.minPracACC || values.ACC_practice2 < parameters.minPracACC ||
			values.RT_practice1 > parameters.maxPracRT || values.RT_practice2 > parameters.maxPracRT){
			return block.practice_part1;
		} else {
			values.practicePass = 1; 
		}
	}
	return null;
]
</block>


<block prematureEnd>
/ trials = [1 = finish]
/ onblockend = [
	script.abort();
]
</block>

**************************************************************************************************************
Test
**************************************************************************************************************

<block testInstructions>
/ onblockbegin = [
	values.phase = "test";
	values.instructselect = 5;
	values.endInstructions = 5;
]
/ trials = [1 = instruction]
</block>

****************************************************************************
* runs the first block of a test round and updates testround Count
(also resets necessary summary data lists)
* RuleConsistency is assigned according to groupid: 
	odd numbers = consistent
	even numbers = inconsistent
* the block ensures that at the end of each test trial,
summary data are collected in respective data lists
* at the end of the block, 
relevant summary data for the first block are stored in respective variables
* automatically calls the second block of the current test round
****************************************************************************


<block test_part1>
/ onblockbegin = [
	list.ACC_test.reset();
	list.RT_test.reset();
	values.countTestRounds += 1;
	list.RT_testround_AA_pooled.reset();
	list.RT_testround_AA.reset();
	list.RT_testround_AB_pooled.reset();
	list.RT_testround_AB.reset();
	list.RT_testround_BA_pooled.reset();
	list.RT_testround_BA.reset();
	list.RT_testround_BB_pooled.reset();
	list.RT_testround_BB.reset();	
	values.trialcount_block = 0;
	
	if (mod(script.groupId, 2) != 0){
		values.ruleConsistency = 1;		
	} else {
		values.ruleConsistency = 2;	
	}		
]
/ trials = [1 = blockInstruction; 2 = getReady; 3-34 = noreplace(AA, AB, BA, BB); 35 = feedback]
/ ontrialend = [
	if (block.test_part1.currenttrialnumber > 2 && block.test_part1.currenttrialnumber < 35){
		list.ACC_test.appendItem(block.test_part1.correct);
		list.RT_test.appendItem(block.test_part1.latency);
		list.testRTs.appendItem(block.test_part1.latency >= parameters.minTestRT);
		values.trialcount_block += 1;
		
		if (block.test_part1.latency <= parameters.maxTestRT){
			if (values.trialcode == "AA"){
				list.RT_testround_AA_pooled.appendItem(block.test_part1.latency);
				list.RT_testround_AA.appendItem(block.test_part1.latency);
			} else if (values.trialcode == "AB"){
				list.RT_testround_AB_pooled.appendItem(block.test_part1.latency);
				list.RT_testround_AB.appendItem(block.test_part1.latency);						
			} else if (values.trialcode == "BA"){
				list.RT_testround_BA_pooled.appendItem(block.test_part1.latency);
				list.RT_testround_BA.appendItem(block.test_part1.latency);						
			} else if (values.trialcode == "BB"){
				list.RT_testround_BB_pooled.appendItem(block.test_part1.latency);
				list.RT_testround_BB.appendItem(block.test_part1.latency);						
			}				
		}

	}

]
/ onblockend = [
	if (values.countTestRounds == 1){
		if (values.RuleConsistency == 1){
			values.meanRT_testround1_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround1_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround1_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround1_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround1_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround1_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround1_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround1_BB_IC = list.RT_testround_BB.mean;			
		}		
	} else if (values.countTestRounds == 2){
		if (values.RuleConsistency == 1){
			values.meanRT_testround2_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround2_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround2_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround2_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround2_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround2_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround2_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround2_BB_IC = list.RT_testround_BB.mean;			
		}			
	} else if (values.countTestRounds == 3){
		if (values.RuleConsistency == 1){
			values.meanRT_testround3_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround3_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround3_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround3_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround3_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround3_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround3_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround3_BB_IC = list.RT_testround_BB.mean;			
		}

		
	}
	
	if (values.minTestblockACC > list.ACC_test.mean){
		values.minTestblockACC = list.ACC_test.mean;
	}	
]	

/ branch = [
	return block.test_part2;
]
</block>

****************************************************************************
* runs the second block of a test round;
(resets necessary summary data lists)
* RuleConsistency is assigned according to groupid: 
	odd numbers = inconsistent
	even numbers = consistent
* the block ensures that at the end of each test trial,
summary data are collected in respective data lists
* at the end of the block, 
relevant summary data for the entire round are stored in respective variables
* calls another block.test_part1 if the maximum number of test rounds has
not run yet
****************************************************************************

<block test_part2>
/ onblockbegin = [
	list.ACC_test.reset();
	list.RT_test.reset();
	list.RT_testround_AA.reset();
	list.RT_testround_AB.reset();
	list.RT_testround_BA.reset();
	list.RT_testround_BB.reset();
	values.trialcount_block = 0;

	if (mod(script.groupId, 2) != 0){
		values.ruleConsistency = 2;		
	} else {
		values.ruleConsistency = 1;	
	}		
]
/ trials = [1 = blockInstruction; 2 = getReady; 3-34 = noreplace(AA, AB, BA, BB); 35 = feedback]
/ ontrialend = [
	if (block.test_part2.currenttrialnumber > 2 && block.test_part2.currenttrialnumber < 35){
		list.ACC_test.appendItem(block.test_part2.correct);	
		list.RT_test.appendItem(block.test_part2.latency);
		list.testRTs.appendItem(block.test_part2.latency >= parameters.minTestRT);
		values.trialcount_block += 1;
		
		if (block.test_part2.latency <= parameters.maxTestRT){
			if (values.trialcode == "AA"){
				list.RT_testround_AA_pooled.appendItem(block.test_part2.latency);
				list.RT_testround_AA.appendItem(block.test_part2.latency);
			} else if (values.trialcode == "AB"){
				list.RT_testround_AB_pooled.appendItem(block.test_part2.latency);
				list.RT_testround_AB.appendItem(block.test_part2.latency);						
			} else if (values.trialcode == "BA"){
				list.RT_testround_BA_pooled.appendItem(block.test_part2.latency);
				list.RT_testround_BA.appendItem(block.test_part2.latency);						
			} else if (values.trialcode == "BB"){
				list.RT_testround_BB_pooled.appendItem(block.test_part2.latency);
				list.RT_testround_BB.appendItem(block.test_part2.latency);						
			}				
		}
	}

]
/ onblockend = [
	if (values.countTestRounds == 1){
		values.SDpooled_testround1_AA = list.RT_testround_AA_pooled.standarddeviation;
		values.SDpooled_testround1_AB = list.RT_testround_AB_pooled.standarddeviation;		
		values.SDpooled_testround1_BA = list.RT_testround_BA_pooled.standarddeviation;
		values.SDpooled_testround1_BB = list.RT_testround_BB_pooled.standarddeviation;		
	
		if (values.RuleConsistency == 1){
			values.meanRT_testround1_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround1_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround1_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround1_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround1_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround1_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround1_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround1_BB_IC = list.RT_testround_BB.mean;			
		}		
	} else if (values.countTestRounds == 2){
		values.SDpooled_testround2_AA = list.RT_testround_AA_pooled.standarddeviation;
		values.SDpooled_testround2_AB = list.RT_testround_AB_pooled.standarddeviation;		
		values.SDpooled_testround2_BA = list.RT_testround_BA_pooled.standarddeviation;
		values.SDpooled_testround2_BB = list.RT_testround_BB_pooled.standarddeviation;	
		
		if (values.RuleConsistency == 1){
			values.meanRT_testround2_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround2_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround2_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround2_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround2_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround2_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround2_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround2_BB_IC = list.RT_testround_BB.mean;			
		}			
	} else if (values.countTestRounds == 3){
		values.SDpooled_testround3_AA = list.RT_testround_AA_pooled.standarddeviation;
		values.SDpooled_testround3_AB = list.RT_testround_AB_pooled.standarddeviation;		
		values.SDpooled_testround3_BA = list.RT_testround_BA_pooled.standarddeviation;
		values.SDpooled_testround3_BB = list.RT_testround_BB_pooled.standarddeviation;	
		
		if (values.RuleConsistency == 1){
			values.meanRT_testround3_AA_C = list.RT_testround_AA.mean;
			values.meanRT_testround3_AB_C = list.RT_testround_AB.mean;
			values.meanRT_testround3_BA_C = list.RT_testround_BA.mean;
			values.meanRT_testround3_BB_C = list.RT_testround_BB.mean;
		} else {
			values.meanRT_testround3_AA_IC = list.RT_testround_AA.mean;
			values.meanRT_testround3_AB_IC = list.RT_testround_AB.mean;
			values.meanRT_testround3_BA_IC = list.RT_testround_BA.mean;
			values.meanRT_testround3_BB_IC = list.RT_testround_BB.mean;			
		}			
	}
	
	if (values.minTestblockACC > list.ACC_test.mean){
		values.minTestblockACC = list.ACC_test.mean;
	}	
]
/ branch = [
	if (values.countTestRounds < parameters.numberOfTestRounds){
		return block.test_part1;		
	}
	return null;
]
</block>


<block finish>
/ trials = [1 = finish]
</block>


