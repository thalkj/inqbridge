<expt irap1>
/ groups = (1 of 2)
/ onexptbegin = [
	values.conditionOrder = "c-ic";
	text.ruleChange.skip = true;
	
	values.responseOptionA_x = list.responseOptionA_x.nextValue;
	values.responseOptionB_x = list.responseOptionB_x.nextValue;
	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;		
	}
	
	list.responseOptionA_x.reset();
	list.responseOptionB_x.reset();
]
/ blocks = [
	1 = instruction;
	2 = practice_part1;
	3 = testInstructions;
	4 = test_part1;	
	5 = finish;
]
</expt>


<expt irap2>
/ groups = (2 of 2)
/ onexptbegin = [
	values.conditionOrder = "ic-c";
	text.ruleChange.skip = true;
	
	values.responseOptionA_x = list.responseOptionA_x.nextValue;
	values.responseOptionB_x = list.responseOptionB_x.nextValue;
	if (values.responseOptionA_x == 25%){
		values.responseOptionA = parameters.leftkey;
		values.responseOptionB = parameters.rightkey;
	} else {
		values.responseOptionA = parameters.rightkey;
		values.responseOptionB = parameters.leftkey;		
	}
	
	list.responseOptionA_x.reset();
	list.responseOptionB_x.reset();
]
/ blocks = [
	1 = instruction;
	2 = practice_part1;
	3 = testInstructions;
	4 = test_part1;	
	5 = finish;
]
</expt>

