/orientation = horizontalequal
</radiobuttons>

<radiobuttons q15>
/caption = "15. I remember my dreams."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
