/orientation = horizontalequal
</radiobuttons>

<radiobuttons q20>
/caption = "20. I have dreamed that I woke up (that is, waking up was part of the dream experience)."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
