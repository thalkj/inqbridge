/orientation = horizontalequal
</radiobuttons>

<radiobuttons q12>
/caption = "12. While awake, I experience a sudden weakness in my body muscles during states of strong emotion such as anger or excitement."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q13>
