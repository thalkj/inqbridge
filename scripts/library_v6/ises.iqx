"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q10>
/caption = "10. I am able to wake myself out of dreams that I find unpleasant or disturbing."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q11>
/caption = "11. I have spells of sudden, overpowering sleepiness during the day."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
