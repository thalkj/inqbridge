"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q18>
/caption = "18. I have dreamed that I was falling."
/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
