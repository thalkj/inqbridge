/ options = (
"Never", 
"Rarely", 
"Infrequently", 
"Occasionally", 
"Frequently",
"Very~nFrequently",
"Regularly"
)
/ optionvalues = ("0", "1", "2", "3", "4", "5", "6")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q14>
