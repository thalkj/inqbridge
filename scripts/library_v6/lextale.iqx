**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = black
/ screencolor = white
/ inputdevice = mouse
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 
values.itemnumber, values.testitem, values.wordstatus, response, correct, latency)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,
expressions.propCorrect, expressions.meanCorrRT,
expressions.numberCorrectWords, expressions.numberCorrectNonwords, 
expressions.HITrate, expressions.FArate,
expressions.avg_percent_correct)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

<values>
/index = ""
/testitem = ""
/itemnumber = ""
/wordstatus = ""
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/propCorrect = list.ACC.mean
/meanCorrRT = list.corrRT.mean
/numberCorrectWords = list.corrRT_words.itemCount
/numberCorrectNonwords = list.corrRT_nonwords.itemCount

/HITrate = list.ACC_words.mean
/FArate = 1 - list.ACC_nonwords.mean

/avg_percent_correct = (((expressions.numberCorrectWords/40)*100) + ((expressions.numberCorrectNonwords/20)*100))/2
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial intro>
/ stimulusframes = [1 = instructions, startbutton]
/ validresponse = (startbutton)
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, score, finish]
/ timeout = 2000
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text testitem>
/ items = testitems
/ select = values.index
/ fontstyle = ("Arial", parameters.testitemSize, false, false, false, false, 5, 1)
/ vjustify = center
/ size = (80%, 50%)
/ erase = false
</text>

<shape backgr_progressbar>
/ shape = rectangle
/ color = lightGray
/ position = (20%, 90%)
/ halign = left
/ valign = bottom
/ size = (63%, 5%)
/ erase = false
</shape>

<shape progressbar>
/ shape = rectangle
/ color = gray
/ position = (20%, 90%)
/ halign = left
/ valign = bottom
/ size = (1%, 5%)
/ erase = false
</shape>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************


*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC>
</list>

<list corrRT>
</list>

<list ACC_words>
</list>

<list corrRT_words>
</list>

<list ACC_nonwords>
</list>

<list corrRT_nonwords>
</list>


**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial lexTALE>
/ ontrialbegin = [
	values.index += 1; //sequential selection of test items
	values.itemnumber = item.itemnumber.item(values.index);	
	values.testitem = item.testitems.item(values.index);
	values.wordstatus = item.wordstatus.item(values.index);
]
/ stimulusframes = [1 = clearScreen, testitem, backgr_yes, yes, backgr_no, no, backgr_progressbar, progressbar]
/ validresponse = (yes,no)
/ iscorrectresponse = [
	return ((trial.lexTALE.response == "yes" && values.wordstatus == 1) || 
	(trial.lexTALE.response == "no" && values.wordstatus == 0))	
]
/ ontrialend = [
	shape.progressbar.width += 1%;

	//summary variables:
	if (values.itemnumber > 0){//first three items are practice items and should not be scored
		list.ACC.appendItem(trial.lexTALE.correct);
		if (trial.lexTALE.correct){
			list.corrRT.appendItem(trial.lexTALE.latency);
		}
		
		//separate summary variables depending on 'wordstatus'
		if (values.wordstatus == 1){
			list.ACC_words.appendItem(trial.lexTALE.correct);
			if (trial.lexTALE.correct){
				list.corrRT_words.appendItem(trial.lexTALE.latency);
			}
		} else {
			list.ACC_nonwords.appendItem(trial.lexTALE.correct);
			if (trial.lexTALE.correct){
				list.corrRT_nonwords.appendItem(trial.lexTALE.latency);
			}			
		}
	}
]
</trial>


**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block intro>
/ trials = [1 = intro]
</block>

<block lexTALE>
/ onblockbegin = [
	values.index = 0;
	shape.progressbar.width = 0%;
]
/ trials = [
	1-63 = lexTALE;
]
</block>

<block finish>
/ trials = [
	1 = finish;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt lexTale>
/ blocks = [
	1 = intro;
	2 = lexTALE;
	3 = finish;
]
</expt>

