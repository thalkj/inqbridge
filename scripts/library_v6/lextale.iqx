<parameters>
/ testitemSize = 7%				//the proportional size of the testitems on screen (default: 7%)

/yesButton_x = 75%				//the horizontal location of the yes-button (default: 75% -> on left hand side)
/noButton_x = 25%				//the horizontal location of the no-button (default: 25% -> on right hand side)

/showScore = true				//true = the final score is presented to participants
								//false = the final score is not presented to participants
</parameters>

