**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************
<instruct>
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ finishlabel = "press [space] to start"
</instruct>

<page recallIntro>
<center><hr><h2>List Learning</h2><hr></center><br>
We present you with a list of words, one word at a time, in the middle of the screen.<br><br>
Pay close attention to each word.<br><br>
Once the list has finished, you will be asked to enter as many of these words as you remember into a provided textbox.<br><br>
You can enter the words in any order.<br><br><br><br>
Start when you are ready.
</page>

<page recallRepeat>
<center><hr><h2>List Learning</h2><hr></center><br>
We are repeating the same list of words as before. Again, pay close attention to each word.<br><br>
You will be asked to enter as many of these words as you remember into a provided textbox, even if you have already done so before. <br><br>
You can enter the words in any order.<br><br><br><br>
Start when you are ready.
</page>

<page delayedRecall>
<center><hr><h2>List Learning</h2><hr></center><br>
Remember the list of words you were shown repeatedly before the break? <br><br> 
You will be asked to enter as many of these words as your remember into a provided textbox.<br><br> 
You can enter the words in any order.<br><br><br><br>
Start when you are ready.
</page>

<page recognition>
<center><hr><h2>List Learning</h2><hr></center><br>
We are going to present you with another list of words, one word at a time. Some of these words were on the earlier list; but some were not.<br><br>  
<div style='background-color:lightGray'><center>For each word, ask the question:<br><br> 
<b>"was this word on the list?"</b>.<br>
If the answer to that question is "Yes", press the "<%parameters.oldKey%>" key.<br>
If the answer to that question is "No", press the "<%parameters.newKey%>" key.</center></div><br><br>
Start when you are ready.
</page>

<page End>
<center><br><br><br><br><br><br>
You have reached the end of the task.<br>
<h2>Thank you!</h2></center>
</page>

<text recallInstructions>
/ items = ("Recall as many of the words from the list as you can.
 Press <Enter> key after each word.")
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ size = (90%, 10%)
</text>

<text recognitionInstructions>
/ items = ("Was this word on the list?

press '<%parameters.oldKey%>' for yes
press '<%parameters.newKey%>' for no")
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text break>
/ items = ("Take a break")
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>


