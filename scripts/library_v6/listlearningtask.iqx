	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial listLearning>
/ stimulusframes = [1 = word]
/ trialduration = parameters.wordSOA
</trial>


************************
immediate Recall
************************

Note: openended.recall 
* presents a textbox to collect all recalled items
(each of these items should ideally be put on a new line in the textbox)
* trial estimates the number of estimated words (whether or not they really are words)
* trial checks which list words have been mentioned 
and counts the number of correctly recalled items.

<openended immediateRecall>
/ stimulusframes = [1 = recallInstructions]
/ pretrialpause = parameters.recallDelay
/ ontrialbegin = [
	values.Recall = "";
	values.countCorrect_Recall = 0;
]
/ size = (20%, 60%)
/ multiline = true
/ charlimit = 5000
/ position = (50%, 80%)
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ monkeyresponse = (
"market,package,elbow,apple,story,carpet,bubble,highway,saddle,powder", 
"story,bubble, carpet,market,elbow,apple,powder",
"package,saddle,elbow,apple,carpet,bubble,highway,powder,story,bank"
"market,package,elbow,apple,story,carpet,buble,highway,saddle,powder")
/ ontrialend = [
	values.Recall = tolower(openended.immediateRecall.response);
	expressions.wordcountEstimate;
	list.wordCountEstimates.insertItem(values.RecallWordEstimate, values.count_allRecallRounds);	
		
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(1));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word1_recall += 1;
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(2));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word2_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(3));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word3_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(4));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word4_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(5));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word5_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(6));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word6_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(7));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word7_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(8));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;	
		values.word8_recall += 1;		
	}
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(9));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word9_recall += 1;		
	}	
	values.tempSearchTarget = "";
	values.tempSearchTarget = concat(",",item.words.item(10));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");
	if (contains(values.Recall, values.tempSearchTarget)){
		values.countCorrect_Recall += 1;
		values.word10_recall += 1;		
	}	
	
	
	values.nr_otherRecalledWords = values.RecallWordEstimate - values.countCorrect_Recall;
	list.intrusions.insertItem(values.nr_otherRecalledWords, values.count_allRecallRounds);	
	expressions.otherWordIntrusions;

	list.accuracy_recall.insertItem(values.countCorrect_Recall, values.count_allRecallRounds);

]
</openended>


************************
break
************************

<trial break>
/ stimulusframes = [1 = break, breakTimer]
/ recorddata = false
/ trialduration = parameters.MinRecognitionDelay;
</trial>

