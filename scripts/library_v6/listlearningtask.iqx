	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/count_immediateRounds:			counts the number of immediate recall trials run (1-4)
/count_allRecallRounds:				counts the number of immediate and delayed recall trials run 

/tempSearchTarget:				helper variable to look for certain words in the recall string
/Recall:						stores the recall text input (with single commas to separate the different words)
/countCorrect_Recall:			tracks the number of correctly recalled words per trial
/recallLength:					helper variable to estimate number of words recalled
/reducedRecall:					helper variable to estimate number of words recalled
/RecallWordEstimate:			stores the computer-derived estimate of the number of words recalled
									Note: see below of algoritm implemented. Algorithm does not check whether the recalled words are actual words.
/helperRecall:					helper variable to analyze recall words

/word1_recall-
/word10_recall:					stores the number of times the first (second, third, etc) word of a list was recalled

/intrusionOther:				stores the character strings contained in the recall string that not list words
									Note: misspelled study words will show up here
/recallIntrusions:				a storage variable that stores all recall intrusion words across the 4 trials									
/nr_otherRecalledWords			stores the number of other recalled words that are not list words
/recognitionScore:				the number of words correctly identified

/trial1_recalledWords-
/trial4_recalledWords:			stores the list of the recalled words for trial1, trial2, trial3, trial4

<values>
/count_immediateRounds = 0
/count_allRecallRounds = 0
/tempSearchTarget = ""
/Recall = "";
/countCorrect_Recall = 0
/recallLength = 0;
/reducedRecall = "";
/RecallWordEstimate = ""
/helperRecall = ""
/word1_recall = ""
/word2_recall = ""
/word3_recall = ""
/word4_recall = ""
/word5_recall = ""
/word6_recall = ""
/word7_recall = ""
/word8_recall = ""
/word9_recall = ""
/word10_recall = ""
/nr_otherRecalledWords = 0
/intrusionOther = ""
/recallIntrusions = ""
/wordCategory = ""
/recognitionScore = 0
/trial1_recalledWords = ""
/trial2_recalledWords = ""
/trial3_recalledWords = ""
/trial4_recalledWords = ""
/delayedRecall_recalledWords = "not run"
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/wordcountEstimate: 	algorithm to estimate the number of words recalled
						-> algorithm replaces 7 possible word separators (" ", ;, etc) with "," in values.Recall
						-> algorithm adds a comma before the first word
						-> algoritm replaces multiple consecutive "," (up to 5) with a single one in values.Recall
						-> algorithm adds a comma at the end of the string
							-> values.Recall is as cleaned up as possible of random word separators
						-> algorithm removes all "," from values.Recall and stores the resulting reduced string in values.reducedRecall
						-> algorithm compares the length of values.reducedRecall to that of values.Recall
						and uses the reduced length to estimate the number of words in between the separators
						NOTE: values.recall will ideally contain only lower letter words separated by a single comma each at
						the end of this function + a start and an ending comma

/removeConsecutiveCommas:	recursive helper function to remove instances of consecutive commas from values.Recall						

/otherWordIntrusions:		function to find falsely recalled words (= words not part of the list)


<expressions>
/wordcountEstimate = {	
	values.Recall = replaceAll(values.Recall, "\", ",");
	values.Recall = replaceAll(values.Recall, "|", ",");	
	values.Recall = replaceAll(values.Recall, "/", ",");	
	values.Recall = replaceAll(values.Recall, ";", ",");	
	values.Recall = replaceAll(values.Recall, " ", ",");	
	values.Recall = replaceAll(values.Recall, ":", ",");
	values.Recall = replaceAll(values.Recall, ".", ",");
	values.Recall = replaceAll(values.Recall, "~n", ",");		
	
	values.Recall = concat(",", values.Recall);
	expressions.removeConsecutiveCommas;
		
	if (!endswith(values.Recall, ",")){
		values.Recall = concat(values.Recall, ",");	
	}

	values.RecallLength = length(values.Recall);
	values.reducedRecall = replaceAll(values.Recall, ",", "");	
	values.RecallWordEstimate= values.RecallLength - length(values.reducedRecall) - 1;
}
/removeConsecutiveCommas = {
	values.Recall = replaceAll(values.Recall, ",,", ",");
	if (contains(values.Recall, ",,")){
		expressions.removeConsecutiveCommas;
	}
}	
/otherWordIntrusions = {
	
	values.helperRecall = values.Recall;
	values.tempSearchTarget = concat(",", item.words.item(1));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");
	
	values.tempSearchTarget = concat(",", item.words.item(2));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(3));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(4));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(5));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(6));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(7));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
	
	values.tempSearchTarget = concat(",", item.words.item(8));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");

	values.tempSearchTarget = concat(",", item.words.item(9));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");

	values.tempSearchTarget = concat(",", item.words.item(10));
	values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
	values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");
	
	if (length(replaceAll(values.helperRecall, ",", "")) > 0){
		values.intrusionOther = values.helperRecall;		
	} else {
		values.intrusionOther = "";
	}
	
	values.recallIntrusions = concat(values.recallIntrusions, values.intrusionOther);
	values.recallIntrusions = concat(values.recallIntrusions, ",");
}
</expressions>

******************************
Summary Variables
******************************
/recallScore:					sum of all correctly recalled items across the 4 immediate recall trials
/delayedRecallScore:			number of correctly recalled items during delayed recall
/mean_WordRecall:				mean of the estimated number of words recalled (immediate recall only) - independent of recall accuracy
/meanRecall:					mean number of correctly recalled words per immediate recall list
/Recall1:						number of correctly recalled words on list 1 
/Recall2:						number of correctly recalled words on list 2  
/Recall3:						number of correctly recalled words on list 3  
/Recall4:						number of correctly recalled words on list 4 

/prop_word1Recall-
/prop_word10Recall:				stores the immediate recall proportion of words in study positions 1 - 10 across the number of trials (Max: 4/4 for each item)
/meanIntrusions:				mean number of intrusions on recall lists (recalling words that were not on the list)

/r_hits_recognition:			hit rate during recognition (hit => participant categorized old word as 'old')
/r_FAs_recognition :			false alarm rate during recognition (false alarm => participant categorized new word as 'old')

Note: z-score calculations: adjustments (see Gregg & Sedikides, 2010, p.148)
If the hit rate / FA rate is 0 => 0.005 is used instead (aka 0.005 is added to the hit/FA rate)
IF the hit rate / FA rate is 1.0 => 0.995 is used instead (aka 0.005 is subtracted from the hit/FA rate)

/z_hr_recognition:				z-score of hit rate
/z_fr_recognition:				z-score of false alarm rate
/dprime_recognition:			Computes d' (parametric measure of discriminability).

<expressions>
/recallScore = 
if (list.accuracy_recall.itemCount > 0){
	if (list.accuracy_recall.itemCount > 1){

		if (list.accuracy_recall.itemCount > 2){
			if (list.accuracy_recall.itemCount > 3){
				list.accuracy_recall.item(1) + list.accuracy_recall.item(2) + list.accuracy_recall.item(3) + list.accuracy_recall.item(4);
			} else {
				list.accuracy_recall.item(1) + list.accuracy_recall.item(2) + list.accuracy_recall.item(3);
			}//only three items
		} else {
			list.accuracy_recall.item(1) + list.accuracy_recall.item(2);
		}//only two items	
	} else {
		list.accuracy_recall.item(1);
	}		
} else {
	0; 
}

/delayedRecallScore = if (list.accuracy_recall.itemCount > 4) list.accuracy_recall.item(5) else "not run"
/mean_WordRecall = 
if (list.wordCountEstimates.itemCount > 0){
	if (list.wordCountEstimates.itemCount > 1){
		if (list.wordCountEstimates.itemCount > 2){
			if (list.wordCountEstimates.itemCount > 3){
				(list.wordCountEstimates.item(1) + list.wordCountEstimates.item(2) + list.wordCountEstimates.item(3) + list.wordCountEstimates.item(4))/values.count_immediateRounds;
			} else {
				(list.wordCountEstimates.item(1) + list.wordCountEstimates.item(2) + list.wordCountEstimates.item(3))/values.count_immediateRounds;
			}
		} else {
			(list.wordCountEstimates.item(1) + list.wordCountEstimates.item(2))/values.count_immediateRounds;
		}
	} else {
		(list.wordCountEstimates.item(1))/values.count_immediateRounds;
	}		
} else {
	0; 
}

/meanRecall = expressions.recallScore/values.count_immediateRounds

/Recall1 = if (list.accuracy_recall.itemCount >= 1) list.accuracy_recall.item(1) else "NA"
/Recall2 = if (list.accuracy_recall.itemCount >= 2) list.accuracy_recall.item(2) else "NA"
/Recall3 = if (list.accuracy_recall.itemCount >= 3) list.accuracy_recall.item(3) else "NA"
/Recall4 = if (list.accuracy_recall.itemCount >= 4) list.accuracy_recall.item(4) else "NA"

/meanIntrusions = 
if (list.intrusions.itemCount > 0){
	if (list.intrusions.itemCount > 1){

		if (list.intrusions.itemCount > 2){
			if (list.intrusions.itemCount > 3){
				(list.intrusions.item(1) + list.intrusions.item(2) + list.intrusions.item(3) + list.intrusions.item(4))/values.count_immediateRounds;
			} else {
				(list.intrusions.item(1) + list.intrusions.item(2) + list.intrusions.item(3))/values.count_immediateRounds;
			}
		} else {
			(list.intrusions.item(1) + list.intrusions.item(2))/values.count_immediateRounds;
		}
	} else {
		list.intrusions.item(1)/values.count_immediateRounds;
	}		
} else {
	0; 
}

/prop_word1Recall = values.word1_recall/values.count_immediateRounds
/prop_word2Recall = values.word2_recall/values.count_immediateRounds
/prop_word3Recall = values.word3_recall/values.count_immediateRounds
/prop_word4Recall = values.word4_recall/values.count_immediateRounds
/prop_word5Recall = values.word5_recall/values.count_immediateRounds
/prop_word6Recall = values.word6_recall/values.count_immediateRounds
/prop_word7Recall = values.word7_recall/values.count_immediateRounds
/prop_word8Recall = values.word8_recall/values.count_immediateRounds
/prop_word9Recall = values.word9_recall/values.count_immediateRounds
/prop_word10Recall = values.word10_recall/values.count_immediateRounds

/r_hits_recognition = list.hits.mean
/r_misses_recognition = (1-expressions.r_hits_recognition)
/r_FAs_recognition = list.falseAlarms.mean
/r_CRS_recognition = (1-expressions.r_FAs_recognition)

/z_hr_recognition = if (expressions.r_hits_recognition == 0){
	zofp(expressions.r_hits_recognition + 0.005);
} else if (expressions.r_hits_recognition == 1){
	zofp(expressions.r_hits_recognition - 0.005);
} else {
	zofp(expressions.r_hits_recognition);
}

/z_fr_recognition = if (expressions.r_FAs_recognition == 0){
	zofp(expressions.r_FAs_recognition + 0.005);
} else if (expressions.r_FAs_recognition == 1){
	zofp(expressions.r_FAs_recognition - 0.005);
} else {
	zofp(expressions.r_FAs_recognition);	
}

/dprime_recognition = (expressions.z_hr_recognition-expressions.z_fr_recognition)
/c_recognition = return (-1*((expressions.z_hr_recognition + expressions.z_fr_recognition)/2))
</expressions>

