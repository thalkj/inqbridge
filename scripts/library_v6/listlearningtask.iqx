************************
delayed Recognition
************************

<trial recognition>
/ stimulusframes = [1 = recognitionWord, recognitionInstructions, ]
/ validresponse = (parameters.oldKey, parameters.newKey)
/ iscorrectresponse = [
	values.wordCategory = item.wordCategories.item(text.recognitionWord.currentItemNumber);

	return (
	(values.wordCategory == 1 && trial.recognition.responseText == parameters.oldKey) ||
	(values.wordCategory == 0 && trial.recognition.responseText == parameters.newKey));
]
/ ontrialend = [
	values.wordCategory = item.wordCategories.item(text.recognitionWord.currentItemNumber);
	if (values.wordCategory == 1){
		list.hits.appendItem(trial.recognition.correct);
		values.recognitionScore += trial.recognition.correct;
	} else {
		list.falseAlarms.appendItem(trial.recognition.error);
		values.recognitionScore += trial.recognition.correct;		
	}

]
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block recallIntro>
/ preinstructions = (recallIntro)
</block>

<block recallRepeat>
/ preinstructions = (recallRepeat)
</block>


<block recall>
/ onblockbegin = [
	values.count_immediateRounds += 1;
	values.count_allRecallRounds += 1;
	values.tempSearchTarget = "";
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.recallLength = 0;
	values.reducedRecall = "";
	values.RecallWordEstimate = "";
	values.helperRecall = "";
	values.nr_otherRecalledWords = 0;
	values.intrusionOther = "";	
	values.wordCategory = 1;
	values.recallIntrusions = concat(values.recallIntrusions, values.count_allRecallRounds);
	values.recallIntrusions = concat(values.recallIntrusions, ":");
	
]
/ trials = [1-10 = listLearning; 11 = immediateRecall]
/ onblockend = [
	if (values.count_immediateRounds == 1){
		values.trial1_recalledWords = values.Recall;
	} else if (values.count_immediateRounds == 2){
		values.trial2_recalledWords = values.Recall;
	} else if (values.count_immediateRounds == 3){
		values.trial3_recalledWords = values.Recall;
	} else if (values.count_immediateRounds == 4){
		values.trial4_recalledWords = values.Recall;
	}
]
</block>

<block break>
/ trials = [1 = break]
/ recorddata = false
</block>

<block delayedRecall>
/ preinstructions = (delayedRecall)
/ skip = [
	parameters.runDelayedRecall == false;
]
/ onblockbegin = [
	values.count_allRecallRounds += 1;
	values.tempSearchTarget = "";
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.recallLength = 0;
	values.reducedRecall = "";
	values.RecallWordEstimate = "";
	values.helperRecall = "";
	values.nr_otherRecalledWords = 0;
	values.intrusionOther = "";	
	values.wordCategory = 1;
	values.recallIntrusions = concat(values.recallIntrusions, values.count_allRecallRounds);
	values.recallIntrusions = concat(values.recallIntrusions, ":");
	
]
/ trials = [1 = delayedRecall]
/ onblockend = [
	values.delayedRecall_recalledWords = values.Recall;
]
</block>



Note: block.recognition
* presents 20 items (10 old, 10 new) in predetermined order
<block recognition>
/ onblockbegin = [
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.RecallWordEstimate = "";
	values.nr_otherRecalledWords = 0;
	values.intrusionOther = "";		
]
/ preinstructions = (recognition)
/ trials = [1-20 = recognition]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt listLeaning>
/ blocks = [
	1 = recallIntro;
	2 = recall;
	3 = recallRepeat;
	4 = recall;
	5 = recallRepeat;
	6 = recall;
	7 = recallRepeat;
	8 = recall;
	9 = break;
	10 = delayedRecall;
	11 = recognition;
]

</expt>


