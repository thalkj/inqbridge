**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/oldKey = "Y"
/newKey = "N"

/wordSize = 8%

/wordSOA = 2000
/recallDelay = 0
/MinRecognitionDelay = 900000

/runDelayedRecall = true
</parameters>


