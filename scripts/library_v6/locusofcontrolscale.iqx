	}
}

/IEscore_percentile_M = {
	if (expressions.IEscore <= 0) {
		0.87;
	} else if (expressions.IEscore <= 1){
		2.61;	
	} else if (expressions.IEscore <= 2){
		6.43;
	} else if (expressions.IEscore <= 3) {
		11.48;
	} else if (expressions.IEscore <= 4) {
