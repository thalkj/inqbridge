**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,

expressions.MASQD30_Total, expressions.MASQD30_AA, expressions.MASQD30_AD, expressions.MASQD30_GD,

//individual responses
radioButtons.q1_GD.response,
radioButtons.q2_AA.response,
radioButtons.q3R_AD.response,
radioButtons.q4_GD.response,
radioButtons.q5_AA.response,
radioButtons.q6R_AD.response,
radioButtons.q7_GD.response,
radioButtons.q8_AA.response,
radioButtons.q9R_AD.response,
radioButtons.q10_GD.response,
radioButtons.q11R_AD.response,
radioButtons.q12_GD.response,
radioButtons.q13_GD.response,
radioButtons.q14R_AD.response,
radioButtons.q15_AA.response,
radioButtons.q16R_AD.response,
radioButtons.q17_GD.response,
radioButtons.q18_AA.response,
radioButtons.q19R_AD.response,
radioButtons.q20_AA.response,
radioButtons.q21_AA.response,
radioButtons.q22R_AD.response,
radioButtons.q23_GD.response,
radioButtons.q24_AA.response,
radioButtons.q25_GD.response,
radioButtons.q26R_AD.response,
radioButtons.q27_AA.response,
radioButtons.q28_GD.response,
radioButtons.q29R_AD.response,
radioButtons.q30_AA.response)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/ MASQD30_GD = return (radioButtons.q1_GD.response + radioButtons.q4_GD.response + radioButtons.q7_GD.response +
radioButtons.q10_GD.response + radioButtons.q12_GD.response + radioButtons.q13_GD.response +
radioButtons.q17_GD.response + radioButtons.q23_GD.response + radioButtons.q25_GD.response +
radioButtons.q28_GD.response)

/ MASQD30_AD = return (radioButtons.q3R_AD.response + radioButtons.q6R_AD.response + radioButtons.q9R_AD.response +
radioButtons.q11R_AD.response + radioButtons.q14R_AD.response + radioButtons.q16R_AD.response +
radioButtons.q19R_AD.response + radioButtons.q22R_AD.response + radioButtons.q26R_AD.response +
radioButtons.q29R_AD.response)

/ MASQD30_AA = return (radioButtons.q2_AA.response + radioButtons.q5_AA.response + radioButtons.q8_AA.response +
radioButtons.q15_AA.response + radioButtons.q18_AA.response + radioButtons.q20_AA.response + 
radioButtons.q21_AA.response + radioButtons.q24_AA.response + radioButtons.q27_AA.response +
radioButtons.q30_AA.response)

/ MASQD30_Total = return (expressions.MASQD30_AA + expressions.MASQD30_AD + expressions.MASQD30_GD)

</expressions>

*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<radioButtons q1_GD>
/ caption = "1. Felt confused"
/ options = ("not at all", "a little bit", "moderately", "quite a bit", "extremely")
/ optionvalues = ("1", "2", "3", "4", "5")
/ required = true
/ orientation = horizontalequal
</radioButtons>

<radioButtons q2_AA>
