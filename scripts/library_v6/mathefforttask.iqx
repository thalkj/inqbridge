/ countLevel1 = 0
/ countLevel2 = 0
/ countLevel3 = 0
/ countLevel4 = 0
/ countLevel5 = 0
/ countcorrectLevel1 = 0
/ countcorrectLevel2 = 0
/ countcorrectLevel3 = 0
/ countcorrectLevel4 = 0
/ countcorrectLevel5 = 0

/ countLevelChange = 0
/ selectFeedback = 0
/ selectInstructions = 0
</values>


**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************	
		
/METScore: calculates the final METScore by adjusting the number of correctly solved problems on each level by
			the difficulty factor of that level:
			
			difficulty factor for level 5 => 5/5 = 1
			difficulty factor for level 4 => 4/5 = 0.8
			difficulty factor for level 3 => 3/5 = 0.6
			difficulty factor for level 2 => 2/5 = 0.4
			difficulty factor for level 1 => 1/5 = 0.2	

			If a person solves 100 level 5 problems correctly, the METScore = 1 * parameters.maxNrTrials = 100 (the top score), if the number of problems provided is 100
			If a person solves 100 level 4 problems correctly, the METScore = 0.8 * parameters.maxNrTrials = 80
			If a person solves 100 level 3 problems correctly, the METScore = 0.6 * parameters.maxNrTrials = 60
			If a person solves 100 level 2 problems correctly, the METScore = 0.4 * parameters.maxNrTrials = 40
			If a person solves 100 level 1 problems correctly, the METScore = 0.2 * parameters.maxNrTrials = 20			
	
<expressions>
/ METScore = values.countcorrectLevel5*1 + values.countcorrectLevel4*0.8 +
 values.countcorrectLevel3*0.6 + values.countcorrectLevel2*0.4 + values.countCorrectLevel1*0.2

/finalMessage = if (parameters.presentFinalScore == true) {
	"Your final score: <%expressions.METScore%>";
} else {
	"";
}
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text instructions>
/ items = instructions
/ select = values.selectInstructions
/ position = (10%, 10%)
/ valign = top
/ halign = left
/ hjustify = left
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ erase = false
/ size = (80%, 80%)
/ txbgcolor = white
</text>

<trial intro>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ stimulusframes = [1 = clearScreen, instructions, continue]
/ validresponse = (" ")
/ recorddata = false
</trial>

<trial intro2>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ ontrialbegin = [
	values.number1 = list.level1.nextValue;
	values.number2 = list.level1.nextValue;
	values.number3 = list.level1.nextValue;
	values.number4 = list.level1.nextValue;
	values.number5 = list.level1.nextValue;
	
	trial.intro2.insertStimulusTime(shape.numberErase, (0*parameters.ISI + 1*parameters.numberDuration + 500));
	trial.intro2.insertStimulusTime(text.number2, (1*parameters.numberDuration + 1*parameters.ISI + 500));
	if (values.nrDigits > 2){
		trial.intro2.insertStimulusTime(shape.numberErase, (1*parameters.ISI + 2*parameters.numberDuration + 500));
		trial.intro2.insertStimulusTime(text.number3, (2*parameters.numberDuration + 2*parameters.ISI + 500));		
	}
	if (values.nrDigits > 3){
		trial.intro2.insertStimulusTime(shape.numberErase, (2*parameters.ISI + 3*parameters.numberDuration + 500));
		trial.intro2.insertStimulusTime(text.number4, (3*parameters.numberDuration + 3*parameters.ISI + 500));		
	}
	if (values.nrDigits > 4){
		trial.intro2.insertStimulusTime(shape.numberErase, (3*parameters.ISI + 4*parameters.numberDuration + 500));
		trial.intro2.insertStimulusTime(text.number5, (4*parameters.numberDuration + 4*parameters.ISI + 500));		
	}	
]
/ stimulustimes = [0 = clearScreen, instructions; 
500 = number1]
/ timeout =(values.nrDigits*parameters.numberDuration + (values.nrDigits-1)*parameters.ISI + 500)
/ recorddata = false
/ ontrialend = [
	trial.intro2.resetStimulusFrames();
]
</trial>

<trial intro3>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ stimulusframes = [1 = clearScreen, instructions, demostart]
/ validresponse = (" ")
/ recorddata = false
</trial>


<trial intro4>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ stimulusframes = [1 = clearScreen, instructions, continue]
/ validresponse = (" ")
/ branch = [
	return trial.intro5;
]
/ recorddata = false
</trial>

<trial intro5>
/ ontrialbegin = [
	values.selectInstructions += 1;
]
/ stimulusframes = [1 = clearScreen, instructions, start, back]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro5.responseText == "B") {
		values.selectInstructions -= 2;
		return trial.intro4;
	}
]
/ recorddata = false
</trial>



