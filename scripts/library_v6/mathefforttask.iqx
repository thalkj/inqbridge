**************************************************************************************************************

<text number1>
/ items = ("<%values.number1%>")
/ fontstyle = ("Arial", parameters.numberSize, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ vjustify = center
</text>

<text number2>
/ items = ("<%values.number2%>")
/ fontstyle = ("Arial", parameters.numberSize, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ vjustify = center
</text>

<text number3>
/ items = ("<%values.number3%>")
/ fontstyle = ("Arial", parameters.numberSize, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ vjustify = center
</text>

<text number4>
/ items = ("<%values.number4%>")
/ fontstyle = ("Arial", parameters.numberSize, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ vjustify = center
</text>

<text number5>
/ items = ("<%values.number5%>")
/ fontstyle = ("Arial", parameters.numberSize, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ vjustify = center
</text>

<shape numberErase>
/ shape = rectangle
/ position = (50%, 50%)
/ size = (20%, parameters.numberSize)
/ erase = false
/ color = white
</shape>


<text feedback>
/ items = feedback
/ select = values.selectFeedback
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 20%)
/ hjustify = center
/ vjustify = center
</text>

**************************************************************************************************************
**************************************************************************************************************
	PRACTICE TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial getReady_practice>
/ ontrialbegin = [
	values.changeLevel = 0;
	values.rt="";
	values.ACC = "";
	values.solution = "";
	values.currentResponse = "";
]
/ stimulusframes = [1 = clearScreen, getReady_Practice]
/ timeout = parameters.ITI
/ branch = [
	return trial.numberPresentations_practice;
]
/ posttrialpause = parameters.ISI
/ recorddata = false
</trial>


<trial numberPresentations_practice>
/ ontrialbegin = [
	if (values.currentLevel == 1) {
		values.number1 = list.level1.nextValue;
		values.number2 = list.level1.nextValue;
		values.number3 = list.level1.nextValue;
		values.number4 = list.level1.nextValue;
		values.number5 = list.level1.nextValue;
		values.countLevel1 += 1;
	} else if (values.currentLevel == 2) {
		values.number1 = list.level2.nextValue;
		values.number2 = list.level2.nextValue;
		values.number3 = list.level2.nextValue;
		values.number4 = list.level2.nextValue;
		values.number5 = list.level2.nextValue;
		values.countLevel2 += 1;
	} else if (values.currentLevel == 3) {
		values.number1 = list.level3.nextValue;
		values.number2 = list.level3.nextValue;
		values.number3 = list.level3.nextValue;
		values.number4 = list.level3.nextValue;
		values.number5 = list.level3.nextValue;
		values.countlevel3 += 1;
	} else if (values.currentLevel == 4) {
		values.number1 = list.level4.nextValue;
		values.number2 = list.level4.nextValue;
		values.number3 = list.level4.nextValue;
		values.number4 = list.level4.nextValue;
		values.number5 = list.level4.nextValue;
		values.countLevel4 += 1;
	} else if (values.currentLevel == 5) {
		values.number1 = list.level5.nextValue;
		values.number2 = list.level5.nextValue;
		values.number3 = list.level5.nextValue;
		values.number4 = list.level5.nextValue;
		values.number5 = list.level5.nextValue;
		values.countLevel5 += 1;
	}
	if (values.nrDigits < 5){
		values.number5 = 0;
	}
	if (values.nrDigits < 4){
		values.number4 = 0;
	}
	if (values.nrDigits < 3){
		values.number3 = 0;
	}
	
	trial.numberPresentations_practice.insertStimulusTime(clearScreen, (0*parameters.ISI + 1*parameters.numberDuration));
	trial.numberPresentations_practice.insertStimulusTime(text.number2, (1*parameters.numberDuration + 1*parameters.ISI));
	if (values.nrDigits > 2){
		trial.numberPresentations_practice.insertStimulusTime(clearScreen, (1*parameters.ISI + 2*parameters.numberDuration));
		trial.numberPresentations_practice.insertStimulusTime(text.number3, (2*parameters.numberDuration + 2*parameters.ISI));		
	}
	if (values.nrDigits > 3){
		trial.numberPresentations_practice.insertStimulusTime(clearScreen, (2*parameters.ISI + 3*parameters.numberDuration));
		trial.numberPresentations_practice.insertStimulusTime(text.number4, (3*parameters.numberDuration + 3*parameters.ISI));		
	}
	if (values.nrDigits > 4){
		trial.numberPresentations_practice.insertStimulusTime(clearScreen, (3*parameters.ISI + 4*parameters.numberDuration));
		trial.numberPresentations_practice.insertStimulusTime(text.number5, (4*parameters.numberDuration + 4*parameters.ISI));		
	}	

]
/ stimulustimes = [0 = number1]
/ trialduration = (values.nrDigits*parameters.numberDuration + (values.nrDigits-1)*parameters.ISI)
/ ontrialend = [
	trial.numberPresentations_practice.resetStimulusFrames();
	values.solution = values.number1 + values.number2 + values.number3 + values.number4 + values.number5;
]
/ branch = [
	return surveypage.response_practice;
]
/ recorddata = false
</trial>

<surveypage response_practice>
/ questions = [1 = response]
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ showbackbutton = false
/ showmousecursor = true
/ showpagenumbers = false
/ showquestionnumbers = false
/ ontrialend = [
	values.currentResponse = textbox.response.response;
	
	if (values.currentResponse == values.solution) {
		values.ACC = 1;
	} else {
		values.ACC = 0;
	}
	values.rt = surveypage.response_practice.latency;
	
]
/ nextbuttonposition = (45%, 70%)
/ finishlabel = "submit"
/ recorddata = true
/ branch = [
	return trial.practiceFeedback;
]
/ timeout = parameters.RW
</surveypage>

<trial practicefeedback>
/ ontrialbegin = [
	if (values.ACC == 1) {
		values.selectFeedback = 1;
		text.feedback.textColor = green;
	} else {
		values.selectFeedback = 2;
		text.feedback.textColor = red;
	}
]
/ stimulusframes = [1 = clearScreen, feedback]
/ trialduration = 2000
/ recorddata = false
/ ontrialend = [
	values.currentLevel += 1;
]
</trial>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<surveypage chooseLevel>
/ ontrialbegin = [
	values.countTrialsCurrentLevel = 0;
]
/ questions = [1 = chooseLevel]
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ showbackbutton = false
/ showmousecursor = true
/ showpagenumbers = false
/ showquestionnumbers = false
/ ontrialend = [
	values.previousLevel = values.currentLevel;
	if (radiobuttons.chooseLevel.response == "level1") {
		values.currentLevel = 1;
	} else if (radiobuttons.chooseLevel.response == "level2") {
		values.currentLevel = 2;
	} else if (radiobuttons.chooseLevel.response == "level3") {
		values.currentLevel = 3;
	} else if (radiobuttons.chooseLevel.response == "level4") {
		values.currentLevel = 4;
	} else if (radiobuttons.chooseLevel.response == "level5") {
		values.currentLevel = 5;
	}
	if (values.previousLevel != 0) {
		if (values.currentlevel != values.previousLevel) {
			values.countLevelChange += 1;
		}
	}
]
/ branch = [
	trial.getReady;
]
/ nextbuttonposition = (10%, 40%)
/ finishlabel = "submit"
/ recorddata = false
</surveypage>


<trial getReady>
/ ontrialbegin = [
	values.changeLevel = 0;
	values.rt="";
	values.ACC = "";
	values.solution = "";
	values.currentResponse = "";
]
/ stimulusframes = [1 = clearScreen, getReady]
/ timeout = parameters.ITI
/ branch = [
	return trial.numberPresentations;
]
/ posttrialpause = parameters.ISI
/ recorddata = false
</trial>


<trial numberPresentations>
/ ontrialbegin = [
	values.countTotalTrials += 1;
	values.countTrialsCurrentLevel += 1;
	if (values.currentLevel == 1) {
		values.number1 = list.level1.nextValue;
		values.number2 = list.level1.nextValue;
		values.number3 = list.level1.nextValue;
		values.number4 = list.level1.nextValue;
		values.number5 = list.level1.nextValue;
		values.countLevel1 += 1;
	} else if (values.currentLevel == 2) {
		values.number1 = list.level2.nextValue;
		values.number2 = list.level2.nextValue;
		values.number3 = list.level2.nextValue;
		values.number4 = list.level2.nextValue;
		values.number5 = list.level2.nextValue;
		values.countLevel2 += 1;
	} else if (values.currentLevel == 3) {
		values.number1 = list.level3.nextValue;
		values.number2 = list.level3.nextValue;
		values.number3 = list.level3.nextValue;
		values.number4 = list.level3.nextValue;
		values.number5 = list.level3.nextValue;
		values.countlevel3 += 1;
	} else if (values.currentLevel == 4) {
		values.number1 = list.level4.nextValue;
		values.number2 = list.level4.nextValue;
		values.number3 = list.level4.nextValue;
		values.number4 = list.level4.nextValue;
		values.number5 = list.level4.nextValue;
		values.countLevel4 += 1;
	} else if (values.currentLevel == 5) {
		values.number1 = list.level5.nextValue;
		values.number2 = list.level5.nextValue;
		values.number3 = list.level5.nextValue;
		values.number4 = list.level5.nextValue;
		values.number5 = list.level5.nextValue;
		values.countLevel5 += 1;
	}
	if (values.nrDigits < 5){
		values.number5 = 0;
	}
	if (values.nrDigits < 4){
		values.number4 = 0;
	}
	if (values.nrDigits < 3){
		values.number3 = 0;
	}
	
	trial.numberPresentations.insertStimulusTime(clearScreen, (0*parameters.ISI + 1*parameters.numberDuration));
	trial.numberPresentations.insertStimulusTime(text.number2, (1*parameters.numberDuration + 1*parameters.ISI));
	
	if (values.nrDigits > 2){
		trial.numberPresentations.insertStimulusTime(clearScreen, (1*parameters.ISI + 2*parameters.numberDuration));
		trial.numberPresentations.insertStimulusTime(text.number3, (2*parameters.numberDuration + 2*parameters.ISI));		
	}
	if (values.nrDigits > 3){
		trial.numberPresentations.insertStimulusTime(clearScreen, (2*parameters.ISI + 3*parameters.numberDuration));
		trial.numberPresentations.insertStimulusTime(text.number4, (3*parameters.numberDuration + 3*parameters.ISI));		
	}
	if (values.nrDigits > 4){
		trial.numberPresentations.insertStimulusTime(clearScreen, (3*parameters.ISI + 4*parameters.numberDuration));
		trial.numberPresentations.insertStimulusTime(text.number5, (4*parameters.numberDuration + 4*parameters.ISI));		
	}	
]
/ stimulustimes = [0 = number1]
/ trialduration = (values.nrDigits*parameters.numberDuration + (values.nrDigits-1)*parameters.ISI)
/ ontrialend = [
	trial.numberPresentations.resetStimulusFrames();
	values.solution = values.number1 + values.number2 + values.number3 + values.number4 + values.number5;
]
/ branch = [
	return surveypage.response;
]
/ recorddata = false
</trial>

<surveypage response>
/ questions = [1 = response, changeLevel]
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ responsefontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ timeout = parameters.RW
/ showbackbutton = false
/ showmousecursor = true
/ showpagenumbers = false
/ showquestionnumbers = false
/ ontrialend = [
	if (radiobuttons.changeLevel.response == "Yes") {
		values.changeLevel = 1;
	} else {
		values.changeLevel = 0;
	}
	values.currentResponse = textbox.response.response;
	if (monkey.monkeyMode && replace(0,1) == 1){
		values.currentResponse = values.solution;
	}
	if (values.currentResponse == values.solution) {
		values.ACC = 1;
	} else {
		values.ACC = 0;
	}
	if (values.currentLevel == 1) {
		values.countcorrectLevel1 += values.ACC;
	} else if (values.currentLevel == 2) {
		values.countcorrectLevel2 += values.ACC;
	} else if (values.currentLevel == 3) {
		values.countcorrectLevel3 += values.ACC;
	} else if (values.currentLevel == 4) {
		values.countcorrectLevel4 += values.ACC;
	} else if (values.currentLevel == 5) {
		values.countcorrectLevel5 += values.ACC;
	}
	values.rt = surveypage.response.latency;
]
/ branch = [
	if (values.changeLevel == 1) {
		return surveypage.chooseLevel;
	} else {
		if (values.countTrialsCurrentLevel == parameters.numberBatchedProblems) {
			values.countTrialsCurrentLevel = 0;
			return surveypage.chooseLevel;
		} else {
			return trial.getReady;
		}
	}
]
/ nextbuttonposition = (45%, 70%)
/ finishlabel = "submit"
/ recorddata = true
</surveypage>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block intro>
/ onblockbegin = [
	values.currentLevel = 1;
]
/ trials = [
	1= intro; 
	2 = intro2; 
	3 = intro3 ; 
	4-8 = getReady_practice; 
	9=intro4;
]
</block>

<block met>
/ onblockbegin = [
	values.countTotalTrials = 0;
	values.countLevel1 = 0;
	values.countcorrectLevel1 = 0;
	values.countLevel2 = 0;
	values.countcorrectLevel2 = 0;	
	values.countLevel3 = 0;
	values.countcorrectLevel3 = 0;
	values.countLevel4 = 0;
	values.countcorrectLevel4 = 0;	
	values.countLevel5 = 0;
	values.countcorrectLevel5 = 0;	
]
/ trials = [1 = chooseLevel]
/ stop = [
	values.countTotalTrials > parameters.maxNrTrials;
]
/ onblockend = [
	if (values.countTotalTrials > parameters.maxNrTrials){
		values.countTotalTrials -= 1;
		
		if (values.currentLevel == 1){
			values.countLevel1 -= 1;
		} else if (values.currentLevel == 2){
			values.countLevel2 -= 1;
		} else if (values.currentLevel == 3){
			values.countLevel3 -= 1;
		} else if (values.currentLevel == 4){
			values.countLevel4 -= 1;
		} else if (values.currentLevel == 5){
			values.countLevel5 -= 1;
		}
	}
]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt mathEffort>
/ onexptbegin = [
	if (parameters.numberOfDigits < 2){
		values.nrDigits = 2;
	} else if (parameters.numberOfDigits > 5){
		values.nrDigits = 5;
	} else {
		values.nrDigits = parameters.numberOfDigits;		
	}
]
/ blocks = [
	1 = intro; 
	2 = met;
]

</expt>


**************************************************************************************************************
												End of File
**************************************************************************************************************