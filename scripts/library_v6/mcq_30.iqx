*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************

<surveypage MCQ_30_1>
/caption ="<%parameters.pageinstructions%>"
/questions = [1 = q1_pb, q2_ud, q3_cs]
</surveypage>

<surveypage MCQ_30_2>
/caption ="Please respond to all the items, there are no right or wrong answers.
"
/questions = [1 = q4_ud, q5_cs, q6_ct]
