/skipIntro:						true (1) = the intro and practice trials are skipped
								false (0) = the intro and practice trials are run

<values>
/countCategorizationTrials = 0
/countCategorizationBlocks = 0
/responseCategory = ""
/valence = ""

/meKey = 0
/notmeKey = 0
/skipIntro = 0
</values>

