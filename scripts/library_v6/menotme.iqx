**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/leftKey = "E"
/rightKey = "I"

/leftcategory = 1
/leftcategory_label = "me"
/rightcategory = 2
/rightcategory_label = "not me"

/traitSize = 8%
/iti = 1000
/readyDuration = 5000
/nrCategorizationBlocks = 1
</parameters>

