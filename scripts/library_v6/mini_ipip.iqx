*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************

<surveypage mini_ipip_1>
/ caption = "Describe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age."
/ subcaption = ""
/questions = [1 = q1_E, q2_A, q3_C]
</surveypage>

<surveypage mini_ipip_2>
/ caption = "Describe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age."
/ subcaption = ""
/questions = [1 = q4_N, q5_I, q6R_E]
</surveypage>

