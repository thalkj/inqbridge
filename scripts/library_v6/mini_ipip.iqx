**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.6.1.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.6.1.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = (0, 0, 0)
</defaults>


**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,
expressions.miniIPIP_Extraversion,
expressions.miniIPIP_Agreeableness,
expressions.miniIPIP_Conscientiousness,
expressions.miniIPIP_Neuroticism,
expressions.miniIPIP_Imagination,

//raw responses
radiobuttons.q1_E.response,
radiobuttons.q2_A.response,
radiobuttons.q3_C.response,
radiobuttons.q4_N.response,
radiobuttons.q5_I.response,
radiobuttons.q6R_E.response,
radiobuttons.q7R_A.response,
radiobuttons.q8R_C.response,
radiobuttons.q9R_N.response,
radiobuttons.q10R_I.response,
radiobuttons.q11_E.response,
radiobuttons.q12_A.response,
radiobuttons.q13_C.response,
radiobuttons.q14_N.response,
radiobuttons.q15R_I.response,
radiobuttons.q16R_E.response,
radiobuttons.q17R_A.response,
radiobuttons.q18R_C.response,
radiobuttons.q19R_N.response,
radiobuttons.q20R_I.response
)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/ miniIPIP_Extraversion = return (radiobuttons.q1_E.response + radiobuttons.q6R_E.response + radiobuttons.q11_E.response + radiobuttons.q16R_E.response)
/ miniIPIP_Agreeableness = return (radiobuttons.q2_A.response + radiobuttons.q7R_A.response + radiobuttons.q12_A.response + radiobuttons.q17R_A.response)
/ miniIPIP_Conscientiousness = return (radiobuttons.q3_C.response + radiobuttons.q8R_C.response + radiobuttons.q13_C.response + radiobuttons.q18R_C.response)
/ miniIPIP_Neuroticism = return (radiobuttons.q4_N.response + radiobuttons.q9R_N.response + radiobuttons.q14_N.response + radiobuttons.q19R_N.response)
/ miniIPIP_Imagination = return (radiobuttons.q5_I.response + radiobuttons.q10R_I.response + radiobuttons.q15R_I.response + radiobuttons.q20R_I.response)
</expressions>

*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are required to be answered. To change
/required = false

<radiobuttons q1_E>
/caption = "1. Am the life of the party."
/ options = ("Very<br>Inaccurate", "Moderately<br>Inaccurate", "Neither Accurate<br>Nor Inaccurate", 
"Moderately<br>Accurate", "Very<br>Accurate")
/ optionvalues = ("1", "2", "3", "4", "5")
/required = true
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q2_A>
/caption = "2. Sympathize with others’ feelings"
