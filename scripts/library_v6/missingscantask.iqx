/ erase = false
/ txbgcolor = red
/ width = text.response.width
/height = text.response.height
/ vjustify = center
/ hjustify = center
</text>

<text summaryFeedback>
/ items = ("<%expressions.summaryFeedback%>")
/ size = (80%, 30%)
/ position = (50%, 60%)
/ txcolor = blue
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
</text>

<expressions>
/summaryFeedback = {
	if (parameters.runDSAssessment){
		"Missing Scan Span: <%expressions.MST%>
		Digit Span: <%expressions.DS%>"
	} else {
		"Missing Scan Span: <%expressions.MST%>"		
	}
}
</expressions>

<button reset>
/ caption = "reset"
/ position = (25%, 95%)
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ size = (30%, 6%)
/ erase = false
</button>

