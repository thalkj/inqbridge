//it randomly selects any of the class members including the missing Number
<list classNumbers>
/ replace = false
/ selectionrate = always
</list>

//list is used for number presentation purposes
//it selects the randomized class numbers in sequence but skips the missing Number
<list Numbers>
/ selectionmode = sequence
</list>


