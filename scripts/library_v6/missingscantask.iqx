**************************************************************************************************************
**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
/debugmode = false	//true: the missing number as well as (verbal) numbers are presented on screen; 
					//false: the missing number is not presented and the verbal numbers are 'hidden' (=> test mode)

/responseFormat = "written" //select btw. written ("written" => select number from a number dial) or verbal response ("verbal")

/runDSAssessment = false //true = script runs DS assessment in addition to MST assessment; false = only MST assessment is run
						 //Note: if DS assessment is run, order of assessment types can be counterbalanced by groupnumber
						
/skipSummaryFeedback = false //true: the summary feedback (Span Feedback) is skipped; false: summary feedback (Span Feedback) if provided at the end						


//Duration Parameters:

/numberPresentationDelay = 500 // the delay (in ms) of presenting the first oral number after pressing start button
/numberPresentationDuration_inms = 1000 //the presentation duration (in ms) of the verbally presented numbers
/responseDelay = 0 //the delay (in ms) of the response collecting trials after offset of last oral number
/iti = 1000 //intertrial interval (in ms); blank screen in between trials

</parameters>

**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************
<instruct>
/ finishLabel = "start"
/ inputdevice = mouse
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</instruct>

************************************************************
MST
************************************************************

<page MST_intro>
<hr><h1>Missing Scan Test</h1><hr>
<p>You will hear sequences of numbers, taken from numbers 1-16.</p><br>
<p>Each sequence consists of <b>consecutive</b> numbers, but the numbers will be presented in <u>random</u> order.</p><br>
<p>However: One of the numbers will be missing. Your task will be to name this missing number.</p><br>
<p>Continue on to a demonstration.</p>
</page>

<page MST_start>
<hr><h1>Missing Scan Test</h1><hr>
<p>The test will now begin. It will take approximately 30 minutes.</p><br>
<p><b>Remember</b>:</p>
<ul>
<li>You will hear sequences of numbers, taken from the numbers 1-16.</li>
<li>The sequences will vary in length. Some of these sequences will be shorter and others will be longer.</li>
<li>The numbers of each sequence will be presented in <u>random order</u> and one of the numbers will be missing.</li>
</ul><br>
<p style="text-align: center"><b><i>Your task is to name this missing number.</i><b><br><br><br></p>
<p>Start the test when you are ready.</p>
</page>


<text MSTdemo1>
/ items = ("First you will be told the number sequence you will hear:")
/ size = (80%, 11%)
/ vjustify = center
/ hjustify = center
/ position = (50%,30%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ erase = false
</text>

<text MSTdemo2>
/ items = ("These numbers will be presented in <b>random order</b><br> 
but <u>one of the numbers will be missing</u><br><br>
Pay good attention!")
/ position = (50%,70%)
/ txcolor = blue
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ erase = false
</text>

<text MSTdemo3a>
/ items = ("Now you are asked to <b>SAY<b> the Missing Number<br>
 (Hint: the missing number was <b><%values.missingNumber%></b>):")
/ position = (50%,15%)
/ txcolor = blue
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ erase = false
</text>

<text MSTdemo3b>
/ items = ("Now select the Missing Number<br>
 (here: <b><%values.missingNumber%></b>):")
/ position = (50%,45%)
/ txcolor = blue
/ fontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ erase = false
</text>

<text MSTdemo_repeat>
/ items = ("Would you like to repeat the demo?")
/ position = (50%,50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
</text>

<button yes>
/ caption = "YES"
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ size = (20%, 7%)
/ position = (25%, 75%)
</button>

<button no>
/ caption = "NO"
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ size = (20%, 7%)
/ position = (75%, 75%)
</button>

<text MST_classAnnouncement>
/items = ("The next number class is:")
/ position = (50%, 30%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ erase = false
</text>

<text MST_responseReminder>
/items = ("The missing number is:")
/ position = (50%, 8%)
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ erase = false
</text>

************************************************************
DS
************************************************************

<page DS_intro>
<hr><h1>Digit Span Test</h1><hr>
<p>You will hear sequences of numbers, taken from numbers 1-16.</p><br>
<p>Each sequence consists of <b>consecutive</b> numbers, but the numbers will be presented in <u>random</u> order.</p><br>
<p>However: One of the numbers will be missing. Your task is to report <b>ALL</b> of the numbers presented.</p><br>
<p>Continue on to a demonstration.</p>
</page>

<page DS_start>
<hr><h1>Digit Span Test</h1><hr>
<p>The test will now begin. It will take approximately 30 minutes.</p><br>
<p><b>Remember</b>:</p>
<ul>
<li>You will hear sequences of numbers, taken from the numbers 1-16.</li>
<li>The sequences will vary in length. Some of these sequences will be shorter and others will be longer.</li>
<li>The numbers of each sequence will be presented in <u>random order</u> and one of the numbers will be missing.</li>
</ul><br>
<p style="text-align: center"><b><i>Your task is to report <b>ALL</b> of the numbers presented.</i><b><br><br><br></p>
<p>Start the test when you are ready.</p>
</page>


