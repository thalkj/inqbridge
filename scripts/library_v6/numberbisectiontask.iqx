**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = black
/ screencolor = white
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, blockcode, blocknum, 
trialcode, trialnum,
values.blockcount, values.trialcount, values.bisectionality, values.multiplicativity, values.bisectionTaskRange, values.bisectionPossibility, values.distance,
stimulusitem, stimulusnumber, response, values.resp, correct, latency)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, script.elapsedTime, 
script.completed,
expressions.propCorrect_practice,
expressions.meanRT_practice,							

expressions.propCorrect_bisectional_multi_small,		
expressions.meanRT_bisectional_multi_small,			
expressions.propCorrect_bisectional_multi_wide,		
expressions.meanRT_bisectional_multi_wide,				
expressions.propCorrect_bisectional_nonmulti_small,	
expressions.meanRT_bisectional_nonmulti_small,			
expressions.propCorrect_bisectional_nonmulti_wide,		
expressions.meanRT_bisectional_nonmulti_wide,			

expressions.propCorrect_nonbisectional_possible_near,	
expressions.meanRT_nonbisectional_possible_near,		
expressions.propCorrect_nonbisectional_possible_far,	
expressions.meanRT_nonbisectional_possible_far,		
expressions.propCorrect_nonbisectional_impossible_near,	
expressions.meanRT_nonbisectional_impossible_near,		
expressions.propCorrect_nonbisectional_impossible_far,	
expressions.meanRT_nonbisectional_impossible_far,		
)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/trialcount:			number of test trials run in the current block
/bisectionality:		1 = bisectional; 2 = non-bisectional
/multiplicativity:		for bisectional problems only: 
							1 = part of a multiplication set; 
							2 = otherwise
/bisectionTaskRange:	for bisectional problems only: 
							1 = difference btw. the target numbers ('outer numbers') is btw. 2-8
							2 = difference btw. the target numbers ('outer' numbers) is btw. 12-18
/bisectionPossibility:	for non-bisectional problems only:
							1 = the actual arithmetic mean of the target numbers (=mean of first and third number) is an integer (e.g. 4-8-10; (4+10)/2 = 7)
							2 = otherwise (e.g. 4-7-9 => (4+9)/2 = 6.5)
/distance:				for non-bisectional problems only:
							1 = the difference btw. the actual and the provided arithmetic mean (= the second number) is 0.5-1.5
							2 = the difference btw. the actual and the provided arithmetic mean (= the second number) is 2-8


/resp:					"yes" vs. "no" vs " " (empty = no response)							
							
<values>
/blockcount = 0
/trialcount = 0
/bisectionality = ""
/multiplicativity = ""
/bisectionTaskRange = ""
/bisectionPossibility = ""
/distance = ""

/resp = ""
/selectInstruct = 0
/startInstruct = 0
/endInstruct = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************
/propCorrect_practice:						proportion correct responses during the practice trials
/meanRT_practice:							mean response time (in ms) of correct responses in practice trials

/propCorrect_bisectional_multi_small:		proportion correct responses for bisectional, 'multiplication-triplets' problems with a small task range
/meanRT_bisectional_multi_small:			mean response time (in ms) of correct responses for bisectional, 'multiplication-triplets' problems with a small task range
/propCorrect_bisectional_multi_wide:		proportion correct responses for bisectional, 'multiplication-triplets' problems with a wide task range
/meanRT_bisectional_multi_wide:				mean response time (in ms) of correct responses for bisectional, 'multiplication-triplets' problems with a wide task range
/propCorrect_bisectional_nonmulti_small:	proportion correct responses for bisectional, 'non-multiplication-triplets' problems with a small task range
/meanRT_bisectional_nonmulti_small:			mean response time (in ms) of correct responses for bisectional, 'non-multiplication-triplets' problems with a small task range
/propCorrect_bisectional_nonmulti_wide:		proportion correct responses for bisectional, 'nonmultiplication-triplets' problems with a wide task range
/meanRT_bisectional_nonmulti_wide:			mean response time (in ms) of correct responses for bisectional, 'non-multiplication-triplets' problems with a wide task range

/propCorrect_nonbisectional_possible_near:	proportion correct responses for nonbisectional, 'possible mean' problems with a near distance of suggested mean to actual mean
/meanRT_nonbisectional_possible_near:		mean response time (in ms) of correct responses for nonbisectional, 'possible mean' problems with a near distance of suggested mean to actual mean
/propCorrect_nonbisectional_possible_far:	proportion correct responses for nonbisectional, 'possible mean' problems with a far distance of suggested mean to actual mean
/meanRT_nonbisectional_possible_far:		mean response time (in ms) of correct responses for nonbisectional, 'possible mean' problems with a far distance of suggested mean to actual mean
/propCorrect_nonbisectional_impossible_near:	proportion correct responses for nonbisectional, 'impossible mean' problems with a near distance of suggested mean to actual mean
/meanRT_nonbisectional_impossible_near:		mean response time (in ms) of correct responses for nonbisectional, 'impossible mean' problems with a near distance of suggested mean to actual mean
/propCorrect_nonbisectional_impossible_far:	proportion correct responses for nonbisectional, 'impossible mean' problems with a far distance of suggested mean to actual mean
/meanRT_nonbisectional_impossible_far:		mean response time (in ms) of correct responses for nonbisectional, 'impossible mean' problems with a far distance of suggested mean to actual mean


<expressions>
/propCorrect_practice = list.ACC_practice.mean
/meanRT_practice = list.RT_practice.mean

/propCorrect_bisectional_multi_small = list.ACC_bisect_multi_small.mean
/meanRT_bisectional_multi_small = list.RT_bisect_multi_small.mean
/propCorrect_bisectional_multi_wide = list.ACC_bisect_multi_wide.mean
/meanRT_bisectional_multi_wide = list.RT_bisect_multi_wide.mean
/propCorrect_bisectional_nonmulti_small = list.ACC_bisect_nonmulti_small.mean
/meanRT_bisectional_nonmulti_small = list.RT_bisect_nonmulti_small.mean
/propCorrect_bisectional_nonmulti_wide = list.ACC_bisect_nonmulti_wide.mean
/meanRT_bisectional_nonmulti_wide = list.RT_bisect_nonmulti_wide.mean

/propCorrect_nonbisectional_possible_near = list.ACC_nonbisect_possible_near.mean
/meanRT_nonbisectional_possible_near = list.RT_nonbisect_possible_near.mean
/propCorrect_nonbisectional_possible_far = list.ACC_nonbisect_possible_far.mean
/meanRT_nonbisectional_possible_far = list.RT_nonbisect_possible_far.mean
/propCorrect_nonbisectional_impossible_near = list.ACC_nonbisect_impossible_near.mean
/meanRT_nonbisectional_impossible_near = list.RT_nonbisect_impossible_near.mean
/propCorrect_nonbisectional_impossible_far = list.ACC_nonbisect_impossible_far.mean
/meanRT_nonbisectional_impossible_far = list.RT_nonbisect_impossible_far.mean
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text instructions>
/ items = instructions
/ select = values.selectInstruct
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
</text>

<trial instructions>
/ ontrialbegin = [
	text.goback.skip = false;
	
	if (values.selectInstruct == 1){
		text.goback.skip = true;
	}
]
/ stimulusframes = [1 = instructions, yes, no, goback]
/ validresponse = ("B", parameters.responsekey_yes, parameters.responsekey_no)
/ isvalidresponse = [
	return (
	(values.selectInstruct == 2 && trial.instructions.responseText == parameters.responsekey_yes) || 
	(values.selectInstruct == 3 && trial.instructions.responseText == parameters.responsekey_no) ||	
	((values.selectInstruct == 1 || values.selectInstruct == 4) && 
	(trial.instructions.responseText ==parameters.responsekey_yes || trial.instructions.responseText == parameters.responsekey_no)) ||
	(values.selectInstruct > 1 && trial.instructions.responseText == "B"));
]
/ branch = [
	if (trial.instructions.responseText == "B"){
		if (values.selectInstruct > values.startInstruct){
			values.selectInstruct -= 1;
			return trial.instructions;			
		} else {
			return trial.instructions;
		}
	} else if (values.selectInstruct < values.endInstruct){
		values.selectInstruct += 1;
		return trial.instructions;		
	}

]
/ recorddata = false
</trial>

<trial startpractice>
/ ontrialbegin = [
	values.selectInstruct = 4;
]
/ stimulusframes = [1 = instructions, yes, no]
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ recorddata = false
</trial>

<trial start>
/ stimulusframes = [1 = instructions, blockinfo, yes, no]
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ recorddata = false
/ ontrialend = [
	values.selectInstruct = 6;
]
</trial>


<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

