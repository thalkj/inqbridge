**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block instructions>
/ onblockbegin = [
	values.startInstruct = 1;
	values.selectInstruct = values.startInstruct;
	values.endInstruct = 3;
]
/ trials = [1 = instructions]
</block>

Note: block.practice runs
* 16 practice trials (8 bisectional and 8 non-bisectional)
<block practice>
/ stop = [
	values.trialcount > parameters.numberOfPracticeTrials;
]
/ onblockbegin = [
	values.trialcount = 0;	
]
/ trials = [
	1 = startpractice; 
	2 = fixation; 
	3 = trial.selectPracticeTrial;
]
/ onblockend = [
	values.selectInstruct = 5;
]
</block>

Note: block.NBT runs
* 9  of each of the 8 test trials = 72 test trials per block
<block NBT>
/ onblockbegin = [
	values.trialcount = 0;
	values.blockcount += 1;
]
/ trials = [
	1 = start; 
	2 = fixation; 
	3-74 = noreplace(trial.bisect_multi_small, trial.bisect_multi_wide, trial.bisect_nonmulti_small, trial.bisect_nonmulti_wide,
	trial.nonbisect_impossible_far, trial.nonbisect_impossible_near, trial.nonbisect_possible_far, trial.nonbisect_possible_near);
]
/ branch = [
	if (values.blockcount < parameters.numberOfTestBlocks){
		return block.NBT;
	}
]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt numberBisection>
/ blocks = [
	1 = instructions;
	2 = practice;
	3 = NBT;
	4 = finish;
]
</expt>

<monkey>
/ latencydistribution = normal(200, 100)
</monkey>


