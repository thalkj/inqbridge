**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************
<instruct>
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
</instruct>

<item instructions>
/1 = "
<center><hr><h1>Welcome!</h1><hr></center><br>
In this game you will be presented with a new triplet of numbers (e.g. 42_44_50) every 
<%(parameters.stimPresentationTime + parameters.ISI)/1000%> seconds.<br><br>

You have <%parameters.stimPresentationTime/1000%> seconds to decide whether the <b>center</b> number (here: <b>44</b>) 
is the <i>arithmetic mean</i> of the numbers flanking it.<br><br>

If it is the arithmetic mean press the '<%parameters.responsekey_yes%>' <%expressions.buttoninstruct1%> for YES.<br>
If it is NOT the arithmetic mean press the '<%parameters.responsekey_no%>' <%expressions.buttoninstruct1%> for NO.<br><br>

Press any response <%expressions.buttoninstruct1%> to continue with the instructions."
/2 = "Consider the following triplet.<br><br>
<center><div style='background-color:lightGray'><h1>16_19_22</h1></div><br>
The <b>center</b> number <b>19</b> is the <i>arithmetic mean</i> of 16 and 22:<br>
(16 + 22) ÷ 2 = 38 ÷ 2 = 19.<br><br>
<b>Therefore you should press the 'yes' <%expressions.buttoninstruct1%> ('<%parameters.responsekey_yes%>')</b>.<br>
Press the 'yes' <%expressions.buttoninstruct1%> now to continue.</center>"
/3 = "Consider the following triplet.<br><br>
<center><div style='background-color:lightGray'><h1>25_29_37</h1></div><br>
The <b>center</b> number <b>29</b> is <b>NOT</b> the arithmetic mean of 25 and 37:<br>
(25 + 37) ÷ 2 = 62 ÷ 2 = 31.<br><br>
<b>Therefore you should press the 'no' <%expressions.buttoninstruct1%> ('<%parameters.responsekey_no%>')</b>.<br>
Press the 'no' <%expressions.buttoninstruct1%> now to start a practice session.</center>"
/4 = "<hr><center><h1>Practice</h1></center><hr><br>
Let's practice this task.<br><br> 
Put your fingers on the '<%parameters.responsekey_yes%>' and '<%parameters.responsekey_no%>' <%expressions.buttoninstruct1%>s 
and press one of these response keys to start practice.<br><br><br>"
/5 = "<hr><center><h1>Test</h1></center><hr><br>
Let's begin the actual task. It is just like practice but you will no longer get any feedback 
and you will get more triplets to work with.<br><br>
<center><div style='background-color:lightGray'><big><u>Remember:</u></big><br><br>
A new triplet of numbers (e.g. 42_44_50) will be presented every <%(parameters.stimPresentationTime + parameters.ISI)/1000%> seconds.
You have <%parameters.stimPresentationTime/1000%> seconds to decide whether the <b>center</b> number is 
the <b>arithmetic mean</b> of the numbers flanking it.</div></center><br><br>
Put your fingers on the '<%parameters.responsekey_yes%>' and '<%parameters.responsekey_no%>' <%expressions.buttoninstruct1%>s and press one of these response keys to start the task."
/6 = "<center>Put your fingers on the '<%parameters.responsekey_yes%>' and '<%parameters.responsekey_no%>' 
<%expressions.buttoninstruct1%>s and <br> press one of these response keys to continue.</center>"
</item>

<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {
	"button";} else {"key";}
/buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {
	"Put your fingers on the ";} else {"key";}
</expressions>

<text goback>
/ items = ("press 'B' to go back")
/ fontstyle = ("Courier New", 2%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
/ size = (40%, 2.5%)
/ position = (50%, 95%)
/ txcolor = gray
</text>

<text yes>
/ items = ("yes")
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ position = (25%, 90%)
/ size = (20%, 5%)
/ vjustify = center
/ txcolor = gray
</text>

<text no>
/ items = ("no")
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ position = (75%, 90%)
/ size = (20%, 5%)
/ vjustify = center
/ txcolor = gray
</text>

<text correctFeedback>
/ items = ("Correct!")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (20%, 5%)
/ vjustify = center
/ txcolor = green
</text>

<text errorFeedback>
/ items = ("Incorrect!")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (20%, 5%)
/ vjustify = center
/ txcolor = red
</text>

<text noresponseFeedback>
/ items = ("Too slow")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (20%, 5%)
/ vjustify = center
/ txcolor = orange
</text>

<text blockinfo>
/ items = ("Test Block <%values.blockcount%> of <%parameters.numberOfTestBlocks%>")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 10%)
/ size = (80%,5%)
/ vjustify = center
</text>

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
/ vjustify = center
</text>

<text exit>
/ items = ("<press spacebar to exit>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (80%, 5%)
/ vjustify = center
</text>

