**************************************************************************************************************
**************************************************************************************************************
	PRACTICE TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<list selectPracticeTrial>
/ items = (1, 2)
/ replace = false
/ poolSize = parameters.numberOfPracticeTrials
</list>

<trial selectPracticeTrial>
/ ontrialbegin = [
	values.trialcount += 1;
	values.bisectionality = "";
	values.multiplicativity = "";
	values.bisectionTaskRange = "";
	values.bisectionPossibility = "";
	values.distance = "";	
]
/ stimulusframes = [1 = clearScreen, fixation]

//for touchscreens: present the inactive response buttons
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ isvalidresponse = [
	return false;
]

/ ontrialend = [
	values.bisectionality = list.selectPracticeTrial.nextValue;
]
/ branch = [
	if (values.bisectionality == 1){
		trial.practice_bisect;
	} else {
		trial.practice_nonbisect;
	}
]
/ trialduration = parameters.ISI
/ recorddata = false
</trial>

<trial practice_bisect>
/ stimulustimes = [1 = practice_bisect, yes, no]
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ correctresponse = (parameters.responsekey_yes)
/ timeout = parameters.stimPresentationTime
/ ontrialend = [
	list.ACC_practice.appendItem(trial.practice_bisect.correct);
	if (trial.practice_bisect.correct && trial.practice_bisect.latency >= parameters.minLatency){
		list.RT_practice.appendItem(trial.practice_bisect.latency);
	}
	if (trial.practice_bisect.responseText == parameters.responsekey_yes){
		values.resp = "yes";
	} else if (trial.practice_bisect.responseText == parameters.responsekey_no){
		values.resp = "no";
	} else {
		values.resp = "";
	}
	
	if (trial.practice_bisect.response == 0){
		text.errorFeedback.skip = true;
		text.correctFeedback.skip = true;
		text.noresponseFeedback.skip = false;
	} else if (trial.practice_bisect.correct){
		text.errorFeedback.skip = true;
		text.correctFeedback.skip = false;
		text.noresponseFeedback.skip = true;		
	} else {
		text.errorFeedback.skip = false;
		text.correctFeedback.skip = true;
		text.noresponseFeedback.skip = true;		
	}
]
/ branch = [
	trial.practiceFeedback;
]
</trial>

<trial practice_nonbisect>
/ stimulustimes = [1 = practice_nonbisect, yes, no]
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ correctresponse = (parameters.responsekey_no)
/ timeout = parameters.stimPresentationTime
/ ontrialend = [
	list.ACC_practice.appendItem(trial.practice_nonbisect.correct);
	if (trial.practice_nonbisect.correct && trial.practice_nonbisect.latency >= parameters.minLatency){
		list.RT_practice.appendItem(trial.practice_nonbisect.latency);
	}

	if (trial.practice_nonbisect.responseText == parameters.responsekey_yes){
		values.resp = "yes";
	} else if (trial.practice_nonbisect.responseText == parameters.responsekey_no){
		values.resp = "no";
	} else {
		values.resp = "";
	}
	
	if (trial.practice_nonbisect.response == 0){
		text.errorFeedback.skip = true;
		text.correctFeedback.skip = true;
		text.noresponseFeedback.skip = false;
	} else if (trial.practice_nonbisect.correct){
		text.errorFeedback.skip = true;
		text.correctFeedback.skip = false;
		text.noresponseFeedback.skip = true;		
	} else {
		text.errorFeedback.skip = false;
		text.correctFeedback.skip = true;
		text.noresponseFeedback.skip = true;		
	}	
]
/ branch = [
	trial.practiceFeedback;
]
</trial>

<trial practiceFeedback>
/ stimulusframes = [1 = errorFeedback, correctFeedback, noresponseFeedback]

/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)//for touchscreens: present inactive response buttons
/ isvalidresponse = [
	return false;
]

/ trialduration = 1000
/ recorddata = false
/ branch = [
	trial.selectPracticeTrial;
]
</trial>



**************************************************************************************************************
**************************************************************************************************************
	TEST TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial fixation>
/ stimulusframes = [1 = fixation]

/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)//for touchscreens: present inactive response buttons
/ isvalidresponse = [
	return false;
]

/ trialduration = parameters.ISI
/ recorddata = false
</trial>


<trial bisect_multi_small>
/ ontrialbegin = [
	values.trialcount += 1;
	values.bisectionality = 1;
	values.multiplicativity = 1;
	values.bisectionTaskRange = 1;
	values.bisectionPossibility = "";
	values.distance = "";
]
/ stimulustimes = [1 = bisect_multi_small, yes, no]
/ validresponse = (parameters.responsekey_yes, parameters.responsekey_no)
/ correctresponse = (parameters.responsekey_yes)
/ trialduration = parameters.stimPresentationTime
/ ontrialend = [
	list.ACC_bisect_multi_small.appendItem(trial.bisect_multi_small.correct);
	if (trial.bisect_multi_small.correct && trial.bisect_multi_small.latency >= parameters.minLatency){
		list.RT_bisect_multi_small.appendItem(trial.bisect_multi_small.latency);
	}
	
	if (trial.bisect_multi_small.responseText == parameters.responsekey_yes){
		values.resp = "yes";
	} else if (trial.bisect_multi_small.responseText == parameters.responsekey_no){
		values.resp = "no";
	} else {
		values.resp = "";
	}
]
/ branch = [
	if (values.trialcount < 72){
		return trial.fixation;
	}
]
/ responsemessage = (anyresponse, clearScreen, 0)
/ responsemessage = (anyresponse, text.fixation, 0)
</trial>

