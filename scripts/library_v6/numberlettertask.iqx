Note:
* trial practice_letterTask presents the 2x2 matrix with a character pair in the assigned letter task positions
* one character is a letter (target); one character is a number (distractor)
* waits for response
* call trial.practiceITI
<trial practice_letterTask>
/ ontrialbegin = [
	values.countPracticeTrials += 1;
	values.quadrant += 1;

	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant > 2){
			values.quadrant = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant > 4){
			values.quadrant = 3;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant > 3){
			values.quadrant = 2;
		}
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant > 4){
			values.quadrant = 1;
		} else if (values.quadrant == 2){
			values.quadrant = 4;
		}
	}
		
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}	

	values.taskCategory = list.practice_letterTask.nextValue;
	if (values.taskCategory == 1){
		values.targetCategory = "CONSONANT";
		values.targetSymbol = list.consonants.nextValue;
		values.avoidConsonant = values.targetSymbol;
	} else {
		values.targetCategory = "VOWEL";
		values.targetSymbol = list.vowels.nextValue;
		values.avoidVowel = values.targetSymbol;
	}
	
	values.congruence = list.practiceCongruence_letterTask.nextValue;
	if (values.congruence == 1){
		if (values.targetCategory == "CONSONANT"){
			if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
			}

		} else {
			if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
			}			
		}
	
	} else {
		if (values.targetCategory == "CONSONANT"){
			if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
			}

		} else {
			if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
			}			
		}		
	}
	
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	return (
	(values.taskCategory == 1 && trial.practice_letterTask.responseText == parameters.consonantKey) || 
	(values.taskCategory == 2 && trial.practice_letterTask.responseText == parameters.vowelKey));
]
/ ontrialend = [
	if (trial.practice_letterTask.correct){
		values.iti = parameters.correctITI;
	} else {
		values.iti = parameters.errorITI;
	}
	
	values.countBlockErrors += trial.practice_letterTask.error;
	if (trial.practice_letterTask.correct){
		list.RT_block.appendItem(trial.practice_letterTask.latency);
	} else {
		trial.practiceITI.insertStimulusTime(text.errorFeedback, 0);
	}
	
	if (values.countPracticeTrials >= 8){
		text.left.textColor = white;
		text.right.textColor = white;
		text.right_HL.textColor = white;
		text.left_HL.textColor = white;		
	}
]
/ responsemessage = (parameters.leftKey, text.left_HL, 0)
/ responsemessage = (parameters.rightKey, text.right_HL, 0)
/ branch = [
	return trial.practiceITI;
]
</trial>

Note:
* trial practice_letterTask presents the 2x2 matrix with a character pair in the assigned letter task positions
* one character is a number (target); one character is a letter (distractor)
* waits for response
* call trial.practiceITI
<trial practice_numberTask>
/ ontrialbegin = [
	values.countPracticeTrials += 1;
	values.quadrant += 1;

	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant > 4){
			values.quadrant = 3;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant > 2){
			values.quadrant = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant > 3){
			values.quadrant = 2;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant > 4){
			values.quadrant = 1;
		} else if (values.quadrant == 2){
			values.quadrant = 4;
		}
	}
		
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}	

	values.taskCategory = list.practice_numberTask.nextValue;
	if (values.taskCategory == 1){
		values.targetCategory = "ODD";
		values.targetSymbol = list.odd.nextValue;
		values.avoidOdd = values.targetSymbol;
	} else {
		values.targetCategory = "EVEN";
		values.targetSymbol = list.even.nextValue;
		values.avoidEven = values.targetSymbol;
	}
	
	values.congruence = list.practiceCongruence_numberTask.nextValue;
	if (values.congruence == 1){
		if (values.targetCategory == "ODD"){
			if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
			}

		} else {
			if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
			}			
		}
	
	} else {
		if (values.targetCategory == "ODD"){
			if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
			}

		} else {
			if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
			} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
			}			
		}		
	}
	
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	return (
	(values.taskCategory == 1 && trial.practice_numberTask.responseText == parameters.oddKey) || 
	(values.taskCategory == 2 && trial.practice_numberTask.responseText == parameters.evenKey));
]
/ ontrialend = [
	if (trial.practice_numberTask.correct){
		values.iti = parameters.correctITI;
	} else {
		values.iti = parameters.errorITI;
	}
	
	values.countBlockErrors += trial.practice_numberTask.error;
	if (trial.practice_numberTask.correct){
		list.RT_block.appendItem(trial.practice_numberTask.latency);
	} else {
		trial.practiceITI.insertStimulusTime(text.errorFeedback, 0);
	}
	
	if (values.countPracticeTrials >= 8){
		text.left.textColor = white;
		text.right.textColor = white;
		text.right_HL.textColor = white;
		text.left_HL.textColor = white;		
	}	
]
/ responsemessage = (parameters.leftKey, text.left_HL, 0)
/ responsemessage = (parameters.rightKey, text.right_HL, 0)
/ branch = [
	return trial.practiceITI;
]
</trial>

Note:
trial.practiceITI adds an iti to each practice trial (it is longer for error trials)
<trial practiceITI>
/ stimulusframes = [1 = clearScreen, quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, left, right]
/ trialduration = values.iti
/ recorddata = false
/ ontrialend = [
	trial.practiceITI.resetStimulusFrames();
]
</trial>


**************************************************************************************************************
**************************************************************************************************************
	TRIALS: combined task trials
**************************************************************************************************************
**************************************************************************************************************


Note:
* trial.start presents an empty matrix with one highlighted (yellow) box
* the highlighted box signals the location for the first character pair in the first switch trial 
for either the letter task or the digit task
* at the end of the trial, all quadrants are returned to a white background

<trial combinedstartPractice>
/ skip = [
	values.countCombinedPracticeBlocks > 1;
]
/ ontrialbegin = [
	values.startQuadrant = values.quadrant + 1;
	if (values.startQuadrant > 4){
		values.startQuadrant = 1;
	}	
	if (values.startQuadrant == 1){
		shape.quadrant1_inner.color = yellow;
	} else if (values.startQuadrant == 2){
		shape.quadrant2_inner.color = yellow;
	} else if (values.startQuadrant == 3){
		shape.quadrant3_inner.color = yellow;
	} else if (values.startQuadrant == 4){
		shape.quadrant4_inner.color = yellow;
	} 
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner]
/ trialduration = parameters.blockstartDuration
/ recorddata = false
/ ontrialend = [
	shape.quadrant1_inner.color = white;
	shape.quadrant2_inner.color = white;	
	shape.quadrant3_inner.color = white;
	shape.quadrant4_inner.color = white;	
	
	values.iti = parameters.correctITI;
]
</trial>

Notes:
* trial.combinedPractice presents the 2x2 matrix and presents the character pair in the assigned quadrant
* it assembles the character pair based on:
	- type of task (letter or digit => depends on current quadrant)
	- type of switch category 
	- type of sampled task category (letter task: consonant or vowel; digit task: even or odd - randomly sampled)
	- type of sampled congruence (randomly sampled)
	- order of target and distractor symbol (random)
* it presents the character pair in the assigned quadrant
* waits for response (no response deadline)
* if correct, calls trial.PracticeITI; if incorrect, calls trial.combinedErrorFeedback
<trial combinedPractice>
/ ontrialbegin = [
	values.quadrant += 1;
	if (values.quadrant > 4){
		values.quadrant = 1;
	}
	
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		if (mod(values.quadrant, 2)== 0){
			values.switch = 0;
		} else {
			values.switch = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		
		if (mod(values.quadrant, 2)== 0){
			values.switch = 1;
		} else {
			values.switch = 0;
		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}	
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}		
	}
	
	if (values.targetTask == values.taskA){	
		values.taskCategory = replace(1, 2);
		values.congruence = replace(1, 2);
		
		if (values.taskCategory == 1){
			values.targetCategory = "CONSONANT";
			values.targetSymbol = list.consonants.nextValue;
			values.avoidConsonant = values.targetSymbol;		
		} else {
			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;				
		}
				
		if (values.congruence == 1){
			if (values.targetCategory == "CONSONANT"){
				if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}

			} else {
				if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}			
			}
	
		} else {
			if (values.targetCategory == "CONSONANT"){
				if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}

			} else {
				if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}			
			}
		}

	} else {
		values.taskCategory = replace(1, 2);
		values.congruence = replace(1, 2);
		
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;
			values.avoidOdd = values.targetSymbol;		
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;
			values.avoidEven = values.targetSymbol;				
		}
				
		if (values.congruence == 1){
			if (values.targetCategory == "ODD"){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}

			} else {
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}			
			}
	
		} else {
			if (values.targetCategory == "ODD"){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}

			} else {
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}			
			}
		}	
	
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ iscorrectresponse = [
	return (
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.combinedPractice.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.combinedPractice.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.combinedPractice.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.combinedPractice.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.combinedPractice.error && trial.combinedPractice.response != 0){
		values.iti = parameters.errorITI;
	}
	
	list.combinedPracticeACC.appendItem(trial.combinedPractice.correct);
]
/ branch = [
	if (trial.combinedPractice.correct){
		return trial.combinedITI;		
	} else {
		return trial.combinedErrorFeedback;
	}

]
</trial>


Note:
* trial.start presents an empty matrix with one highlighted (yellow) box
* the highlighted box signals the location for the first character pair in the first switch trial 
for either the letter task or the digit task
* at the end of the trial, all quadrants are returned to a white background

<trial combinedstart>
/ ontrialbegin = [
	values.startQuadrant = values.quadrant + 1;
	if (values.startQuadrant > 4){
		values.startQuadrant = 1;
	}	
	if (values.startQuadrant == 1){
		shape.quadrant1_inner.color = yellow;
	} else if (values.startQuadrant == 2){
		shape.quadrant2_inner.color = yellow;
	} else if (values.startQuadrant == 3){
		shape.quadrant3_inner.color = yellow;
	} else if (values.startQuadrant == 4){
		shape.quadrant4_inner.color = yellow;
	} 
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner]
/ trialduration = parameters.blockstartDuration
/ recorddata = false
/ ontrialend = [
	shape.quadrant1_inner.color = white;
	shape.quadrant2_inner.color = white;	
	shape.quadrant3_inner.color = white;
	shape.quadrant4_inner.color = white;	
	
	values.iti = parameters.correctITI;
]
</trial>


Notes:
* trial.combined presents the 2x2 matrix and presents the character pair in the assigned quadrant
* it assembles the character pair based on:
	- type of task (letter or digit => depends on current quadrant)
	- type of switch category
	- type of sampled task category (letter task: consonant or vowel; digit task: even or odd)
	- type of sampled congruence
	- order of target and distractor symbol (random)
* it presents the character pair in the assigned quadrant
* waits for response (no response deadline)
* updates summary variable list if appropriate
* then calls trial.combinedITI
<trial combined>
/ ontrialbegin = [
	values.countCombinedTrials += 1;
	values.quadrant += 1;
	if (values.quadrant > 4){
		values.quadrant = 1;
	}
	
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		if (mod(values.quadrant, 2)== 0){
			values.switch = 0;
		} else {
			values.switch = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		
		if (mod(values.quadrant, 2)== 0){
			values.switch = 1;
		} else {
			values.switch = 0;
		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}	
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}		
	}
	
	if (values.targetTask == values.taskA){	
		if (values.switch == 1){
			values.taskCategory = list.combined_letterTask_switch.nextValue;
			values.congruence = list.combinedCongruence_letterTask_switch.nextValue;
		} else {
			values.taskCategory = list.combined_letterTask_nonswitch.nextValue;
			values.congruence = list.combinedCongruence_letterTask_nonswitch.nextValue;			
		}
		
		if (values.taskCategory == 1){
			values.targetCategory = "CONSONANT";
			values.targetSymbol = list.consonants.nextValue;
			values.avoidConsonant = values.targetSymbol;		
		} else {
			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;				
		}
				
		if (values.congruence == 1){
			if (values.targetCategory == "CONSONANT"){
				if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}

			} else {
				if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}			
			}
	
		} else {
			if (values.targetCategory == "CONSONANT"){
				if (parameters.consonantKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}

			} else {
				if (parameters.vowelKey == parameters.oddKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}			
			}
		}

	} else {
		if (values.switch == 1){
			values.taskCategory = list.combined_numberTask_switch.nextValue;
			values.congruence = list.combinedCongruence_numberTask_switch.nextValue;
		} else {
			values.taskCategory = list.combined_numberTask_nonswitch.nextValue;
			values.congruence = list.combinedCongruence_numberTask_nonswitch.nextValue;			
		}
		
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;
			values.avoidOdd = values.targetSymbol;		
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;
			values.avoidEven = values.targetSymbol;				
		}
				
		if (values.congruence == 1){
			if (values.targetCategory == "ODD"){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}

			} else {
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}			
			}
	
		} else {
			if (values.targetCategory == "ODD"){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}

			} else {
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}			
			}
		}	
	
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ iscorrectresponse = [
	return (
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.combined.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.combined.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.combined.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.combined.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.combined.error && trial.combined.response != 0){
		values.iti = parameters.errorITI;
		trial.combinedITI.insertStimulusTime(text.errorFeedback, 0);
	}
	
	if (trial.combined.latency >= parameters.minRT){
		if (values.switch == 0){
			list.ACC_nonswitch.appendItem(trial.combined.correct);
			if (trial.combined.correct){
				list.RT_nonswitch.appendItem(trial.combined.latency);
			}						
		} else {
			list.ACC_switch.appendItem(trial.combined.correct);
			if (trial.combined.correct){
				list.RT_switch.appendItem(trial.combined.latency);
			}			
		}
	} else {
		values.countExcludedTrials += 1;
	}
	
	values.countBlockErrors += trial.combined.error;
	if (trial.combined.correct){
		list.RT_block.appendItem(trial.combined.latency);
	}		
]
/ branch = [
	return trial.combinedITI;
]
</trial>


<trial combinedITI>
/ trialduration = values.iti
/ ontrialend = [
	trial.combinedITI.resetStimulusFrames();
]
/ recorddata = false
</trial>

Note:
trial.combinedErrorFeedback is presented during combined practice if participants make a mistake.
Task and Key Reminders are presented and the correct key has to be pressed to continue.
<trial combinedErrorFeedback>
/ stimulusframes = [1 = TaskReminder, KeyReminder, combinedPracticeContinue]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	return (
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.combinedErrorFeedback.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.combinedErrorFeedback.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.combinedErrorFeedback.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.combinedErrorFeedback.responseText == parameters.evenKey));
]
/ recorddata = true
/ response = correct
/ posttrialpause = values.iti
/ correctmessage = true(text.targetPairEraser, 0)
</trial>



**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block generalInstructions>
/ trials = [1 = generalInstructions]
</block>


<block practice_LetterTask>
/ onblockbegin = [
	values.countPracticeTrials = 0;
	values.countPracticeBlocks += 1;
	values.targetTask = values.taskA;
	text.left_HL.textColor = yellow;
	text.right_HL.textColor = yellow;
	text.left.textColor = gray;
	text.right.textColor = gray;	
	
	values.countBlockErrors = 0;
	list.RT_block.reset();
	
	if (parameters.quadrantTaskAssignment == 1){
		values.quadrant = 0;
	} else if (parameters.quadrantTaskAssignment == 2){
		values.quadrant = 2;
	}  else if (parameters.quadrantTaskAssignment == 3){
		values.quadrant = 3;
	} else if (parameters.quadrantTaskAssignment == 4){
		values.quadrant = 1;
	}
]
/ trials = [
	1 = instructions_lettertask; 
	2 = getReady_practice; 
	3-34 = practice_letterTask; 
	35 = instructions_practiceBlockFeedback;
]
</block>

<block practiceTaskNumberTask>
/ onblockbegin = [
	values.countPracticeTrials = 0;
	values.countPracticeBlocks += 1;
	values.targetTask = values.taskB;
	text.left_HL.textColor = yellow;
	text.right_HL.textColor = yellow;
	text.left.textColor = gray;
	text.right.textColor = gray;	
	
	values.countBlockErrors = 0;
	list.RT_block.reset();
	
	if (parameters.quadrantTaskAssignment == 2){
		values.quadrant = 0;
	} else if (parameters.quadrantTaskAssignment == 1){
		values.quadrant = 2;
	}  else if (parameters.quadrantTaskAssignment == 4){
		values.quadrant = 3;
	} else if (parameters.quadrantTaskAssignment == 3){
		values.quadrant = 1;
	}	
	
]
/ trials = [
	1 = instructions_numbertask; 
	2 = getReady_practice; 
	3-34 = practice_numberTask; 
	35 = instructions_practiceBlockFeedback;
]
</block>


<block testInstructions>
/ trials = [
	1 = instructions_combinedStart; 
	2 = getReady_combined;
]
</block>



Note:
- block.combinedTask samples the first task quadrant (!because the quadrant gets increased by 1 at the start of each trial, the sampled
quadrant needs to be one less at block start)
- runs 16 combined trials with task and key reminders if errors are made
<block combinedTaskPractice>
/ onblockbegin = [
	values.countCombinedPracticeBlocks += 1;
	list.combinedPracticeACC.reset();
]
/ trials = [
	1 = combinedstartPractice; 
	2-17 = combinedPractice;
]
/ branch = [
	if (expressions.ACC_combinedPractice < parameters.minCombinedPracticeACC && !monkey.monkeyMode){
		if (values.countCombinedPracticeBlocks < parameters.maxCombinedPracticeBlocks){
			return block.combinedTaskPractice;
		} else {
			values.prematureEnd = 1;
		}
	}
]
</block>

Note:
- block.combinedTask samples the first task quadrant (!because the quadrant gets increased by 1 at the start of each trial, the sampled
quadrant needs to be one less at block start)
- runs 128 combined trials
<block combinedTask>
/ skip = [
	values.prematureEnd == 1;
]
/ onblockbegin = [
	values.countCombinedBlocks += 1;
	values.countBlockErrors = 0;
	list.RT_block.reset();
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		values.quadrant = replace(2,4);
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		values.quadrant = replace(1,3);
	}	
]
/ trials = [
	1 = instructions_practiceEnd;  
	2 = getReady_combined; 
	3 = combinedstart; 
	4-131 = combined; 
	132 = instructions_finish;
]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt numberLetter>
/ onexptbegin = [
	
	if (parameters.consonantKey == parameters.evenKey){
		values.congruentTasks = "consonant-even; vowel-odd";
	} else if (parameters.consonantKey == parameters.oddKey){
		values.congruentTasks = "consonant-odd; vowel-even";
	}
	
	//hide the spacebar reminder for touch devices that present built-in keys
	if (computer.touch && !computer.hasKeyboard){
		text.spacebar.skip = true;
	}
]
/ blocks = [
	1 = generalInstructions;
	2-3 = noreplace(practice_LetterTask, practiceTaskNumberTask);
	4 = testInstructions;
	5 = combinedTaskPractice;
	6 = combinedTask;
]
</expt>



**************************************************************************************************************
												End of File
**************************************************************************************************************