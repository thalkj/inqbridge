~n<%expressions.buttoninstruct1%>")
/ fontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ size = (80%, 40%)
</text>

****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {
"place your index fingers over the '<%parameters.leftKey%>' and '<%parameters.rightKey%>' buttons";} 
else {"put your index fingers on the '<%parameters.leftKey%>' and <%parameters.rightKey%>' keys";}
</expressions>


