**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
SOA:								stores the current SOA between onset of primes/noprimes
quadrant:							determines the screen quadrant in which the prime will appear
counttrials:						counts the number of test trials run
adjust_height/adjust_width:			helper variable to determine appropriate screen coordinates for primes (determine the quadrants)
practice:							0 = experimental; 1 = practice
instructions:						determines the instructions to be shown for each part
totalcorrect:						keeps a total of the correct responses
distance:							the x/y coordinate distance of stimuli (e.g. prime) from the center (in mm)

<values>
/SOA = 0
/quadrant = 0
/counttrials = 0
/adjust_height = 1
/adjust_width = 1
/practice = 0
/instruction = 1
/totalcorrect = 0
/distance = parameters.distance_primefromfixation_inmm / sqrt(2)
/practiceReminder = 1
/responseCategory = ""
/stimLocation = ""
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/px_per_mm:					pixel per mm (conversion rate on the current monitor)
/pixeldistance:				converts the relevant mm distances into pixel distances
/primefontheight:			calculats the appropriate fontheight for the stimuli in mm

<expressions>
/ px_per_mm = display.height/display.getmmy(display.height, 1)
/pixeldistance = values.distance * expressions.px_per_mm
/primefontheight = 1px* expressions.px_per_mm* parameters.fontheight_inmm

/propCorrect = values.totalcorrect / values.counttrials
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI: Parafoveal Priming
**************************************************************************************************************
**************************************************************************************************************

<text fixation>
/items = ("+++")
/position = (1px*0.5*display.width, 1px*0.50*display.height)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/erase = false
</text>

<text prime>
/items = primes
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_height)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/select = replace
</text>

<text noprime>
/items = noprimes
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_height)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/select = replace
</text>

<text practicestim>
/items = practicestims
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_height)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/select = replace
</text>

<text mask>
/items = ("XQFBZRMQWGBX")
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_height)
</text>

**************************************************************************************************************
**************************************************************************************************************
	Fontsize Determination
**************************************************************************************************************
**************************************************************************************************************
Instructions:
(1) figure out the longest word in your stimulus set and use that one in text.longestword
(2) run block.fontsizedetermination
(3) change the fontsize until the word fits snuggly into the provided green rectangle and note
the fontsize as given on the screen
(4) set parameters.fontheight_inmm to the determined value


draws a box around the center of the prime and extends to 2degrees and 6 degrees visual angle
<shape boundaries>
/shape = rectangle
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)  
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_width)
/size = (1px*expressions.pixeldistance, 1px*expressions.pixeldistance/2)
/color = green
</shape>

<text longestword>
/items = ("personality")
/hposition = text.fixation.hposition + (expressions.pixeldistance * values.adjust_width)  
/vposition = text.fixation.vposition + (expressions.pixeldistance * values.adjust_width)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/ txcolor = black
</text>

<text fontsize_instruct>
/items = ("Below you see the longest stimulus used in this script in a green rectangle. The width of the green rectangle should measure <%values.distance%> mm. Its width is calculated to cover the distance between 2degree visual angle to 6degree visual angle (the center of the stimulus should be at 4degree visual angle). The longest stimulus should fit snuggly into this rectangle.
~nif <%text.longestword.currentItem%> is bigger than the green rectangle, press 'D' to decrease the fontsize
if <%text.longestword.currentItem%> is smaller than the green rectangle, press 'I' to increase the fontsize
if <%text.longestword.currentItem%> fits just fine into the green rectangle, press 'G' for 'Good enough'
~nCurrent fontheight (in mm): <%parameters.fontheight_inmm%>")
/size = (80%, 30%)
/position = (50%, 20%)
/txcolor = black
</text>

<trial Determine_fontheight>
/stimulusframes = [1 = fontsize_instruct, fixation, boundaries, longestword]
/validresponse = ("D", "I", "G")
/branch = [
	if (trial.determine_fontheight.responseText == "D") {
		parameters.fontheight_inmm -= 0.1; 
		return trial.determine_fontheight;
	} else if (trial.determine_fontheight.responseText == "I") {
		parameters.fontheight_inmm += 0.1; 
		return trial.determine_fontheight;
	}
]
</trial>

<block FontsizeDetermination>
/trials = [1 = determine_fontheight]
</block>

**************************************************************************************************************
**************************************************************************************************************
	LISTS: Parafoveal Priming
**************************************************************************************************************
**************************************************************************************************************

<list quadrantlist>
/items = (1, 2, 3, 4)
/replace = true
</list>

<list quadrantlist_practice>
/items = (1, 2, 3, 4)
/replace = true
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS: Parafoveal Priming
**************************************************************************************************************
**************************************************************************************************************


*****************************************
Parafoveal Priming: Main Trial sequence
*****************************************

Note: trial.fixation
*shows +++ in the middle of the screen
* selects first values.SOA

<trial fixation>
/ontrialbegin = [
	if (values.practice == 0) {
		values.SOA = list.SOAs.nextValue;
	} else if (values.practice == 1) {
		values.SOA = list.SOAs_practice.nextValue;
	}
]
/stimulustimes = [0 = fixation]

/validresponse = ("A", "L")//for touchscreens: present inactive response buttons
/ isvalidresponse = [
	return false;
]

/trialduration = (values.SOA)
/recorddata = false
</trial>


Note: trial.prime (trial.noprime)
*presents the prime for 60ms which is then covered up by a mask for 60ms. After 120 an "eraser" erases prime/mask combo
*selects values.SOA (duration of current trial until next prime/noprime is presented)
*selects the monitor quadrant for the current prime/noprime and determines hpositions and vpositions of stimuli
*latency is measured from onset of prime/noprime

<trial prime>
/ontrialbegin = [
	values.counttrials += 1;
	values.SOA = list.SOAs.nextValue;
	values.quadrant = list.quadrantlist.nextValue;
	if (values.quadrant == 1) {
		values.adjust_width = -1; 
		values.adjust_height = -1;
		values.stimLocation = "left";
	} else if (values.quadrant == 2) {
		values.adjust_width = 1; 
		values.adjust_height = -1;
		values.stimLocation = "right";
	} else if (values.quadrant == 3) {
		values.adjust_width = -1; 
		values.adjust_height = 1;
		values.stimLocation = "left";
	} else if (values.quadrant == 4) {
		values.adjust_width = 1; 
		values.adjust_height = 1;
		values.stimLocation = "right";
	}
	values.responseCategory = "no response";
]										
/stimulustimes = [0 = prime; 60 = mask; 120 = clearScreen, fixation]
/ beginresponsetime = 0
/trialduration = values.SOA
/validresponse = ("A", "L", noresponse)
/iscorrectresponse = [
	return(
		((values.quadrant == 1 || values.quadrant == 3) && trial.prime.responseText == "A") ||
		((values.quadrant == 2 || values.quadrant == 4) && trial.prime.responseText == "L"));
]
/ontrialend = [
	values.totalcorrect += trial.prime.correct;
	
	if (trial.prime.responseText == "A"){
		values.responseCategory = "left";
	} else if (trial.prime.responseText == "L"){
		values.responseCategory = "right";
	}	
]
</trial>

<trial noprime>
/ontrialbegin = [
	values.counttrials += 1;
	values.SOA = list.SOAs.nextValue;
	values.quadrant = list.quadrantlist.nextValue;
	if (values.quadrant == 1) {
		values.adjust_width = -1; 
		values.adjust_height = -1;
		values.stimLocation = "left";
	} else if (values.quadrant == 2) {
		values.adjust_width = 1; 
		values.adjust_height = -1;
		values.stimLocation = "right";
	} else if (values.quadrant == 3) {
		values.adjust_width = -1; 
		values.adjust_height = 1;
		values.stimLocation = "left";
	} else if (values.quadrant == 4) {
		values.adjust_width = 1; 
		values.adjust_height = 1;
		values.stimLocation = "right";
	}
	values.responseCategory = "no response";
]
/stimulustimes = [0 = noprime; 60 = mask; 120 = clearScreen, fixation]
/beginresponsetime = 0
/validresponse = ("A", "L")
/iscorrectresponse = [
	return (
		((values.quadrant == 1 || values.quadrant == 3) && trial.noprime.responseText == "A") ||
		((values.quadrant == 2 || values.quadrant == 4) && trial.noprime.responseText == "L"));
]
/ontrialend = [
	values.totalcorrect += trial.noprime.correct;
	
	if (trial.noprime.responseText == "A"){
		values.responseCategory = "left";
	} else if (trial.noprime.responseText == "L"){
		values.responseCategory = "right";
	}
]	

/trialduration = values.SOA
</trial>

Note:
practicetrial use their own set of stimuli and randomly sample quadrant and SOA
independent of the randomized experimental sequence
<trial PPF_practicetrial>
/ontrialbegin= [
	values.SOA = list.SOAs_practice.nextValue;
	values.quadrant = list.quadrantlist_practice.nextValue;
	if (values.quadrant == 1) {
		values.adjust_width = -1; 
		values.adjust_height = -1;
		values.stimLocation = "left";
	} else if (values.quadrant == 2) {
		values.adjust_width = 1; 
		values.adjust_height = -1;
		values.stimLocation = "right";
	} else if (values.quadrant == 3) {
		values.adjust_width = -1; 
		values.adjust_height = 1;
		values.stimLocation = "left";
	} else if (values.quadrant == 4) {
		values.adjust_width = 1; 
		values.adjust_height = 1;
		values.stimLocation = "right";
	}
	
	values.responseCategory = "no response";
]
/stimulustimes = [0 = practicestim; 60 = mask; 120 = clearScreen, fixation]
/beginresponsetime = 0
/validresponse = ("A", "L")
/ responseinterrupt = immediate //to give feedback for wrong responses, practice trials interrupt the trials immediately after a response
/iscorrectresponse = [
	return (
	((values.quadrant == 1 || values.quadrant == 3) && trial.PPF_practicetrial.responseText == "A") ||
	((values.quadrant == 2 || values.quadrant == 4) && trial.PPF_practicetrial.responseText == "L"));
]
/ ontrialend = [
	if (trial.PPF_practicetrial.responseText == "A"){
		values.responseCategory = "left";
	} else if (trial.PPF_practicetrial.responseText == "L"){
		values.responseCategory = "right";
	}	
]
/trialduration = values.SOA
/ errormessage = true(text.practiceFeedback, 5000)
/ responsemessage = (0, text.practiceNRFeedback, 5000)
/ branch = [
	//practice trials run another trial.fixation as they are not so concerned with actual SOAs
	trial.fixation;
]
</trial>



*****************************
General Helper Trial
*****************************

<trial getReady>
/ stimulusframes = [1 = getReady]
/ trialduration = 5000
/ validresponse = ("A", "L")
/ beginresponsetime = 5000
/ errormessage = false
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS: Parafoveal Priming
**************************************************************************************************************
**************************************************************************************************************

<block ParafovealPriming_Practice>
/ preinstructions = (intro1, intro2)
/onblockbegin = [
	values.practice = 1; 
	values.counttrials = 0;
]
/trials = [
	1 = getReady; 
	2 = fixation; 
	3-8 = PPF_practicetrial; 
]
/ postinstructions = (teststart)
</block>

<block ParafovealPriming>
/onblockbegin = [
	values.practice = 0; 
	values.counttrials = 0;
]
/trials = [
	1 = getReady; 
	2 = fixation; 
	3-77 = prime;
]
</block>

<block ParafovealNoPriming>
/onblockbegin = [
	values.practice = 0; 
	values.counttrials = 0;
]
/trials = [
	1 = getReady; 
	2= fixation; 
	3-77= noprime; 
]
</block>

<block finish>
/ trials = [
	1 = finish;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	DISPLAY SIZE CHECK 
**************************************************************************************************************
**************************************************************************************************************

<text testStim>
/items = primes
/hposition = text.fixation.hposition + (expressions.pixeldistance)
/vposition = text.fixation.vposition + (expressions.pixeldistance)
/ fontstyle = ("Arial", expressions.primefontheight, false, false, false, false, 5, 1)
/ txcolor = black
/select = replace
</text>

<expressions>
/widthcheck = if ((text.testStim.hposition + 0.5* text.testStim.width) < display.width){
	true;
} else {
	false;
}
/heightcheck =if ((text.testStim.vposition + 0.5* text.testStim.height) < display.height){
	true;
} else {
	false;
}
</expressions>

<trial displayCheck>
/ trialduration = 0
/ branch = [
	if (expressions.widthcheck == false || expressions.heightcheck == false){
		return trial.prematureEnd;
	}
]
/ recorddata = false
</trial>

<text prematureEnd>
/items = ("The current screen is too small to run this test.

Press Spacebar to exit.")
/ fontstyle = ("Arial", 6%, true, false, false, false, 5, 1)
/ size = (80%, 50%)
/ vjustify = center
</text>

<trial prematureEnd>
/ stimulusframes = [1 = prematureEnd]
/ validresponse = (" ")
/ ontrialend = [
	script.abort();
]
</trial>

<block displayCheck>
/ trials = [1 = displayCheck]
</block>


**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/groups = (1 of 2)
/blocks = [
	1 = displayCheck;
	2 = ParafovealPriming_Practice; 
	3 = ParafovealPriming;
	4 = Finish;
]
</expt>

<expt b>
/groups = (2 of 2)
/blocks = [
	1 = displayCheck;
	2 = ParafovealPriming_Practice; 
	3 = ParafovealNoPriming;
	4 = Finish;
]
</expt>

To check fontsize heights run:
/blocks = [1 = FontsizeDetermination]


**************************************************************************************************************
												End of File
**************************************************************************************************************