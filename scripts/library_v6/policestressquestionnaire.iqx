**************************

<radiobuttons Op_q1>
/caption = "Shift work:"
/ options = ("1~nNot at all~nstressful", "2", "3",
"4", "5", "6", "7~nVery~nstressful")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/required = true
/orientation = horizontalequal
