**************************
PSQ-Op
**************************

<surveypage PSQ_Op1>
/ skip = [
	parameters.runPSQ_Op == false;
]
/caption ="<%parameters.pageinstructions%>"
/questions = [1 = Op_q1, Op_q2, Op_q3]
</surveypage>

