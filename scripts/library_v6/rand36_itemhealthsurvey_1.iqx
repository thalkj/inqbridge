script.completed, 
expressions.selfreported_HT,
expressions.PF, expressions.RP, expressions.BP, expressions.GH,
expressions.MH, expressions.RE, expressions.SF, expressions.VT,

//raw data
radiobuttons.q1.response,
radiobuttons.q2.response,
radiobuttons.q3.response,
radiobuttons.q4.response,
radiobuttons.q5.response,
radiobuttons.q6.response,
radiobuttons.q7.response,
radiobuttons.q8.response,
radiobuttons.q9.response,
radiobuttons.q10.response,
radiobuttons.q11.response,
radiobuttons.q12.response,
radiobuttons.q13.response,
radiobuttons.q14.response,
radiobuttons.q15.response,
radiobuttons.q16.response,
radiobuttons.q17.response,
radiobuttons.q18.response,
radiobuttons.q19.response,
radiobuttons.q20.response,
radiobuttons.q21.response,
radiobuttons.q22.response,
radiobuttons.q23.response,
radiobuttons.q24.response,
radiobuttons.q25.response,
radiobuttons.q26.response,
radiobuttons.q27.response,
radiobuttons.q28.response,
radiobuttons.q29.response,
radiobuttons.q30.response,
radiobuttons.q31.response,
radiobuttons.q32.response,
radiobuttons.q33.response,
radiobuttons.q34.response,
radiobuttons.q35.response,
radiobuttons.q36.response)
</summarydata>

*******************************************************************************************************************
*******************************************************************************************************************
	VALUES: automatically updated
*******************************************************************************************************************
*******************************************************************************************************************

*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

the 8 scores are the mean scores of their corresponding items 

 => Physical Health (PCS) (summary measure)
/PF: 					Physical Functioning (PF): questions 3-12
/RP:					Role-Physical (RP): questions 13-16  (4 items)
/BP:					Bodily Pain (BP): question 21-22 (2 items)
/GH:					General Health (GH): questions 1,33,34,35,36 (5 items)

=> Mental Health (MCS) (summary measure)
/MH:					Mental Health (MH): questions 24,25,26,28,30 (5 items)
/RE:					Role-Emotional (RE): questions 17,18,19 (3 items)
/SF:					Social Functioning (SF): questions 20,32 (2 items)
/VT:					Vitality (VT): question 23, 27, 29, 31  (4 items)

/selfreported_HT: q2

<expressions>
/ PF =   return ((radiobuttons.q3.response + radiobuttons.q4.response + radiobuttons.q5.response + radiobuttons.q6.response + 
radiobuttons.q7.response + radiobuttons.q8.response + radiobuttons.q9.response + radiobuttons.q10.response + 
radiobuttons.q11.response + radiobuttons.q12.response)/10)
/ RP =   return ((radiobuttons.q13.response + radiobuttons.q14.response + radiobuttons.q15.response + radiobuttons.q16.response)/4)
/ BP =   return ((radiobuttons.q21.response + radiobuttons.q22.response)/2)
/ GH =   return ((radiobuttons.q1.response + radiobuttons.q33.response + radiobuttons.q34.response + radiobuttons.q35.response + radiobuttons.q36.response) / 5)
/ MH =   return ((radiobuttons.q24.response + radiobuttons.q25.response + radiobuttons.q26.response + radiobuttons.q28.response + radiobuttons.q30.response) / 5)
/ RE =   return ((radiobuttons.q17.response + radiobuttons.q18.response + radiobuttons.q19.response) / 3)
/ SF =   return ((radiobuttons.q20.response + radiobuttons.q32.response) / 2)
/ VT =   return ((radiobuttons.q23.response + radiobuttons.q27.response + radiobuttons.q29.response + radiobuttons.q31.response) / 4)

/ selfreported_HT =   return radiobuttons.q2.response
</expressions>

*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************

Note: the responses saved in the datafile are the assigned numeric values (= percentages of total well-being)

<radiobuttons q1>
/ caption =   "1. In general, would you say your health is:"
/ options =   ("Excellent", "Very Good", "Good", "Fair", "Poor")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ required =   true
/ orientation =   horizontalequal
</radiobuttons>

<radiobuttons q2>
/ caption =   "2. Compared to one year ago, how would you rate your health in general now?"
/ options =   ("Much better now than one year ago", "Somewhat better now than one year ago", "About the same as one year ago", "Somewhat worse now than one year ago", "Much worse than one year ago")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ required =   true
/ orientation =   vertical
</radiobuttons>

<caption part3_caption>
/ caption =   "<span style='background-color:#00FEFE'>The following items are about activities you might do during a typical day. Does <b>your health now limit you</b> in these activities? If so, how much?</span>"
</caption>

<radiobuttons q3>
/ caption =   "3. <b>Vigorous activities</b>, such as running, lifting heavy objects, participating in strenuous sports"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q4>
/ caption =   "4. <b>Moderate activities</b>, such as moving a table, pushing a vacuum cleaner, bowling, or playing golf"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q5>
/ caption =   "5. Lifting or carrying groceries"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q6>
/ caption =   "6. Climbing <b>several</b> flights of stairs"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q7>
/ caption =   "7. Climbing <b>one</b> flight of stairs"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q8>
/ caption =   "8. Bending, kneeling, or stooping"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q9>
/ caption =   "9. Walking <b>more than a mile</b>"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q10>
/ caption =   "10. Walking <b>several blocks</b>"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q11>
/ caption =   "11. Walking <b>one</b> block"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q12>
/ caption =   "12. Bathing or dressing yourself"
/ options =   ("Yes, limited a lot", "Yes, limited a little", "No, not limited at all")
/ optionvalues =   ("0", "50", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<caption part4_caption>
/ caption =  "<span style='background-color:#00FEFE'>During the <b><b>past 4 weeks</b></b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of your PHYSICAL HEALTH</b>?</span>"
</caption>

<radiobuttons q13>
/ caption =   "13. Cut down the <b>amount of time<b> you spent on work or other activities."
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q14>
/ caption =   "14. <b>Accomplished less</b> than you would like"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q15>
/ caption =   "15. Were limited in the <b>kind</b> of work or other activities"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q16>
/ caption =   "16. Had <b>difficulty</b> performing the work or other activities (for example, it took extra effort)"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<caption part5_caption>
/ caption =   "<span style='background-color:#00FEFE'>During the <b><b>past 4 weeks</b></b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of any EMOTIONAL PROBLEMS</b> (such as feeling depressed or anxious)?</span>"
</caption>

<radiobuttons q17>
/ caption =   "17. Cut down the <b>amount of time</b> you spent on work or other activities"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q18>
/ caption =   "18. <b>Accomplished less</b> than you would like"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q19>
/ caption =   "19. Didn't do work or other activities as <b>carefully</b> as usual"
/ options =   ("Yes", "No")
/ optionvalues =   ("0", "100")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q20>
/ caption =   "20. During the <b>past 4 weeks</b>, to what extent has your physical health or emotional problems interfered with your normal social activities with family, friends, neighbors, or groups?"
/ options =   ("Not at all", "Slightly", "Moderately", "Quite a bit", "Extremely")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q21>
/ caption =   "21. How much <b>bodily</b> pain have you had during the <b>past 4 weeks</b>?"
/ options =   ("None", "Very mild", "Mild", "Moderate", "Severe", "Very severe")
/ optionvalues =   ("100", "80", "60", "40", "20", "0")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<radiobuttons q22>
/ caption =   "22. During the <b>past 4 weeks</b>, how much did <b>pain</b> interfere with your normal work (including both work outside the home and housework)?"
/ options =   ("Not at all", "A little bit", "Moderately", "Quite a bit", "Extremely")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ orientation =   vertical
/ required =   true
</radiobuttons>

<caption part9_caption>
/ caption =   "<span style='background-color:#00FEFE'>These questions are about how you feel and how things have been with you during the <b>past 4 weeks</b>. For each question, please give the one answer that comes closest to the way you have.</span>"
</caption>

<radiobuttons q23>
/ caption =   "23. How much of the time during the <b>past 4 weeks</b> did you feel full of pep?"
/ options =   ("All ~nof the time  ", "Most ~nof the time  ", "A good bit ~nof the time  ", "Some ~nof the time  ", "A little ~nof the time  ", "None ~nof the time  ")
/ optionvalues =   ("100", "80", "60", "40", "20", "0")
/ orientation =   horizontalequal
/ required =   true
</radiobuttons>

<radiobuttons q24>
/ caption =   "24. How much of the time during the <b>past 4 weeks</b> have you been a very nervous person?"
/ options =   ("All ~nof the time  ", "Most ~nof the time  ", "A good bit ~nof the time  ", "Some ~nof the time  ", "A little ~nof the time  ", "None ~nof the time  ")
/ optionvalues =   ("0", "20", "40", "60", "80", "100")
/ orientation =   horizontalequal
/ required =   true
</radiobuttons>

<radiobuttons q25>
/ caption =   "25. How much of the time during the <b>past 4 weeks</b> have you felt so down in the dumps that nothing could cheer you up?"
/ options =   ("All ~nof the time  ", "Most ~nof the time  ", "A good bit ~nof the time  ", "Some ~nof the time  ", "A little ~nof the time  ", "None ~nof the time  ")
/ optionvalues =   ("0", "20", "40", "60", "80", "100")
