</radiobuttons>

<caption part11_caption>
/ caption =   "<span style='background-color:#00FEFE'>How TRUE or FALSE is <b>each</b> of the following statements for you?</span>"
</caption>

<radiobuttons q33>
/ caption =   "33. I seem to get sick a little easier than other people"
/ options =   ("Definitely true", "Mostly true", "Don't know", "Mostly false", "Definitely false")
/ optionvalues =   ("0", "25", "50", "75", "100")
/ orientation =   horizontalequal
/ required =   true
</radiobuttons>

<radiobuttons q34>
/ caption =   "34. I am as healthy as anybody I know"
/ options =   ("Definitely true", "Mostly true", "Don't know", "Mostly false", "Definitely false")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ orientation =   horizontalequal
