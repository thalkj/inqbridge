/ options =   ("All ~nof the time  ", "Most ~nof the time  ", "A good bit ~nof the time  ", "Some ~nof the time  ", "A little ~nof the time  ", "None ~nof the time  ")
/ optionvalues =   ("100", "80", "60", "40", "20", "0")
