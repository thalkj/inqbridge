/ options =   ("Definitely true", "Mostly true", "Don't know", "Mostly false", "Definitely false")
/ optionvalues =   ("100", "75", "50", "25", "0")
/ orientation =   horizontalequal
/ required =   true
</radiobuttons>

*******************************************************************************************************************
*******************************************************************************************************************
	SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************

<surveypage RAND36_1>
/ caption =   "<%parameters.instructions%>"
/ questions =   [1 = q1, q2]
</surveypage>

<surveypage RAND36_2>

/ questions =   [1 = part3_caption, q3, q4]
</surveypage>

<surveypage RAND36_3>

/ questions =   [1 = part3_caption, q5, q6]
</surveypage>

<surveypage RAND36_4>

/ questions =   [1 = part3_caption, q7, q8]
</surveypage>

<surveypage RAND36_5>

/ questions =   [1 = part3_caption, q9, q10]
</surveypage>

<surveypage RAND36_6>

/ questions =   [1 = part3_caption, q11, q12]
</surveypage>

<surveypage RAND36_7>

/ questions =   [1 = part4_caption, q13, q14]
