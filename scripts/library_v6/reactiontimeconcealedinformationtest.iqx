**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

<expressions>
/createTargetStorage = {
	var i = 1;
	var currentItem = "";
	values.targetStorage = ",";
	while (i <= item.targetItems.itemCount){
		currentItem = tolower(item.targetItems.item(i));
		currentItem = replaceAll(currentItem, " ", "");	
		currentItem = replaceAll(currentItem, "\", "");
		currentItem = replaceAll(currentItem, "|", "");	
		currentItem = replaceAll(currentItem, "/", "");	
		currentItem = replaceAll(currentItem, ";", "");		
		currentItem = replaceAll(currentItem, ":", "");
		currentItem = replaceAll(currentItem, ".", "");
		currentItem = replaceAll(currentItem, ",", "");	
		currentItem = replaceAll(currentItem, "-", "");			
		
		values.targetStorage = concat(values.targetStorage, currentItem);//store the target items in lowercase letters
		values.targetStorage = concat(values.targetStorage, ",");
		i += 1;
	}//at this point targetStorage should contain all targetwords as lowercase letters sandwhiched btw. two commas (e.g. ,target1,target2,....)	
}
/cleanRecall = {
	var recall = values.recall;
	
	recall = replaceAll(recall, " ", "");	
	recall = replaceAll(recall, "\", "");
	recall = replaceAll(recall, "|", "");	
	recall = replaceAll(recall, "/", "");	
	recall = replaceAll(recall, ";", "");		
	recall = replaceAll(recall, ":", "");
	recall = replaceAll(recall, ".", "");
	recall = replaceAll(recall, ",", "");	
	recall = replaceAll(recall, "-", "");
	
	recall = concat(",", recall);
	
	//end trailing comma if not yet added
	if (!endswith(recall, ",")){
		recall = concat(recall, ",");	
	}	
	
	return (recall); //at this point 'recall' should be a lowercase word sandwiched btw. two commas (e.g. ",target1,")
}
/checkRecall = {
	var countCorrectRecall = 0;
	var tempStorage = values.targetStorage;

	if (contains(tempStorage, values.recall1)){
		countCorrectRecall += 1;
		tempStorage = replaceAll(tempStorage, values.recall1, "");
	}
	if (contains(tempStorage, values.recall2)){
		countCorrectRecall += 1;
		tempStorage = replaceAll(tempStorage, values.recall2, "");
	}
	if (contains(tempStorage, values.recall3)){
		countCorrectRecall += 1;
		tempStorage = replaceAll(tempStorage, values.recall3, "");
	}	
	if (contains(tempStorage, values.recall4)){
		countCorrectRecall += 1;
		tempStorage = replaceAll(tempStorage, values.recall4, "");
	}	
	if (contains(tempStorage, values.recall5)){
		countCorrectRecall += 1;
		tempStorage = replaceAll(tempStorage, values.recall5, "");
	}
	return(countCorrectRecall);
}
</expressions>

//summary statistics
<expressions>
/propCorrect_targets = list.ACC_targets.mean
/mean_hit_RT_targets = list.HIT_RT_targets.mean
/propCorrect_probes = list.ACC_probes.mean
/mean_CR_RT_probes = list.CR_RT_probes.mean
/propCorrect_controls = list.ACC_controls.mean
/mean_CR_RT_controls = list.CR_RT_controls.mean
/SD_CR_RT_controls = list.CR_RT_controls.standarddeviation

/RTDiff = expressions.mean_CR_RT_probes - expressions.mean_CR_RT_controls
/RT_CIT_Effect = if (expressions.RTDiff > 0){
	1;
} else {
	0;
}

</expressions>


**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text target>
/ items = targetItems
/ select = noreplace
/ resetinterval = 0
/ fontstyle = ("Arial", parameters.StimSize, false, false, false, false, 5, 1)
/ vjustify = center
/ resetinterval = 0
</text>

<text probe>
/ items = probeItems
/ select = noreplace
/ resetinterval = 0
/ fontstyle = ("Arial", parameters.StimSize, false, false, false, false, 5, 1)
/ vjustify = center
/ resetinterval = 0
</text>

<text control>
/ items = controlItems
/ select = noreplace
/ resetinterval = 0
/ fontstyle = ("Arial", parameters.StimSize, false, false, false, false, 5, 1)
/ vjustify = center
/ resetinterval = 0
</text>

<shape wordEraser>
/ shape = rectangle
/ height = 1.1 * parameters.stimSize
/ width = 100%
/ color = white
/ erase = false
</shape>

<shape feedbackEraser>
/ shape = rectangle
/ height = 9%
/ width = 100%
/ color = white
/ erase = false
</shape>


**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************


*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

<list ACC_targets>
</list>

<list ACC_probes>
</list>

<list ACC_controls>
</list>

<list HIT_RT_targets>
</list>

<list CR_RT_probes>
</list>

<list CR_RT_controls>
</list>


**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial target>
/ ontrialbegin = [
	values.iti = list.iti.nextValue;
	values.trialCounter += 1;
]
/ stimulusframes = [1 = clearScreen, target, yesResponseReminder, noResponseReminder]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ monkeyresponse = (parameters.leftKey, parameters.rightKey)
/ correctresponse = (parameters.yesKey)
/ response = timeout(parameters.maxStimDuration)
/ responsemessage = (parameters.yesKey, text.yesResponseReminder_HL, 0)
/ responsemessage = (parameters.noKey, text.noResponseReminder_HL, 0)
/ ontrialend = [
	values.word = text.target.currentItem;
	values.itemnumber = text.target.currentItemNumber;
	list.ACC_targets.appendItem(trial.target.correct);
	if (trial.target.correct){
		list.HIT_RT_targets.appendItem(trial.target.latency);
	}
	
	if (trial.target.correct){
		values.RESP = "1"; //correct response
	} else if (trial.target.response != 0){
		values.RESP = "2"; //error response
	} else {
		values.RESP = 0;//no response
		values.NR_targets += 1;
	}
]
/ branch = [
	return trial.iti;
]
</trial>

<trial probe>
/ ontrialbegin = [
	values.iti = list.iti.nextValue;
	values.trialCounter += 1;
]
/ stimulusframes = [1 = clearScreen, probe, yesResponseReminder, noResponseReminder]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ monkeyresponse = (parameters.leftKey, parameters.rightKey)
/ correctresponse = (parameters.noKey)
/ response = timeout(parameters.maxStimDuration)
/ responsemessage = (parameters.yesKey, text.yesResponseReminder_HL, 0)
/ responsemessage = (parameters.noKey, text.noResponseReminder_HL, 0)
/ ontrialend = [
	values.word = text.probe.currentItem;
	values.itemnumber = text.probe.currentItemNumber;
	list.ACC_probes.appendItem(trial.probe.correct);
	if (trial.probe.correct){
		list.CR_RT_probes.appendItem(trial.probe.latency);
	}
	
	if (trial.probe.correct){
		values.RESP = "1"; //correct response
	} else if (trial.probe.response != 0){
		values.RESP = "2"; //error response
	} else {
		values.RESP = 0;//no response
		values.NR_probes += 1;
	}
]
/ branch = [
	return trial.iti;
]
</trial>

<trial control>
/ ontrialbegin = [
	values.iti = list.iti.nextValue;
	values.trialCounter += 1;
]
/ stimulusframes = [1 = clearScreen, control, yesResponseReminder, noResponseReminder]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ monkeyresponse = (parameters.leftKey, parameters.rightKey)
/ correctresponse = (parameters.noKey)
/ response = timeout(parameters.maxStimDuration)
/ responsemessage = (parameters.yesKey, text.yesResponseReminder_HL, 0)
/ responsemessage = (parameters.noKey, text.noResponseReminder_HL, 0)
/ ontrialend = [
	values.word = text.control.currentItem;
	values.itemnumber = text.control.currentItemNumber;
	list.ACC_controls.appendItem(trial.control.correct);
	if (trial.control.correct){
		list.CR_RT_controls.appendItem(trial.control.latency);
	}
	
	if (trial.control.correct){
		values.RESP = "1"; //correct response
	} else if (trial.control.response != 0){
		values.RESP = "2"; //error response
	} else {
		values.RESP = 0;//no response
		values.NR_controls += 1;
	}
]
/ branch = [
	return trial.iti;
]
</trial>

<trial iti>
/ ontrialbegin = [
	values.word = "";
	if (values.RESP == 0){
		trial.iti.insertStimulusTime(text.responseFeedback, 0);
		trial.iti.insertStimulusTime(shape.feedbackEraser, parameters.feedbackDuration);
		values.iti += parameters.feedbackDuration;
	}
]
/ stimulustimes = [100 = yesResponseReminder, noResponseReminder]
/ trialduration = values.iti
/ recorddata = false
/ ontrialend = [
	trial.iti.resetStimulusFrames();
]
/ branch = [
	if (mod(values.trialCounter, 90) == 0){
		return trial.break;
	}
]
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block intro>
/ onblockbegin = [
	expressions.createTargetStorage;
]
/ trials = [1 = generalIntroduction]
</block>

<block targetLearning>
/ onblockbegin = [
	values.learningBlockCounter += 1;
]
/ trials = [
	1 = trial.targetIntroduction; 
	2 = surveypage.recallTargetWords;
]
/ branch = [
	if (values.learningBlockCounter < parameters.minLearningBlocks){
		return block.targetLearning;		
	} else if ((values.countCorrectRecall/5)*100 < parameters.learningCriteriumACC){//check the performance of the last block
		if (values.learningBlockCounter < parameters.maxLearningBlocks){
			return block.targetLearning; //add another learning block
		} else {
			if (parameters.prematureAbort_learningFail && !monkey.monkeyMode){
				return block.prematureEnd;
			}			
		}
	} else {
		values.learningPass = 1;
	}
]
</block>

<block prematureEnd>
/ trials = [1 = finish]
/ onblockend = [
	script.abort();
]
</block>

<block test>
/ trials = [
	1 = testIntroduction;
	2 = getReady;
	3-182 = noreplace(target, probe, control, control, control, control);
]
</block>

<block finish>
/ trials = [
	1 = finish;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt rt>
/ blocks = [
	1 = intro;
	2 = targetLearning;
	3 = test;
	4 = finish;
]
</expt>

monkey>
/ latencydistribution = normal(600,300)
</monkey>


**************************************************************************************************************
												End of File
**************************************************************************************************************