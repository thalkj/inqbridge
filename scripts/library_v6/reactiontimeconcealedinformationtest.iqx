**************************************************************************************************************
**************************************************************************************************************
	EDITABLE PARAMETERS: change editable parameters here
**************************************************************************************************************
**************************************************************************************************************

<parameters>
//timing parameters
/targetLearningDuration = 30000				//the duration (in ms) that all five target words are presented during the learning phase
/getReadyDuration = 5000					//the duration (in ms) of the get-ready sign before the start of the test

/maxStimDuration = 800						//the maximum duration (in ms) that the words are on screen
											//Note: this is also the response timeout (default: 800ms)
											
/feedbackDuration = 1000					//the duration (in ms) of the 'too slow' feedback message (default: 1000ms)											
											
//UI parameters
/stimSize = 5%

//expt-design parameters
/minLearningBlocks = 3						//the minimum number of times block.targetLearning has to run (default: 3 times)
/maxLearningBlocks = 10						//the maximum number of times block.targetLearning has to run (default: 10 times)

/learningCriteriumACC = 100%				//the percent correct recall of the 5 target words after the last learning block

/prematureAbort_learningFail = false		//true = the script prematurely ends if the learning criterium has not been reached after all learning blocks have run
											//false = the script moves from learning to test even if the learning criterium has not been reached


//ResponseKey Assignment
/leftKey = "A"
/rightKey = "L"
/yesKey = parameters.leftKey
/noKey = parameters.rightKey
</parameters>


