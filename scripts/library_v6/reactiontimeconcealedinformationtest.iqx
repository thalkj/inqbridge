**************************************************************************************************************
general  Introduction
**************************************************************************************************************
<text generalIntroduction>
/ items = ("<h1>Reaction Time Test</h1><hr><br>
This is a reaction time test to quickly and correctly categorize words into the categories 'Old Words' versus 'New Words'.<br><br>
There will only be <u>five words</u> that belong to the category 'Old Words'. We will refer to these words as the 'targets'.
Study these words well, so that you readily recognize them for the reaction time test.<br><br>
Go on to study your 5 target words now.")
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
</text>

<text continue>
/ onprepare = [
	if (!computer.hasKeyboard){
		text.continue.skip = true;
	}
]
/ items = ("press [space] to continue")
/ position = (75%, 95%)
/ vjustify = center
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txbgcolor = lightGray
/ size = (30%, 5%)
</text>


<trial generalIntroduction>
/ stimulusframes = [1 = generalIntroduction, continue]
/ validresponse = (" ")
</trial>

