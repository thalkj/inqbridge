/ items = ("<center><h1>Target Words</h1><hr><br>
<%item.targetItems.item(1)%><br><br>
<%item.targetItems.item(2)%><br><br>
<%item.targetItems.item(3)%><br><br>
<%item.targetItems.item(4)%><br><br>
<%item.targetItems.item(5)%><br></center>
")
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
</text>

