radiobuttons.cq53.response + radiobuttons.cq61.response + radiobuttons.cq73.response

/PhAssault_partner_Max300 = radiobuttons.cq8.response + radiobuttons.cq10.response + radiobuttons.cq18.response +
radiobuttons.cq22.response + radiobuttons.cq28.response + radiobuttons.cq34.response +
radiobuttons.cq38.response + radiobuttons.cq44.response + radiobuttons.cq46.response +
radiobuttons.cq54.response + radiobuttons.cq62.response + radiobuttons.cq74.response

/PsAggr_self_Max200 = radiobuttons.cq5.response + radiobuttons.cq25.response + radiobuttons.cq29.response + 
radiobuttons.cq35.response + radiobuttons.cq49.response + radiobuttons.cq65.response + 
radiobuttons.cq67.response + radiobuttons.cq69.response

/PsAggr_partner_Max200 = radiobuttons.cq6.response + radiobuttons.cq26.response + radiobuttons.cq30.response + 
radiobuttons.cq36.response + radiobuttons.cq50.response + radiobuttons.cq66.response + 
