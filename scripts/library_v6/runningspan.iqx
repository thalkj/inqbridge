</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text instructions>
/ items = instructions
/ txcolor = white
/ txbgcolor = transparent
/ hjustify = center
/ vjustify = center
/ fontstyle = ("Arial", 2.5%)
/ size = (90%, 90%)
/ position = (50%, 50%)
/ select = values.instructions
/ resetinterval = 0
/ erase = false
</text>

<text navigation>
/ items = navigation
/ txcolor = white
/ txbgcolor = transparent
/ halign = left
/ valign = top
/ hjustify = left
/ vjustify = center
/ fontstyle = ("Arial", 2.5%)
/ size = (75%, 5%)
/ position = (2.5%, 88.5%)
/ select = values.instructions
/ resetinterval = 0
/ erase = false
</text>

<trial instructions>
/ ontrialbegin = [
	if(values.instructions==5){
		text._.textColor=black; 
		text._.textBgColor=white;
		text.clear.textColor=black; 
		text.clear.textBgColor=white;
		text.exit.textColor=black; 
		text.exit.textBgColor=white;
		text._.hposition=50%; 
		text._.vposition=42%;
		text.clear.hposition=50%; 
		text.clear.vposition=57%;
		text.exit.hposition=50%; 
		text.exit.vposition=27%;
	} else {
		text._.textColor=blue; 
		text._.textBgColor=blue;
		text.clear.textColor=blue; 
		text.clear.textBgColor=blue;
		text.exit.textColor=blue; 
		text.exit.textBgColor=blue;
		text._.hposition=text.click_.hposition; 
		text._.vposition=text.click_.vposition;
		text.clear.hposition=text.clickclear.hposition; 
		text.clear.vposition=text.clickclear.vposition;
		text.exit.hposition=text.clickexit.hposition; 
		text.exit.vposition=text.clickexit.vposition;
	}
]
/ stimulusframes = [1=BlueScreen, _, clear, exit, instructions, navigation, StatusBar, ProgressBar, 
	InstructionsLabel, PracticeLabel, ReminderLabel, TestLabel]
/ validresponse = (lbuttondown, rbuttondown)
/ monkeyresponse = ("lbuttondown","lbuttondown","lbuttondown","rbuttondown") 
/ beginResponseTime = 0
/ ontrialend = [
	if(trial.instructions.response=="lbuttondown"){
		values.instructions+=1; 
		values.progressbar+=3%;
	} else if(trial.instructions.response=="rbuttondown" && values.instructions>1){
		values.instructions-=1; 
		values.progressbar-=3%;
	}
	if(values.instructions>6){
		values.stopblock=1;
	}
]
/ branch = [return trial.instructions;]
/ recorddata = true
</trial>

<trial reminder>
/ stimulusframes = [1=BlueScreen, instructions, navigation, StatusBar, ProgressBar, 
	InstructionsLabel, PracticeLabel, ReminderLabel, TestLabel]
/ validresponse = (lbuttondown)
/ recorddata = true
</trial>
/ ontrialbegin = [
	if (parameters.showScoreReport == true){
		button.exit.caption = "continue";
	}
]
<trial end>
/ stimulusframes = [1=BlueScreen, instructions]
/ timeout = 1000
/ recorddata = true
</trial>


/ ontrialbegin = [
	if (parameters.showScoreReport == true){
		button.exit.caption = "submit";
	}
]
<trial score_report>

/ showmousecursor = true
/ skip = [
	parameters.showScoreReport == false;
]
/ stimulusframes = [1=Bluescreen, scorereport, navigation2]
/ validresponse = (lButtonDown, rButtonDown)
/ recorddata = true
</trial>

<text navigation2>
/ items = ("left-click to continue")
/ txcolor = white
/ txbgcolor = transparent
/ halign = left
/ valign = top
/ hjustify = left
/ vjustify = center
/ fontstyle = ("Arial", 2.5%)
/ size = (75%, 5%)
/ position = (2.5%, 88.5%)
/ resetinterval = 0
/ erase = false
</text>

