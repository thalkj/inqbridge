/ color = silver
/ size = (78.3%, 78%)
/ erase = false
</shape>

<shape BlackFrame>
/ shape = rectangle
/ color = black
/ size = (80%, 80%)
/ position = (50%, 50%)
/ erase = false
</shape>

<shape BlankScreen>
/ shape = rectangle
/ color = silver
/ size = (100%, 100%)
/ halign = left
/ valign = top
/ position = (0%, 0%)
/ erase = false
</shape>

<shape BlueScreen>
/ shape = rectangle
/ color = blue
/ size = (100%, 100%)
/ halign = left
/ valign = top
/ position = (0%, 0%)
/ erase = false
</shape>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
	Practice Block: Number of Targets & Distractors
**************************************************************************************************************

<list nTargetsPrac>
/ items = (2)
/ resetinterval = 0
</list>

<list nDistractorsPrac>
/ items = (0,1,2,3)
/ resetinterval = 0
</list>

**************************************************************************************************************
	Test Block: Number of Targets & Distractors
**************************************************************************************************************

<list nTargetsTest>
/ items = (3,4,5,6)
/ resetinterval = 0
</list>

<list nDistractorsTest>
/ items = (0,1,2)
/ resetinterval = 0
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
	Get Number Of Targets:
	Determine number of target items and display reminder message
**************************************************************************************************************

<trial getTargets>
/ ontrialbegin = [
	list.nDistractorsPrac.resetSelection(); 
	list.nDistractorsTest.resetSelection();
	if(script.currentblock=="practice"){
		values.nTargets=list.nTargetsPrac.nextValue;
	}  else if(script.currentblock=="test"){
		values.nTargets=list.nTargetsTest.nextValue;
	}
]
/ stimulusframes = [1=BlueScreen, instructions, navigation, StatusBar, ProgressBar, 
	InstructionsLabel, PracticeLabel, ReminderLabel, TestLabel]
/ inputdevice = mouse
/ validresponse = (lbuttondown)
/ branch = [return trial.getDistractors;]
/ recorddata = true
</trial>

**************************************************************************************************************
	Get Number Of Distractors
	Determine number of distractor items and display fixation cross
**************************************************************************************************************

<trial getDistractors>
/ ontrialbegin = [
	values.nInputs=0; 
	values.lettercount=0; 
	values.correctletters=0; 
	values.recallcount=0; 
	values.recalledletters=""; 
	values.recalltrial+=1;
	if(script.currentblock=="practice"){
		values.nDistractors=list.nDistractorsPrac.nextValue;
	} else if(script.currentblock=="test"){
		values.nDistractors=list.nDistractorsTest.nextValue;
	}
	
	values.nInputs=values.nDistractors+values.nTargets;
]
/ stimulusframes = [1=BlankScreen, BlackFrame, GrayFrame, FixationCross]
/ validresponse = (noresponse)
/ trialduration = 1000
/ ontrialend = [
	item.InputLetters.clearItems(); 
	item.TargetLetters.clearItems(); 
	item.RecalledLetters.clearItems(); 
	text.Letter.resetSelection();
]
/ branch = [
	return trial.show_letter;
]	
/ posttrialpause = 500
/ recorddata = true
</trial>

**************************************************************************************************************
	Display Trial
	Display single letter according to values.stimduration and parameters.inputrate
**************************************************************************************************************

<trial show_letter>
/ ontrialbegin = [
	values.lettercount+=1;
]
/ stimulusframes = [1=BlankScreen, BlackFrame, GrayFrame, Letter]
/ validresponse = (noresponse)
/ trialduration = parameters.inputrate
/ ontrialend= [
	item.InputLetters.items=text.Letter.currentItem;
	if(values.lettercount>values.nDistractors){
		item.TargetLetters.items=text.Letter.currentItem;
	}
]
/ branch = [
	if(values.lettercount>=values.nInputs){
		return  trial.recall_letter;
	} else {
		return trial.show_letter;
	}
]
/ posttrialpause = parameters.inputrate - values.stimduration
/ recorddata = true
</trial>

**************************************************************************************************************
	Recall Trial
	Collect subject's responses
**************************************************************************************************************

<trial recall_letter>
/ inputdevice = mouse
/ pretrialpause = values.recalldelay
/ ontrialbegin = [
	values.recallcount+=1;
	if(values.recallcount==1){
		values.recalldelay=500;
	} else {
		values.recalldelay=0;
	}
]
/ stimulusframes = [1=BlankScreen, F, H, J, K, L, N, P, Q, R, S, T, Y, _, clear, exit, 
	recalledletters, recallprompt, letterstrings]
/ validresponse = (F, H, J, K, L, N, P, Q, R, S, T, Y, _, clear, exit)
/ monkeyresponse = ("F", "H", "J", "K", "exit")
/ ontrialend = [
	if(trial.recall_letter.response!="exit" && trial.recall_letter.response!="clear"){
		item.RecalledLetters.items=trial.recall_letter.response; 
		values.recalledletters=concat(values.recalledletters, trial.recall_letter.response);
	} else if(trial.recall_letter.response=="clear"){
		item.RecalledLetters.clearItems(); 
		values.recalledletters="";
	}
]
/ responsemessage = (F, clickF, 150)
/ responsemessage = (H, clickH, 150)
/ responsemessage = (J, clickJ, 150)
/ responsemessage = (K, clickK, 150)
/ responsemessage = (L, clickL, 150)
/ responsemessage = (N, clickN, 150)
/ responsemessage = (P, clickP, 150)
/ responsemessage = (Q, clickQ, 150)
/ responsemessage = (R, clickR, 150)
/ responsemessage = (S, clickS, 150)
/ responsemessage = (T, clickT, 150)
/ responsemessage = (Y, clickY, 150)
/ responsemessage = (clear, clickclear, 150)
/ responsemessage = (exit, clickexit, 150)
/ responsemessage = (_, click_, 150)
/ branch = [
	if(trial.recall_letter.response=="exit"){
		return trial.letter_feedback;
	} else {
		return trial.recall_letter;
	}
]
/ recorddata = true
</trial>

**************************************************************************************************************
	Feedback Trial
	Provide response feeback and handle scoring
**************************************************************************************************************

<trial letter_feedback>
/ pretrialpause = 500
/ ontrialbegin = [
	values.correctletters=0;
	if(item.RecalledLetters.items.1 != ""){
		if (item.TargetLetters.items.1==item.RecalledLetters.items.1){
			values.correctletters+=1; 
		}
	}
	if (item.RecalledLetters.items.2 != ""){
		if (item.TargetLetters.items.2==item.RecalledLetters.items.2){
			values.correctletters+=1;
		}
	}		
	if(item.RecalledLetters.items.3 != ""){
		if (item.TargetLetters.items.3==item.RecalledLetters.items.3){
			values.correctletters+=1;
		}
	}
	if(item.RecalledLetters.items.4 != ""){
		if (item.TargetLetters.items.4==item.RecalledLetters.items.4){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.5 != ""){
		if (item.TargetLetters.items.5==item.RecalledLetters.items.5){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.6 != ""){
		if (item.TargetLetters.items.6==item.RecalledLetters.items.6){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.7 != ""){
		if (item.TargetLetters.items.7==item.RecalledLetters.items.7){
			values.correctletters+=1;
		}
	}
	if(item.RecalledLetters.items.8 != ""){
		if (item.TargetLetters.items.8==item.RecalledLetters.items.8){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.9 != ""){
		if (item.TargetLetters.items.9==item.RecalledLetters.items.9){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.10 != ""){
		if (item.TargetLetters.items.10==item.RecalledLetters.items.10){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.11 != ""){
		if (item.TargetLetters.items.11==item.RecalledLetters.items.11){
			values.correctletters+=1; 
		}
	}
	if(item.RecalledLetters.items.12 != ""){
		if (item.TargetLetters.items.12==item.RecalledLetters.items.12){
			values.correctletters+=1;
		}
	}

	if(values.nDistractors!=0){
		values.runspanscore=values.runspanscore+values.correctletters;
	}
	values.runspantotal=values.runspantotal+values.correctletters;
]
/ stimulusframes = [1=BlankScreen, LetterFeedback]
/ validresponse = (noresponse)
/ trialduration = values.feedbackduration
/ ontrialend = [
	if(script.currentblock=="practice" && list.nTargetsPrac.unselectedCount==0 && list.nDistractorsPrac.unselectedCount==0){
		values.stopblock=1;
	} else if(script.currentblock=="test" && list.nTargetsTest.unselectedCount==0 && list.nDistractorsTest.unselectedCount==0){
		values.stopblock=1;
	}
]
/ branch = [
	if(script.currentblock=="practice"){
		if (list.nDistractorsPrac.unselectedCount==0){
			return trial.getTargets;
		} else if (list.nDistractorsPrac.unselectedCount!=0){
			return trial.getDistractors;
		}
	} else if(script.currentblock=="test"){
		if (list.nDistractorsTest.unselectedCount==0){
			return trial.getTargets;
		} else if(list.nDistractorsTest.unselectedCount!=0){
			return trial.getDistractors;
		}
	}
]
/ recorddata = true
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block instructions>
/ stop = [values.stopblock==1]
/ onblockbegin = [
	values.instructions=1;
	text.InstructionsLabel.textColor=black;
]
/ trials = [1=instructions]
/ onblockend = [
	text.InstructionsLabel.textColor=white;
	values.stopblock=0;
]
</block>

<block practice>
/ stop = [values.stopblock==1]
/ onblockbegin = [
	values.instructions=8;
	text._.textColor=black; 
	text._.textBgColor=white;
	text.clear.textColor=black; 
	text.clear.textBgColor=white;
	text.exit.textColor=black; 
	text.exit.textBgColor=white; 
	values.recalltrial=0;
	text.PracticeLabel.textColor=black;
]
/ trials = [1=getTargets]
/ onblockend = [
	text.PracticeLabel.textColor=white;
	values.stopblock=0;
]
</block>

<block reminder>
/ onblockbegin = [values.instructions=7]
/ onblockbegin = [text.ReminderLabel.textColor=black]
/ onblockend = [text.ReminderLabel.textColor=white]
/ trials = [1=reminder]
</block>

<block test>
/ stop = [values.stopblock==1]
/ onblockbegin = [
	values.instructions=8;
	values.lettercount=0; 
	values.correctletters=0; 
	values.nInputs=0;
	values.recallcount=0; 
	values.recalledletters=""; 
	values.runspantotal=0; 
	values.runspanscore=0;
	values.recalltrial=0;
	text._.textColor=black; 
	text._.textBgColor=white;
	text.clear.textColor=black; 
	text.clear.textBgColor=white;
	text.exit.textColor=black; 
	text.exit.textBgColor=white;
	text.TestLabel.textColor=black;
]
/ trials = [1=getTargets]
/ onblockend = [
	text.TestLabel.textColor=white;
]
</block>

<block end>
/ onblockbegin = [
	values.instructions=9;
]
/ trials = [
	1=score_report;
	2 = end;
]
/ onblockend = [
	values.stopblock=0;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt RunSPAN>
/ blocks = [
	1=instructions; 
	2=practice; 
	3=reminder; 
	4=test; 
	5=end;
]
</expt>

**************************************************************************************************************
**************************************************************************************************************
	Debug Stuff
**************************************************************************************************************
**************************************************************************************************************
<text letterstrings>
/ onprepare = [text.letterstrings.skip = !parameters.debugmode;]
/ items = ("~tInput Letters:~t~t<%item.InputLetters.items.1%><%item.InputLetters.items.2%><%item.InputLetters.items.3%><%item.InputLetters.items.4%><%item.InputLetters.items.5%><%item.InputLetters.items.6%><%item.InputLetters.items.7%><%item.InputLetters.items.8%><%item.InputLetters.items.9%><%item.InputLetters.items.10%><%item.InputLetters.items.11%><%item.InputLetters.items.12%>
~tTarget Letters:~t~t<%item.TargetLetters.items.1%><%item.TargetLetters.items.2%><%item.TargetLetters.items.3%><%item.TargetLetters.items.4%><%item.TargetLetters.items.5%><%item.TargetLetters.items.6%><%item.TargetLetters.items.7%><%item.TargetLetters.items.8%><%item.TargetLetters.items.9%><%item.TargetLetters.items.10%><%item.TargetLetters.items.11%><%item.TargetLetters.items.12%>
~tRecalled Letters:~t<%item.RecalledLetters.items.1%><%item.RecalledLetters.items.2%><%item.RecalledLetters.items.3%><%item.RecalledLetters.items.4%><%item.RecalledLetters.items.5%><%item.RecalledLetters.items.6%><%item.RecalledLetters.items.7%><%item.RecalledLetters.items.8%><%item.RecalledLetters.items.9%><%item.RecalledLetters.items.10%><%item.RecalledLetters.items.11%><%item.RecalledLetters.items.12%>")
/ fontstyle = ("Arial", 2.5%, true)
/ txcolor = black
/ txbgcolor = transparent
/ size = (55%, 25%)
/ position = (50%, 87%)
/ hjustify = left
/ vjustify = center
/ erase = false
</text>

**************************************************************************************************************
												End of File
**************************************************************************************************************