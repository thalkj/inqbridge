**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

/completed:						0 = script was not completed; 1 = script was completed (all condisions run)
/phase:							"training" vs. "test"
/responsetimeout_target:		time in ms that is allowed for response in the current target trial
/responsetimeout_noise:			time in ms that is allowed for response in the current noise trial
/signal:						1 = signal trial (spacebar response is correct); 0 = noisetrial (no response is correct)

/targettype:					"A" vs. "B" (here: A-me; B-me)
/pairing:						"AA" -> targetA-attributeA (here: not meand nice)
								"AB" -> targetA-attributeB (here: not meand nasty)
								"BA" -> targetB-attributeA (here: me-nice)
								"BB" -> targetB-attributeB (here: me-nasty)
/trialtype:						"practice" vs. "test"

<values>
/ completed = 0
/ phase = "training"
/ responsetimeout_target = 0
/ responsetimeout_noise = 0
/ signal = 0
/ targettype = ""
/ pairing = ""
/ trialtype = "training"
/ selectReminders = 1
</values>

******************************
Summary values
******************************

/count_signalAA:			counts signal trials for pairing targetA-attributeA (here: me- nice) - across all responsetimeouts
/count_NoiseAA:				counts noise trials for pairing targetA-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalAB:			counts signal trials for pairing targetA-attributeB (here: me- nasty) - across all responsetimeouts
/count_NoiseAB:				counts noise trials for pairing targetA-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBA:			counts signal trials for pairing targetB-attributeA (here: not me- nice) - across all responsetimeouts
/count_NoiseBA:				counts noise trials for pairing targetB-attributeA - across all responsetimeouts
(and separately for responsetimeouts)

/count_signalBB:			counts signal trials for pairing targetB-attributeB (here: not me- nasty) - across all responsetimeouts
/count_NoiseBB:				counts noise trials for pairing targetB-attributeB - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AA:					counts hits for pairing targetA-attributeA (here: me- nice) - across all responsetimeouts
/FA_AA:						counts false alarms for pairing targetA-attributeA (here: me- nice) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_AB:					counts hits for pairing targetA-attributeB (here: me- nasty) - across all responsetimeouts
/FA_AB:						counts false alarms for pairing targetA-attributeA (here: me- nasty) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_BA:					counts hits for pairing targetB-attributeA (here: not me- nice) - across all responsetimeouts
/FA_BA:						counts false alarms for pairing targetA-attributeA (here: not me- nice) - across all responsetimeouts
(and separately for responsetimeouts)

/hits_BB:					counts hits for pairing targetB-attributeB (here: not me- nasty) - across all responsetimeouts
/FA_BB:						counts false alarms for pairing targetA-attributeB (here: not me- nasty) - across all responsetimeouts
(and separately for responsetimeouts)


<values>
/ count_signalAA = 0
/ count_NoiseAA = 0
/ count_signalAA1 = 0
/ count_NoiseAA1 = 0
/ count_signalAA2 = 0
/ count_NoiseAA2 = 0
/ count_signalAA3 = 0
/ count_NoiseAA3 = 0
/ count_signalAA4 = 0
/ count_NoiseAA4 = 0

/ count_signalAB = 0
