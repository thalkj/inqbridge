/ count_NoiseBA1 = 0
/ count_signalBA2 = 0
/ count_NoiseBA2 = 0
/ count_signalBA3 = 0
/ count_NoiseBA3 = 0
/ count_signalBA4 = 0
/ count_NoiseBA4 = 0

/ count_signalBB = 0
/ count_NoiseBB = 0
