**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/rHit_AA:					hit rate for pairing targetA-attributeA (here: me- nice) across all responsetimeouts
/rHit_AB:					hit rate for pairing targetA-attributeB (here: me- nasty) across all responsetimeouts
/rHit_BA:					hit rate for pairing targetB-attributeA (here: not me- nice) across all responsetimeouts
/rHit_BB:					hit rate for pairing targetB-attributeB (here: not me- nasty) across all responsetimeouts

/rFA_AA:					false alarm (FA) rate for pairing targetA-attributeA (here: me- nice) across all responsetimeouts
/rFA_AB:					false alarm (FA) rate for pairing targetA-attributeB (here: me- nasty) across all responsetimeouts
/rFA_BA:					false alarm (FA) rate for pairing targetB-attributeA (here: not me- nice) across all responsetimeouts
/rFA_BB:					false alarm (FA) rate for pairing targetB-attributeB (here: not me- nasty) across all responsetimeouts


Note: the following expressions calculate z-scores based on hit and FA rate.(see Gregg & Sedikides, 2010, p.148)
If the hit rate / FA rate is 0 => 0.005 is used instead
IF the hit rate / FA rate is 1.0 => 0.995 is used instead
()

/zhit_AA:					z-score of hit rate for pairings targetA-attributeA (here: me- nice)
/zhit_AB:					z-score of hit rate for pairings targetA-attributeB (here: me- nasty)
/zhit_BA:					z-score of hit rate for pairings targetB-attributeA (here: not me- nice)
/zhit_BB:					z-score of hit rate for pairings targetB-attributeB (here: not me- nasty)

/zFA_AA:					z-score of FA rate for pairings targetA-attributeA (here: me- nice)
/zFA_AB:					z-score of FA rate for pairings targetA-attributeB (here: me- nasty)
/zFA_BA:					z-score of FA rate for pairings targetB-attributeA (here: not me- nice)
/zFA_BB:					z-score of FA rate for pairings targetB-attributeB (here: not me- nasty)

/AA_dprime:					Computes d' (parametric measure of discriminability) for me-nice Pairings
/AB_dprime:					Computes d' (parametric measure of discriminability) for me-nasty Pairings
/BA_dprime:					Computes d' (parametric measure of discriminability) for not me- nice Pairings
/BB_dprime:					Computes d' (parametric measure of discriminability) for not me- nasty Pairings

/ AA_beta:					Computes ß (beta) (parametric measure of bias) for me-nice Pairings
/ AB_beta:					Computes ß (beta) (parametric measure of bias) for me-nasty Pairings
/ BA_beta:					Computes ß (beta) (parametric measure of bias) for not me- nice Pairings
/ BB_beta :					Computes ß (beta) (parametric measure of bias) for not me- nasty Pairings

/propcorrect_AA:			overall proportion correct for pairing targetA-attributeA (here: me- nice)
/propcorrect_AB:			overall proportion correct for pairing targetA-attributeB (here: me- nasty)
/propcorrect_BA:			overall proportion correct for pairing targetB-attributeA (here: not me- nice)
/propcorrect_BB:			overall proportion correct for pairing targetB-attributeB (here: not me- nasty)

GNATpart1:					(a) subtracting d' for the Not-me & Nice block from d' for the me & Nice block;
GNATpart2:					(b) subtracting d' for the me & Nasty block from d' for the Not-me & Nasty block;
GNATALL:					A composite index of implicit self-esteem (Gregg & Sedikides, 2010)
							=> sum of GNATpart1 and GNATpart2


<expressions>
/ targetALabel = return item.targetAlabel.item(1)
/ targetBLabel = return item.targetBlabel.item(1)
/ attributeALabel = return item.attributeAlabel.item(1)
/ attributeBLabel = return item.attributeBlabel.item(1)

/ rHit_AA = return (values.hits_AA/values.count_signalAA)
/ rMiss_AA = return (1-expressions.rHit_AA)
/ rFa_AA = return (values.fa_AA/values.count_noiseAA)
/ rCr_AA = return (1-expressions.rFa_AA)

/ zHit_AA = {
	if (expressions.rHit_AA == 0){
		return zOfP(expressions.rHit_AA + 0.005)		
	} else if (expressions.rHit_AA == 1){
		return zOfP(expressions.rHit_AA - 0.005)
	} else {
		return zOfP(expressions.rHit_AA)	
	}
}

/ zFa_AA = {
	if (expressions.rFa_AA == 0){
		return zOfP(expressions.rFa_AA + 0.005)		
	} else if (expressions.rFa_AA == 1){
		return zOfP(expressions.rFa_AA - 0.005)
	} else {
		return zOfP(expressions.rFa_AA)	
	}
}
/ dPrime_AA = return (expressions.zHit_AA-expressions.zFa_AA)
/ c_AA = return (-1*((expressions.zHit_AA + expressions.zFa_AA)/2))

/ rHit_AB = return (values.hits_AB/values.count_signalAB)
/ rMiss_AB = return (1-expressions.rHit_AB)
/ rFa_AB = return (values.fa_AB/values.count_noiseAB)
/ rCr_AB = return (1-expressions.rFa_AB)

/ zHit_AB = {
	if (expressions.rHit_AB == 0){
		return zOfP(expressions.rHit_AB + 0.005)		
	} else if (expressions.rHit_AB == 1){
		return zOfP(expressions.rHit_AB - 0.005)
	} else {
		return zOfP(expressions.rHit_AB)	
	}
}

/ zFa_AB = {
	if (expressions.rFa_AB == 0){
		return zOfP(expressions.rFa_AB + 0.005)		
	} else if (expressions.rFa_AB == 1){
		return zOfP(expressions.rFa_AB - 0.005)
	} else {
		return zOfP(expressions.rFa_AB)	
	}
}
/ dPrime_AB = return (expressions.zHit_AB-expressions.zFa_AB)
/ c_AB = return (-1*((expressions.zHit_AB + expressions.zFa_AB)/2))


/ rHit_BA = return (values.hits_BA/values.count_signalBA)
/ rMiss_BA = return (1-expressions.rHit_BA)
/ rFa_BA = return (values.fa_BA/values.count_noiseBA)
/ rCr_BA = return (1-expressions.rFa_BA)

/ zHit_BA = {
	if (expressions.rHit_BA == 0){
		return zOfP(expressions.rHit_BA + 0.005)		
	} else if (expressions.rHit_BA == 1){
		return zOfP(expressions.rHit_BA - 0.005)
	} else {
		return zOfP(expressions.rHit_BA)	
	}
}

/ zFa_BA = {
	if (expressions.rFa_BA == 0){
		return zOfP(expressions.rFa_BA + 0.005)		
	} else if (expressions.rFa_BA == 1){
		return zOfP(expressions.rFa_BA - 0.005)
	} else {
		return zOfP(expressions.rFa_BA)	
	}
}
/ dPrime_BA = return (expressions.zHit_BA-expressions.zFa_BA)
/ c_BA = return (-1*((expressions.zHit_BA + expressions.zFa_BA)/2))

/ rHit_BB = return (values.hits_BB/values.count_signalBB)
/ rMiss_BB = return (1-expressions.rHit_BB)
/ rFa_BB = return (values.fa_BB/values.count_noiseBB)
/ rCr_BB = return (1-expressions.rFa_BB)

/ zHit_BB = {
	if (expressions.rHit_BB == 0){
		return zOfP(expressions.rHit_BB + 0.005)		
	} else if (expressions.rHit_BB == 1){
		return zOfP(expressions.rHit_BB - 0.005)
	} else {
		return zOfP(expressions.rHit_BB)	
	}
}

/ zFa_BB = {
	if (expressions.rFa_BB == 0){
		return zOfP(expressions.rFa_BB + 0.005)		
	} else if (expressions.rFa_BB == 1){
		return zOfP(expressions.rFa_BB - 0.005)
	} else {
		return zOfP(expressions.rFa_BB)	
	}
}
/ dPrime_BB = return (expressions.zHit_BB-expressions.zFa_BB)
/ c_BB = return (-1*((expressions.zHit_BB + expressions.zFa_BB)/2))

/ propcorrect_AA = (values.hits_AA + (values.count_noiseAA - values.FA_AA)) / (values.count_signalAA + values.count_noiseAA)
/ propcorrect_AB = (values.hits_AB + (values.count_noiseAB - values.FA_AB)) / (values.count_signalAB + values.count_noiseAB)
/ propcorrect_BA = (values.hits_BA + (values.count_noiseBA - values.FA_BA)) / (values.count_signalBA + values.count_noiseBA)
/ propcorrect_BB = (values.hits_BB + (values.count_noiseBB - values.FA_BB)) / (values.count_signalBB + values.count_noiseBB)

/ GNATpart1 = expressions.dPrime_AA- expressions.dPrime_BA
/ GNATpart2 = expressions.dPrime_BB- expressions.dPrime_AB
/ GNATALL = expressions.GNATpart1 + expressions.GNATpart2
</expressions>


**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text NoiseA>
/ items = NoiseA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
/ select = noreplace
</text>

<text NoiseB>
/ items = NoiseB 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
/ select = noreplace
</text>


<text TargetA>
/ items = TargetA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
/ select = noreplace
</text>

<text TargetB>
/ items = TargetB 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = white 
/ select = noreplace
</text>

<text attributeA>
/ items = attributeA 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = (0, 255, 255) 
/ select = noreplace
</text>

<text attributeB>
/ items = attributeB 
/ fontstyle = ("Arial", 5%, false, false, false, false, 5, 1)
/ txcolor = (0, 255, 255) 
/ select = noreplace
</text>

********************* Reminder Stimuli *********************

<text TargetAremind>
/ items = ("<%item.targetAlabel.item(1)%>") 
/ color = white 
/ position = (30,15) 
</text>

<text TargetBremind>
/ items = ("<%item.targetBlabel.item(1)%>") 
/ color = white 
/ position = (30,15) 
</text>

<text attributeAremind>
/ items = ("<%item.attributealabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70,15) 
</text>

<text attributeBremind>
/ items = ("<%item.attributeBlabel.item(1)%>") 
/ color = (0, 255, 255) 
/ position = (70, 15) 
</text>

<text error>
/ items = ("X") 
/ position = (50,65) 
/ color = red 
</text>

<text correctresp>
/ items = ("O") 
/ position = (50,65) 
/ color = green 
</text>

<text remind>
/ items = reminders
/ select = values.selectReminders
/ position = (50%, 65%) 
/ size = (80%, 50%)
/ txcolor = white 
/ fontstyle = ("Arial", 2.67%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = center
</text>

