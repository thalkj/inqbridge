<expt selfesteemgnat>
/ blocks = [
	1 = instructions;
	2 = trainingStart;
	3-6   = random (attributeA_responsetimeout1, attributeB_responsetimeout1, TargetA_responsetimeout1, TargetB_responsetimeout1);
    7 = testStart;			
	8-11   = random(TargetBattributeA_responsetimeout1, TargetBattributeB_responsetimeout1, TargetAattributeA_responsetimeout1, TargetAattributeB_responsetimeout1);			
]

</expt>

