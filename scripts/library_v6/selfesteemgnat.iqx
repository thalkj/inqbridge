**************************************************************************************************************

<trial TargetA_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100) 
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=TargetA] 
/ posttrialpause = parameters.isi
</trial>

<trial TargetB_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=TargetB] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeA_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
