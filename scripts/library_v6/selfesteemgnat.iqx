/ count_NoiseBB1 = 0
/ count_signalBB2 = 0
/ count_NoiseBB2 = 0
/ count_signalBB3 = 0
/ count_NoiseBB3 = 0
/ count_signalBB4 = 0
/ count_NoiseBB4 = 0

/ hits_AA = 0
/ FA_AA = 0
/ hits_AA1 = 0
/ FA_AA1 = 0
/ hits_AA2 = 0
/ FA_AA2 = 0
/ hits_AA3 = 0
/ FA_AA3 = 0
/ hits_AA4 = 0
/ FA_AA4 = 0

/ hits_AB = 0
