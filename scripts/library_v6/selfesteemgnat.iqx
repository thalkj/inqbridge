/ correctresponse = (" ") 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeA] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeB_true>
/ ontrialbegin = [values.signal = 1]
/ timeout = values.responsetimeout_target 
/ validresponse = (" ")
/ correctresponse = (" ") 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeB] 
/ posttrialpause = parameters.isi
</trial>

<trial NoiseA_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise 
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=NoiseA] 
/ posttrialpause = parameters.isi
</trial>

<trial NoiseB_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise 
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=NoiseB]
/ posttrialpause = parameters.isi
</trial>

<trial attributeB_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeB] 
/ posttrialpause = parameters.isi
</trial>

<trial attributeA_false>
/ ontrialbegin = [values.signal = 0]
/ timeout = values.responsetimeout_noise 
/ validresponse = (" ")
/ correctresponse = (0) 
/ errormessage = true(error, 100)
/ correctmessage = true(correctresp, 100) 
/ stimulusFrames = [1=attributeA]
/ posttrialpause = parameters.isi
</trial>

<trial reminder>
/ validresponse = (" ")
/ correctresponse = (" ") 
/ stimulusFrames = [1=remind] 
/ response = correct 
/ recorddata = false
/ posttrialpause = 1000
</trial> 

<trial testTrialReminder>
/ correctresponse = (" ") 
/ stimulusFrames = [1=testTrialReminder] 
/ response = correct 
/ recorddata = false
/ ontrialend = [
	text.TargetA.resetSelection();
	text.TargetB.resetSelection();
	text.NoiseA.resetSelection();
	text.NoiseB.resetSelection();
	text.attributeA.resetSelection();
	text.attributeB.resetSelection();
]
/ posttrialpause = 1000
</trial> 

<trial trainingStart>
/ ontrialbegin = [
	item.NoiseB.appendItem(textbox.name.response);
	item.TargetA.appendItem(textbox.name.response);
	values.phase = "training";
]
/ trialduration = 0
/ recorddata = false
</trial>

<trial testStart>
/ ontrialbegin = [
	values.phase = "test";
	values.selectReminders = 3;
]
/ stimulusframes = [1 = trainingEnd]
/ validresponse = (" ")
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<survey instructions>
/ pages = [
	1 = intro1; 
	2 = intro2;
	3 = intro3;
	4 = intro4;
]
/ finishlabel = "START"
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</survey>

<block trainingStart>
/ trials = [1 = trainingStart]
</block>

<block testStart>
/ trials = [1 = testStart]
</block>

*********************************************************************
Training Blocks: separate presentation of attributes and targets
*********************************************************************

Note: this block presents Attribute trials for which attribute A (nice) is the correct response 
with responsetimeout1
<block attributeA_responsetimeout1>
/ bgstim = (attributeAremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [2-21 = random(attributeA_true, attributeB_false); 1 = reminder] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

Note: this block presents Attribute trials for which attribute B (nasty) is the correct response 
with responsetimeout1
<block attributeB_responsetimeout1>
/ bgstim = (attributeBremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [2-21 = random(attributeB_true, attributeA_false); 1 = reminder] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

Note: this block presents TargetA (me) and NoiseA (not me) trials
with responsetimeout1
<block TargetA_responsetimeout1>
/ bgstim = (TargetAremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [2-21 = random(TargetA_true, NoiseA_false); 1 = reminder] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>

Note: this block presents TargetB (not me) and NoiseB (me) trials
with responsetimeout1
<block TargetB_responsetimeout1>
/ bgstim = (TargetBremind)
/ onblockbegin = [
	values.targettype = "training";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [2-21 = random(TargetB_true, NoiseB_false); 1 = reminder] 
/ onblockend = [
	values.selectReminders = 2;
]
</block>


****************************************************************************
responsetimeout1:
****************************************************************************

<block TargetBattributeA_responsetimeout1>
/ bgstim = (TargetBremind, attributeAremind)
/ onblockbegin = [
	values.targettype = "B";
	values.pairing = "BA";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [
	1 = reminder;
	2-17 = random(TargetB_true, NoiseB_false, attributeA_true, attributeB_false);
    18 = testTrialReminder;
	19-66 = random(TargetB_true, NoiseB_false, attributeA_true, attributeB_false);
] 

/ ontrialend = [
	if (block.TargetBattributeA_responsetimeout1.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1) {
			values.hits_BA += block.TargetBattributeA_responsetimeout1.correct;
			values.hits_BA1 += block.TargetBattributeA_responsetimeout1.correct;
			values.count_signalBA += 1;
			values.count_signalBA1 += 1;
		} else if (values.signal == 0) {
			values.FA_BA += block.TargetBattributeA_responsetimeout1.error;
			values.FA_BA1 += block.TargetBattributeA_responsetimeout1.error;
			values.count_noiseBA += 1;
			values.count_noiseBA1 += 1;
		}		
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]					

</block>

Note: this block pairs targetB (me) with attributeB (nasty) with responsetimeout1
<block TargetBattributeB_responsetimeout1>
/ bgstim = (TargetBremind, attributeBremind)
/ onblockbegin = [
	values.targettype = "B";
	values.pairing = "BB";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [
	1 = reminder;
	2-17 = random(TargetB_true, NoiseB_false, attributeA_false, attributeB_true);
    18 = testTrialReminder;
    19-66 = random(TargetB_true, NoiseB_false, attributeA_false, attributeB_true);
] 

/ ontrialend = [
	if (block.TargetBattributeB_responsetimeout1.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1) {
			values.hits_BB += block.TargetBattributeB_responsetimeout1.correct;
			values.hits_BB1 += block.TargetBattributeB_responsetimeout1.correct;
			values.count_signalBB += 1;
			values.count_signalBB1 += 1;
		} else if (values.signal == 0) {
			values.FA_BB += block.TargetBattributeB_responsetimeout1.error;
			values.FA_BB1 += block.TargetBattributeB_responsetimeout1.error;
			values.count_noiseBB += 1;
			values.count_noiseBB1 += 1;
		}		
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]
</block>

Note: this block pairs targetA (me) with attributeA (nice) with responsetimeout1
<block TargetAattributeA_responsetimeout1>
/ bgstim = (TargetAremind, attributeAremind)
/ onblockbegin = [
	values.targettype = "A";
	values.pairing = "AA";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [
	1 = reminder;
	2-17 = random(TargetA_true, NoiseA_false, attributeA_true, attributeB_false);
    18 = testTrialReminder;
    19-66 = random(TargetA_true, NoiseA_false, attributeA_true, attributeB_false);
] 

/ ontrialend = [
	if (block.TargetAattributeA_responsetimeout1.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1) {
			values.hits_AA += block.TargetAattributeA_responsetimeout1.correct;
			values.hits_AA1 += block.TargetAattributeA_responsetimeout1.correct;
			values.count_signalAA += 1;
			values.count_signalAA1 += 1;
		} else if (values.signal == 0) {
			values.FA_AA += block.TargetAattributeA_responsetimeout1.error;
			values.FA_AA1 += block.TargetAattributeA_responsetimeout1.error;
			values.count_noiseAA += 1;
			values.count_noiseAA1 += 1;
		}		
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]
</block>

Note: this block pairs targetA (me) with attributeB (nasty) with responsetimeout1
<block TargetAattributeB_responsetimeout1>
/ bgstim = (TargetAremind, attributeBremind)
/ onblockbegin = [
	values.targettype = "A";
	values.pairing = "AB";
	values.responsetimeout_target = parameters.responsetimeout1_signal;
	values.responsetimeout_noise = parameters.responsetimeout1_noise;
]
/ trials = [
	1 = reminder;
	2-17 = random(TargetA_true, NoiseA_false, attributeA_false, attributeB_true);
	18 = testTrialReminder;
	19-66 = random(TargetA_true, NoiseA_false, attributeA_false, attributeB_true);
] 

/ ontrialend = [
	if (block.TargetAattributeB_responsetimeout1.trialcount > 18){
		values.trialtype = "test";
		if (values.signal == 1) {
			values.hits_AB += block.TargetAattributeB_responsetimeout1.correct;
			values.hits_AB1 += block.TargetAattributeB_responsetimeout1.correct;
			values.count_signalAB += 1;
			values.count_signalAB1 += 1;
		} else if (values.signal == 0) {
			values.FA_AB += block.TargetAattributeB_responsetimeout1.error;
			values.FA_AB1 += block.TargetAattributeB_responsetimeout1.error;
			values.count_noiseAB += 1;
			values.count_noiseAB1 += 1;
		}		
	} else {
		values.trialtype = "practice";
	}
]
/ onblockend = [
	values.selectReminders = 4;
]
</block>

