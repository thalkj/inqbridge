/textboxsize = (70%, 10%)
/required = true
</textbox>

<textbox stem11>
/caption= "<%parameters.stem11%>"
/textboxsize = (70%, 10%)
/required = true
</textbox>

Add additional stems
textbox stem12>
/caption= "<%parameters.stem12%>"    <= under Editable Values create the value caption for stem12 OR simply write the caption here
/textboxsize = (70%, 10%)
/required = false
</textbox>

*******************************************************************************************************************
*******************************************************************************************************************
	SCT SURVEYPAGES
*******************************************************************************************************************
*******************************************************************************************************************

<surveypage SCT1>
/caption = "<h2>Sentence Completion Task</h2>"
/subcaption = "<%parameters.instructions%>"
/questions = [1 = stem1; 2 = stem2; 3 = stem3]
/ontrialend = [
	values.response_stem1 = textbox.stem1.response;
	values.response_stem2 = textbox.stem2.response;
	values.response_stem3 = textbox.stem3.response;
]
</surveypage>

<surveypage SCT2>
/caption = "<h2>Sentence Completion Task</h2>"
/subcaption = "<%parameters.instructions%>"
/questions = [1 = stem4; 2 = stem5; 3 = stem6]
/ontrialend = [
	values.response_stem4 = textbox.stem4.response;
	values.response_stem5 = textbox.stem5.response;
	values.response_stem6 = textbox.stem6.response;
]
</surveypage>

<surveypage SCT3>
/caption = "<h2>Sentence Completion Task</h2>"
/subcaption = "<%parameters.instructions%>"
/questions = [1 = stem7; 2 = stem8; 3 = stem9]
/ontrialend = [
	values.response_stem7 = textbox.stem7.response;
	values.response_stem8 = textbox.stem8.response;
	values.response_stem9 = textbox.stem9.response;
]
</surveypage>

<surveypage SCT4>
/caption = "<h2>Sentence Completion Task</h2>"
/subcaption = "<%parameters.instructions%>"
/questions = [1 = stem10; 2 = stem11]
/ontrialend = [
	values.response_stem10 = textbox.stem10.response;
	values.response_stem11 = textbox.stem11.response;
]
</surveypage>

*******************************************************************************************************************
*******************************************************************************************************************
	SCT SURVEY
*******************************************************************************************************************
*******************************************************************************************************************

<survey SentenceCompletionTask>
/pages = [
	1 = SCT1; 
	2 = SCT2; 
	3 = SCT3; 
	4 = SCT4;
]
/fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/subcaptionfontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/itemspacing = 3%
/itemfontstyle = ("Arial", 2.5%, true, false, false, false, 5, 1)
/responsefontstyle = ("Arial", 2.5%, true, false, false, false, 5, 1)
/showpagenumbers = false
/ showquestionnumbers = false
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</survey>

*******************************************************************************************************************
*******************************************************************************************************************
	RATING QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************

<radiobuttons rating_response1>
/caption = "<%values.response_stem1%>
"
/ options=("1: what you wrote down refers to one specific moment or a particular time
", 
"2: what you wrote down refers to a repeated activity or a category of similar events without the specification of a particular time
", 
"3: what you wrote down refers to an extended period of time which lasted longer than a day
",
"4: you had something in mind, but did not want to write it down for whatever reason(e.g., too personal). What you had in mind refers to one specific moment or a particular time
",
"5: you had something in mind, but did not want to write it down for whatever reason(e.g., too personal). What you had in mind refers to refers to a repeated activity or a category of similar events without the specification of a particular time
",
"6: you had something in mind, but did not want to write it down for whatever reason(e.g., too personal). What you had in mind refers to refers refers to an extended period of time which lasted longer than a day
",
"7: you seriously tried to complete the sentence, but could not come up with something
",
"8: you did not seriously try to complete the sentence in a meaningful way")
/ required=true
</radiobuttons>

