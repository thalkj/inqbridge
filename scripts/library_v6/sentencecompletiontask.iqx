*******************************************************************************************************************
*******************************************************************************************************************
	RATING SURVEY
*******************************************************************************************************************
*******************************************************************************************************************
Note:
- survey.rating only runs if parameters.participant_responserating = 1 (Editable Value)

<survey SentenceCompletionTask_Rating>
/skip = [parameters.participant_responserating != 1]
/pages = [
	1 = rating1; 
	2 = rating2; 
	3 = rating3; 
	4 = rating4; 
	5 = rating5; 
	6 = rating6; 
	7 = rating7; 
	8 = rating8;
	9 = rating9; 
	10 = rating10; 
	11 = rating11;
]
/fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/itemspacing = 3%
/itemfontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/responsefontstyle = ("Arial", 2%, false, false, false, false, 5, 1)
/showpagenumbers = false
/ showquestionnumbers = false
/ navigationbuttonfontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
</survey>

*******************************************************************************************************************
*******************************************************************************************************************
EXPERIMENT
*******************************************************************************************************************
*******************************************************************************************************************

