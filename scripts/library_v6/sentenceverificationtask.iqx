**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
<list accuracy>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list latencies>
</list>

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
<list accuracy_truthConsistent>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list latencies_truthConsistent>
</list>

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
<list accuracy_truthInconsistent>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list latencies_truthInconsistent>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

Note: trial.domain1
- presents a randomly selected statement for domain 1 and waits for response 
- evaluates the accuracy of the response: if the response equals the response under the scientific theory, the response is scored as 'correct'
- evaluates truth consistency of the statement and stores accuracy/latency in corresponding summary lists
<trial domain1>
/ stimulusframes = [1 = domain1_stim, true, false]
/ validresponse = (parameters.trueResponsekey, parameters.falseResponsekey)
/ iscorrectresponse = [
	values.stimConcept = item.domain1_concepts.item(text.domain1_stim.currentItemNumber);
	values.naiveCorrect = item.domain1_T1.item(text.domain1_stim.currentItemNumber);
	values.scientificCorrect = item.domain1_T2.item(text.domain1_stim.currentItemNumber);
	if (trial.domain1.responseText == parameters.trueResponsekey){
		values.responseCat = 1;
	} else {
		values.responseCat = 0;
	}

	return (values.responseCat == values.scientificCorrect);
]
/ ontrialend = [
	if (values.naiveCorrect == values.scientificCorrect){
		values.truthConsistency = 1;
	} else {
		values.truthConsistency = 0;
	}
	
	list.accuracy.appendItem(trial.domain1.correct);	
	if (values.truthConsistency == 1){
		list.accuracy_truthConsistent.appendItem(trial.domain1.correct);		
	} else {
		list.accuracy_truthInconsistent.appendItem(trial.domain1.correct);
	}		
	if (trial.domain1.correct){
		list.latencies.appendItem(trial.domain1.latency);
		if (values.truthConsistency == 1){
			list.latencies_truthConsistent.appendItem(trial.domain1.latency);		
		} else {
			list.latencies_truthInconsistent.appendItem(trial.domain1.latency);		
		}
	}	
]
</trial>

<trial domain2>
/ stimulusframes = [1 = domain2_stim, true, false]
/ validresponse = (parameters.trueResponsekey, parameters.falseResponsekey)
/ iscorrectresponse = [
	values.stimConcept = item.domain2_concepts.item(text.domain2_stim.currentItemNumber);
	values.naiveCorrect = item.domain2_T1.item(text.domain2_stim.currentItemNumber);
	values.scientificCorrect = item.domain2_T2.item(text.domain2_stim.currentItemNumber);
	if (trial.domain2.responseText == parameters.trueResponsekey){
		values.responseCat = 1;
	} else {
		values.responseCat = 0;
	}

	return (values.responseCat == values.scientificCorrect);
]
/ ontrialend = [
	if (values.naiveCorrect == values.scientificCorrect){
		values.truthConsistency = 1;
	} else {
		values.truthConsistency = 0;
	}
	
	list.accuracy.appendItem(trial.domain2.correct);	
	if (values.truthConsistency == 1){
		list.accuracy_truthConsistent.appendItem(trial.domain2.correct);		
	} else {
		list.accuracy_truthInconsistent.appendItem(trial.domain2.correct);
	}		
	if (trial.domain2.correct){
		list.latencies.appendItem(trial.domain2.latency);
		if (values.truthConsistency == 1){
			list.latencies_truthConsistent.appendItem(trial.domain2.latency);		
		} else {
			list.latencies_truthInconsistent.appendItem(trial.domain2.latency);		
		}
	}	
]
</trial>

<trial domain3>
/ stimulusframes = [1 = domain3_stim, true, false]
/ validresponse = (parameters.trueResponsekey, parameters.falseResponsekey)
/ iscorrectresponse = [
	values.stimConcept = item.domain3_concepts.item(text.domain3_stim.currentItemNumber);
	values.naiveCorrect = item.domain3_T1.item(text.domain3_stim.currentItemNumber);
	values.scientificCorrect = item.domain3_T2.item(text.domain3_stim.currentItemNumber);
	if (trial.domain3.responseText == parameters.trueResponsekey){
