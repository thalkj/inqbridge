**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = (0, 0, 0)
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	INCLUDE
**************************************************************************************************************
**************************************************************************************************************

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 
values.domain, values.stimConcept, values.naiveCorrect, values.scientificCorrect, values.truthConsistency, 
stimulusitem, response, values.responseCat, correct, latency)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,
expressions.propCorrect, expressions.meanRT, expressions.SD,
expressions.propCorrect_truthConsistent, expressions.meanRT_truthConsistent, expressions.SD_truthConsistent,
expressions.propCorrect_truthInconsistent, expressions.meanRT_truthInconsistent, expressions.SD_truthInconsistent,
expressions.RTDiff)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/ domain:				domain name tested
/ stimConcept:			stimulus concept
/ naiveCorrect:			1 = true by naive understanding; 0 = otherwise
/ scientificCorrect:	1 = true by scientific understanding; 0 = otherwise
/ response:				1 = true; 0 = false
/ truthConsistency: 	1 = naive understanding and scientific understanding are consistent; 0 = otherwise

<values>
/ domain = 0
/ stimConcept = 0
/ naiveCorrect = 0
/ scientificCorrect = 0
/ responseCat = 0
/ truthConsistency = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

Note: correct = correct according to scientific theory

/propCorrect:					overall proportion correct responses
/meanRT:						overall mean latency (in ms) of correct responses
/SD:							overall standard deviation (in ms) of latencies to correct responses

/propCorrect_truthConsistent:	proportion correct responses of truth consistent statements 
/meanRT_truthConsistent:		mean latency (in ms) of correct responses of truth consistent statements 
/SD_truthConsistent:			standard deviation (in ms) of latencies to correct responses of truth consistent statements

/propCorrect_truthInconsistent:	proportion correct responses of truth inconsistent statements 
/meanRT_truthInconsistent:		mean latency (in ms) of correct responses of truth inconsistent statements 
/SD_truthInconsistent:			standard deviation (in ms) of latencies to correct responses of truth inconsistent statements


<expressions>
/propCorrect = list.accuracy.mean
/meanRT = list.latencies.mean
/SD = list.latencies.standarddeviation

/propCorrect_truthConsistent = list.accuracy_truthConsistent.mean
/meanRT_truthConsistent = list.latencies_truthConsistent.mean
/SD_truthConsistent = list.latencies_truthConsistent.standarddeviation

/propCorrect_truthInconsistent = list.accuracy_truthInconsistent.mean
/meanRT_truthInconsistent = list.latencies_truthInconsistent.mean
/SD_truthInconsistent = list.latencies_truthInconsistent.standarddeviation

/RTDiff = expressions.meanRT_truthInconsistent - expressions.meanRT_truthConsistent
</expressions>


**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text testInstructions>
/items = instructions
/ select = 1
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (90%, 60%)
/ vjustify = center
/ hjustify = left
</text>

<text blockInstructions>
/items = instructions
/ select = 2
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (90%, 60%)
/ vjustify = center
/ hjustify = left
</text>

<text domain>
/items = ("<%values.domain%>")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ position = (50%, 30%)
/ size = (90%, 5%)
/ vjustify = center
/ hjustify = center
/ txcolor = blue
</text>


Note: trial.domain presents the domain label at the start of each block
<trial blockInstructions>
/ stimulusframes = [1 = blockInstructions, domain, true, false]
/ validresponse = (" ")
/ recorddata = false
</trial>

Note: trial.domain presents the domain label at the start of each block
<trial intro>
/ stimulusframes = [1 = header, testInstructions]
/ validresponse = (" ")
/ recorddata = false
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

*************************************
General Helper Instruction Trials/Blocks
*************************************

This trial is used when participants are asked to place their fingers on specific response
buttons. On the touchscreen, this trial presents the (inactive) response buttons to the participants.
<trial getReady>
/ stimulusframes = [1 = getReady]
/ trialduration = 5000
/ validresponse = (parameters.trueResponsekey, parameters.falseResponsekey)
/ beginresponsetime = 5000
/ errormessage = false
/ recorddata = false
</trial>

