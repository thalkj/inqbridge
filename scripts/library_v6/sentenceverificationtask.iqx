**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************

<text header>
/ items = ("Statement Verifications")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ vjustify = center
/ txbgcolor = blue
/ txcolor = white
/ position = (50%, 10%)
</text>


<item instructions>
/1 = "In this task you are asked to evaluate the truthfulness of statements, such as 'A virus is a living organism'.

The statements will come from 10 different knowledge domains and the task will take about 15 minutes.




Press the Spacebar to learn about your first domain."
/2 = "The next 20 statements come from the domain: 



<%expressions.buttoninstruct1%>


Respond as fast as you can.




Press the Spacebar to start."
</item>


<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<text exit>
/ items = ("<press spacebar to exit>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (80%, 5%)
/ vjustify = center
/ valign = center
/ halign = center
</text>


<text true>
/items = ("TRUE")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ txcolor = green
/ position = (15%, 5%)
/ size = (20%, 5%)
/ vjustify = center
/ erase = false
</text>

<text false>
/items = ("FALSE")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ txcolor = red
/ position = (85%, 5%)
/ size = (20%, 5%)
/ vjustify = center
/ erase = false
</text>

*******************************
General Helper Instructions
******************************

<text getReady>
/items = ("Get Ready:
~n<%expressions.buttoninstruct2%>")
/ fontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ size = (80%, 40%)
</text>

****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {"Tap the left key ('E') if the statement is true.~nTap the the right key ('I') if the presented statement is false.";} else {"Press the left 'E' key if the presented statement is true.~nPress the right 'I' key if the statement is false.";}
/buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {"Place your index fingers over the left and right response buttons";} else {"Place your index fingers on the left 'E' and right 'I' key.";}
</expressions>

