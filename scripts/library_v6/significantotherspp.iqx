-----------------------------------------------------------------------------------
***	BLOCKS *****
-----------------------------------------------------------------------------------

**** Common Blocks ****

<block intro>
/ trials = [1=intro]
</block>

<block getItemsPartner>
/ trials = [1=getItemsPartner]
</block>


**** Priming Blocks ****

<block practiceUP1>
/ onblockend = [
	values.errorrate = 100-block.practiceUP1.percentcorrect;
	values.meanrt = block.practiceUP1.meanlatency;
]
/ bgstim = (unpleasantreminder_left, pleasantreminder_right)
/ trials = [
	1 = intro1UP; 
	2 = blockintro2; 
	3 = readyprac1UP; 
	4 = getReady; 
	5-20 = random(prac_concept_posUP, prac_concept_negUP, prac_base_posUP, prac_base_negUP);
]
/ errormessage = (errormessage, 200)
/ branch = [
	if (monkey.monkeyMode){
		return null;
	} else if (block.practiceUP1.meanlatency > 1500) {
		return block.practiceUP2;
	} else if (block.practiceUP1.percentcorrect < 80) {
		return block.practiceUP2;
	}
]
</block>

<block practiceUP2>
/ onblockend = [
	values.errorrate = 100-block.practiceUP2.percentcorrect;
	values.meanrt = block.practiceUP2.meanlatency;
]
