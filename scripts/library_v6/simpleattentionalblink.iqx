	LISTS
*******************************************************************************************************************
*******************************************************************************************************************

//stores and assigns the 20 onsettimes randomly 
//skips the timings already assigned to T1 and T2
<list onsettimes>
/items = (expressions.onsettime_stim1, expressions.onsettime_stim2, expressions.onsettime_stim3,
expressions.onsettime_stim4, expressions.onsettime_stim5, expressions.onsettime_stim6,
expressions.onsettime_stim7, expressions.onsettime_stim8, expressions.onsettime_stim9,
expressions.onsettime_stim10, expressions.onsettime_stim11, expressions.onsettime_stim12,
expressions.onsettime_stim13, expressions.onsettime_stim14, expressions.onsettime_stim15,
expressions.onsettime_stim16, expressions.onsettime_stim17, expressions.onsettime_stim18,
expressions.onsettime_stim19,expressions.onsettime_stim20)
/ selectionrate = always
/ replace = false
/not = [
	values.T1_onset; values.T2_onset;
]
</list>

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC_T1_pos1lag1>
</list>

<list ACC_T1_pos1lag2>
</list>

<list ACC_T1_pos2lag1>
</list>

<list ACC_T1_pos2lag2>
</list>

<list ACC_T2_pos1lag1>
</list>

<list ACC_T2_pos1lag2>
</list>

<list ACC_T2_pos2lag1>
</list>

<list ACC_T2_pos2lag2>
</list>

*******************************************************************************************************************
*******************************************************************************************************************
	TRIALS
*******************************************************************************************************************
*******************************************************************************************************************
	
<trial fixation>
/ ontrialbegin = [
	values.trialcount_perblock += 1;

	//determine streampositions of T1 and T2:
	values.t1_stim = "";
	values.t2_stim = "";
	values.t1_streamposition = list.streampositions.nextValue;
	values.t2_lag = list.lags.nextValue;
	values.t2_streamposition = values.t1_streamposition + values.t2_lag;

	list.letters.reset();
	values.letter1 = list.letters.nextValue;
	values.letter2 = list.letters.nextValue;
	values.letter3 = list.letters.nextValue;
	values.letter4 = list.letters.nextValue;
	values.letter5 = list.letters.nextValue;
	values.letter6 = list.letters.nextValue;
	values.letter7 = list.letters.nextValue;
	values.letter8 = list.letters.nextValue;
	values.letter9 = list.letters.nextValue;
	values.letter10 = list.letters.nextValue;
	values.letter11 = list.letters.nextValue;
	values.letter12 = list.letters.nextValue;
	values.letter13 = list.letters.nextValue;
	values.letter14 = list.letters.nextValue;
	values.letter15 = list.letters.nextValue;
	values.letter16 = list.letters.nextValue;
	values.letter17 = list.letters.nextValue;
	values.letter18 = list.letters.nextValue;
	values.T1_stim = list.letters.nextValue;
	values.t2_stim = list.T2selection.nextValue;
	if (parameters.random_lettercolor == true) {
		text.letter1.textColor = list.randomlettercolors.nextValue;
		text.letter2.textColor = list.randomlettercolors.nextValue;
		text.letter3.textColor = list.randomlettercolors.nextValue;
		text.letter4.textColor = list.randomlettercolors.nextValue;
		text.letter5.textColor = list.randomlettercolors.nextValue;
		text.letter6.textColor = list.randomlettercolors.nextValue;
		text.letter7.textColor = list.randomlettercolors.nextValue;
		text.letter8.textColor = list.randomlettercolors.nextValue;
		text.letter9.textColor = list.randomlettercolors.nextValue;
		text.letter10.textColor = list.randomlettercolors.nextValue;
		text.letter11.textColor = list.randomlettercolors.nextValue;
		text.letter12.textColor = list.randomlettercolors.nextValue;
		text.letter13.textColor = list.randomlettercolors.nextValue;
		text.letter14.textColor = list.randomlettercolors.nextValue;
		text.letter15.textColor = list.randomlettercolors.nextValue;
		text.letter16.textColor = list.randomlettercolors.nextValue;
		text.letter17.textColor = list.randomlettercolors.nextValue;
		text.letter18.textColor = list.randomlettercolors.nextValue;
	} else {
		text.letter1.textColor = parameters.lettercolor;
		text.letter2.textColor = parameters.lettercolor;
		text.letter3.textColor = parameters.lettercolor;
		text.letter4.textColor = parameters.lettercolor;
		text.letter5.textColor = parameters.lettercolor;
		text.letter6.textColor = parameters.lettercolor;
		text.letter7.textColor = parameters.lettercolor;
		text.letter8.textColor = parameters.lettercolor;
		text.letter9.textColor = parameters.lettercolor;
		text.letter10.textColor = parameters.lettercolor;
		text.letter11.textColor = parameters.lettercolor;
		text.letter12.textColor = parameters.lettercolor;
		text.letter13.textColor = parameters.lettercolor;
		text.letter14.textColor = parameters.lettercolor;
		text.letter15.textColor = parameters.lettercolor;
		text.letter16.textColor = parameters.lettercolor;
		text.letter17.textColor = parameters.lettercolor;
		text.letter18.textColor = parameters.lettercolor;
	}
	if (parameters.T2_color != "")
		text.t2.textColor = parameters.T2_color
	else {
		if (parameters.random_lettercolor == true)
			text.t2.textColor = list.randomlettercolors.nextValue;
		else
			text.t2.textColor = parameters.lettercolor;
	}
	
	expressions.determineOnsettimes;//assign the onset times to the various stimuli
]
/ stimulusframes = [1 = fixation]
/ trialduration = parameters.fixationDuration
/ branch = [
	return trial.showstream;
]
/ errormessage = false
/ recorddata = false
</trial>


<trial showstream>
/ ontrialbegin = [

	//prepare the stimuli for dynamic stimuli insertion:
	trial.showstream.insertStimulusFrame(text.T1, values.T1_onset);
	trial.showstream.insertStimulusFrame(text.T2, values.T2_onset);
	trial.showstream.insertStimulusFrame(text.letter1, values.distractor1_onset);
	trial.showstream.insertStimulusFrame(text.letter2, values.distractor2_onset);	
	trial.showstream.insertStimulusFrame(text.letter3, values.distractor3_onset);	
	trial.showstream.insertStimulusFrame(text.letter4, values.distractor4_onset);	
	trial.showstream.insertStimulusFrame(text.letter5, values.distractor5_onset);	
	trial.showstream.insertStimulusFrame(text.letter6, values.distractor6_onset);	
	trial.showstream.insertStimulusFrame(text.letter7, values.distractor7_onset);
	trial.showstream.insertStimulusFrame(text.letter8, values.distractor8_onset);
	trial.showstream.insertStimulusFrame(text.letter9, values.distractor9_onset);
	trial.showstream.insertStimulusFrame(text.letter10, values.distractor10_onset);
	trial.showstream.insertStimulusFrame(text.letter11, values.distractor11_onset);
	trial.showstream.insertStimulusFrame(text.letter12, values.distractor12_onset);	
	trial.showstream.insertStimulusFrame(text.letter13, values.distractor13_onset);	
	trial.showstream.insertStimulusFrame(text.letter14, values.distractor14_onset);	
	trial.showstream.insertStimulusFrame(text.letter15, values.distractor15_onset);	
	trial.showstream.insertStimulusFrame(text.letter16, values.distractor16_onset);	
	trial.showstream.insertStimulusFrame(text.letter17, values.distractor17_onset);
	trial.showstream.insertStimulusFrame(text.letter18, values.distractor18_onset);
	
	//prepare 'isi' for dynmaic stimuli insertations
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi1);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi2);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi3);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi4);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi5);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi6);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi7);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi8);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi9);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi10);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi11);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi12);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi13);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi14);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi15);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi16);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi17);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi18);	
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi19);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_isi20);
	trial.showstream.insertStimulusFrame(shape.eraser, expressions.onsettime_stim21);	
	
]
/ timeout = 0
/ responseinterrupt = frames
/ ontrialend = [
	trial.showstream.resetStimulusFrames();
	
	//store the presented T1, T2, sT1, sT2 images in respective variables for data collection purposes:
	values.T1_stim = text.T1.currentItem;
	values.T2_stim = text.T2.currentItem;	
]
/ branch = [
	return trial.responsecue;
]
/ errormessage = false
/ recorddata = false
</trial>

*****************************************
Response Trials
*****************************************
Note:
* presents the responsecue
* calls T1task
<trial responsecue>
/ stimulusframes = [1 = responsecue]
/ recorddata = false
/ trialduration = parameters.responsecue_duration
/ recorddata = false
/ branch = [return openended.t1_task;]
/ errormessage = false
</trial>

Note: openended.targetnaming
collects the response for T1
<openended T1_Task>
/ mouse = true
/ charlimit = 1
/ mask = alphabetic
/ stimulusframes = [1 = targetnaminginstructions]
/ validresponse = (anyresponse)
/ correctresponse = (values.t1_stim)
/ monkeyresponse = ("A", "B", "C", "D", "E", "F", "G", "H", "J", "K", "L", "M", "N", "P", "Q", "R", "S", "T", "U", "V", "Y")
/ recorddata = true
/ ontrialend = [
	
	if (values.t1_streamposition == 5) {
		if (values.t2_lag == 1) {
			list.ACC_T1_pos1lag1.appendItem(openended.t1_task.correct);
		} else if (values.t2_lag == 7) {
			list.ACC_T1_pos1lag2.appendItem(openended.t1_task.correct);
		}
	} else if (values.t1_streamposition == 10) {
		if (values.t2_lag == 1) {
			list.ACC_T1_pos2lag1.appendItem(openended.t1_task.correct);
		} else if (values.t2_lag == 7) {
			list.ACC_T1_pos2lag2.appendItem(openended.t1_task.correct);
		}
	}	
		
]
/ branch = [return trial.T2_Task;]
</openended>

Note: collects the response for T2
<trial T2_task>
/ stimulusframes = [1 = targetnaminginstructions]
/ validresponse = (parameters.responsekey_T2_1, parameters.responsekey_T2_2)

/ iscorrectresponse = [
	if (trial.t2_task.responseText == parameters.responsekey_T2_1){
		if (values.t2_stim == "X"){
			return true;
		} else {
			return false;
		}
	} else if (trial.t2_task.responseText == parameters.responsekey_T2_2) {
		if (values.t2_stim == "Z"){
			return true;
		} else {
			return false;
		}
	} else {
		return false;
	}
]
/ recorddata = true
/ ontrialend = [
	if (values.t1_streamposition == parameters.streampositionT1_1) {
		if (values.t2_lag == parameters.lagT2_1) {
			list.ACC_T2_pos1lag1.appendItem(trial.T2_task.correct);
		} else if (values.t2_lag == parameters.lagT2_2) {
			list.ACC_T2_pos1lag2.appendItem(trial.T2_task.correct);
		}
	} else if (values.t1_streamposition == parameters.streampositionT1_2) {
		if (values.t2_lag == parameters.lagT2_1) {
			list.ACC_T2_pos2lag1.appendItem(trial.T2_task.correct);
		} else if (values.t2_lag == parameters.lagT2_2) {
			list.ACC_T2_pos2lag2.appendItem(trial.T2_task.correct);
		}
	}	
	
]
/ branch = [
	if (mod(values.trialcount_perblock, parameters.restperiods) == 0){
		return trial.rest;		
	} else {
		if (values.trialcount_perblock < values.totalTrials){
			return trial.fixation;
		}
	}
]					
</trial>

*****************************************
Rest Trial
*****************************************

Note: provides a rest after a specified number of trials (parameters.restperiods)
<trial rest>
/ skip = [
	values.trialcount_perblock >= values.totalTrials;
]

/ stimulusframes = [1 = restinstructions, restclock]
/ timeout = clock.restclock.timeout
/ recorddata = true
/ errormessage = false
/ branch = [
	if (values.trialcount_perblock < values.totalTrials){
		return trial.fixation;
	}
]
</trial>

*****************************************
Finish Trial
*****************************************

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

*******************************************************************************************************************
*******************************************************************************************************************
	BLOCKS
*******************************************************************************************************************
*******************************************************************************************************************
<block practice>
/ onblockbegin = [
	values.totalTrials = parameters.practiceTrials;
	values.trialcount_perblock = 0;
	list.streampositions.poolSize = parameters.practiceTrials;
	list.lags.poolSize = parameters.practiceTrials;
	list.T2selection.poolSize = parameters.practiceTrials;
]
/ trials = [1 = fixation]
/ errormessage = true(errorfeedback, 500)
</block>

<block AB>
/ onblockbegin = [
	values.totalTrials = parameters.testTrials;
	values.trialcount_perblock = 0;
	
	list.ACC_T1_pos1lag1.reset();
	list.ACC_T1_pos1lag2.reset();
	list.ACC_T1_pos2lag1.reset();
	list.ACC_T1_pos2lag2.reset();
	list.ACC_T2_pos1lag1.reset();
	list.ACC_T2_pos1lag2.reset();
	list.ACC_T2_pos2lag1.reset();
	list.ACC_T2_pos2lag2.reset();	
	
	list.streampositions.reset();
	list.lags.reset();
	list.T2selection.reset();	
	
	list.streampositions.poolSize = parameters.testTrials;
	list.lags.poolSize = parameters.testTrials;
	list.T2selection.poolSize = parameters.testTrials;
]
/ preinstructions = (teststart)
/ trials = [1 = fixation]
</block>

<block finish>
/ trials = [1 = finish]
</block>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPERIMENT
*******************************************************************************************************************
*******************************************************************************************************************
<expt a>
/ preinstructions = (intro1)
/ blocks = [
	1 = practice;
	2 = AB;
	3 = finish;
]
</expt>

*******************************************************************************************************************
												End of File
*******************************************************************************************************************