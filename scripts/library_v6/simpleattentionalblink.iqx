//calculate the onsettimes of 20 stream items
<expressions>
/onsettime_stim1 = 1
/onsettime_isi1 = expressions.onsettime_stim1 + parameters.stimDuration

/onsettime_stim2 = expressions.onsettime_isi1 + parameters.isi
/onsettime_isi2 = expressions.onsettime_stim2 + parameters.stimDuration

/onsettime_stim3 = expressions.onsettime_isi2 + parameters.isi
/onsettime_isi3 = expressions.onsettime_stim3 + parameters.stimDuration

/onsettime_stim4 = expressions.onsettime_isi3 + parameters.isi
/onsettime_isi4 = expressions.onsettime_stim4 + parameters.stimDuration

/onsettime_stim5 = expressions.onsettime_isi4 + parameters.isi
/onsettime_isi5 = expressions.onsettime_stim5 + parameters.stimDuration

/onsettime_stim6 = expressions.onsettime_isi5 + parameters.isi
/onsettime_isi6 = expressions.onsettime_stim6 + parameters.stimDuration

/onsettime_stim7 = expressions.onsettime_isi6 + parameters.isi
/onsettime_isi7 = expressions.onsettime_stim7 + parameters.stimDuration

/onsettime_stim8 = expressions.onsettime_isi7 + parameters.isi
/onsettime_isi8 = expressions.onsettime_stim8 + parameters.stimDuration

/onsettime_stim9 = expressions.onsettime_isi8 + parameters.isi
/onsettime_isi9 = expressions.onsettime_stim9 + parameters.stimDuration

/onsettime_stim10 = expressions.onsettime_isi9 + parameters.isi
/onsettime_isi10 = expressions.onsettime_stim10 + parameters.stimDuration

/onsettime_stim11 = expressions.onsettime_isi10 + parameters.isi
/onsettime_isi11 = expressions.onsettime_stim11 + parameters.stimDuration

/onsettime_stim12 = expressions.onsettime_isi11 + parameters.isi
/onsettime_isi12 = expressions.onsettime_stim12 + parameters.stimDuration

/onsettime_stim13 = expressions.onsettime_isi12 + parameters.isi
/onsettime_isi13 = expressions.onsettime_stim13 + parameters.stimDuration

/onsettime_stim14 = expressions.onsettime_isi13 + parameters.isi
/onsettime_isi14 = expressions.onsettime_stim14 + parameters.stimDuration

/onsettime_stim15 = expressions.onsettime_isi14 + parameters.isi
/onsettime_isi15 = expressions.onsettime_stim15 + parameters.stimDuration

/onsettime_stim16 = expressions.onsettime_isi15 + parameters.isi
/onsettime_isi16 = expressions.onsettime_stim16 + parameters.stimDuration

/onsettime_stim17 = expressions.onsettime_isi16 + parameters.isi
/onsettime_isi17 = expressions.onsettime_stim17 + parameters.stimDuration

/onsettime_stim18 = expressions.onsettime_isi17 + parameters.isi
/onsettime_isi18 = expressions.onsettime_stim18 + parameters.stimDuration

/onsettime_stim19 = expressions.onsettime_isi18 + parameters.isi
/onsettime_isi19 = expressions.onsettime_stim19 + parameters.stimDuration

/onsettime_stim20 = expressions.onsettime_isi19 + parameters.isi
/onsettime_isi20 = expressions.onsettime_stim20 + parameters.stimDuration

/onsettime_stim21 = expressions.onsettime_isi20 + parameters.isi

/determineOnsettimes = {
	values.T1_onset = 0; 
	values.T2_onset = 0; 
	list.onsettimes.reset();//reset the selection for each new trial
	
	//determine the onsettimes of the T1/T2:
	values.T1_onset = list.onsettimes.item(values.t1_streamposition);//select the onsettime at position 't1_streamposition' and assign to T1
	values.T2_onset = list.onsettimes.item(values.t2_streamposition);//select the onsettime at position 't2_streamposition' and assign to T2
	
	//determine the onsettimes for the distractor letters
	//Note: the onsettimes of T1, T2 should be avoided at this point
	values.distractor1_onset = list.onsettimes.nextValue;
	values.distractor2_onset = list.onsettimes.nextValue;
	values.distractor3_onset = list.onsettimes.nextValue;	
	values.distractor4_onset = list.onsettimes.nextValue;	
	values.distractor5_onset = list.onsettimes.nextValue;	
	values.distractor6_onset = list.onsettimes.nextValue;	
	values.distractor7_onset = list.onsettimes.nextValue;	
	values.distractor8_onset = list.onsettimes.nextValue;
	values.distractor9_onset = list.onsettimes.nextValue;
	values.distractor10_onset = list.onsettimes.nextValue;
	values.distractor11_onset = list.onsettimes.nextValue;
	values.distractor12_onset = list.onsettimes.nextValue;
	values.distractor13_onset = list.onsettimes.nextValue;	
	values.distractor14_onset = list.onsettimes.nextValue;	
	values.distractor15_onset = list.onsettimes.nextValue;	
	values.distractor16_onset = list.onsettimes.nextValue;	
	values.distractor17_onset = list.onsettimes.nextValue;	
	values.distractor18_onset = list.onsettimes.nextValue;
	//at this point all times in list.onsettimes have been assigned to the 20 stimuli...
}
</expressions>


Summary variables:
/T1_meancorr_pos1lag1:			proportion correct responses to T1 task with T1 pos = 5 and T2 lag = 1
/T1_meancorr_pos1lag2:			proportion correct responses to T1 task with T1 pos = 5 and T2 lag = 7
/T1_meancorr_pos2lag1:			proportion correct responses to T1 task with T1 pos = 10 and T2 lag = 1
/T1_meancorr_pos2lag2:			proportion correct responses to T1 task with T1 pos = 10 and T2 lag = 7

/T2_meancorr_pos1lag1:			proportion correct responses to T2 task with T1 pos = 5 and T2 lag = 1
/T2_meancorr_pos1lag2:			proportion correct responses to T2 task with T1 pos = 5 and T2 lag = 7
/T2_meancorr_pos2lag1:			proportion correct responses to T2 task with T1 pos = 10 and T2 lag = 1
/T2_meancorr_pos2lag2:			proportion correct responses to T2 task with T1 pos = 10 and T2 lag = 7

<expressions>
/ T1_meancorr_pos1lag1 = list.ACC_T1_pos1lag1.mean
/ T1_meancorr_pos1lag2 = list.ACC_T1_pos1lag2.mean
