<surveypage socrates_1>
/ caption = "Please read the following statements carefully. Each one describes a way that
you might (or might not) feel about your drinking. For each statement, select how much you agree or disagree with it right now."
/ subcaption = ""
/ questions = [1 = q1_Re, q2_Am, q3_Re]
</surveypage>

