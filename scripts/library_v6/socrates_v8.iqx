/ options = ("<b>NO!</b><br>Strongly<br>Disagree", "<b>No</b><br><br>Disagree", 
"<b>?</b><br>Undecided or<br>Unsure", "<b>Yes</b><br><br>Agree", "<b>YES!</b><br>Strongly<br>Agree")
/ optionValues = ("1", "2", "3", "4", "5")
/ required = true
/ orientation = horizontalequal
</radiobuttons>

<radiobuttons q12_Re>
/ caption = "12. My drinking is causing a lot of harm."
/ options = ("<b>NO!</b><br>Strongly<br>Disagree", "<b>No</b><br><br>Disagree", 
"<b>?</b><br>Undecided or<br>Unsure", "<b>Yes</b><br><br>Agree", "<b>YES!</b><br>Strongly<br>Agree")
/ optionValues = ("1", "2", "3", "4", "5")
/ required = true
/ orientation = horizontalequal
</radiobuttons>

<radiobuttons q13_Ts>
/ caption = "13. I am actively doing things now to cut down or stop drinking."
/ options = ("<b>NO!</b><br>Strongly<br>Disagree", "<b>No</b><br><br>Disagree", 
"<b>?</b><br>Undecided or<br>Unsure", "<b>Yes</b><br><br>Agree", "<b>YES!</b><br>Strongly<br>Agree")
/ optionValues = ("1", "2", "3", "4", "5")
