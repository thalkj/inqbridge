/ orientation = horizontalequal
</radiobuttons>

<radiobuttons q14_Ts>
/ caption = "14. I want help to keep from going back to the drinking problems that I had before."
/ options = ("<b>NO!</b><br>Strongly<br>Disagree", "<b>No</b><br><br>Disagree", 
