*******************************************************************************************************************
*******************************************************************************************************************
	SURVEY
*******************************************************************************************************************
*******************************************************************************************************************
Notes:
- presents the surveypages
- to take pictures of each screen set /screencapture = true

<survey sro_scale>
/pages = [
	1 = SRO1; 
	2 = SRO2; 
	3 = SRO3; 
	4 = SRO4; 
	5 = SRO5; 
	6 = SRO6; 
	7 = SRO7; 
	8 = SRO8; 
