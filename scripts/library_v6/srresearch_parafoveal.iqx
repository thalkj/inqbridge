**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************

<text instructions>
/ items = ("In this task, you will attempt to identify words that are 
briefly flashed in your peripheral vision. At the start of the trial, 
a fixation cross will appear on the center of the screen. You must stare
at this fixation cross in order for the word to appear. The eye tracker 
will be used to verify you are looking at the fixation point before the 
word is flashed.

When you are ready to begin, press the Space Bar.")
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ size = (75%, 75%)
/ hjustify = center
/ vjustify = center
</text>

**************************************************************************************************************
				!!!REMAINING CODE: Customize after careful consideration only!!!
**************************************************************************************************************


**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = (0, 0, 0)
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

***********************
summary data file
***********************

<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial instructions>
/ stimulusframes = [1=instructions]
/ inputdevice = keyboard
/ validresponse = (" ")
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text fixation>
/ items = ("+")
/ fontstyle = ("Arial", 15%, false, false, false, false, 5, 1)
/ txcolor = black
/ size = (12%, 12%)
/ txbgcolor = darkgray
</text>

<text targets>
/ items = targets
/ fontstyle = ("Arial", 2.50%, false, false, false, false, 5, 1)
/ txcolor = black
/ position = (25%, 25%)
</text>

<shape blank>
/ color = white
/ size = (25%, 10%)
/ position = (text.targets.hposition, text.targets.vposition)
</shape>

<shape brush>
/ shape = circle
/ size = (1px, 1px)
/ color = gray
</shape>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

<list xcoordinate>
/ items = (25, 25, 75, 75)
/ poolSize = 48
</list>

<list ycoordinate>
/ items = (25, 75, 75, 25)
/ selectionmode = list.xcoordinate.currentIndex
/ poolSize = 48
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

For demonstration purposes, the trials will draw gazepoints on the screen. To turn this off,
simply remove the /draw command


<trial ready>
/ ontrialbegin = [
	text.targets.hposition = list.xcoordinate.nextValue; 
	text.targets.vposition = list.ycoordinate.nextValue;
]
/ stimulustimes = [1=fixation; 250=fixation]
/ inputdevice = eyetracker
/ validresponse = (fixation)
/ branch = [return openended.recall;]
/ draw = brush
</trial>

<openended recall>
/ stimulusframes = [1=targets; 2=blank]
</openended>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block test>
/ trials = [
	1=instructions; 
	2-51=ready;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt test>
/ blocks = [1=test]
</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************