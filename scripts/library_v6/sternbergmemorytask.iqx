**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

NOTE: default number of trials per setsize = 3

/propcorrect2-
/propcorrect7:			proportion correct responses by setsize

<expressions>
/ propcorrect2 = return (values.countcorrect2/values.count2)
/ propcorrect3 = return (values.countcorrect3/values.count3)
/ propcorrect4 = return (values.countcorrect4/values.count4)
/ propcorrect5 = return (values.countcorrect5/values.count5)
/ propcorrect6 = return (values.countcorrect6/values.count6)
/ propcorrect7 = return (values.countcorrect7/values.count7)
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

<trial instruction>
/ stimulusframes = [1=instructions]
/ validresponse = (" ")
/ recorddata = false
</trial>

<block instruction>
/ trials = [1 =instruction]
</block>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

Note: 
this item list is dynamtically created for each digit sequence and resets for each new sequence
<item in>
</item>

<list in>
</list>

<text digit1>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit2>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit3>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit4>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit5>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit6>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text digit7>
/ items = digits
/ txcolor = white
/ fontstyle = ("Arial", 10%)
/ select = digits
/ selectionrate = always
</text>

<text blank>
/ items = ("00")
/ txcolor = black
/ txbgcolor = black
/ fontstyle = ("Arial", 10%)
</text>

<text in>
/ items = in
/ txcolor = yellow
/ fontstyle = ("Arial", 10%)
/ erase = false
/ select = noreplace
</text>

<text out>
/ items = digits
/ txcolor = yellow
/ fontstyle = ("Arial", 10%)
/ erase = false
/ select = list.digits.nextValue
</text>

<text errorsignal>
/ items = ("X")
/ fontstyle = ("Arial", 10%)
