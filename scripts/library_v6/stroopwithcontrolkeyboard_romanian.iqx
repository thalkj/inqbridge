~n<%expressions.buttoninstruct2%>")
/ fontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ size = (80%, 40%)
</text>

****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {"butoane de răspuns";} else {"taste";}
/buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {"Plasați-vă degetele index și mijlociu de la fiecare mână deasupra butoanelor de răspuns 'd', 'f', 'j', și 'k'.";} else {" Plasați-vă degetele index și mijlociu de la fiecare mână deasupra  tastelor 'd', 'f', 'j', și 'k'";}
</expressions>

