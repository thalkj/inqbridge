/ txbgcolor = transparent
</text>


**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

the following list is used for block feedback at the end of a block:

stores correct latencies for that block
<list RT_block>
</list>


Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list ACC_C_switch>
</list>

<list ACC_C_nonswitch>
</list>

<list ACC_N_switch>
</list>

<list ACC_N_nonswitch>
</list>


Note: list stores the latency of correct responses for each relevant trial
<list RT_C_switch>
</list>

<list RT_C_nonswitch>
</list>

<list RT_N_switch>
</list>

<list RT_N_nonswitch>
</list>
**************************************************************************************************************
**************************************************************************************************************
	TRIALS: PRACTICE
**************************************************************************************************************
**************************************************************************************************************

Note:
* trial practice_taskA presents one box with a character pair
* one character is a letter; one character is a control symbol
* waits for response (if incorrect response, response needs to be corrected)
* call trial.practiceITI
<trial practice_taskA>
/ ontrialbegin = [
	values.taskCategory = list.practice_taskA.nextValue;
	if (values.taskCategory == 1){
		values.targetCategory = "CONSONANT";
		values.targetSymbol = list.consonants.nextValue;
		values.avoidConsonant = values.targetSymbol;
	} else {
		values.targetCategory = "VOWEL";
		values.targetSymbol = list.vowels.nextValue;
		values.avoidVowel = values.targetSymbol;
	}
	
	values.distractorSymbol = list.control.nextValue;
	values.avoidControl = values.distractorSymbol;
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = practiceBox_frame, practiceBox_inner, practiceTargetPair, left, right]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	return(
	(values.taskCategory == 1 && trial.practice_taskA.responseText == parameters.consonantKey) || 
	(values.taskCategory == 2 && trial.practice_taskA.responseText == parameters.vowelKey));
]
/ ontrialend = [
	if (trial.practice_taskA.correct){
		values.iti = parameters.correctITI;
	} else {
		values.iti = parameters.errorITI;
	}
	
	values.countBlockErrors += trial.practice_taskA.error;
	if (trial.practice_taskA.correct){
		list.RT_block.appendItem(trial.practice_taskA.latency);
	}
]
/ errormessage = true(errorFeedback, 2000)
/ responsemessage = (parameters.leftKey, text.left_HL, 0)
/ responsemessage = (parameters.rightKey, text.right_HL, 0)
/ response = correct
/ branch = [
	return trial.practiceITI;
]
</trial>

Note:
* trial practice_taskB presents one box with a character pair
* one character is a digit; one character is a control symbol
* waits for response (if incorrect response, response needs to be corrected)
* call trial.practiceITI
<trial practice_taskB>
/ ontrialbegin = [
	values.taskCategory = list.practice_taskB.nextValue;
	if (values.taskCategory == 1){
		values.targetCategory = "ODD";
		values.targetSymbol = list.odd.nextValue;
		values.avoidOdd = values.targetSymbol;
	} else {
		values.targetCategory = "EVEN";
		values.targetSymbol = list.even.nextValue;
		values.avoidEven = values.targetSymbol;
	}
	
	values.distractorSymbol = list.control.nextValue;
	values.avoidControl = values.distractorSymbol;
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = practiceBox_frame, practiceBox_inner, practiceTargetPair, left, right]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ iscorrectresponse = [
	return(
	(values.taskCategory == 1 && trial.practice_taskB.responseText == parameters.oddKey) || 
	(values.taskCategory == 2 && trial.practice_taskB.responseText == parameters.evenKey));
]
/ ontrialend = [
	if (trial.practice_taskB.correct){
		values.iti = parameters.correctITI;
	} else {
		values.iti = parameters.errorITI;
	}
	
	values.countBlockErrors += trial.practice_taskB.error;
	if (trial.practice_taskB.correct){
		list.RT_block.appendItem(trial.practice_taskB.latency);
	}	
]
/ errormessage = true(errorFeedback, 2000)
/ responsemessage = (parameters.leftKey, text.left_HL, 0)
/ responsemessage = (parameters.rightKey, text.right_HL, 0)
/ response = correct
/ branch = [
	return trial.practiceITI;
]
</trial>

Note:
trial.practiceITI adds an iti to each practice trial (it is longer for error trials)
<trial practiceITI>
//for touchscreens: present the inactive response buttons
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ isvalidresponse = [
	return false;
]

/ stimulusframes = [1 = clearScreen, left, right]
/ trialduration = values.iti
/ recorddata = false
</trial>


**************************************************************************************************************
**************************************************************************************************************
	TRIALS: TEST (CROSS TALK CONDITION)
**************************************************************************************************************
**************************************************************************************************************


Note:
* trial.start presents an empty matrix with one highlighted (yellow) box
* the highlighted box signals the location for the first character pair in the first switch trial 
for either the letter task or the digit task
* at the end of the trial, all quadrants are returned to a white background

<trial C_start>
/ ontrialbegin = [
	values.startQuadrant = values.quadrant + 1;
	if (values.startQuadrant > 4){
		values.startQuadrant = 1;
	}	
	if (values.startQuadrant == 1){
		shape.quadrant1_inner.color = yellow;
	} else if (values.startQuadrant == 2){
		shape.quadrant2_inner.color = yellow;
	} else if (values.startQuadrant == 3){
		shape.quadrant3_inner.color = yellow;
	} else if (values.startQuadrant == 4){
		shape.quadrant4_inner.color = yellow;
	} 
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner]

//for touchscreens: present the inactive response buttons
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ isvalidresponse = [
	return false;
]

/ trialduration = parameters.blockstartDuration
/ recorddata = false
/ ontrialend = [
	shape.quadrant1_inner.color = white;
	shape.quadrant2_inner.color = white;	
	shape.quadrant3_inner.color = white;
	shape.quadrant4_inner.color = white;	
	
	values.iti = parameters.correctITI;
]
</trial>


Notes:
* trial.C_warmup runs the first 12 trials in a block that do NOT count towards summary variables
* establishes the switch nature of the trial based on assigned quadrant
* it assembles the character pair based on:
	- type of task (letter or digit => depends on current quadrant)
	- type of sampled task category (letter task: consonant or vowel; digit task: even or odd)
	- type of sampled congruence
	- order of target and distractor symbol (random)
* it presents the character pair in the assigned quadrant
* waits for a response for max.5000ms
* then calls trial.testITI

<trial C_warmup>
/ ontrialbegin = [
	values.quadrant += 1;
	if (values.quadrant > 4){
		values.quadrant = 1;
	}
	
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		if (mod(values.quadrant, 2)== 0){
			values.switch = 0;
		} else {
			values.switch = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		
		if (mod(values.quadrant, 2)== 0){
			values.switch = 1;
		} else {
			values.switch = 0;
		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}	
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}		
	}
	
	if (values.targetTask == values.taskA){
		values.taskCategory = list.warmup_taskA.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "CONSONANT";
			values.targetSymbol = list.consonants.nextValue;
			values.avoidConsonant = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_warmupTaskA_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_warmupTaskA_switch.nextValue;
			}
		
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.consonantKey == parameters.evenKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.consonantKey == parameters.evenKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}
			}				
		} else {
			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_warmupTaskA_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_warmupTaskA_switch.nextValue;
			}

			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.vowelKey == parameters.evenKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.vowelKey == parameters.evenKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}
			}
		}
	} else {
		values.taskCategory = list.warmup_taskB.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;
			values.avoidOdd = values.targetSymbol;		
			if (values.switch == 0){
				values.congruence = list.Ccongruence_warmupTaskB_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_warmupTaskB_switch.nextValue;
			}
	
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidConsonant = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}
			}				
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;	
			values.avoidEven = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_warmupTaskB_nonswitch.nextValue;			
			} else {
				values.congruence = list.Ccongruence_warmupTaskB_switch.nextValue;
			}
	
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}
			}
		}
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ response = timeout(parameters.responseDeadline)
/ iscorrectresponse = [
	return(
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.C_warmup.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.C_warmup.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.C_warmup.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.C_warmup.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.C_warmup.error && trial.C_warmup.response != 0){
		values.iti = parameters.errorITI;
		text.errorFeedback.hposition = values.x;
		text.errorFeedback.vposition = values.y;		
		trial.testITI.insertStimulusTime(text.errorFeedback, 0);		
	}
	
	values.countBlockErrors += trial.C_warmup.error;
	if (trial.C_warmup.correct){
		list.RT_block.appendItem(trial.C_warmup.latency);
	}	
]
/ branch = [
	return trial.testITI;
]
</trial>



Notes:
* trial.C_test runs the remaining 36 trials in a block that DO potentially count towards summary variables
* it assembles the character pair based on:
	- type of task (letter or digit => depends on current quadrant)
	- type of sampled task category (letter task: consonant or vowel; digit task: even or odd)
	- type of sampled congruence
	- order of target and distractor symbol (random)
* it presents the character pair in the assigned quadrant
* waits for a response for max.5000ms
* updates summary variable list if appropriate
* then calls trial.testITI
<trial C_test>
/ ontrialbegin = [
	values.countTestTrials += 1;
	values.quadrant += 1;
	if (values.quadrant > 4){
		values.quadrant = 1;
	}
	
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		if (mod(values.quadrant, 2)== 0){
			values.switch = 0;
		} else {
			values.switch = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		
		if (mod(values.quadrant, 2)== 0){
			values.switch = 1;
		} else {
			values.switch = 0;
		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}	
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}		
	}
	
	if (values.targetTask == values.taskA){
		values.taskCategory = list.test_taskA.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "CONSONANT";
			values.targetSymbol = list.consonants.nextValue;
			values.avoidConsonant = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_testTaskA_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_testTaskA_switch.nextValue;
			}
		
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.consonantKey == parameters.evenKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.consonantKey == parameters.evenKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}
			}				
		} else {
			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_testTaskA_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_testTaskA_switch.nextValue;
			}

			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.vowelKey == parameters.evenKey){
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.vowelKey == parameters.evenKey){
					values.distractorSymbol = list.odd.nextValue;
					values.avoidOdd = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.even.nextValue;
					values.avoidEven = values.distractorSymbol;
				}
			}
		}
	} else {
		values.taskCategory = list.test_taskB.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;
			values.avoidOdd = values.targetSymbol;		
			if (values.switch == 0){
				values.congruence = list.Ccongruence_testTaskB_nonswitch.nextValue;				
			} else {
				values.congruence = list.Ccongruence_testTaskB_switch.nextValue;
			}
	
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidConsonant = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.oddKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}
			}				
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;	
			values.avoidEven = values.targetSymbol;
			if (values.switch == 0){
				values.congruence = list.Ccongruence_testTaskB_nonswitch.nextValue;			
			} else {
				values.congruence = list.Ccongruence_testTaskB_switch.nextValue;
			}
	
			if (values.congruence == 1)	{
				values.distractorSymbol = list.control.nextValue;
				values.avoidControl = values.distractorSymbol;
			} else if (values.congruence == 2){
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				}
			} else if (values.congruence == 3){
				if (parameters.evenKey == parameters.consonantKey){
					values.distractorSymbol = list.vowels.nextValue;
					values.avoidVowel = values.distractorSymbol;
				} else {
					values.distractorSymbol = list.consonants.nextValue;
					values.avoidConsonant = values.distractorSymbol;
				}
			}
		}
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ response = timeout(parameters.responseDeadline)
/ iscorrectresponse = [
	return(
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.C_test.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.C_test.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.C_test.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.C_test.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.C_test.error && trial.C_test.response != 0){
		values.iti = parameters.errorITI;
		text.errorFeedback.hposition = values.x;
		text.errorFeedback.vposition = values.y;
		trial.testITI.insertStimulusTime(text.errorFeedback, 0);
	}
	
	if (trial.C_test.response !=0 && trial.C_test.latency >= parameters.minRT){
		if (values.switch == 0){
			list.ACC_C_nonswitch.appendItem(trial.C_test.correct);
			if (trial.C_test.correct){
				list.RT_C_nonswitch.appendItem(trial.C_test.latency);
			}						
		} else {
			list.ACC_C_switch.appendItem(trial.C_test.correct);
			if (trial.C_test.correct){
				list.RT_C_switch.appendItem(trial.C_test.latency);
			}			
		}
	} else {
		values.countExcludedTrials += 1;
	}
	
	values.countBlockErrors += trial.C_test.error;
	if (trial.C_test.correct){
		list.RT_block.appendItem(trial.C_test.latency);
	}		
]
/ branch = [
	return trial.testITI;
]
</trial>

