/ size = (parameters.quadrantSize * 0.75, parameters.quadrantSize)
/ color = white
/ position = (50%, 50%)
</shape>

<shape quadrant1_frame>
/ shape = rectangle
/ size = (parameters.quadrantSize * 0.75, parameters.quadrantSize)
/ color = black
/ hposition = shape.quadrantBox.hposition - 0.5*shape.quadrantBox.width
/ vposition = shape.quadrantBox.vposition - 0.5*shape.quadrantBox.height
/ erase = false
</shape>

<shape quadrant1_inner>
/ shape = rectangle
/ size = (expressions.innerBoxSize * 0.75, expressions.innerBoxSize)
/ color = white
/ hposition = shape.quadrant1_frame.hposition
/ vposition = shape.quadrant1_frame.vposition
/ erase = false
</shape>

<shape quadrant2_frame>
/ shape = rectangle
/ size = (parameters.quadrantSize * 0.75, parameters.quadrantSize)
/ color = black
/ hposition = shape.quadrantBox.hposition + 0.5*shape.quadrantBox.width
/ vposition = shape.quadrantBox.vposition - 0.5*shape.quadrantBox.height
/ erase = false
</shape>

<shape quadrant2_inner>
/ shape = rectangle
/ size = (expressions.innerBoxSize * 0.75, expressions.innerBoxSize)
/ color = white
/ hposition = shape.quadrant2_frame.hposition
/ vposition = shape.quadrant2_frame.vposition
/ erase = false
</shape>

<shape quadrant3_frame>
/ shape = rectangle
/ size = (parameters.quadrantSize * 0.75, parameters.quadrantSize)
/ color = black
/ hposition = shape.quadrantBox.hposition + 0.5*shape.quadrantBox.width
/ vposition = shape.quadrantBox.vposition + 0.5*shape.quadrantBox.height
/ erase = false
</shape>

<shape quadrant3_inner>
