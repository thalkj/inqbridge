		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
