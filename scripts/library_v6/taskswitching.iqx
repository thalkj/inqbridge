/ size = (parameters.quadrantSize * 0.75, parameters.quadrantSize)
/ color = black
/ hposition = 50%
/ vposition = 50%
/ erase = false
</shape>

<shape practiceBox_inner>
/ shape = rectangle
/ size = (expressions.innerBoxSize * 0.75, expressions.innerBoxSize)
/ color = white
/ hposition = shape.practiceBox_frame.hposition
/ vposition = shape.practiceBox_frame.vposition
/ erase = false
</shape>

<text practiceTargetPair>
/ items = ("<%values.targetPair%>")
/ hposition = 50%
/ vposition = 50%
/ fontstyle = ("Courier New", parameters.targetSize, false, false, false, false, 5, 1)
/ erase = false
</text>

<text practiceTargetPairEraser>
/ items = ("<%values.targetPair%>")
/ hposition = 50%
/ vposition = 50%
/ fontstyle = ("Courier New", parameters.targetSize, false, false, false, false, 5, 1)
/ erase = false
/ txcolor = white
</text>


<text left>
/items = ("<%expressions.left%>")
/ position = (25%, 90%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txcolor = gray
/ erase = false
/ size = (20%, 5%)
/ hjustify = center
/ vjustify = center
</text>

<text right>
/items = ("<%expressions.right%>")
/ position = (75%, 90%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txcolor = gray
/ erase = false
/ size = (20%, 5%)
/ hjustify = center
/ vjustify = center
</text>

<text left_HL>
/items = ("<%expressions.left%>")
/ position = (25%, 90%)
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txcolor = yellow
/ erase = false
/ size = (20%, 5%)
/ hjustify = center
/ vjustify = center
</text>

<text right_HL>
