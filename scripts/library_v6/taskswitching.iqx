			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;

			values.distractorSymbol = list.control.nextValue;
			values.avoidControl = values.distractorSymbol;
		}
	} else {
		values.taskCategory = list.warmup_taskB.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;

			values.distractorSymbol = list.control.nextValue;
			values.avoidConsonant = values.distractorSymbol;				
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;	
			values.avoidEven = values.targetSymbol;
			values.distractorSymbol = list.control.nextValue;
			values.avoidControl = values.distractorSymbol;
		}
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ response = timeout(parameters.responseDeadline)
/ iscorrectresponse = [
	return(
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.N_warmup.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.N_warmup.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.N_warmup.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.N_warmup.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.N_warmup.error && trial.N_warmup.response != 0){
		values.iti = parameters.errorITI;
		text.errorFeedback.hposition = values.x;
		text.errorFeedback.vposition = values.y;		
		trial.testITI.insertStimulusTime(text.errorFeedback, 0);		
	}
	
	values.countBlockErrors += trial.N_warmup.error;
	if (trial.N_warmup.correct){
		list.RT_block.appendItem(trial.N_warmup.latency);
	}		
]
/ branch = [
	return trial.testITI;
]
</trial>

<trial N_test>
/ ontrialbegin = [
	values.countTestTrials += 1;
	values.quadrant += 1;
	if (values.quadrant > 4){
		values.quadrant = 1;
	}
	
	if (values.quadrant == 1){
		values.x = shape.quadrant1_frame.hposition;
		values.y = shape.quadrant1_frame.vposition;
	} else if (values.quadrant == 2){
		values.x = shape.quadrant2_frame.hposition;
		values.y = shape.quadrant2_frame.vposition;	
	} else if (values.quadrant == 3){
		values.x = shape.quadrant3_frame.hposition;
		values.y = shape.quadrant3_frame.vposition;	
	} else if (values.quadrant == 4){
		values.x = shape.quadrant4_frame.hposition;
		values.y = shape.quadrant4_frame.vposition;	
	}
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		if (mod(values.quadrant, 2)== 0){
			values.switch = 0;
		} else {
			values.switch = 1;
		}
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		
		if (mod(values.quadrant, 2)== 0){
			values.switch = 1;
		} else {
			values.switch = 0;
		}	
	}
	
	if (parameters.quadrantTaskAssignment == 1){
		if (values.quadrant < 3){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}
	} else if (parameters.quadrantTaskAssignment == 2){
		if (values.quadrant < 3){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}
	} else if (parameters.quadrantTaskAssignment == 3){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskA;
		} else {
			values.targetTask = values.taskB;
		}	
	} else if (parameters.quadrantTaskAssignment == 4){
		if (values.quadrant == 1 || values.quadrant == 4){
			values.targetTask = values.taskB;
		} else {
			values.targetTask = values.taskA;
		}		
	}
	
	if (values.targetTask == values.taskA){
		values.taskCategory = list.test_taskA.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "CONSONANT";
			values.targetSymbol = list.consonants.nextValue;
			values.avoidConsonant = values.targetSymbol;

			values.distractorSymbol = list.control.nextValue;
			values.avoidControl = values.distractorSymbol;		
		} else {
			values.targetCategory = "VOWEL";
			values.targetSymbol = list.vowels.nextValue;
			values.avoidVowel = values.targetSymbol;

			values.distractorSymbol = list.control.nextValue;
			values.avoidControl = values.distractorSymbol;
		}
	} else {
		values.taskCategory = list.test_taskB.nextValue;
		if (values.taskCategory == 1){
			values.targetCategory = "ODD";
			values.targetSymbol = list.odd.nextValue;
			values.avoidOdd = values.targetSymbol;		

			values.distractorSymbol = list.control.nextValue;
			values.avoidConsonant = values.distractorSymbol;		
		} else {
			values.targetCategory = "EVEN";
			values.targetSymbol = list.even.nextValue;	
			values.avoidEven = values.targetSymbol;

			values.distractorSymbol = list.control.nextValue;
			values.avoidControl = values.distractorSymbol;
		}
	}
	
	if (list.targetPairPosition.nextValue == 1){
		values.targetPair = concat(values.targetSymbol, values.distractorSymbol);
	} else {
		values.targetPair = concat(values.distractorSymbol, values.targetSymbol);
	}
]
/ stimulustimes = [0 = quadrant1_frame, quadrant1_inner, quadrant2_frame, quadrant2_inner, 
quadrant3_frame, quadrant3_inner, quadrant4_frame, quadrant4_inner, targetPair]
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = 0
/ response = timeout(parameters.responseDeadline)
/ iscorrectresponse = [
	return (
	(values.targetTask == values.taskA && values.taskCategory == 1 && trial.N_test.responseText == parameters.consonantKey) ||
	(values.targetTask == values.taskA && values.taskCategory == 2 && trial.N_test.responseText == parameters.vowelKey) ||	
	(values.targetTask == values.taskB && values.taskCategory == 1 && trial.N_test.responseText == parameters.oddKey) ||
	(values.targetTask == values.taskB && values.taskCategory == 2 && trial.N_test.responseText == parameters.evenKey));
]
/ ontrialend = [
	values.iti = parameters.correctITI;
	if (trial.N_test.error && trial.N_test.response != 0){
		values.iti = parameters.errorITI;
		text.errorFeedback.hposition = values.x;
		text.errorFeedback.vposition = values.y;
		trial.testITI.insertStimulusTime(text.errorFeedback, 0);
	}
	
	if (trial.N_test.response !=0 && trial.N_test.latency >= parameters.minRT){
		if (values.switch == 0){
			list.ACC_N_nonswitch.appendItem(trial.N_test.correct);
			if (trial.N_test.correct){
				list.RT_N_nonswitch.appendItem(trial.N_test.latency);
			}						
		} else {
			list.ACC_N_switch.appendItem(trial.N_test.correct);
			if (trial.N_test.correct){
				list.RT_N_switch.appendItem(trial.N_test.latency);
			}			
		}
	} else {
		values.countExcludedTrials += 1;
	}
	
	values.countBlockErrors += trial.N_test.error;
	if (trial.N_test.correct){
		list.RT_block.appendItem(trial.N_test.latency);
	}	
]
/ branch = [
	return trial.testITI;
]
</trial>


<trial testITI>

//for touchscreens: present the inactive response buttons
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ isvalidresponse = [
	return false;
]

/ trialduration = values.iti
/ ontrialend = [
	trial.testITI.resetStimulusFrames();
]
/ recorddata = false
</trial>


**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block generalInstructions>
/ skip = [
	parameters.maxPracticeBlocks < 4;
]
/ trials = [1 = generalInstructions]
</block>


<block practiceTaskA>
/ skip = [
	parameters.maxPracticeBlocks < 4;
]
/ onblockbegin = [
	values.countPracticeBlocks += 1;
	values.targetTask = values.taskA;
	if (values.countPracticeBlocks >  parameters.maxPracticeBlocks/2){
		text.left.skip = true;
		text.right.skip = true;
		text.left_HL.textColor = white;
		text.right_HL.textColor = white;
	}
	
	values.countBlockErrors = 0;
	list.RT_block.reset();
]
/ trials = [
	1 = instructions_lettertask; 
	2 = getReady_practice; 
	3-26 = practice_taskA; 
	27 = instructions_practiceBlockFeedback;
]
/ branch = [
	if (values.countPracticeBlocks < parameters.maxPracticeBlocks){
		return block.practiceTaskB;
	}
]
</block>

<block practiceTaskB>
/ skip = [
	parameters.maxPracticeBlocks < 4;
]
/ onblockbegin = [
	values.countPracticeBlocks += 1;
	values.targetTask = values.taskB;
	if (values.countPracticeBlocks >  parameters.maxPracticeBlocks/2){
		text.left.skip = true;
		text.right.skip = true;
		text.left_HL.textColor = white;
		text.right_HL.textColor = white;		
	}

	values.countBlockErrors = 0;
	list.RT_block.reset();	
]
/ trials = [
	1 = instructions_digittask; 
	2 = getReady_practice; 
	3-26 = practice_taskB; 
	27 = instructions_practiceBlockFeedback;
]
/ branch = [
	if (values.countPracticeBlocks ==  parameters.maxPracticeBlocks/2){
		return block.warning;
	} else if (values.countPracticeBlocks <  parameters.maxPracticeBlocks){
		return block.practiceTaskA;
	}
]
</block>

<block warning>
/ trials = [1 = instructions_alert]
/ branch = [
	return block.practiceTaskA;
]
</block>

*******************************************************
Test:
*******************************************************

block.testStart calls the sequence of test blocks
<block testStart>
/ trials = [1 = instructions_testStart]
/ onblockend = [
	values.countTestBlocks = 0;
]
/ branch = [
	if (length(parameters.conditionSequence) > 0){
		return block.blockSelection;
	}
]
</block>

Note: block.blockSelection selects the next block as specified by parameters.conditionSequence
<block blockSelection>
/ onblockbegin = [
	values.nextBlock = subString(parameters.conditionSequence, values.countTestBlocks, 1);
]
/ branch = [
	if (values.nextBlock == "C"){
		return block.C;
	} else {
		return block.N;
	}
]
</block>


Note:
- block.C samples the first task quadrant (!because the quadrant gets increased by 1 at the start of each trial, the sampled
quadrant needs to be one less at block start)
- runs 12 warmup trials and 36 test trials
- returns to block.blockSelection unless all blocks have been run
<block C>
/ onblockbegin = [
	values.countTestBlocks += 1;
	
	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		values.quadrant = replace(2,4);
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		values.quadrant = replace(1,3);
	}
	
	list.warmup_taskA.reset();
	list.warmup_taskB.reset();
	list.Ccongruence_warmupTaskA_switch.reset();
	list.Ccongruence_warmupTaskA_nonswitch.reset();	
	list.Ccongruence_warmupTaskB_switch.reset();
	list.Ccongruence_warmupTaskB_nonswitch.reset();
	list.test_taskA.reset();
	list.test_taskB.reset();
	list.Ccongruence_testTaskA_switch.reset();
	list.Ccongruence_testTaskA_nonswitch.reset();	
	list.Ccongruence_testTaskB_switch.reset();
	list.Ccongruence_testTaskB_nonswitch.reset();	

	values.countBlockErrors = 0;
	list.RT_block.reset();
]
/ trials = [
	1 = getReady_test; 
	2 = C_start; 
	3-14 = C_warmup; 
	15 - 50 = C_test; 
	51 = instructions_break;
]
/ branch = [
	if (values.countTestBlocks < length(parameters.conditionSequence)){
		return block.blockSelection;
	}
]
</block>


- block.N samples the first task quadrant (!because the quadrant gets increased by 1 at the start of each trial, the sampled
quadrant needs to be one less at block start)
- runs 12 warmup trials and 36 test trials
- returns to block.blockSelection unless all blocks have been run
<block N>
/ onblockbegin = [
	values.countTestBlocks += 1;
	values.congruence = 1;

	if (parameters.quadrantTaskAssignment == 1 || parameters.quadrantTaskAssignment == 2){
		values.quadrant = replace(2,4);
	} else if (parameters.quadrantTaskAssignment == 3 || parameters.quadrantTaskAssignment == 4){
		values.quadrant = replace(1,3);
	}
	
	list.warmup_taskA.reset();
	list.warmup_taskB.reset();
	list.test_taskA.reset();
	list.test_taskB.reset();
	
	values.countBlockErrors = 0;
	list.RT_block.reset();	
	
]	
/ trials = [
	1 = getReady_test; 
	2 = N_start; 
	3-14 = N_warmup; 
	15 - 50 = N_test; 
	51 = instructions_break;
]
/ branch = [
	if (values.countTestBlocks < length(parameters.conditionSequence)){
		return block.blockSelection;
	}
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt taskSwitching>
/ onexptbegin = [	
	if (parameters.consonantKey == parameters.evenKey){
		values.congruentTasks = "consonant-even; vowel-odd";
	} else if (parameters.consonantKey == parameters.oddKey){
		values.congruentTasks = "consonant-odd; vowel-even";
	}
	
	if (computer.touch && !computer.hasKeyboard){
		text.spacebar.skip = true;
	}
]
/ blocks = [
	1 = generalInstructions;
	2 = practiceTaskA;
	3 = testStart;	
]

</expt>

**************************************************************************************************************
												End of File
**************************************************************************************************************