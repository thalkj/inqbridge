*****************************************************************************
PHASE II: 
*****************************************************************************

<openended phaseII_repeat1RecallPair>
/ ontrialbegin = [
	values.pairNumber = list.repeat1_recall_pairNumbers.nextIndex;
	values.index_cueword = list.repeat1_cueword_recall.item(values.pairNumber);
	values.index_recallword = list.repeat1_recallword_recall.item(values.pairNumber);
	values.cueWord = item.words.item(values.index_cueword);
	values.recallWord = item.words.item(values.index_recallword);
	values.phaseII_firstcharlatency = 0;	
]
/ stimulusframes = [1 = cue]
/ position = (75%, 56%)
/ size = (50%, parameters.wordHeight*1.1%)
/ fontstyle = ("Arial", parameters.wordHeight, true, false, false, false, 5, 1)
/ isvalidresponse = [
	openended.phaseII_repeat1RecallPair.latency >= parameters.phase2Timeout;
]
/ iscorrectresponse = [
	values.phaseII_firstcharlatency = openended.phaseII_repeat1RecallPair.firstcharlatency;
	return (openended.phaseII_repeat1RecallPair.response == item.words.item(values.index_recallword));
]
/ timeout = parameters.phase2Timeout
/ buttonlabel = "Wait"
/ errormessage = true(text.phaseII_recallErrorMessage, 500)
</openended>

<openended phaseII_repeat1SuppressionPair>
/ ontrialbegin = [
	values.pairNumber = list.repeat1_suppression_pairNumbers.nextIndex;
	values.index_cueword = list.repeat1_cueword_suppression.item(values.pairNumber);
