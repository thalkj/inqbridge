***********************************************************************
Phase III
***********************************************************************

<block phaseIII_intro>
/ skip = [
	!values.Phase1Pass || parameters.runPhase3 == false
]
/ trials = [1 = phaseIII_intro1]
</block>

<block phaseIII>
/ skip = [
	!values.Phase1Pass || parameters.runPhase3 == false
]
/ onblockbegin = [
	values.trialCount = 0;
	values.phaseII_firstcharlatency = "";
]
/ ontrialbegin = [
	values.trialCount += 1;
]
/ trials = [1 - 40 = noreplace(openended.phaseIII_repeat0RecallPair, openended.phaseIII_repeat0SuppressionPair,
openended.phaseIII_repeat1RecallPair, openended.phaseIII_repeat1SuppressionPair,
openended.phaseIII_repeat8RecallPair, openended.phaseIII_repeat8SuppressionPair,
openended.phaseIII_repeat16RecallPair, openended.phaseIII_repeat16SuppressionPair)]
</block>


***********************************************************************
End
***********************************************************************

<block finish>
/ trials = [
	1 = finish;
]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt thinknothink>
/ onexptbegin = [
	if (parameters.runPhase1 == false){//in case phase1 is skipped, it's automatically assumed that the criterium has been reached
		values.Phase1Pass = true;
	}
]

/ blocks = [
	1 = generalIntro;
	2 = phaseI_intro;
	3 = phaseI_study;
	4 = phaseII_intro;
	5 = phaseII;
	6 = phaseIII_intro;
	7 = phaseIII;
	8 = finish;
]
</expt>

