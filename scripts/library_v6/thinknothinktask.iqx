*****************************************************************************
PHASE I: Study/Recall Phase Trials
*****************************************************************************

<trial study_repeat0RecallPair>
/ ontrialbegin = [
	values.pairNumber = list.repeat0_recall_pairNumbers.nextIndex;
	values.index_cueword = list.repeat0_cueword_recall.item(values.pairNumber);
	values.index_recallword = list.repeat0_recallword_recall.item(values.pairNumber);	
	values.cueWord = item.words.item(values.index_cueword);
	values.recallWord = item.words.item(values.index_recallword);
]
/ stimulusframes = [1 = wordPair]
/timeout = parameters.acquisitionDuration
/ recorddata = true
</trial>

<openended studyrecall_repeat0RecallPair>
/ ontrialbegin = [
	values.pairNumber = list.repeat0_recall_pairNumbers.nextIndex;
	values.index_cueword = list.repeat0_cueword_recall.item(values.pairNumber);
	values.index_recallword = list.repeat0_recallword_recall.item(values.pairNumber);
	values.cueWord = item.words.item(values.index_cueword);
	values.recallWord = item.words.item(values.index_recallword);
]
/ stimulusframes = [1 = cue, studyrecall_Instructions]
/ position = (75%, 56%)
/ size = (50%, parameters.wordHeight*1.1%)
/ fontstyle = ("Arial", parameters.wordHeight, true, false, false, false, 5, 1)
/ iscorrectresponse = [openended.studyrecall_repeat0RecallPair.response == item.words.item(values.index_recallword)]
/ ontrialend = [
	list.ACC_phaseI.appendItem(openended.studyrecall_repeat0RecallPair.correct);
]
/ monkeyresponse = (values.recallWord, "monkey")
</openended>

