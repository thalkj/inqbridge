**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************

<values>
/pairNumber = 0
/index_cueword = 0
/index_recallword = 0

/cueWord = ""
/recallWord = ""

/trialCount = 0

/countPhaseI = 0
/consecutiveCorrectRecall = 0

/propCorrect_Phase1 = ""
/Phase1Pass = false
/phaseII_firstcharlatency = ""
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

//Summary Variables:
<expressions>
/propCorrect_Phase3 = list.ACC_phaseIII.mean

/propCorrect_Phase3_0Recall = list.ACC_phaseIII_0Recall.mean
/propCorrect_Phase3_0Suppression = list.ACC_phaseIII_0Suppression.mean

/propCorrect_Phase3_1Recall = list.ACC_phaseIII_1Recall.mean
/propCorrect_Phase3_1Suppression = list.ACC_phaseIII_1Suppression.mean

/propCorrect_Phase3_8Recall = list.ACC_phaseIII_8Recall.mean
/propCorrect_Phase3_8Suppression = list.ACC_phaseIII_8Suppression.mean

/propCorrect_Phase3_16Recall = list.ACC_phaseIII_16Recall.mean
/propCorrect_Phase3_16Suppression = list.ACC_phaseIII_16Suppression.mean
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial generalintro>
/ stimulusframes = [1 = generalintro, continuebutton]
/ validresponse = (continuebutton)
/ recorddata = false
</trial>

******************************************************
Phase I
******************************************************

<trial phaseI_intro>
/ stimulusframes = [1 = phaseI_intro, continueButton]
/ validresponse = (continueButton)
/ recorddata = false
</trial>

<trial studyInstructions>
/ stimulusframes = [1 = study_Instructions, startButton]
/ validresponse = (startButton)
/ recorddata = false
/ posttrialpause = 1000
</trial>

******************************************************
Phase II
******************************************************

<trial phaseII_intro1>
/ stimulusframes = [1 = phaseII_intro1, continuebutton]
/ validresponse = (continuebutton)
/ recorddata = false
/ branch = [
	return trial.phaseII_intro2;
]
</trial>

<trial phaseII_intro2>
/ stimulusframes = [1 = phaseII_intro2, continuebutton, backbutton]
/ validresponse = (continuebutton, backbutton)
/ recorddata = false
/ branch = [
	if (trial.phaseII_intro2.response == "backbutton"){
		return trial.phaseII_intro1;
	} else {
		return trial.phaseII_intro3;
	}
]
</trial>

<trial phaseII_intro3>
/ stimulusframes = [1 = phaseII_intro3, suppressionCues, continuebutton, backbutton]
/ validresponse = (continuebutton, backbutton)
/ recorddata = false
/ branch = [
	if (trial.phaseII_intro3.response == "backbutton"){
		return trial.phaseII_intro2;
	} else {
		return trial.phaseII_intro4;
	}
]
</trial>

<trial phaseII_intro4>
/ stimulusframes = [1 = phaseII_intro4, startbutton, backbutton]
/ validresponse = (startbutton, backbutton)
/ recorddata = false
/ branch = [
	if (trial.phaseII_intro4.response == "backbutton"){
		return trial.phaseII_intro3;
	}
	return null;
]
</trial>

******************************************************
Phase III
******************************************************

<trial phaseIII_intro1>
/ stimulusframes = [1 = phaseIII_intro1, startbutton]
/ validresponse = (startbutton)
/ recorddata = false
</trial>

**************************************************************************************************************
finish trial
**************************************************************************************************************
<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

<trial finish_mouse>
/ inputdevice = mouse
/ stimulusframes = [1 = finish, exitButton]
/ validresponse = (exitButton)
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

//presents the cue word on the left and the recall word on the right
<text wordPair>
/ items = ("<%item.words.item(values.index_cueword)%> - <%item.words.item(values.index_recallword)%>")
/ fontstyle = ("Arial", parameters.wordHeight, true, false, false, false, 5, 1)
</text>

<text cue>
/ items = ("<%item.words.item(values.index_cueword)%> - ")
/ position = (49%, 50%)
/ fontstyle = ("Arial", parameters.wordHeight, true, false, false, false, 5, 1)
/ halign = right
/ vjustify = center
</text>


<text suppressionCues>
/ items = ("
<%item.words.item(list.repeat1_cueword_suppression.item(1))%>
<%item.words.item(list.repeat1_cueword_suppression.item(2))%>
<%item.words.item(list.repeat1_cueword_suppression.item(3))%>
<%item.words.item(list.repeat1_cueword_suppression.item(4))%>
<%item.words.item(list.repeat1_cueword_suppression.item(5))%>
<%item.words.item(list.repeat8_cueword_suppression.item(1))%>
<%item.words.item(list.repeat8_cueword_suppression.item(2))%>
<%item.words.item(list.repeat8_cueword_suppression.item(3))%>
<%item.words.item(list.repeat8_cueword_suppression.item(4))%>
<%item.words.item(list.repeat8_cueword_suppression.item(5))%>
<%item.words.item(list.repeat16_cueword_suppression.item(1))%>
<%item.words.item(list.repeat16_cueword_suppression.item(2))%>
<%item.words.item(list.repeat16_cueword_suppression.item(3))%>
<%item.words.item(list.repeat16_cueword_suppression.item(4))%>
<%item.words.item(list.repeat16_cueword_suppression.item(5))%>")
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
</text>




