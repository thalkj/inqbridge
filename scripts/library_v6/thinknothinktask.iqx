**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************

<text generalintro>
/ items = ("<h1>Welcome!</h1><hr>
We are interested in studying the nature of <i>thought suppression and unwanted memories</i>. Specifically we are interested in studying
whether actively suppressing thoughts impacts your memory of them.<br><br>
To this end, this study is divided into 3 phases:<br>
1. Phase I: Learning of <i>word pair associations</i><br>
2. Phase II: Active Thought Suppression of some of these learned word pair associations<br>
3. Phase III: Retesting the studied word pair associations<br><br>

Let's begin.")
/ fontstyle = ("Arial", 3.5%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
</text>


*************************************
Phase I
*************************************

<text phaseI_intro>
/ items = ("<h2>Phase I</h2><hr>
You will be presented with 40 word pairs, one at a time.<br><br>
Study them well. You will be given a Recall Test at the end.")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
</text>

<text study_Instructions>
/ items = ("Let's study the word pairs <%expressions.repeat%>")
/ fontstyle = ("Arial", 7%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 20%)
/ vjustify = center
</text>

<expressions>
/repeat = if (values.countPhaseI > 1){
	"some more"
} else {
	" "
}
</expressions>

<text studyrecall_Instructions>
/ items = ("Recall the word pairs!")
/ fontstyle = ("Arial", 7%, true, false, false, false, 5, 1)
/ position = (50%, 20%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<text recallFeedback>
/ items = ("Recall Performance: <%list.ACC_phaseI.mean*100%>% correct")
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ position = (50%, 20%)
/ size = (80%, 10%)
/ vjustify = center
</text>

*************************************
Phase II
*************************************

<text phaseII_intro1>
/ items = ("<h2>Phase II</h2><hr>
As before, you are given one of the words from the word pairs that you have studied. We will refer to this word as the 'Cue'.<br><br>
Some of these cues require you to respond as before. Recall the associated word and enter it into the provided textbox.")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
</text>

<text phaseII_intro2>
/ items = ("But some of these cues require you to SUPPRESS the recall of the associated word.

Whenever you see one of those SUPPRESSION cues, look at the cue but try NOT to think about the associated word. 

In fact, do NOT allow these words to enter your consciousness at all.


Continue on to get the list of SUPPRESSION cues.")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<text phaseII_intro3>
/ items = ("These are the Suppression Cues:")
/ position = (50%, 5%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
</text>

<text phaseII_intro4>
/ items = ("Remember:

Whenever you see one of those SUPPRESSION cues, look at the cue but try NOT to think about the associated word at all.

For any other cue, respond as before.


Start when you are ready.")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<text phaseII_recallErrorMessage>
/ items = ("Incorrect Recall")
/ txcolor = red
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 80%)
</text>

<text phaseII_suppressionErrorMessage>
/ items = ("Suppression Cue:

Try not to think about the associated word!")
/ txcolor = red
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ position = (50%, 7%)
</text>


*************************************
Phase III
*************************************

<text phaseIII_intro1>
/ items = ("<h1>Phase III</h1><hr>
We will now present you with all the word pairs you have studied once more.<br><br>
As before we will give you a cue word. Recall the associated word and enter it into the textbox.<br><br>
There are NO MORE suppression cues. ALL cues require you to respond!<br><br><br>
Start when you are ready.")
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
</text>

<text phaseIII_Instructions>
/ items = ("Recall the word pairs!")
/ fontstyle = ("Arial", 7%, true, false, false, false, 5, 1)
/ position = (50%, 20%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>


*************************************
End
*************************************

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<text exit>
/ items = ("<press spacebar to exit>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (80%, 5%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<button exitbutton>
/ caption = "EXIT"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 80%)
/ size = (25%, 5%)
/ valign = center
/ halign = center
</button>

<button continuebutton>
/ caption = "continue >>"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (75%, 95%)
/ size = (25%, 5%)
/ valign = center
/ halign = center
</button>

<button backbutton>
/ caption = "<< back"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (25%, 95%)
/ size = (25%, 5%)
/ valign = center
/ halign = center
</button>

<button startbutton>
/ caption = "start"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (75%, 95%)
/ size = (25%, 5%)
/ valign = center
/ halign = center
</button>

