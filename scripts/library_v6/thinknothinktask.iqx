	openended.phaseII_repeat1SuppressionPair.latency >= parameters.phase2Timeout;
]
/ iscorrectresponse = [
	values.phaseII_firstcharlatency = openended.phaseII_repeat1SuppressionPair.firstcharlatency;
	return (values.phaseII_firstcharlatency == 0);
]
/ timeout = parameters.phase2Timeout
/ errormessage = true(text.phaseII_suppressionErrorMessage, 1000)
