]
/ monkeyresponse = (values.recallWord, "monkey")
</openended>

<trial phaseIII_feedback>
/ stimulusframes = [1 = recallFeedback, continuebutton]
/ validresponse = (continuebutton)
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block generalIntro>
/ trials = [1 = generalintro]
</block>

***********************************************************************
Phase I
***********************************************************************

<block phaseI_intro>
/ skip = [
	parameters.runPhase1 == false;
]

/ trials = [1 = phaseI_intro]
</block>

<block phaseI_study>
/ skip = [
	parameters.runPhase1 == false;
]
/ onblockbegin = [
	values.trialCount = 0;
	values.countPhaseI += 1;
]
/ ontrialbegin = [
	values.trialCount += 1;
]
/ trials = [1 = studyInstructions;
2 - 41 = noreplace(trial.study_repeat0RecallPair, trial.study_repeat0SuppressionPair,
trial.study_repeat1RecallPair, trial.study_repeat1SuppressionPair,
trial.study_repeat8RecallPair, trial.study_repeat8SuppressionPair,
trial.study_repeat16RecallPair, trial.study_repeat16SuppressionPair)]
/ branch = [
	return block.phaseI_recall;
]
</block>


<block phaseI_recall>
/ skip = [
	parameters.runPhase1 == false;
]
/ onblockbegin = [
	values.trialCount = 0;
	list.ACC_phaseI.reset();
]
/ ontrialbegin = [
	values.trialCount += 1;
]
/ trials = [1 - 40 = noreplace(openended.studyrecall_repeat0RecallPair, openended.studyrecall_repeat0SuppressionPair,
openended.studyrecall_repeat1RecallPair, openended.studyrecall_repeat1SuppressionPair,
openended.studyrecall_repeat8RecallPair, openended.studyrecall_repeat8SuppressionPair,
openended.studyrecall_repeat16RecallPair, openended.studyrecall_repeat16SuppressionPair);
41 = studyrecall_feedback]
/ onblockend = [
	values.propCorrect_Phase1 = list.ACC_phaseI.mean;
	if (values.propCorrect_Phase1 >= parameters.minPropRecall_phase1){
		values.Phase1Pass = true;
	}
]

/ branch = [
	if (!values.Phase1Pass){//in case recall performance was too low
		if (values.countPhaseI < parameters.maxStudyRepeats_phase1){//check the number of study blocks run so far
			return block.phaseI_study;
		} else if (monkey.monkeyMode){
			values.Phase1Pass = true;
		}
	}
	return null;
]
</block>

***********************************************************************
Phase II
***********************************************************************

<block phaseII_intro>
/ skip = [
	!values.Phase1Pass || parameters.runPhase2 == false
]
/ trials = [1 = phaseII_intro1]
</block>

