/ fontstyle = ("Arial", parameters.wordHeight, true, false, false, false, 5, 1)
/ iscorrectresponse = [openended.phaseIII_repeat0RecallPair.response == item.words.item(values.index_recallword)]
/ ontrialend = [
	list.ACC_phaseIII.appendItem(openended.phaseIII_repeat0RecallPair.correct);
	list.ACC_phaseIII_0Recall.appendItem(openended.phaseIII_repeat0RecallPair.correct);
]
/ monkeyresponse = (values.recallWord, "monkey")
</openended>

