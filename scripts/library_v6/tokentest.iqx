	shape.lC_green.vposition = list.phase5_Cy.nextValue;

	values.itemnumber = 1;
	values.remainingduration = parameters.phase5_timelimit;
	if (values.repeat == 0){
		values.trialcount_phase += 1;
	}
]
/ stimulusframes = [1 = background, phase5_instructions]
/ trialduration = parameters.instructionsduration
/ recorddata = false
/ branch = [
	return trial.phase5_1;
]
</trial>

* trial.phase5_1:
* It presents a row of large rectangles, an empty row, a row of large circles, and an empty row. 
All of these spaces are clickable and all of the stimuli can be used as a dropsource and a droptarget.
The empty spaces can be used as a droptarget.
*correct response is: the red circle is placed on top of the green square
<trial phase5_1>
/ inputdevice = dragdrop
/ ontrialbegin = [
	values.attempts += 1;
	values.repeat = 0;
	values.points = 0;
]
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple,
R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5]
/ validresponse = (R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, background)
/ iscorrectresponse = [
		if (trial.phase5_1.response == "lS_green" && shape.lC_red.hposition == shape.lS_green.hposition && 
		shape.lC_red.vposition == shape.lS_green.vposition){
			return true;
		} else {
			return false;
		}
]
/ ontrialend = [			
	values.instructions = text.phase5_instructions.currentItem;
	
	if (values.attempts == 1){
		if (trial.phase5_1.error){
			values.repeat = 1;
		} else {
			values.points = 2;
			values.totalpoints += values.points;
			values.phasepoints += values.points;			
		}
	} else {
		if (trial.phase5_1.correct){
			values.points = 1;
			values.totalpoints += values.points;
			values.phasepoints += values.points;			
		}
	}	
]

/ branch = [
	if (values.repeat == 1){
		return trial.repeatproblem_phase5_1
	} else {
		return trial.nextproblem;
	}	
]

/ timeout = values.remainingduration
</trial>

<trial repeatproblem_phase5_1>
/ stimulusframes = [1 = background, feedback]
/ trialduration = parameters.iti
/ recorddata = false
/ branch = [
	return trial.phase5_1positions;
]
</trial>


