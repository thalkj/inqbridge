<item intro>
/ 1 = "In this test you will see rows of squares and rows of circles. The shapes have different colors.

The computer will ask you to perform different tasks."
/ 2 = "<%expressions.buttoninstruct2%> here to start"
</item>

<item feedback>
/ 1 = "Let's try that one again"
/ 2 = "<h1><div style='background-color:green'><font color='white'>Next</font></div></h1>"
</item>


<page phase1>
<center><br><br><br><br>
<hr><h1>Phase 1</h1><hr></center>
</page>

<page phase2>
<center><br><br><br><br>
<hr><h1>Phase 2</h1><hr><br>
In this phase there will be <u>additional</u> rows of small squares and small circles.</center>
</page>

<page phase3>
<center><br><br><br><br>
<hr><h1>Phase 3</h1><hr></center>
</page>

<page phase4>
<center><br><br><br><br>
<hr><h1>Phase 4</h1><hr><br>
In this phase there will be <u>additional</u> rows of small squares and small circles.<center>
</page>

<page phase5>
<center><br><br><br><br>
<hr><h1>Phase 5</h1><hr></center>
</page>

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 10%)
/ vjustify = center
/ valign = center
/ halign = center
</text>

<button exitbutton>
/ caption = "EXIT"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 80%)
/ size = (20%, 5%)
/ valign = center
/ halign = center
</button>

<instruct>
/ fontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ navigationbuttonfontstyle = ("Arial", 3.00%, false, false, false, false, 5, 1)
/ finishlabel = "START"
</instruct>

****************************************************************************************************
general instruction expressions: adjust the instruction text depending on device used to run script
****************************************************************************************************
<expressions>
/ buttoninstruct1 = if (computer.touch && !computer.hasKeyboard) {return "touch with your pointer";} else {return "click with your mouse";}
/ buttoninstruct2 = if (computer.touch && !computer.hasKeyboard) {return "touch";} else {return "click";}
</expressions>


