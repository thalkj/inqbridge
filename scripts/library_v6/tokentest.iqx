								!!!REMAINING CODE: Customize after careful consideration only!!!
**************************************************************************************************************


**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/ canvasaspectratio = (4,3)
/ minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txbgcolor = white
/ txcolor = black
/ inputdevice = mouse
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 
values.trialcount_phase, values.itemnumber, values.instructions, 
values.attempts, response, correct, latency, 
values.points, values.phasepoints, values.totalpoints, values.repeat)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed, 
values.points_phase1, values.points_phase2, values.points_phase3, values.points_phase4, values.points_phase5, values.totalpoints)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/touch_x:				the x coordinate of the selected/touched screen				
/touch_y:				the y coordinate of the selected/touched screen	
/itemnumber:			the number of the currently selected item 
/instructions:			stores the currently selected instructions
/attempts:				stores the number of attempts per trial (Max 2)
/trialcount_phase:		number of trials run per phase
/repeat:				0 = the trial will not be repeated; 1 = the trial will be repeated
/points:				stores the points for the given trial (0-2)
/totalpoints:			stores the accumulated points across phases 
/phasepoints:			stores the accumulated points for the current phase
/points_phase1-
/points_phase5:			stores the accumulated points for each of the 5 phases

/remainingduration:		stores the duration (in ms) left for a trial

/phase3_response1 -
/phase4_response1:		helper variables to keep track of responses that span more than one Inquisit trial

<values>
/ touch_x = 0
/ touch_y = 0
/ itemnumber = 0
/ instructions = 0
/ attempts = 0
/ trialcount_phase = 0
/ repeat = 0
/ points = 0
/ totalpoints = 0
/ phasepoints = 0;
/ points_phase1 = 0
/ points_phase2 = 0;
/ points_phase3 = 0;
/ points_phase4 = 0;
/ points_phase5 = 0;

/ remainingduration = 0

/ phase3_response1 = 0
/ phase4_response1 = 0

</values>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text intro>
/ items = intro
/ select = 1
/ position = (50%, 80%)
/ vjustify = center
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ size = (90%, 40%)
</text>

<text click>
/ items = intro
/ select = 2
/ position = (50%, 95%)
/ vjustify = center
/ txbgcolor = black
/ txcolor = white
</text>

<trial intro>
/ inputdevice = mouse
/ ontrialbegin = [
	shape.lS_red.hposition = list.largeRx.nextValue;
	shape.lS_red.vposition = list.largeRy.nextValue;
	shape.lS_green.hposition = list.largeRx.nextValue;
	shape.lS_green.vposition = list.largeRy.nextValue;	
	shape.lS_blue.hposition = list.largeRx.nextValue;
	shape.lS_blue.vposition = list.largeRy.nextValue;	
	shape.lS_yellow.hposition = list.largeRx.nextValue;
	shape.lS_yellow.vposition = list.largeRy.nextValue;
	shape.lS_purple.hposition = list.largeRx.nextValue;
	shape.lS_purple.vposition = list.largeRy.nextValue;
	shape.lC_red.hposition = list.largeCx.nextValue;
	shape.lC_red.vposition = list.largeCy.nextValue;
	shape.lC_green.hposition = list.largeCx.nextValue;
	shape.lC_green.vposition = list.largeCy.nextValue;	
	shape.lC_blue.hposition = list.largeCx.nextValue;
	shape.lC_blue.vposition = list.largeCy.nextValue;	
	shape.lC_yellow.hposition = list.largeCx.nextValue;
	shape.lC_yellow.vposition = list.largeCy.nextValue;
	shape.lC_purple.hposition = list.largeCx.nextValue;
	shape.lC_purple.vposition = list.largeCy.nextValue;	
]
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, intro, click]
/ validresponse = (click)
/ recorddata = false
</trial>

<text phase1_instructions>
/ items = phase1_instructions
/ select = values.itemnumber
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ voiceover = true
</text>

<text phase2_instructions>
/ items = phase2_instructions
/ select = values.itemnumber
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ voiceover = true
</text>

<text phase3_instructions>
/ items = phase3_instructions
/ select = values.itemnumber
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ voiceover = true
</text>

<text phase4_instructions>
/ items = phase4_instructions
/ select = values.itemnumber
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ voiceover = true
</text>

<text phase5_instructions>
/ items = phase5_instructions
/ select = values.itemnumber
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 8%)
/ voiceover = true
</text>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<shape lS_red>
/ shape = rectangle
/ size = (parameters.largesize * 0.75, parameters.largesize)
/ color = red
/ erase = false
/ dropsource = true
/ droptarget = true
/ dropposition = (shape.lS_red.hposition, shape.lS_red.vposition)
</shape>

<shape lS_red_highlight>
/ shape = rectangle
/ width = (parameters.largesize + 3%) * 0.75
/ height = parameters.largesize + 3%
/ hposition = shape.lS_red.hposition
/ vposition = shape.lS_red.vposition
/ color = orange
/ erase = false
</shape>

<shape lS_yellow>
/ shape = rectangle
/ size = (parameters.largesize * 0.75, parameters.largesize)
/ color = yellow
/ erase = false
/ dropsource = true
/ droptarget = true
/ dropposition = (shape.lS_yellow.hposition, shape.lS_yellow.vposition)
</shape>

<shape lS_green>
/ shape = rectangle
/ size = (parameters.largesize * 0.75, parameters.largesize)
/ color = green
/ erase = false
/ dropsource = true
