**********************************
Phase 5 - Trial 1
**********************************
/1 = "Drop the red circle onto the green square"

<trial phase5_1positions>
/ ontrialbegin = [
	shape.lS_red.hposition = list.phase5_Rx.nextValue;
	shape.lS_red.vposition = list.phase5_Ry.nextValue;
	shape.lS_blue.hposition = list.phase5_Rx.nextValue;
	shape.lS_blue.vposition = list.phase5_Ry.nextValue;	
