	shape.lS_green.hposition = list.phase5_Rx.nextValue;
	shape.lS_green.vposition = list.phase5_Ry.nextValue;	
	shape.lS_yellow.hposition = list.phase5_Rx.nextValue;
	shape.lS_yellow.vposition = list.phase5_Ry.nextValue;
	shape.lS_purple.hposition = list.phase5_Rx.nextValue;
	shape.lS_purple.vposition = list.phase5_Ry.nextValue;
	shape.lC_blue.hposition = list.phase5_Cx.nextValue;
	shape.lC_blue.vposition = list.phase5_Cy.nextValue;
	shape.lC_purple.hposition = list.phase5_Cx.nextValue;
	shape.lC_purple.vposition = list.phase5_Cy.nextValue;	
	shape.lC_red.hposition = list.phase5_Cx.nextValue;
	shape.lC_red.vposition = list.phase5_Cy.nextValue;	
	shape.lC_yellow.hposition = list.phase5_Cx.nextValue;
	shape.lC_yellow.vposition = list.phase5_Cy.nextValue;
	shape.lC_green.hposition = list.phase5_Cx.nextValue;
	shape.lC_green.vposition = list.phase5_Cy.nextValue;	

	values.points = 0;
	values.itemnumber = 10;
	values.remainingduration = parameters.phase5_timelimit;
	if (values.repeat == 0){
		values.trialcount_phase += 1;
	}
]
/ stimulusframes = [1 = background, phase5_instructions]
/ trialduration = parameters.instructionsduration
/ recorddata = false
/ branch = [
	return trial.phase5_10A;
]
</trial>

<trial phase5_10A>
/ inputdevice = mouse
/ ontrialbegin = [
	values.attempts += 1;
]
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, 
					R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5]
/ validresponse = (R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, background)
/ correctresponse = (lS_yellow)
/ ontrialend = [			
	values.instructions = text.phase5_instructions.currentItem;
	values.touch_x = trial.phase5_10A.responseX;
	values.touch_y = trial.phase5_10A.responseY;
	
	if (values.attempts == 1 && trial.phase5_10A.response == 0){
		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
]
/ branch = [
	if (trial.phase5_10A.latency < values.remainingduration){
		return trial.phase5_10Ahighlight;
	} else if (values.repeat == 1){
		return trial.repeatproblem_phase5_10;
	} else {
		return trial.nextproblem;
	}
]
/ timeout = values.remainingduration
</trial>

<trial phase5_10Ahighlight>
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, pointer]
/ trialduration = 17
/ recorddata = false
/ branch = [ 
		return trial.phase5_10B;
]
</trial>

<trial phase5_10B>
/ inputdevice = mouse
/ ontrialbegin = [
	values.remainingduration -= trial.phase5_10A.latency;
]
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, 
					R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5]
/ validresponse = (R2C1, R2C2, R2C3, R2C4, R2C5, R4C1, R4C2, R4C3, R4C4, R4C5, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, background)
/ correctresponse = (lC_green)
/ ontrialend = [

	if (trial.phase5_10B.correct && trial.phase5_10A.correct) {
		if (values.attempts == 1){
			values.points = 2;
		} else {
			values.points = 1;
		}
	}
	
	values.totalpoints += values.points;
	values.phasepoints += values.points;
	
	if (values.attempts == 1 && values.points == 0){
		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
		
	values.instructions = text.phase5_instructions.currentItem;
	values.touch_x = trial.phase5_10B.responseX;
	values.touch_y = trial.phase5_10B.responseY;
]
/ branch = [
	if (trial.phase5_10B.latency < values.remainingduration){
		return trial.phase5_10Bhighlight;
	} else if (values.repeat == 1){
		return trial.repeatproblem_phase5_10;
	} else {
		return trial.nextproblem;	
	}
]
/ timeout = values.remainingduration
</trial>

<trial phase5_10Bhighlight>
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, pointer]
/ trialduration = 17
/ recorddata = false
/ branch = [
	if (values.attempts == 1 && values.points == 0){
		return trial.repeatproblem_phase5_10;
	} else {
		return trial.nextproblem;
	}
]
</trial>

<trial repeatproblem_phase5_10>
/ stimulusframes = [1 = background, feedback]
/ trialduration = parameters.iti
/ recorddata = false
/ branch = [
	return trial.phase5_10positions;
]
</trial>

<trial nextproblem>
/ skip = [
	values.trialcount_phase == 10
]
/ ontrialbegin = [
	values.repeat = 0;
	values.attempts = 0;
]
/ stimulustimes = [0 = background, nextproblem]
/ trialduration = parameters.iti
/ recorddata = false
</trial>

