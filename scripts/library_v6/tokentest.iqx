/ correctresponse = (lC_green)
/ ontrialend = [
	values.touch_x = trial.phase5_5A.responseX;
	values.touch_y = trial.phase5_5A.responseY;	
	values.instructions = text.phase5_instructions.currentItem;
	if (values.attempts == 1 && trial.phase5_5A.response == 0){
		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
]
/ branch = [
	if (trial.phase5_5A.latency < values.remainingduration){
		return trial.phase5_5Ahighlight;
	} else if (values.repeat == 1){
		return trial.repeatproblem_phase5_5;
	} else {
		return trial.nextproblem;
	}
]
