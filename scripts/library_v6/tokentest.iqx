!Note: phase 5 instructions are all unique and each of these problems has its own trial.
If the problems are changed, the trials will have to be edited accordingly.
<item phase5_instructions>
/ 1 = "Drop the red circle onto the green square"
/ 2 = "Move the yellow square below the purple circle"
/ 3 = "Move the green square far away from the yellow square"
/ 4 = "Move the green circle close to the red square"
/ 5 = "<%expressions.buttoninstruct2%> the yellow circle after you <%expressions.buttoninstruct2%>ed on the green circle"
/ 6 = "Move the purple square above the red circle"
/ 7 = "If there is a black square, <%expressions.buttoninstruct2%> on the yellow circle"
/ 8 = "When the red square is highlighted, <%expressions.buttoninstruct2%> on the purple circle"
/ 9 = "<%expressions.buttoninstruct2%> the green circle - no!- the blue circle!"
/ 10 = "Before <%expressions.buttoninstruct2%>ing on the green circle, <%expressions.buttoninstruct2%> the yellow square"
</item>

