	shape.lS_green.vposition == shape.R2C1.vposition) ||
	(trial.phase5_3.response == "R4C1" && shape.lS_green.hposition == shape.R4C1.hposition && 
	shape.lS_green.vposition == shape.R4C1.vposition));
]
