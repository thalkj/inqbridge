<trial phase3_instructions>
/ ontrialbegin = [
	if (values.repeat == 0) {
		values.itemnumber = list.instructions.nextValue;
		values.attempts = 0;
		values.remainingduration = parameters.phase3_timelimit;
		values.trialcount_phase += 1;		
	}
]
/ stimulusframes = [1 = background, phase3_instructions]
/ trialduration = parameters.instructionsduration
/ recorddata = false
/ branch = [
	return trial.phase3A;
]
</trial>

<trial phase3A>
/ inputdevice = mouse
/ ontrialbegin = [
	values.points = 0;
	values.attempts += 1;
]
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple]
/ validresponse = (lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, background)
/ iscorrectresponse = [
	return(trial.phase3A.response == item.phase3_correctresponsesA.item(text.phase3_instructions.currentItemNumber));
]
/ ontrialend = [
	values.instructions = text.phase3_instructions.currentItem;
	values.phase3_response1  = trial.phase3A.response;
	values.touch_x = trial.phase3A.responseX;
	values.touch_y = trial.phase3A.responseY;
	
	if (values.attempts == 1 && trial.phase3A.latency >= values.remainingduration) {
		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
]
/ branch = [
	if (trial.phase3A.latency < values.remainingduration){
		return trial.phase3Ahighlight;
	} else if (trial.phase3A.response == 0 && values.attempts == 1){
		return trial.repeatproblem_phase3;
	} else {
		return trial.nextproblem;
	}	
]
/ timeout = values.remainingduration
</trial>

<trial phase3Ahighlight>
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, pointer]
/ trialduration = 17
/ recorddata = false
/ branch = [ 
	return trial.phase3B;
]
</trial>

<trial phase3B>
/ ontrialbegin = [
	values.remainingduration -= trial.phase3A.latency;
]
/ inputdevice = mouse
/ stimulusframes = [1 = background, lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple]
/ validresponse = (lS_red, lS_yellow, lS_blue, lS_green, lS_purple, lC_red, lC_yellow, lC_blue, lC_green, lC_purple, background)
/ iscorrectresponse = [
	return(trial.phase3B.response == item.phase3_correctresponsesB.item(text.phase3_instructions.currentItemNumber));
]
/ ontrialend = [

	values.touch_x = trial.phase3B.responseX;
	values.touch_y = trial.phase3B.responseY;

	if (trial.phase3A.correct && trial.phase3B.correct) {
		if (values.attempts == 1) {
			values.points = 2;
		} else {
			values.points = 1;
		}
	}
	
	values.totalpoints += values.points;
	values.phasepoints += values.points;
	
	if (values.attempts == 1 && values.points == 0) {
		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
]
/ branch = [
	if (trial.phase3B.latency < values.remainingduration){
		return trial.phase3Bhighlight;
	} else if (trial.phase3B.response == 0 && values.attempts == 1){
		return trial.repeatproblem_phase3;
	} else {
		return trial.nextproblem;
	}
]
/ timeout = values.remainingduration
</trial>

