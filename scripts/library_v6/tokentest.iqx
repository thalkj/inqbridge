		values.repeat = 1;
	} else {
		values.repeat = 0;
	}
		
	values.instructions = text.phase5_instructions.currentItem;
	values.touch_x = trial.phase5_5B.responseX;
	values.touch_y = trial.phase5_5B.responseY;
]
