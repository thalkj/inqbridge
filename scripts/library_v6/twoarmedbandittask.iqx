**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/countSelections:		counts the number of selections of choice A or B made
/valueA:				stores the current value of choice A
/valueB:				stores the current value of choice B

/totalPoints:			stores the current total points earned

/higherPayOff:			stores the choice with the current higher payoff ("A" or "B")
/flip:					1 = a flip of the pay-offs occurred during this trial; 0 = no payoff changes occurred
/selectedArm:			stores the selected choice ("A" or "B")
/selectedHigherPayOff:	1 = participant selected the currently higher payoff (note: if there was a flip, participant wasn't aware of the flip yet); 
						0 = otherwise

/highestSeenPayOff:		stores the current (at time of data saving) highest payoff that participant has seen
/choice:				1 = exploitative choice (the choice selected was the one attached to the highest seen payoff);
						2 = exploratory choice (participant selected the other choice)

/stop:					helper variable; if values.stops is set to 0, block.game stops
/attempts:				running total of attempts for the current trial (Note: if participant takes too long, the trial gets repeated. Those repeats are called 'attempts')
/repeat:				1 = the selection trial needs to be repeated as no choice was made during the allotted time; 
						0 = otherwise
/previousArm:			stores the previously selected choice ("A" or "B")
/selectionChange:		1 = participant changed selection; 0 = otherwise
/consecutiveSameChoice:	running total of selecting the same choice (resets after switch)

/selectionRT:			stores the response time (in ms) of selecting the last response


<values>
/trialcount = 0
/countSelections = 0
/valueA = 0
/valueB = 0

/totalPoints = 0

/higherPayOff = "B"
/flip = 0
/countFlips = 0
/countFlipsPractice = 0
/selectedArm = "B"
/selectedHigherPayOff = 1

/highestSeenPayOff = 0
/choice = 0

/stop = 0
/attempts = 0
/repeat = 0
/previousArm = 0
/selectionChange = 0
/consecutiveSameChoice = 0

/selectionRT = 0
/continueButton = 1
</values>


**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/adjustment:			the adjustment (in points) made to the inferior option after a flip
/alertSelection:		helper function to select the correct alert message (changed vs. same)
/stayProbability:		the probability that payoff schedule stays the same

/meanFlipEstimate:		the mean estimate of flips over 100 trials
/sumFlipEstimate:		the total number of estimated flips for 400 trials
/flipEstimateACC:		the number of estimated flips for 400 trials compared to the actually occurring flips
/propHigherPayOffs:		proportion of selecting the higher payoff option
/propExploit:			proportion of selecting selecting the option with the known higher payoff
						(Note: at the time of making the choice the participant does not know whether a flip occurred
						and can only use the information gathered up to this point)
/propExplore:			proportion of the selecting the option with the known lower payoff
						(Note: at the time of making the choice the participant does not know whether a flip occurred
						and can only use the information gathered up to this point)
						
<expressions>
/adjustment = abs(parameters.start_A - parameters.start_B) * 2
/alertSelection = values.flip + 1
/stayProbability = 1 - parameters.flipRate

/meanFlipEstimate = list.flipEstimates.mean
/meanFliprateEstimate = list.flipEstimates.mean/100
/sumFlipEstimate = list.flipEstimates.mean * list.flipEstimates.itemCount
/propHigherPayOffs = list.selectedHigherPayOffs.mean
/propExploit = list.exploitativeChoices.mean
/propExplore = 1 - list.exploitativeChoices.mean
</expressions>


**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<text intro1>
/ items = instructions
/ select = 1
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro1>
/ ontrialbegin = [
	values.continueButton = 1;
]
/ stimulusframes = [1 = intro1, task, continue]
/ validresponse = (" ")
/ branch = [
	return trial.intro2;
]
/ recorddata = false
</trial>

<text intro2>
/ items = instructions
/ select = 2
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial intro2>
/ ontrialbegin = [
	values.continueButton = 2;
]
/ stimulusframes = [1 = intro2, goback, continue]
/ validresponse = ("B", " ")
/ branch = [
	if (trial.intro2.response == 48){
		return trial.intro1;
	}
]
/ recorddata = false
</trial>

<text gameStart>
/ items = instructions
/ select = 3
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ vjustify = center
/ hjustify = left
/ size = (80%, 80%)
</text>

<trial gameStart>
/ ontrialbegin = [
	values.continueButton = 3;
]
/ stimulusframes = [1 = gameStart, continue]
/ validresponse = (" ")
/ recorddata = false
</trial>

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

*************************************
General Helper Instruction Trials/Blocks
*************************************

This trial is used when participants are asked to place their fingers on specific response
buttons. On the touchscreen, this trial presents the (inactive) response buttons to the participants.
<trial getReady>
/ stimulusframes = [1 = getReady]
/ timeout = parameters.readyDuration
/ validresponse = (parameters.leftKey, parameters.rightKey)
/ beginresponsetime = parameters.readyDuration
/ errormessage = false
/ recorddata = false
/ posttrialpause = 2000
</trial>

