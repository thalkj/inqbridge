**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

<list flips>
/ items = (0, 1)
/ itemprobabilities = (expressions.stayProbability, parameters.flipRate)
/poolSize = 1000
/ replace = true
</list>

<list demochoices>
/items = ("A", "B")
/ poolSize = 500
