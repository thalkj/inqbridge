</list>

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

list stores the flip estimates made during the demo
<list flipEstimates>
</list>

list stores selected PayOffs during the test trials
1 = higher Payoff selected; 0 = lower Payoff selected
<list selectedHigherPayOffs>
</list>

list stores the number of exploitative choices made
1 = exploitative choice; 0 = otherwise
<list exploitativeChoices>
</list>

Note: list stores 1 = correct response; 0 = incorrect response for each relevant trial
any response coded as an error is automatically coded as 0
<list accuracy>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list latencies>
</list>
**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial demoStart>
/ trialduration = 1000
/ recorddata = false
</trial>


<trial selectBandit_demo>
/ ontrialbegin = [
	values.countSelections += 1;
	values.trialcount += 1;
	values.previousArm = values.selectedArm;
	values.flip = list.flips.nextValue;	
	
	if (values.flip == 1){
		text.alert.textColor = red;
	} else {
		text.alert.textColor = blue;
	}
	
	values.countFlips += values.flip;
	values.countFlipsPractice += values.flip;
	
	if (values.flip == 1){
		if (values.higherPayOff == "A"){
			values.valueB += expressions.adjustment;
			if (values.valueB > values.valueA){
				values.higherPayOff = "B";			
			}
		} else {
			values.valueA += expressions.adjustment;
			if (values.valueA > values.valueB){
				values.higherPayOff = "A";			
			}			
		}
	}	


]
/ stimulusframes = [1 = clearScreen, chooseInstructions, A, B, points, alert, trialcount]
/timeout = parameters.demoSelectionTime

/ ontrialend = [	
	values.selectedArm = list.demochoices.nextValue;
		
		
]
/ branch = [
	return trial.summary_demo;
]
/ recorddata = false
</trial>

<trial summary_demo>
/ ontrialbegin = [
	if (values.selectedArm == "A"){
		values.totalPoints += values.valueA;
		text.A.skip = true;
		text.B_HL.skip = true;		
	} else {
		values.totalPoints += values.valueB;	
		text.B.skip = true;
		text.A_HL.skip = true;			
	}

]
/ stimulusframes = [1 = clearScreen, A, B, A_HL, B_HL, alert, points, trialcount]
/ trialduration = parameters.feedbackDuration
/ ontrialend = [
	if (values.countSelections >= parameters.nrDemotrials){
		values.stop = 1;
	}
	
	text.A.skip = false;
	text.A_HL.skip = false;
	text.B.skip = false;
	text.B_HL.skip = false;	
]
/ branch = [
	if (mod(values.countSelections, 100) == 0){
		return openended.flipEstimate_demo;
	} else {
		return trial.selectBandit_demo;		
	}

]
/ recorddata = true
</trial>

<openended flipEstimate_demo>
/ pretrialpause = 1000
/ required = true
/ mask = integer
/ ontrialbegin = [
	values.selectedArm = "";
]
/ stimulusframes = [1 = clearScreen, flipEstimate, trialcount]
/ responsefontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ size = (30%, 5%)
/ ontrialend = [
	list.flipEstimates.appendItem(openended.flipEstimate_demo.response);
	if (openended.flipEstimate_demo.trialcount == 1){
		values.countFlipsPractice = 0;
	}
]
/ branch = [
	return trial.selectBandit_demo;		
]
/ responsemessage = (anyresponse, clearScreen, 0)
/ posttrialpause = 1000
/ monkeyresponse = ("5", "6", "7", "8", "9", "10")
</openended>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

Note: trial.selectBandit
* checks whether this a repeat or a new trial; if new:
	* randomly selects whether this is a flip trial or not 
* presents the two choices as well as the currently awarded points
* waits for choice (response deadline imposed)
* if response was made in time:
	- determines values.choice (exploitative or exploratory) by checking the response against the known last highest payoff
	- updates values.valueA/values.valueB in case of flip trials
	- counts number of consecutive same responses
	- calls trial.summary
* if response was not made in time: calls trial.noresponseFeedback
	
<trial selectBandit>
/ ontrialbegin = [
	if (values.repeat == 0){
		values.trialcount += 1;
		values.previousArm = values.selectedArm;
		values.attempts = 1;
		
		if (values.trialcount > 1){
			values.flip = list.flips.nextValue;			
		}

		values.countFlips += values.flip;
	} else {
		values.attempts += 1;
	}
	
	values.choice = 0;
	values.selectedArm = "";
	values.selectedHigherPayOff	= "";
]
/ stimulusframes = [1 = clearScreen, chooseInstructions, A, B, points, trialcount]
/ validresponse = (parameters.leftKey,parameters.rightKey, 0)
/ ontrialend = [
	values.selectionRT = trial.selectBandit.latency;

	if (trial.selectBandit.response != 0){	
		values.countSelections += 1;
		values.choice = 1;
		if (trial.selectBandit.responseText == parameters.leftKey){
			values.selectedArm = "A";		
			if (values.highestSeenPayOff != values.valueA){
				values.choice = 2;
			}	

		} else if (trial.selectBandit.responseText == parameters.rightKey){
			values.selectedArm = "B";			
			if (values.highestSeenPayOff != values.valueB){
				values.choice = 2;
			}		
		}	
		if (values.choice == 1){
			list.exploitativeChoices.appendItem(1);
		} else {
			list.exploitativeChoices.appendItem(0);
		}		
				
			
		if (values.previousArm != values.selectedArm){
			values.selectionChange = 1;
			values.consecutiveSameChoice = 1;
		} else {
			values.consecutiveSameChoice += 1;
		}	
	}
]
/ timeout = parameters.selectionTime;
/ branch = [
	if (trial.selectBandit.response == 0){
		return trial.noResponseFeedback;
	} else {
		return trial.summary;
	}
]
/ recorddata = true
</trial>

Note: trial.summary
*  updates the totalpoints and potentially values.highestSeenPayOff
* reports the new total for 1000ms
* checks whether block stop condition has been met (have all trials been run?)
* if not: calls trial.selectBandit
<trial summary>
/ ontrialbegin = [
	if (values.flip == 1){
		if (values.higherPayOff == "A"){
			values.valueB += expressions.adjustment;
			if (values.valueB > values.valueA){
				values.higherPayOff = "B";			
			}
		} else {
			values.valueA += expressions.adjustment;
			if (values.valueA > values.valueB){
				values.higherPayOff = "A";			
			}			
		}
	}
	
	if (values.selectedArm == values.higherPayOff){
		values.selectedHigherPayOff = 1;
	} else {
		values.selectedHigherPayOff = 0;
	}
	
	list.selectedHigherPayOffs.appendItem(values.selectedHigherPayOff);

	if (values.selectedArm == "A"){
		text.A.skip = true;
		text.B_HL.skip = true;	
		values.totalPoints += values.valueA;
		if (values.valueA > values.highestSeenPayOff){
			values.highestSeenPayOff = values.valueA;
		}			
	} else {
		text.B.skip = true;
		text.A_HL.skip = true;		
		values.totalPoints += values.valueB;
		if (values.valueB > values.highestSeenPayOff){
				values.highestSeenPayOff = values.valueB;
		}				
	}
		
]
/ stimulusframes = [1 = clearScreen, A, B, A_HL, B_HL, points, trialcount]
/ trialduration = parameters.feedbackDuration
/ ontrialend = [
	values.repeat = 0;
	if (values.countSelections >= parameters.nrTesttrials){
		values.stop = 1;
	}
	
	text.A.skip = false;
	text.A_HL.skip = false;
	text.B.skip = false;
	text.B_HL.skip = false;
]
/ branch = [
	return trial.selectBandit;
]
/ recorddata = true
</trial>


Note: trial.noResponseFeedback
* presents the noresponse Feedback and a red X for 1000ms
* calls trial.selectBandit again with values.repeat = 1 (which will prevent trial from selecting a new values.flip)
<trial noResponseFeedback>
/ ontrialbegin = [
	values.repeat = 1;
]
/ stimulusframes = [1 = clearScreen, noresponseFeedback, x, trialcount]
/ trialduration = parameters.feedbackDuration
/ branch = [
	return trial.selectBandit;
]
/ recorddata = false
</trial>


**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block intro>
/ trials = [1 = intro1]
/ recorddata = false
</block>


<block passiveGame>
/ stop = [
	values.stop == 1;
]
/ onblockbegin = [
	values.stop = 0;
	values.trialcount = 0;
	values.totalPoints = 0;
	values.countFlips = 0;
	values.attempts = "";
	values.repeat = "";
	values.selectedArm = "";
	values.selectionChange = "";
	values.consecutiveSameChoice = "";
	values.highestSeenPayOff = "";
	values.selectedHigherPayOff = "";
	values.choice = "";
	values.valueA = parameters.start_A;
	values.valueB = parameters.start_B;
	if (values.valueA > values.valueB){
		values.higherPayOff = "A";
	} else if (values.valueB > values.valueA){
		values.higherPayOff = "B";
	} else {
		values.higherPayOff = "NA";
	}
	
	values.totalPoints = 0;

]
/ trials = [1 = demoStart; 2 = selectBandit_demo]
</block>



<block activeGame>
/ stop = [
	values.stop == 1;
]
/ onblockbegin = [
	values.stop = 0;
	values.trialcount = 0;
	values.totalPoints = 0;
	values.countFlips = 0;
	values.attempts = 0;
	values.repeat = 0;
	values.selectedArm = "";
	values.selectionChange = "";
	values.selectedHigherPayOff = "";
	values.consecutiveSameChoice = 1;

	values.choice = 0;
	values.valueA = parameters.start_A;
	values.valueB = parameters.start_B;
	if (values.valueA > values.valueB){
		values.highestSeenPayOff = values.valueA;
	} else {
		values.highestSeenPayOff = values.valueB;
	}
		
	if (values.valueA > values.valueB){
		values.higherPayOff = "A";
	} else if (values.valueB > values.valueA){
		values.higherPayOff = "B";
	} else {
		values.higherPayOff = "NA";
	}
	
	values.totalPoints = 0;
	values.countSelections = 0;
]
/ trials = [1 = gameStart; 2 = getReady; 3 = selectBandit]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt a>
/ blocks = [
	1 = intro;
	2 = passiveGame;
	3 = activeGame;
	4 = finish;
]
</expt>

