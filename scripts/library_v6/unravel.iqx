<trial keyboardtest_Fail>
/ inputdevice = mouse
/ stimulusframes = [1 = keyboardTest_Fail, exitbutton]
/ validresponse = (exitbutton)
/ ontrialend = [
	values.responseKeyLabel = "";
]
</trial>

