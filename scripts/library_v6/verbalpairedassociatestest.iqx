**************************************************************************************************************
**************************************************************************************************************
	EDITABLE INSTRUCTIONS: change instructions here
**************************************************************************************************************
**************************************************************************************************************
<instruct>
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ navigationButtonFontStyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ finishLabel = "Press [space] to start"
</instruct>

<page recallIntro>
<h1>Word Pair Learning Game</h1><hr><br>
We present you with a list of word pairs.<br><br> 
For each word pair, you will see the first word of the pair on the left side
of the screen and then the second word of the pair on the right side of the screen.
Pay close attention to each word pair.<br><br>
Once the list has finished, you will be prompted to recall the second words of each word pair by
presenting the first words as prompts. Enter the second word of each word pair into the provided textbox.<br><br><br>
Start when you are ready.
</page>

<page recallRepeat>
<br><br><br><br>
We are repeating the <u>same</u> list of word pairs as before. Again, pay close attention to each word pair.<br><br>
Just like before, you will be asked to recall the second word of each word pair using the first word as a prompt.<br><br><br>
Start when you are ready.
</page>

<page delayedRecall>
<br><br><br><br>
Remember the list of word pairs you were shown repeatedly before the break? <br><br>
We will provide you the first words of each pair as prompts once again. 
Enter the missing second word of each word pair into the provided textbox.<br><br><br>
Start when you are ready.
</page>

<page recognition>
<br><br><br><br>
We are going to present you with a <u>new</u> list of word pairs.<br>
Some of these word pairs were on the earlier list; but some were not.<br>
<center>For each word pair, ask the question:<br>
<i>"Was this word pair on the original list?"</i></center><br>
&bull; If the answer to that question is "Yes", press the "<%parameters.oldKey%>" key.<br>
&bull; If the answer to that question is "No", press the <%parameters.newKey%>" key."<br><br><br>
Start when you are ready.
</page>

<text recallInstructions>
/ items = ("Enter the second word of this word pair")
/ position = (50%, 30%)
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ size = (90%, 10%)
</text>

<text recognitionInstructions>
/ items = ("Was this word pair on the original list?

press '<%parameters.oldKey%>' for yes
press '<%parameters.newKey%>' for no")
/ position = (50%, 10%)
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text freeRecallInstructions>
/ items = ("Enter all the word pairs from the original list that you can recall")
/ position = (50%, 10%)
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
/ size = (90%, 10%)
</text>

<text break>
/ items = ("Take a break")
/ position = (50%, 50%)
/ fontstyle = ("Arial", 5%, true, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text finish>
/ items = ("Thank you!")
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ position = (50%, 50%)
/ size = (80%, 80%)
/ vjustify = center
</text>

<text exit>
/ items = ("<press spacebar to exit>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (80%, 5%)
/ vjustify = center
</text>

