**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = (0, 0, 0)
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 
 
values.count_immediateRecallRounds, values.count_allRecallRounds,   
values.familiarity, values.pairassociation, values.firstWord, values.secondWord, values.correctResp, response, correct, latency, 
values.Recall,  values.countCorrect_Recall, 
values.word1_recall, values.word2_recall, values.word3_recall, values.word4_recall, values.word5_recall, 
values.word6_recall, values.word7_recall, values.word8_recall, values.word9_recall, values.word10_recall, 
values.word11_recall, values.word12_recall, values.word13_recall, values.word14_recall,
values.intrusions, 
values.recognitionScore,
values.delayedFreeRecall_recalledWords, values.FreeRecallWordEstimate, 
values.countCorrect_FreeRecall, values.countCorrect_FreeRecallA, values.countCorrect_FreeRecallB, values.countCorrect_FreeRecall_pairs,
values.nr_otherFreeRecalledWords, values.nr_recogIntrusions, values.freeRecallIntrusions)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed,
 
expressions.recallScore, expressions.delayedRecallScore, values.recognitionScore, expressions.freeRecallScore,

 expressions.meanRecall, expressions.Recall1, expressions.Recall2, expressions.Recall3, expressions.Recall4,
expressions.prop_word1Recall, expressions.prop_word2Recall, expressions.prop_word3Recall, expressions.prop_word4Recall,
expressions.prop_word5Recall, expressions.prop_word6Recall, expressions.prop_word7Recall, expressions.prop_word8Recall,
expressions.prop_word9Recall, expressions.prop_word10Recall,
expressions.prop_word11Recall, expressions.prop_word12Recall, expressions.prop_word13Recall, expressions.prop_word14Recall,

values.round1_recalledWords, values.round2_recalledWords, values.round3_recalledWords, values.round4_recalledWords,
values.delayedRecall_recalledWords, values.intrusions,

expressions.r_hits_recognition, expressions.r_misses_recognition, 
expressions.r_FAs_recognition, expressions.r_CRs_recognition,
expressions.z_hr_recognition, expressions.z_fr_recognition,
expressions.dprime_recognition, expressions.c,

values.delayedFreeRecall_recalledWords, values.FreeRecallWordEstimate, 
values.countCorrect_FreeRecall, values.countCorrect_FreeRecallA, values.countCorrect_FreeRecallB, values.countCorrect_FreeRecall_pairs,
values.nr_otherFreeRecalledWords, values.nr_recogIntrusions, values.freeRecallIntrusions
)
</summarydata>

**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
/correctResp:					stores the correct response for the given recall/recognition trial
/pairassociation:				1 = strong association; 2 = weak association
/familiarity:					1 = old word pair (from word pair list); 2 = new word pair


Recall Rounds:
/count_immediateRecallRounds:	counts the number of immediate recall trials run (1-4)
/count_allRecallRounds:			counts the number of immediate and delayed recall trials run (free recall round not counted)

/Recall:						stores the free recall text input
/word1_recall-
/word14_recall:					stores the number of times the first (second, third, etc) word of a list was recalled across 
								the immediate recall rounds
/intrusions:					stores the character strings contained in the recall string that are not list words
									Note: misspelled study words will show up here
															
/round1_recalledWords-
/round4_recalledWords:			stores the list of the recalled words for immediate recall round1-round4

/delayedRecall_recalledWords:	stores the list of the recalled words for delayed recall round
/countCorrect_Recall:			stores the number of correctly recalled words during the current (prompted) recall round




Recognition Test:
/recognitionScore:				the number of words correctly identified


Free Recall Trial:

/tempSearchTarget:				helper variable to look for certain words in the free recall string
/recallLength:					helper variable to estimate number of words recalled in the free recall trial
/reducedRecall:					helper variable to estimate number of words recalled in the free recall trial
/FreeRecallWordEstimate:		stores the computer-derived estimate of the number of words recalled in the free recall trial
									Note: see below of algoritm implemented. Algorithm does not check whether the recalled words are actual words.
/helperRecall:					helper variable to analyze recall words in the free recall trial
/freeRecallIntrusions:			stores all the words entered during the free recall trial that were not part of the list
/countCorrect_FreeRecall:		tracks the number of correctly recalled words for the free recall trial
/countCorrect_FreeRecallA:		tracks the number of correctly recalled words A for the free recall trial
/countCorrect_FreeRecallB:		tracks the number of correctly recalled words B for the free recall trial
/countCorrect_FreeRecall_pairs: tracks the number of correctly recalled complete word pairs for the free recall trial
/nr_otherFreeRecalledWords:		stores the number of words not from the word pair list recalled during the free recall trial (based on FreeRecallEstimate)
/delayedFreeRecall_recalledWords:	stores the words entered for the free recall trial
/intrusion:						helper variable to track intrusion words during the free recall trial


<values>
/correctResp = ""
/pairassociation = ""
/familiarity = ""
/firstWord = ""
/secondWord = ""
/index = 0

/count_immediateRecallRounds = 0
/count_allRecallRounds = 0
/Recall = "";
/word1_recall = ""
/word2_recall = ""
/word3_recall = ""
/word4_recall = ""
/word5_recall = ""
/word6_recall = ""
/word7_recall = ""
/word8_recall = ""
/word9_recall = ""
/word10_recall = ""
/word11_recall = ""
/word12_recall = ""
/word13_recall = ""
/word14_recall = ""
/intrusions = ""
/round1_recalledWords = ""
/round2_recalledWords = ""
/round3_recalledWords = ""
/round4_recalledWords = ""
/delayedRecall_recalledWords = "not run"
/countCorrect_Recall = 0

/recognitionScore = 0

/tempSearchTarget = ""
/recallLength = 0;
/reducedRecall = "";
/FreeRecallWordEstimate = ""
/helperRecall = ""
/freeRecallIntrusions = ""
/countCorrect_FreeRecall = 0
/countCorrect_FreeRecallA = 0
/countCorrect_FreeRecallB = 0
/countCorrect_FreeRecall_pairs = 0
/nr_otherFreeRecalledWords = ""
/delayedFreeRecall_recalledWords = ""
/intrusion = ""
/nr_recogIntrusions = ""

</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

***********************************
Functions for Free Recall
***********************************

/wordcountEstimate: 	algorithm to estimate the number of words recalled
						-> algorithm replaces 8 possible word separators (" ", ;, etc) with "," in values.Recall
						-> algorithm adds a comma before the first word
						-> algoritm replaces multiple consecutive "," (up to 5) with a single one in values.Recall
						-> algorithm adds a comma at the end of the string
							-> values.Recall is as cleaned up as possible of random word separators
						-> algorithm removes all "," from values.Recall and stores the resulting reduced string in values.reducedRecall
						-> algorithm compares the length of values.reducedRecall to that of values.Recall
						and uses the reduced length to estimate the number of words in between the separators
						NOTE: values.recall will ideally contain only lower letter words separated by a single comma each at
						the end of this function + a start and an ending comma

/removeConsecutiveCommas:	recursive helper function to remove instances of consecutive commas from values.Recall						

/otherWordIntrusions:		function to find falsely recalled words (= words not part of the list)

<expressions>
/wordcountEstimate = {	

	//clean up the recall string. All words should be stored as "word,"
	values.Recall = replaceAll(values.Recall, "\", ",");
	values.Recall = replaceAll(values.Recall, "|", ",");	
	values.Recall = replaceAll(values.Recall, "/", ",");	
	values.Recall = replaceAll(values.Recall, ";", ",");	
	values.Recall = replaceAll(values.Recall, " ", ",");	
	values.Recall = replaceAll(values.Recall, ":", ",");
	values.Recall = replaceAll(values.Recall, ".", ",");
	values.Recall = replaceAll(values.Recall, "-", ",");
	values.Recall = replaceAll(values.Recall, "~n", ",");		
	values.Recall = concat(",", values.Recall);
	expressions.removeConsecutiveCommas;
		
	if (!endswith(values.Recall, ",")){
		values.Recall = concat(values.Recall, ",");	
	}

	values.RecallLength = length(values.Recall);
	values.reducedRecall = replaceAll(values.Recall, ",", "");	
	values.FreeRecallWordEstimate= values.RecallLength - length(values.reducedRecall) - 1;
}
/removeConsecutiveCommas = {
	values.Recall = replaceAll(values.Recall, ",,", ",");
	if (contains(values.Recall, ",,")){
		expressions.removeConsecutiveCommas;
	}
}	
/otherWordIntrusions = {
	
	values.helperRecall = values.Recall;
	
	var j = 1;	
	while (j <= item.wordsA.itemCount){
		values.tempSearchTarget = concat(",", item.wordsA.item(j));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
		values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
		j += 1;
	}
	
	j = 1;	
	while (j <= item.wordsB.itemCount){
		values.tempSearchTarget = concat(",", item.wordsB.item(j));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");		
		values.helperRecall = replaceAll(values.helperRecall, values.tempSearchTarget, ",");	
		j += 1;
	}	

	
	if (length(replaceAll(values.helperRecall, ",", "")) > 0){
		values.intrusion = values.helperRecall;		
	} else {
		values.intrusion = "";
	}
	
	values.freeRecallIntrusions = concat(values.freeRecallIntrusions, values.intrusion);
	values.freeRecallIntrusions = concat(values.freeRecallIntrusions, ",");
}
</expressions>

******************************
Summary Variables
******************************
/recallScore:					sum of all correctly recalled items across the 4 immediate recall rounds
/delayedRecallScore:			number of correctly recalled items during delayed recall
/mean_WordRecall:				mean of the estimated number of words recalled (immediate recall only) - independent of recall accuracy
/meanRecall:					mean number of correctly recalled words per immediate recall list
/Recall1:						proportion correctly recalled words during immediate recall round 1
/Recall2:						proportion correctly recalled words during immediate recall round 2  
/Recall3:						proportion correctly recalled words during immediate recall round 3  
/Recall4:						proportion correctly recalled words during immediate recall round 4 

/prop_word1Recall-
/prop_word10Recall:				stores the immediate recall proportion of words in study positions 1 - 10 across the number of trials (Max: 4/4 for each item)
/meanIntrusions:				mean number of intrusions on recall lists (recalling words that were not on the list)

/r_hits_recognition:			hit rate during recognition (hit => participant categorized old word as 'old')
/r_FAs_recognition :			false alarm rate during recognition (false alarm => participant categorized new word as 'old')

Note: z-score calculations: adjustments (see Gregg & Sedikides, 2010, p.148)
If the hit rate / FA rate is 0 => 0.005 is used instead (aka 0.005 is added to the hit/FA rate)
IF the hit rate / FA rate is 1.0 => 0.995 is used instead (aka 0.005 is subtracted from the hit/FA rate)

/z_hr_recognition:				z-score of hit rate
/z_fr_recognition:				z-score of false alarm rate
/dprime_recognition:			Computes d' (parametric measure of discriminability).

<expressions>
/recallScore = 
if (list.accuracy_immediaterecall.itemCount == 4){
	list.accuracy_immediaterecall.item(1) + list.accuracy_immediaterecall.item(2) + list.accuracy_immediaterecall.item(3) + list.accuracy_immediaterecall.item(4)
	
} else "not run"

/delayedRecallScore = list.accuracy_delayedrecall.mean * list.accuracy_delayedrecall.itemCount
/freeRecallScore = values.countCorrect_FreeRecall_pairs

/meanRecall = expressions.recallScore/values.count_immediateRecallRounds

/Recall1 = if (list.accuracy_immediaterecall.itemCount > 0) list.accuracy_immediaterecall.item(1)/14 else "round 1 not run"
/Recall2 = if (list.accuracy_immediaterecall.itemCount > 1) list.accuracy_immediaterecall.item(2)/14 else "round 2 not run"
/Recall3 = if (list.accuracy_immediaterecall.itemCount > 2) list.accuracy_immediaterecall.item(3)/14 else "round 3 not run"
/Recall4 = if (list.accuracy_immediaterecall.itemCount > 3)list.accuracy_immediaterecall.item(4)/14 else "round 4 not run"

/prop_word1Recall = values.word1_recall/values.count_immediateRecallRounds
/prop_word2Recall = values.word2_recall/values.count_immediateRecallRounds
/prop_word3Recall = values.word3_recall/values.count_immediateRecallRounds
/prop_word4Recall = values.word4_recall/values.count_immediateRecallRounds
/prop_word5Recall = values.word5_recall/values.count_immediateRecallRounds
/prop_word6Recall = values.word6_recall/values.count_immediateRecallRounds
/prop_word7Recall = values.word7_recall/values.count_immediateRecallRounds
/prop_word8Recall = values.word8_recall/values.count_immediateRecallRounds
/prop_word9Recall = values.word9_recall/values.count_immediateRecallRounds
/prop_word10Recall = values.word10_recall/values.count_immediateRecallRounds
/prop_word11Recall = values.word11_recall/values.count_immediateRecallRounds
/prop_word12Recall = values.word12_recall/values.count_immediateRecallRounds
/prop_word13Recall = values.word13_recall/values.count_immediateRecallRounds
/prop_word14Recall = values.word14_recall/values.count_immediateRecallRounds

/r_hits_recognition = list.hits.mean
/r_misses_recognition = (1-expressions.r_hits_recognition)
/r_FAs_recognition = list.falseAlarms.mean
/r_CRs_recognition = (1-expressions.r_FAS_recognition)

/z_hr_recognition = if (expressions.r_hits_recognition == 0){
	zofp(expressions.r_hits_recognition + 0.005);
} else if (expressions.r_hits_recognition == 1){
	zofp(expressions.r_hits_recognition - 0.005);
} else {
	zofp(expressions.r_hits_recognition);
}

/z_fr_recognition = if (expressions.r_FAs_recognition == 0){
	zofp(expressions.r_FAs_recognition + 0.005);
} else if (expressions.r_FAs_recognition == 1){
	zofp(expressions.r_FAs_recognition - 0.005);
} else {
	zofp(expressions.r_FAs_recognition);	
}

/dprime_recognition = (expressions.z_hr_recognition-expressions.z_fr_recognition)
/c = return (-1*((expressions.z_hr_recognition + expressions.z_fr_recognition)/2))
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	INSTRUCTIONS
**************************************************************************************************************
**************************************************************************************************************

<trial finish>
/ stimulusframes = [1 = clearScreen, finish]
/ timeout = 500
/ recorddata = false
</trial>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

Note: by default, the recall WordsA are called in a random order.
To call them sequentially, change to:
/select = sequence
<text wordA>
/ items = wordsA
/ select = values.index
/ fontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ position = (35%, 50%)
/ size = (30%, parameters.wordSize * 1.1)
</text>

<text wordB>
/ items = wordsB
/ select = values.index
/ fontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ position = (65%, 50%)
/ size = (30%, parameters.wordSize * 1.1)
</text>

Note: by default, the recognition Words are called randomly.
To call them in a fixed sequence, change to
/select = sequence
<text recognitionWordA>
/ items = recognitionWordsA
/ select = values.index
/ fontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ position = (35%, 50%)
/ size = (30%, parameters.wordSize * 1.1)
</text>

<text recognitionWordB>
/ items = recognitionWordsB
/ select = text.recognitionWordA.currentItemNumber
/ fontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ position = (65%, 50%)
/ size = (30%, parameters.wordSize * 1.1)
</text>

<clock breakTimer>
/ mode = timer
/ txcolor = yellow
/ txbgcolor = black
/ timeout = parameters.MinDelay
/ position = (50%, 70%)
/ size = (20%, 10%)
/ format = "hh:mm:ss"
</clock>

<text errorfeedback>
/ items = feedback
/ select = 2
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ size = (30%, 10%)
/ position = (50%, 85%)
/ txcolor = red
</text>

<text correctfeedback>
/ items = feedback
/ select = 1
/ fontstyle = ("Arial", 8%, true, false, false, false, 5, 1)
/ size = (30%, 10%)
/ position = (50%, 85%)
/ txcolor = green
</text>

**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

<list freeRecallWordsA>
/ selectionrate = always
</list>

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores number of correctly recalled items per immediate recall trial
<list accuracy_immediaterecall>
</list>

Note: list stores number of correctly recalled items per immediate recall trial
<list accuracy_delayedrecall>
</list>

Note: this list stores all wordCountEstimates across all immediate recall lists
<list wordCountEstimates>
</list>

Note: list stores number of other intrusions on recall across all immediate recall lists
<list intrusions>
</list>

Note: list stores 1 = hit (recognized old word); 0 = miss
<list hits>
</list>

Note: list stores 1 = False Alarm (recognized new word as old); 0 = correct rejection
<list falseAlarms>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<trial pairLearning>
/ ontrialbegin = [
	if (values.count_immediateRecallRounds == 1){
		values.index = list.round1_presentationOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 2){
		values.index = list.round2_presentationOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 3){
		values.index = list.round3_presentationOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 4){
		values.index = list.round4_presentationOrder.nextValue;
	} else {
		values.index = "error";
	}
	trial.pairLearning.insertStimulusTime(clearScreen, parameters.stimduration);
	trial.pairLearning.insertStimulusTime(text.wordB, parameters.stimduration);
	trial.pairLearning.insertStimulusTime(clearScreen, parameters.stimduration*2);	
]
/ stimulusframes = [1 = wordA]
/ timeout = 2* parameters.stimduration
/ posttrialpause = parameters.pairISI
/ recorddata = false
/ ontrialend = [
	trial.pairLearning.resetStimulusFrames();
	
	values.firstWord = text.wordA.currentItem;
	values.secondWord = text.wordB.currentItem;
]
</trial>


************************
immediate Recall
************************
/ monkeyresponse = (item.wordsB.items.1, item.wordsB.items.2, item.wordsB.items.3, item.wordsB.items.4, item.wordsB.items.5,
item.wordsB.items.6, item.wordsB.items.7, item.wordsB.items.8, item.wordsB.items.9, item.wordsB.items.10,
item.wordsB.items.11, item.wordsB.items.12, item.wordsB.items.13, item.wordsB.items.14)
Note: openended.recall 
* presents the first word of a pair and presents a textbox to collect the second word
* trial counts the number of correctly recalled items and updates the correct count for each item

<openended immediateRecall_wordPairs>
/ ontrialbegin = [
	if (values.count_immediateRecallRounds == 1){
		values.index = list.round1_recallOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 2){
		values.index = list.round2_recallOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 3){
		values.index = list.round3_recallOrder.nextValue;
	} else if (values.count_immediateRecallRounds == 4){
		values.index = list.round4_recallOrder.nextValue;
	} else {
		values.index = "error";
	}
	openended.immediateRecall_wordPairs.insertStimulusTime(clearScreen, parameters.stimduration);
	openended.immediateRecall_wordPairs.insertStimulusTime(text.recallInstructions, parameters.stimduration);	
]
/ stimulusframes = [1 = wordA, recallInstructions]
/ size = (30%, parameters.wordSize+0.5%)
/ charlimit = 100
/ position = (65%, 55%)
/ responsefontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ buttonlabel = "submit"
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ iscorrectresponse = [
	values.correctResp = item.wordsB.item(text.wordA.currentItemNumber);
	
	return(
	tolower(openended.immediateRecall_wordPairs.response) == values.correctResp);
]
/ monkeyresponse = (item.wordsB.items.1)
/ ontrialend = [
	openended.immediateRecall_wordPairs.resetStimulusFrames();

	values.firstWord = text.wordA.currentItem;
	values.secondWord = "";

	values.pairassociation = item.pairAssociations.item(text.wordA.currentItemNumber);
	values.countCorrect_Recall += openended.immediateRecall_wordPairs.correct;
	
	values.Recall = concat(values.Recall, openended.immediateRecall_wordPairs.response);
	values.Recall = concat(values.Recall, ", ");
	
	if (openended.immediateRecall_wordPairs.correct){
		if (text.wordA.currentItemNumber == 1){
			values.word1_recall += 1
		} else if (text.wordA.currentItemNumber == 2){
			values.word2_recall += 1;
		} else if (text.wordA.currentItemNumber == 3){
			values.word3_recall += 1;
		} else if (text.wordA.currentItemNumber == 4){
			values.word4_recall += 1;
		} else if (text.wordA.currentItemNumber == 5){
			values.word5_recall += 1;
		} else if (text.wordA.currentItemNumber == 6){
			values.word6_recall += 1;
		} else if (text.wordA.currentItemNumber == 7){
			values.word7_recall += 1;
		} else if (text.wordA.currentItemNumber == 8){
			values.word8_recall += 1;
		} else if (text.wordA.currentItemNumber == 9){
			values.word9_recall += 1;
		} else if (text.wordA.currentItemNumber == 10){
			values.word10_recall += 1;
		} else if (text.wordA.currentItemNumber == 11){
			values.word11_recall += 1;
		} else if (text.wordA.currentItemNumber == 12){
			values.word12_recall += 1;
		} else if (text.wordA.currentItemNumber == 13){
			values.word13_recall += 1;
		} else if (text.wordA.currentItemNumber == 14){
			values.word14_recall += 1;
		}
	} else {
		values.intrusions = concat(values.intrusions, openended.immediateRecall_wordPairs.response);
		values.intrusions = concat(values.intrusions, ", ");		
	}
]
/ errormessage = true(text.errorfeedback, 1000)
/ correctmessage = true(text.correctfeedback, 1000)
</openended>

************************
break
************************

<trial break>
/ stimulusframes = [1 = break, breakTimer]
/ recorddata = false
/ trialduration = parameters.MinDelay;
</trial>

************************
delayed Recall
************************

<openended delayedRecall_wordPairs>
/ ontrialbegin = [
	values.index = list.delayedRound_recallOrder.nextValue;
	openended.delayedRecall_wordPairs.insertStimulusTime(clearScreen, parameters.stimduration);
	openended.delayedRecall_wordPairs.insertStimulusTime(text.recallInstructions, parameters.stimduration);	
]
/ stimulusframes = [1 = wordA, recallInstructions]
/ size = (30%, parameters.wordSize+0.5%)
/ charlimit = 100
/ position = (65%, 55%)
/ responsefontstyle = ("Arial", parameters.wordSize, true, false, false, false, 5, 1)
/ buttonlabel = "submit"
/ iscorrectresponse = [
	values.correctResp = item.wordsB.item(text.wordA.currentItemNumber);
	
	return(
	tolower(openended.delayedRecall_wordPairs.response) == values.correctResp);
]
/ monkeyresponse = (item.wordsB.items.1, item.wordsB.items.2, item.wordsB.items.3, item.wordsB.items.4, item.wordsB.items.5,
item.wordsB.items.6, item.wordsB.items.7, item.wordsB.items.8, item.wordsB.items.9, item.wordsB.items.10,
item.wordsB.items.11, item.wordsB.items.12, item.wordsB.items.13, item.wordsB.items.14)
/ ontrialend = [
	openended.delayedRecall_wordPairs.resetStimulusFrames();
	
	values.firstWord = text.wordA.currentItem;
	values.secondWord = "";
	
	values.pairassociation = item.pairAssociations.item(text.wordA.currentItemNumber);
	values.countCorrect_Recall += openended.delayedRecall_wordPairs.correct;
	
	values.Recall = concat(values.Recall, openended.delayedRecall_wordPairs.response);
	values.Recall = concat(values.Recall, ", ");
		
	list.accuracy_delayedrecall.appendItem(openended.delayedRecall_wordPairs.correct);
	
	if (openended.delayedRecall_wordPairs.error){
		values.intrusions = concat(values.intrusions, openended.delayedRecall_wordPairs.response);
		values.intrusions = concat(values.intrusions, ", ");		
	}
]
</openended>

************************
delayed Recognition
************************

<trial recognition>
/ ontrialbegin = [
	values.index = list.recognitionRound_presentationOrder.nextValue;
	trial.recognition.insertStimulusTime(clearScreen, parameters.stimduration);
	trial.recognition.insertStimulusTime(text.recognitionWordB, parameters.stimduration);	
	trial.recognition.insertStimulusTime(clearScreen, parameters.stimduration*2);	
	trial.recognition.insertStimulusTime(text.recognitionInstructions, parameters.stimduration*2);	
]
/ stimulusframes = [1 = recognitionWordA]
/ validresponse = (parameters.oldKey, parameters.newKey)
/ iscorrectresponse = [
	values.familiarity = item.pairFamiliarity.item(text.recognitionWordA.currentItemNumber);

	return(
	(values.familiarity == 1 && trial.recognition.responseText == parameters.oldKey) ||
	(values.familiarity == 0 && trial.recognition.responseText == parameters.newKey));
]
/ ontrialend = [
	trial.recognition.resetStimulusFrames();
	values.pairassociation = item.pairAssociations_recognition.item(text.recognitionWordA.currentItemNumber);

	if (values.familiarity == 1){
		list.hits.appendItem(trial.recognition.correct);
		values.recognitionScore += trial.recognition.correct;
		values.correctResp = parameters.oldKey;
	} else {
		list.falseAlarms.appendItem(trial.recognition.error);
		values.recognitionScore += trial.recognition.correct;
		values.correctResp = parameters.newKey;
	}
	values.firstWord = text.recognitionWordA.currentItem;
	values.secondWord = text.recognitionWordB.currentItem;
]
</trial>

************************
delayed Free Recall
************************

<openended delayedFreeRecall>
/ stimulusframes = [1 = freeRecallInstructions]
/ ontrialbegin = [
	values.Recall = "";
	values.countCorrect_FreeRecall = 0;
	values.firstWord = "";
	values.secondWord = "";	
]
/ size = (80%, 70%)
/ multiline = true
/ charlimit = 5000
/ position = (50%, 90%)
/ responsefontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ buttonlabel = "submit"
/ fontstyle = ("Arial", 3%, true, false, false, false, 5, 1)
/ monkeyresponse = (
"story-air; room-moment\ art, area, service, history, city-office, word; job
team")

/ ontrialend = [
	values.Recall = tolower(openended.delayedFreeRecall.response);
	expressions.wordcountEstimate;	
	
	var i = 1;	
	//for each word in item.wordsA check whether it has been recalled (= is part of values.Recall)
	while (i <= item.wordsA.itemCount){
	
		//assemble the search target: next word in item.wordA list followed by a ','
		values.tempSearchTarget = "";
		values.tempSearchTarget = concat(",",item.wordsA.item(i));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");
		
		//check whether the search target is part of values.Recall
		if (contains(values.Recall, values.tempSearchTarget)){//yes, it's part of values.Recall -> add '1' to list.freeRecallWordsA
			values.countCorrect_FreeRecall += 1;
			values.countCorrect_FreeRecallA += 1;
			list.freeRecallWordsA.appendItem(1);
		} else {//no, it's not part of values.Recall -> add '0' to list.freeRecallWordsA
			list.freeRecallWordsA.appendItem(0);
		}	
	
		i += 1;//increase the index for the next check
	}
	
	i = 1;//reset the index variable to 1 for the next while loop

	//for each word in item.wordsB check whether it has been recalled (= is part of values.Recall)	
	while (i <= item.wordsB.itemCount){
		
		values.tempSearchTarget = concat(",",item.wordsB.item(i));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");
		if (contains(values.Recall, values.tempSearchTarget)){
			values.countCorrect_FreeRecall += 1;
			values.countCorrect_FreeRecallB += 1;
			if (list.freeRecallWordsA.item(i) == 1){
				values.countCorrect_FreeRecall_pairs += 1;
			}
		}	

		i += 1;
	}
	
	//Intrusion work analyses
	values.nr_otherFreeRecalledWords = values.FreeRecallWordEstimate - values.countCorrect_FreeRecall;
	expressions.otherWordIntrusions;
	
	i = 15; //reset index i	
	while (i <= item.recognitionWordsA.itemCount){
		values.tempSearchTarget = "";
		values.tempSearchTarget = concat(",",item.recognitionWordsA.item(i));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");
		if (contains(values.Recall, values.tempSearchTarget)){
			values.nr_recogIntrusions += 1;		
		}	
		i += 1;
	}
	
	i=15;
	while (i <= item.recognitionWordsB.itemCount){
		values.tempSearchTarget = "";
		values.tempSearchTarget = concat(",",item.recognitionWordsB.item(i));
		values.tempSearchTarget = concat(values.tempSearchTarget, ",");
		if (contains(values.Recall, values.tempSearchTarget)){
			values.nr_recogIntrusions += 1;		
		}
		i += 1;			
	}
]
</openended>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block recallIntro>
/ preinstructions = (recallIntro)
</block>

<block recallRepeat>
/ preinstructions = (recallRepeat)
</block>

<block recall>
/ onblockbegin = [
	values.count_immediateRecallRounds += 1;
	values.count_allRecallRounds += 1;
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.familiarity = 1;
	values.correctResp = "";
	values.intrusions = concat(values.intrusions, "|round");
	values.intrusions = concat(values.intrusions, values.count_allRecallRounds);	
	values.intrusions = concat(values.intrusions, ": ");	
]
/ trials = [
	1-14 = pairLearning; 
	15-28 = immediateRecall_wordpairs;
]
/ onblockend = [
	if (values.count_immediateRecallRounds == 1){
		values.round1_recalledWords = values.Recall;
	} else if (values.count_immediateRecallRounds == 2){
		values.round2_recalledWords = values.Recall;
	} else if (values.count_immediateRecallRounds == 3){
		values.round3_recalledWords = values.Recall;
	} else if (values.count_immediateRecallRounds == 4){
		values.round4_recalledWords = values.Recall;
	}
	
	list.accuracy_immediaterecall.appendItem(values.countCorrect_Recall);
]
</block>

<block break>
/skip = [
	parameters.runDelayedFreeRecall == false && parameters.runDelayedRecall == false && parameters.runRecognitionTask == false;
]
/ trials = [1 = break]
/ recorddata = false
</block>

<block delayedRecall>
/ preinstructions = (delayedRecall)
/ skip = [
	parameters.runDelayedRecall == false;
]
/ onblockbegin = [
	values.count_allRecallRounds += 1;
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.familiarity = 1;	
	values.intrusions = concat(values.intrusions, "|delayed recall round:");	
]
/ trials = [1-14 = delayedRecall_wordpairs]
/ onblockend = [
	values.delayedRecall_recalledWords = values.Recall;
]
</block>

Note: block.recognition
* presents 28 item pairs (14 old, 14 new) in random order
<block recognition>
/ skip = [
	parameters.runRecognitionTask == false;
]

/ onblockbegin = [
	values.Recall = "";
	values.countCorrect_Recall = 0;
	values.FreeRecallWordEstimate = "";	
]
/ preinstructions = (recognition)
/ trials = [1-28 = recognition]
</block>

<block delayedFreeRecall>
/ skip = [
	parameters.runDelayedFreeRecall == false;
]
/ onblockbegin = [
	values.count_allRecallRounds += 1;
	values.Recall = "";
]
/ trials = [1 = delayedFreeRecall]
/ onblockend = [
	values.delayedFreeRecall_recalledWords = values.Recall;
]
</block>

<block finish>
/ trials = [1 = finish]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt verbalPairedAssociates>
/ blocks = [
	1 = recallIntro;
	2 = recall;
	3 = recallRepeat;
	4 = recall;
	5 = recallRepeat;
	6 = recall;
	7 = recallRepeat;
	8 = recall;
	9 = break;
	10 = delayedRecall;
	11 = recognition;
	12 = delayedFreeRecall;
	13 = finish;
]

</expt>


