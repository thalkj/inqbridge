*******************************************************************************************************************
*******************************************************************************************************************
	DEFAULTS:
*******************************************************************************************************************
*******************************************************************************************************************
requires Inquisit 6.0.1.0

<defaults>
/minimumversion = "6.0.1.0"
/canvasaspectratio = (4,3)
</defaults>

*******************************************************************************************************************
*******************************************************************************************************************
	DATA: this section contains data file information
*******************************************************************************************************************
*******************************************************************************************************************

********************
Summary data
********************

<summarydata>
/columns = (inquisit.version, computer.platform, script.startDate, script.startTime, 
script.subjectId, script.groupId, script.sessionId, script.elapsedTime, script.completed, 
expressions.Domain1_raw, expressions.Domain1_TS100, values.countValid1,
expressions.Domain2_raw, expressions.Domain2_TS100, values.countValid2, 
expressions.Domain3_raw, expressions.Domain3_TS100, values.countValid3, 
expressions.Domain4_raw, expressions.Domain4_TS100, values.countValid4, 
)
</summarydata>

*******************************************************************************************************************
*******************************************************************************************************************
	VALUES: automatically updated
*******************************************************************************************************************
*******************************************************************************************************************
/completed:				0 = script was not completed (script prematurely aborted); 1 = script was completed (all conditions run)
/sum:					helper variable to store the sum for domain1-domain4 questions
/countValid1-
/countValid4:			store the number of questions that were answered for domain1-domain4
/domain1-
/domain4:				store the mean raw score for domain1-domain4

<values>
/sum = 0
/countValid1 = 0
/countValid2 = 0
/countValid3 = 0
/countValid4 = 0
/domain1 = 0
/domain2 = 0
/domain3 = 0
/domain4 = 0
</values>

*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

The coding of the raw scores follows the recommendation of:							
http://depts.washington.edu/seaqol/WHOQOL-BREF	

"If no more than one item from the Physical Health or Environment domains has been
coded as missing, we recommend that a domain score be calculated by substituting a personspecific
average across the completed items in the same scale. For example, if a respondent does
not have a value for item B16 How satisfied are you with your sleep? in the Physical Health
domain, but has answered all of the other items in that domain, then the value for item B16
would be the average of the remaining 6 items. If two or more items are coded missing in these
two domains, the domain score should not be calculated, likewise if any items are coded missing
in the Psychological and Social Relationships domains, a domain score for that respondent
would not be calculated."

/Domain1_raw:				calculates the raw score for Domain1 by adding the responses to the Domain 1 questions
							(reversed items are automatically reversed scored)
							if 1 item is missing: the score gets replaced with the mean of the remaining 6 scores
							if more than 1 item is missing: no raw score is calculated

/Domain2_raw:				calculates the raw score for Domain2 by adding the responses to the Domain 2 questions
							(reversed items are automatically reversed scored)
							No raw score is calculated if not all questions are answered
							
/Domain3_raw:				calculates the raw score for Domain3 by adding the responses to the Domain 3 questions
							(reversed items are automatically reversed scored)
							No raw score is calculated if not all questions are answered
							
/Domain4_raw:				calculates the raw score for Domain4 by adding the responses to the Domain 4 questions
							(reversed items are automatically reversed scored)
							if 1 item is missing: the score gets replaced with the mean of the remaining 7 scores
							if more than 1 item is missing: no raw score is calculated
							
Transformed Scores:
							
/Domain1_TS20:				transformed score for Domain 1 on the scale 4-20
/Domain2_TS20 :				transformed score for Domain 2 on the scale 4-20
/Domain3_TS20:				transformed score for Domain 3 on the scale 4-20	
/Domain4_TS20:				transformed score for Domain 4 on the scale 4-20
	
/Domain1_TS100:				transformed score for Domain 1 on the scale 0-100
/Domain2_TS100:				transformed score for Domain 2 on the scale 0-100
/Domain3_TS100:				transformed score for Domain 3 on the scale 0-100	
/Domain4_TS100:				transformed score for Domain 4 on the scale 0-100

<expressions>
/Domain1_raw = {
	values.sum = 0;
	values.countValid1 = 0;
	if (radiobuttons.q3R.response) {
		values.sum += radiobuttons.q3R.response;
		values.countValid1 += 1;
	}
	if (radiobuttons.q4R.response) {
		values.sum += radiobuttons.q4R.response;
		values.countValid1 += 1;
	} 
	if (radiobuttons.q10.response) {
		values.sum += radiobuttons.q10.response;
		values.countValid1 += 1;
	}	
	if (radiobuttons.q15.response) {
		values.sum += radiobuttons.q15.response;
		values.countValid1 += 1;
	}	
	if (radiobuttons.q16.response) {
		values.sum += radiobuttons.q16.response;
		values.countValid1 += 1;
	}
	if (radiobuttons.q17.response) {
		values.sum += radiobuttons.q17.response;
		values.countValid1 += 1;
	}	
	if (radiobuttons.q18.response) {
		values.sum += radiobuttons.q18.response;
		values.countValid1 += 1;
	}	
	values.domain1 = values.sum/values.countValid1;
	if (values.countValid1 < 6){
		"too few scores";
	} else if (values.countValid1 == 6){
		values.sum += values.domain1;
		values.sum;

	} else {
		values.sum;		
	}
}
/Domain2_raw = {
	values.sum = 0;
	values.countValid2 = 0;
	if (radiobuttons.q5.response) {
		values.sum += radiobuttons.q5.response;
		values.countValid2 += 1;
	}
	if (radiobuttons.q6.response) {
		values.sum += radiobuttons.q6.response;
		values.countValid2 += 1;
	} 
	if (radiobuttons.q7.response) {
		values.sum += radiobuttons.q7.response;
		values.countValid2 += 1;
	}	
	if (radiobuttons.q11.response) {
		values.sum += radiobuttons.q11.response;
		values.countValid2 += 1;
	}	
	if (radiobuttons.q19.response) {
		values.sum += radiobuttons.q19.response;
		values.countValid2 += 1;
	}
	if (radiobuttons.q26R.response) {
		values.sum += radiobuttons.q26R.response;
		values.countValid2 += 1;
	}	
	values.domain2 = values.sum/values.countValid2;
	if (values.countValid2 <= 5){
		"too few scores";
	} else {
		values.sum;
	}
}
/Domain3_raw = {
	values.sum = 0;
	values.countValid3 = 0;
	if (radiobuttons.q20.response) {
		values.sum += radiobuttons.q20.response;
		values.countValid3 += 1;
	}
	if (radiobuttons.q21.response) {
		values.sum += radiobuttons.q21.response;
		values.countValid3 += 1;
	} 
	if (radiobuttons.q22.response) {
		values.sum += radiobuttons.q22.response;
		values.countValid3 += 1;
	}	
	values.domain3 = values.sum/values.countValid3;
	if (values.countValid3 <= 2){
		"too few scores";
	} else {
		values.sum;
	}
}
/Domain4_raw = {
	values.sum = 0;
	values.countValid4 = 0;
	if (radiobuttons.q8.response) {
		values.sum += radiobuttons.q8.response;
		values.countValid4 += 1;
	}
	if (radiobuttons.q9.response) {
		values.sum += radiobuttons.q9.response;
		values.countValid4 += 1;
	} 
	if (radiobuttons.q12.response) {
		values.sum += radiobuttons.q12.response;
		values.countValid4 += 1;
	}	
	if (radiobuttons.q13.response) {
		values.sum += radiobuttons.q13.response;
		values.countValid4 += 1;
	}	
	if (radiobuttons.q14.response) {
		values.sum += radiobuttons.q14.response;
		values.countValid4 += 1;
	}
	if (radiobuttons.q23.response) {
		values.sum += radiobuttons.q23.response;
		values.countValid4 += 1;
	}	
	if (radiobuttons.q24.response) {
		values.sum += radiobuttons.q24.response;
		values.countValid4 += 1;
	}
	if (radiobuttons.q25.response) {
		values.sum += radiobuttons.q25.response;
		values.countValid4 += 1;
	}	
	values.domain4 = values.sum/values.countValid4;
	if (values.countValid4 <= 6){
		"too few scores";
	} else if (values.countValid4 == 7){
		values.sum += values.domain4;
		values.sum;		
	} else {
		values.sum;
	}
}	
	
/Domain1_TS100 = if (expressions.Domain1_raw != "too few scores"){
					((expressions.Domain1_raw - 7)/28) * 100;
				} else {
					"too few scores";
				}		
				
				
/Domain2_TS100 = if (expressions.Domain2_raw != "too few scores"){
					((expressions.Domain2_raw-6)/24) * 100					
				} else {
					"too few scores";
				}		
				
							
/Domain3_TS100 = if (expressions.Domain3_raw != "too few scores"){
					((expressions.Domain3_raw-3)/12) * 100	
				} else {
					"too few scores";
				}			
				
			
				
/Domain4_TS100 = if (expressions.Domain4_raw != "too few scores"){
					((expressions.Domain4_raw-8)/32) * 100
				} else {
					"too few scores";
				}		
	

</expressions>


<expressions>
/buttonInstruct1 = if (computer.touch && !computer.hasKeyboard){"tap with your finger"} else {"click with your mouse"}
</expressions>

*******************************************************************************************************************
*******************************************************************************************************************
	QUESTIONS
*******************************************************************************************************************
*******************************************************************************************************************
Note: by default all questions are not required to be answered. To change
/required = true

<radiobuttons sample1>
/caption = "Question: Do you get the kind of support from others that you need?"
/ options = ("Not at all", "Not much", "Moderately", "A great deal", "Completely")
/ optionvalues = ("1", "2", "3", "4", "5")
/required = false
/orientation = horizontalequal
/ txcolor = purple
</radiobuttons>

<caption sampleInstruct1>
/ caption = "You should select the response that best fits how much support you got from others over the last two weeks.
 
If you got a great deal of support from others in the last two weeks, you would <%expressions.buttonInstruct1%> the circle above 'a great deal' .

If you did not get any of the support that you needed from others in the last two weeks, you would <%expressions.buttonInstruct1%> the circle 'not at all' ."
/ fontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
</caption>


<radiobuttons q1>
/caption = "1. How would you rate your quality of life?"
/ options = ("Very poor", "Poor", "Neither poor ~nnor good", "Good", "Very good")
/ optionvalues = ("1", "2", "3", "4", "5")
/required = false
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q2>
/caption = "2. How satisfied are you with your health?"
/ options = ("Very~n dissatisfied", "Dissatisfied", "Neither satisfied ~nnor dissatisfied", "Satisfied", "Very ~nsatisfied")
/ optionvalues = ("1", "2", "3", "4", "5")
/required = false
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q3R>
/caption = "3. To what extent do you feel that physical pain prevents you from doing what you need to do?"
/ options = ("Not at all", "A little", "A moderate ~namount", "Very much", "An extreme ~namount")
/ optionvalues = ("5", "4", "3", "2", "1")
/required = false
/orientation = horizontalequal
</radiobuttons>

<radiobuttons q4R>
