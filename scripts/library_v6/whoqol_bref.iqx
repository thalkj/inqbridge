</radiobuttons>

<textbox feedback>
/ caption = "Do you have any comments about the assessment?"
/ fontstyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ textboxsize = (80%, 50%)
/ multiline = true
/ maxchars = 10000
/ required = false
</textbox>

<caption caption3>
/ caption = "Thank you!"
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
</caption>

