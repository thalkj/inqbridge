**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.5.2.0 or higher

<defaults>
/canvasaspectratio = (4,3)
/minimumversion = "6.5.2.0"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/txbgcolor = white
/ txcolor = (0, 0, 0)
</defaults>

**************************************************************************************************************
**************************************************************************************************************
	DATA
**************************************************************************************************************
**************************************************************************************************************

Note: data file explanations under User Manual Information at the top

***********************
raw data file
***********************
<data>
/ columns = (build, computer.platform, date, time, subject, group, session, 
blockcode, blocknum, trialcode, trialnum, 
stimulusitem, response, correct, latency)
</data>

***********************
summary data file
***********************
<summarydata>
/ columns = (inquisit.version, computer.platform, script.startDate, script.startTime, script.subjectId, script.groupId, script.sessionId, 
script.elapsedTime, script.completed, 
expressions.Total, expressions.meanRating, expressions.minRating, expressions.maxRating, expressions.meanRT)
</summarydata>


**************************************************************************************************************
**************************************************************************************************************
	VALUES: automatically updated
**************************************************************************************************************
**************************************************************************************************************
                                    
<values>
/scenario = 0
</values>

**************************************************************************************************************
**************************************************************************************************************
	EXPRESSIONS
**************************************************************************************************************
**************************************************************************************************************

/Total:			sum of all 12 ratings
/meanRating:	mean rating 
/minRating:		minimum rating
/maxRating:		maximum rating
/meanRT:		mean latency (in ms) of rating

<expressions>
/Total = list.ratings.mean * 12
/meanRating = list.ratings.mean
/minRating = list.ratings.minimum
/maxRating = list.ratings.maximum
/meanRT = list.latencies.mean
</expressions>

**************************************************************************************************************
**************************************************************************************************************
	STIMULI
**************************************************************************************************************
**************************************************************************************************************

<text scenario>
/ items = scenarios
/ select = sequence
/ size = (80%, 40%)
/ txbgcolor = lightGray
/ vjustify = center
/ position = (50%, 25%)
</text>

<text instructions>
/ items =instructions
/ select = sequence
/ position = (50%, 60%)
/ size = (80%, 10%)
/ fontstyle = ("Arial", 4%, true, false, false, false, 5, 1)
</text>


**************************************************************************************************************
**************************************************************************************************************
	LISTS	
**************************************************************************************************************
**************************************************************************************************************

*************************************************
Data Lists: used for descriptive statistics
store correct latencies/accuracy data
fill up during runtime
*************************************************

Note: list stores the ratings for each scenario
<list ratings>
</list>

Note: list stores the latency of correct responses for each relevant trial
<list latencies>
</list>

**************************************************************************************************************
**************************************************************************************************************
	TRIALS 	
**************************************************************************************************************
**************************************************************************************************************

<likert scenario>
/ ontrialbegin = [
	values.scenario += 1;
]
/ stimulusframes = [1 = scenario, instructions]
/ labels = ("Not at all willing", "", "", "", "", "", "Completely willing")
/ buttonvalues = [1="0"; 2="1"; 3="2"; 4="3"; 5="4"; 6="5"; 7="6"]
/ numpoints = 7
/ position = (50%, 70%)
/ anchorwidth = 12%
/ ontrialend = [
	list.ratings.appendItem(likert.scenario.response);
	list.latencies.appendItem(likert.scenario.latency);
]
</likert>

**************************************************************************************************************
**************************************************************************************************************
	BLOCKS
**************************************************************************************************************
**************************************************************************************************************

<block WTF>
/ trials = [1-12 = scenario]
</block>

**************************************************************************************************************
**************************************************************************************************************
	EXPERIMENT 
**************************************************************************************************************
**************************************************************************************************************

<expt wtf>
/ preinstructions = (intro)

/ blocks = [1 = WTF]
</expt>


**************************************************************************************************************
												End of File
**************************************************************************************************************