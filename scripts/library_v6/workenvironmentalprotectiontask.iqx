////////////////////////////////////////////////////////////////////
navigation buttons
////////////////////////////////////////////////////////////////////

<button submit>
/ caption = "submit"
/ position = (50%, 95%)
/ size = (30%, 8%)
/ erase = false
/ fontStyle = ("Arial", 4%, false, false, false, false, 5, 1)
</button>

<button continue>
/ caption = "continue"
/ position = (50%, 95%)
/ size = (30%, 8%)
/ erase = false
/ fontStyle = ("Arial", 4%, false, false, false, false, 5, 1)
</button>

<button start>
/ caption = "START"
/ position = (50%, 95%)
/ size = (30%, 8%)
/ erase = false
/ fontStyle = ("Arial", 4%, false, false, false, false, 5, 1)
</button>

<button yesButton>
/ caption = "YES"
/ position = (25%, 65%)
/ size = (20%, 8%)
/ erase = false
/ fontStyle = ("Arial", 5%, false, false, false, false, 5, 1)
</button>

<shape yesButtonFrame>
/ shape = rectangle
/ color = black
/ position = (25%, 65%)
/ size = (21%, 9%)
/ erase = false
</shape>

<button noButton>
/ caption = "No"
/ position = (75%, 65%)
/ size = (20%, 8%)
/ erase = false
/ fontStyle = ("Arial", 5%, false, false, false, false, 5, 1)
</button>

<shape noButtonFrame>
/ shape = rectangle
/ color = black
/ position = (75%, 65%)
/ size = (21%, 9%)
/ erase = false
</shape>

<button exit>
/ caption = "exit"
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ position = (50%, 90%)
/ size = (30%, 8%)
</button>

**************************************************************************************************************
intro trial
**************************************************************************************************************

<text intro>
/ items = ("<center><h1>Number Identification Task</h1><hr></center>
On the following page, you will see 20 two digit numbers.<br><br>
Your task will be to identify all those numbers that consist of an <b><i>even</i> first digit</b> and an <b><i>odd</i> second digit</b>.<br><br>
For example, if you see the number '25', you should select it, because the first digit (2) is even and the second digit is odd (5).<br><br>
Press START when you are ready.")
/ position = (50%, 50%)
/ fontStyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ erase = false
</text>

<trial intro>
/ stimulusFrames = [1 = activeCanvas, intro, start]
/ validResponse = (start)
</trial>

<text instructions>
/ items = ("Identify all those stimuli with an even first digit and an odd second digit.
For example, you should click on ‘25’, because the first digit (2) is even and the second digit is odd (5).")
/ position = (50%,5%)
/ fontStyle = ("Arial", 2.5%, false, false, false, false, 5, 1)
/ erase = false
/ size = (100%,11%)
/ vJustify = center
</text>

**************************************************************************************************************
intro trial
**************************************************************************************************************

<text practiceFeedback>
/ onprepare = [
	if (values.feedbackSelection == 1){
		text.practiceFeedback.textColor = red;
	} else {
		text.practiceFeedback.textColor = green;		
	}
]
/ items = ("Red Rings:
missed TARGETS or 
incorrectly selected NON-Targets", "All correct! - Well done!")
/ select = values.feedbackSelection
/ position = (50%, 5%)
/ size = (100%,11%)
/ fontStyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ erase = false
/ vJustify = center
</text>

**************************************************************************************************************
testIntro trial
**************************************************************************************************************

<text testIntro>
/ items = ("In the following, we will ask you if you want to complete additional pages of the number-identification task.<br><br>
For each page that you correctly complete, we will make a donation to <%parameters.charity%>, <%parameters.charityDescription%><br><br>
It is up to you to decide how much time and effort you want to invest in the task.<br><br>
There are a <u>maximum of 15 pages</u> that you can complete. For each page, we will tell you<br>
&bull; <i>how many numbers</i> you will have to check (so that you can estimate the effort) and<br>
&bull; <i>how much money</i> we will donate if you complete the task.<br><br>
You can then decide, for each page separately, if you want to do this additional effort or not.<br>
<center><b>Doing this task is completely voluntary.</b></center>
If you want, you can decline checking the numbers (by selecting 'no') every time and go directly 
to the next part of the study. However, please do not simply close the survey before you have reached the end of it (otherwise we do
not know whom to pay for their participation).<br><br>
Continue on to your first page.")
/ position = (50%, 40%)
/ fontStyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ erase = false
</text>

<trial testIntro>
/ stimulusFrames = [1 = activeCanvas, testIntro, start]
/ validResponse = (start)
</trial>

**************************************************************************************************************
participation decision trial
**************************************************************************************************************

<values>
/ yesSelected = 0
/ noSelected = 0
</values>

<text participationQuestion>
/ items = ("<center><font size=-1>Page <%values.pageCounter%> of <%list.stimNumbers.itemCount%></font><br></center>
<br>The next page will contain <span style='background-color:<%parameters.selectionHighlightColor%>'><%values.pageStims%></span> numbers and 
we will donate <span style='background-color:<%parameters.selectionHighlightColor%>'><%expressions.displayedDonation%></span>
for the protection of the rainforest if you complete this page.<br><br>
If you decide to complete this page, please do so thoroughly because we can only count pages that are at least 90%.<br><br>
We will <b>not</b> give you feedback, so please check whether your answers are correct before proceeding to the next page.<br><br>
<center><h3>Do you want to complete this page?</h3></center>")
/ position = (50%,30%)
/ erase = false
</text>

<trial participationQuestion>
/ skip = [
	return (values.phase != "test"); //should only be asked during the test phase
]
/ onTrialBegin = [
	if (values.yesSelected == 1){
		shape.yesButtonFrame.color = yellow;
	} else {
		shape.yesButtonFrame.color = parameters.canvascolor;
	}
	if (values.noSelected == 1){
		shape.noButtonFrame.color = yellow;
	} else {
		shape.noButtonFrame.color = parameters.canvascolor;
	}	
]
/ stimulusFrames = [1 = activeCanvas, participationQuestion, yesButtonFrame, yesButton, noButtonFrame, noButton, submit]
/ validResponse = (yesButton, noButton, submit)
/ onTrialEnd = [
	if (trial.participationQuestion.response == "yesButton"){
		values.yesSelected = 1;
		values.noSelected = 0;
	} else if (trial.participationQuestion.response == "noButton"){
		values.noSelected = 1;
		values.yesSelected = 0;
	} else if (trial.participationQuestion.response == "submit"){
		if (values.yesSelected){
			values.pageParticipation = 1;
		} else {
			values.pageParticipation = 0;
		}
	}
	values.pageParticipationRt += trial.participationQuestion.latency;
]
/ branch = [
	if (trial.participationQuestion.response != "submit"){
		return trial.participationQuestion;
	} else {
		if (values.yesSelected==0 && values.noSelected ==0){//ensure that either yes or no were selected
			return trial.participationQuestion;
		} else {
			if (monkey.monkeyMode && parameters.debugMode){
				values.pageParticipation = 1;
			}
			if (values.pageParticipation != 1){
				return trial.pageSummary;
			} else {
				return null;
			}
		}
	}
]
</trial>

**************************************************************************************************************
finish trial
**************************************************************************************************************

<text finish>
/ items = ("<%expressions.totalDonationFeedback%>
<center><h1>Thank you!</h1></center>")
/ fontstyle = ("Arial", 4%, false, false, false, false, 5, 1)
/ position = (50%, 50%)
</text>

<expressions>
/ totalDonationFeedback = if (parameters.showTotalDonationAtEnd == true){
	return "<center>Total Donation earned for <%parameters.charity%>: <%expressions.displayedTotalDonation%></center><br><br>";
} else {
	return "";
}
</expressions>

<trial finish>
/ stimulusframes = [1 = activeCanvas, finish]
/ timeout = 1000
/ recorddata = false
</trial>

**************************************************************************************************************
								!!!REMAINING CODE: Customize after careful consideration only!!!
**************************************************************************************************************

**************************************************************************************************************
**************************************************************************************************************
	DEFAULTS
**************************************************************************************************************
**************************************************************************************************************
script requires Inquisit 6.6.1.0 or higher

<defaults>
/ minimumversion = "6.6.1.0"
/ screencolor = parameters.screencolor
/ fontstyle = ("Arial", 3.5%, false, false, false, false, 5, 1)
/ txcolor = parameters.defaultTextColor
/ txbgcolor = parameters.canvascolor
/ canvassize = (expressions.canvasWidth, expressions.canvasHeight)
/ inputdevice = mouse
</defaults>

