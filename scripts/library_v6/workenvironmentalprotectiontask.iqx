]
/ branch = [
	if (trial.page.response != "submit"){
		return trial.page;
	} else {
		return trial.pageSummary;
	}
]
/ recorddata = true//false
</trial>

//used to record a data line for each page after participants submits responses
<trial pageSummary>
/ ontrialbegin = [
	if (values.phase == "test"){
		list.participation.appendItem(values.pageParticipation);
		list.RT.appendItem(values.pageParticipationRt);
		list.propSignals.appendItem(expressions.propSignalsPerPage);
		if (values.pageParticipation){
			values.pageAcc = values.pageCorrect/values.pageStims;
			list.ACC.appendItem(values.pageAcc);		
			if (values.pageAcc >= 0.9){
				values.totalDonation += values.pageDonation;
			}			
		}
	}
]
/ trialduration = 0
/ branch = [
	if (values.phase == "practice"){
		return trial.practiceFeedback;
	} else {
		if (parameters.debugMode && values.pageParticipation == 1){
			return trial.debugFeedback;
		} else {
			return null;
		}
	}
]
</trial>

<trial practiceFeedback>
/ onTrialBegin = [
	values.feedbackSelection = 1;
	if (values.pageCorrect/values.pageStims == 1){
		values.feedbackSelection = 2;
	}
	text.feedbackRing1.skip = text.n1.skip;
	text.feedbackRing2.skip = text.n2.skip;
	text.feedbackRing3.skip = text.n3.skip;
	text.feedbackRing4.skip = text.n4.skip;
