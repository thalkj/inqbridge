<block practice>
/ onBlockBegin = [
	values.phase = "practice";
	values.pageCounter = 0;
]
/ trials = [1 = intro;]
/ branch = [
	return block.pageTest;
]
</block>

<block test>
/ onBlockBegin = [
	values.phase = "test";
	values.pageCounter = 0;
]
/ trials = [1 = testIntro]
/ branch = [
	return block.pageTest;
]
</block>


<block pageTest>
/ onblockbegin = [
	values.pageCounter += 1;
	
	values.yesSelected = 0;
	values.noSelected = 0;
	values.pageCorrect = 0;
	values.pageAcc = 0;
	values.pageHits = 0;
	values.pageFas = 0;
	values.pageSignals = 0;
	values.pageFoils = 0;
	values.pageDuration_inms = 0;
	if (values.phase == "test"){
		values.pageParticipation = 0;
	} else {
		values.pageParticipation = 1; //ensure that for practice the numbers show up
	}

	values.pageParticipationRt = 0;
	
	if (values.phase == "test"){
		values.pageCondition = list.conditions.nextValue;
		values.pageDonation = list.donations.nextValue;
		values.pageStims = list.stimNumbers.nextValue;
	} else {
		values.pageCondition = null;
		values.pageDonation = null;
		values.pageStims = list.stimNumbersPractice.nextValue;	
	}

