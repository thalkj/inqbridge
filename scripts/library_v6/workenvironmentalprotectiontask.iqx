*******************************************************************************************************************
*******************************************************************************************************************
	EXPRESSIONS
*******************************************************************************************************************
*******************************************************************************************************************

<expressions>
/ displayedDonation = if (parameters.unitPlacement == "before"){
	return "<%parameters.montaryUnit%><%expressions.pageDonation%>";
} else {
	return "<%values.pageDonation%><%parameters.montaryUnit%>";
}
/ displayedTotalDonation = if (parameters.unitPlacement == "before"){
	return "<%parameters.montaryUnit%><%expressions.totalDonation%>";
} else {
	return "<%values.totalDonation%><%parameters.montaryUnit%>";
}
/ pageDonation = return format("%.2f", (values.pageDonation*100)/100) //should present 2 decimal digits
/ totalDonation = return format("%.2f", (values.totalDonation*100)/100) //should present 2 decimal digits
</expressions>

//function to generate the experimental design lists appropriate for parameters settings 'numberDonationAmountsToRun' and 'numberStimsToRun'
<expressions>
/ generateIvLists = {
	list.conditions.clearItems();
	list.stimNumbers.clearItems();
	list.donations.clearItems();
	
	var i = 1;
	var numberConditions = parameters.numberDonationAmountsToRun * parameters.numberStimsToRun;
	while (i <= numberConditions){
		list.conditions.appendItem(i);
		i += 1;
	}
	
	i = 1;
	while (i <= parameters.numberStimsToRun){
		if (parameters.numberDonationAmountsToRun >= 1){
			list.donations.appendItem(parameters.donationAmount1);
		}
		if (parameters.numberDonationAmountsToRun >= 2){
			list.donations.appendItem(parameters.donationAmount2);
		}
		if (parameters.numberDonationAmountsToRun >= 3){
			list.donations.appendItem(parameters.donationAmount3);
		}	
		i += 1;
	}
	
	if (parameters.numberStimsToRun >= 1){
		i = 1;
		while (i <= parameters.numberDonationAmountsToRun){
			list.stimNumbers.appendItem(parameters.stimNumbers1);
			i += 1;
		}
	}
	if (parameters.numberStimsToRun >= 2){
		i = 1;
		while (i <= parameters.numberDonationAmountsToRun){
			list.stimNumbers.appendItem(parameters.stimNumbers2);
			i += 1;
		}
	}	
	if (parameters.numberStimsToRun >= 3){
		i = 1;
		while (i <= parameters.numberDonationAmountsToRun){
			list.stimNumbers.appendItem(parameters.stimNumbers3);
			i += 1;
		}
	}
	if (parameters.numberStimsToRun >= 4){
		i = 1;
		while (i <= parameters.numberDonationAmountsToRun){
			list.stimNumbers.appendItem(parameters.stimNumbers4);
			i += 1;
		}
	}
	if (parameters.numberStimsToRun >= 5){
		i = 1;
		while (i <= parameters.numberDonationAmountsToRun){
			list.stimNumbers.appendItem(parameters.stimNumbers5);
			i += 1;
		}
	}
}
</expressions>

<expressions>
/ propSignalsPerPage = values.pageSignals/values.pageStims
/ meanPropSignalsPerPage = list.propSignals.mean
/ propParticipation = return list.participation.mean
/ overallPropCorrect = return list.ACC.mean
/ overallMeanParticipationDecisionRt = return list.RT.mean
</expressions>


//////////////////////////////////////////////////////////////////////////////////
The following expressions are used for canvas scaling
//////////////////////////////////////////////////////////////////////////////////

//functions to calculate screen/canvas areas of the current screen
<expressions>
/ canvasWidth_inmm = 1mm*(parameters.canvasHeight_inmm*4/3)
/ px_per_mm = display.height/display.getmmy(display.height)
/ screenHeight_inmm = display.getmmy(display.height)
/ screenWidth_inmm = display.getmmx(display.width)
/ canvasHeight = if (parameters.runAbsoluteSizes == true && 
	expressions.screenHeight_inmm >= parameters.canvasHeight_inmm &&
	expressions.screenWidth_inmm >= expressions.canvasWidth_inmm){
	1mm * parameters.canvasHeight_inmm;
} else {
	1px * display.height;	
}

/ canvasWidth = if (parameters.runAbsoluteSizes == true && 
	expressions.screenHeight_inmm >= parameters.canvasHeight_inmm &&
	expressions.screenWidth_inmm >= expressions.canvasWidth_inmm){
		1mm * expressions.canvasWidth_inmm;
} else {
		1px * display.height * 4/3;
}
/ activeCanvasHeight = if (parameters.runAbsoluteSizes == true && 
	expressions.screenHeight_inmm >= parameters.canvasHeight_inmm &&
	expressions.screenWidth_inmm >= expressions.canvasWidth_inmm){
		1mm * (parameters.canvasHeight_inmm);
	} else {
		1px * (expressions.canvasHeight)
	}
/ activeCanvasWidth = if (parameters.runAbsoluteSizes == true && 
	expressions.screenHeight_inmm >= parameters.canvasHeight_inmm &&
	expressions.screenWidth_inmm >= expressions.canvasWidth_inmm){
		1mm * (expressions.canvasWidth_inmm);
	} else {
		1px * (expressions.canvasWidth)
	}	
/ canvasAdjustments = {
	if (!parameters.runAbsoluteSizes){
		return "N/A";
	} else if (expressions.screenHeight_inmm >= parameters.canvasHeight_inmm &&
		expressions.screenWidth_inmm >= expressions.canvasWidth_inmm){
		return "0";
	} else {
		return "1";
	}
}

//play area sizes in screen percent and pixels:
/ activeCanvasHeight_inmm = 1mm*display.getmmy(display.canvasHeight)
/ activeCanvasWidth_inmm = 1mm*display.getmmx(display.canvasWidth)
/ activeCanvasHeight_inpct = 100%
/ activeCanvasWidth_inpct = 100%
/ activeCanvasHeight_inpx = 1px*display.getPixelsY(expressions.activeCanvasHeight_inpct)
/ activeCanvasWidth_inpx = 1px*display.getPixelsX(expressions.activeCanvasWidth_inpct)

/ activeCanvas_center_y_inpx = 1px*display.getPixelsY(50%)
/ activeCanvas_center_x_inpx = 1px*display.getPixelsX(50%)

/ leftactiveCanvasBorder_inpx = 1px* (expressions.activeCanvas_center_x_inpx - 0.5*expressions.activeCanvasWidth_inpx)
/ rightactiveCanvasBorder_inpx = 1px* (expressions.activeCanvas_center_x_inpx + 0.5*expressions.activeCanvasWidth_inpx)
/ topactiveCanvasBorder_inpx = 1px* (expressions.activeCanvas_center_y_inpx - 0.5*expressions.activeCanvasHeight_inpx)
/ bottomactiveCanvasBorder_inpx = 1px* (expressions.activeCanvas_center_y_inpx + 0.5*expressions.activeCanvasHeight_inpx)
</expressions>


////////////////////////////////////////////////
picture to distinguish canvas area
////////////////////////////////////////////////

<shape activeCanvas>
/ shape = rectangle
/ width = 100%
/ height = 100%
/ vposition = 50%
/ hposition = 50%
/ color = parameters.canvascolor
/ erase = false
</shape>

