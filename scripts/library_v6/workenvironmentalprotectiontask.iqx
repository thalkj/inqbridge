<text n1>
/ onprepare = [
	if (values.number1Selected == 1){
		text.n1.textBgColor = parameters.selectionHighLightColor;
	} else {
		text.n1.textBgColor = parameters.canvascolor;
	}
]
/ items = ("<%values.number1%>")
/ fontstyle = ("Arial", 3%, false, false, false, false, 5, 1)
/ txcolor = parameters.defaultTextColor
/ erase = false
/ hPosition = 2.5%
/ vPosition = 15%
</text>

