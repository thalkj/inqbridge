/ branch = [
	if (values.phase == "practice"){
		if (values.pageCounter < list.stimNumbersPractice.itemCount){
			return block.pageTest;
		} else {
			return null;
		}
	} else {
		if (values.pageCounter < list.stimNumbers.itemCount){
			return block.pageTest;
		} else {
			return null;
		}
	}
]
