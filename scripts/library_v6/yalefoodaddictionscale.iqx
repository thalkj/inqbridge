		values.q19 = 1;
	}	
	if (radiobuttons.q20.response ==0) {
		values.q20 = 0;
	} else {
		values.q20 = 1;
	}
	if (radiobuttons.q21.response ==0) {
		values.q21 = 0;
	} else {
		values.q21 = 1;
	}	
	if (radiobuttons.q22.response ==0) {
		values.q22 = 0;
	} else {
		values.q22 = 1;
	}
	if (radiobuttons.q24.response ==1) {
		values.q24 = 0;
	} else {
		values.q24 = 1;
	}
	if (radiobuttons.q25.response <= 4) {
		values.q25 = 0;
	} else {
		values.q25 = 1;
	}	
]

