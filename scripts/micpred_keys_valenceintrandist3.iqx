**save data from valuescale (identical trials, but is easier to code afterwards)
<trial savevaluedata>
/ stimulusframes = [1=valueresponse01;2=valueoutcometxtverdi;3=valuepredictiontxtverdi;4= predlatency]
/ response = timeout(0)
/ ontrialend = [values.vpositionAvalueVERT = -10]
/ ontrialend = [values.valuescaleresponsey = -10]  //resets the y-scale of the valuescale
</trial>

<trial savevaluedata2>
/ stimulusframes = [1=valueresponse01;2= valueoutcometxtverdi;3= valuepredictiontxtverdi;4= predlatency]
/ response = timeout(0)
/ ontrialend = [values.vpositionAvalueVERT = -10]
/ ontrialend = [values.valuescaleresponsey = -10]  //resets the y-scale of the valuescale
</trial>

