/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

<dropdown check3b>
/ caption = "Once a year, John is slighlty less productive than usual due to a hangover (drinking alcohol the day before work)"
/ options = ("Totally unacceptable, he should be fired", "Unacceptable", "Slightly unacceptable", "Neutral", "Slightly acceptable", "Acceptable", "Perfectly Acceptable")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

<dropdown check4b>
