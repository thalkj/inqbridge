Keyboard:
<block touchblock>
/ trials = [1=mytrial]
/ ontrialend = [if (computer.haskeyboard == 0) script.abort();]
</block>

<trial mytrial>
/ stimulusframes = [1=mytext]
/ validresponse = (noresponse)
/ timeout = (500)
</trial>

<text mytext>
/ items = ("Touchscreen present: <%computer.touch%>
~nPhysical keyboard detected: <%computer.haskeyboard%>")
/ size = (50%, 40%)
</text>

<expressions>
/ scalemin = 0
/ increment1 = 1
/ increment2 = 5

/ linesize_in_px= (shape.line.width/100 * display.canvaswidth)
/ linestart= (display.canvaswidth-expressions.linesize_in_px) / 2
/ proportionscore = (trial.VisualAnalogueScale.responsex - expressions.linestart) / expressions.linesize_in_px
/ actualscore= round(expressions.proportionscore*values.scalemax)
/ tunepos = expressions.linestart + ((values.lastresponse/values.scalemax)*expressions.linesize_in_px)

/ linesize_in_pxVERT= (shape.lineVERT.height/100 * display.canvasheight)
/ linestartVERT= (display.canvasheight-expressions.linesize_in_pxVERT) / 2
/ tuneposVERT = expressions.linestartVERT + ((values.valuescalelastresponse/values.scalemax)*expressions.linesize_in_pxVERT)
/ valueresponse01 = 1-(values.valuescalelastresponse/values.scalemax)

/ proportionscorevalue = (values.valuescaleresponsey - expressions.linestartVERT) / expressions.linesize_in_pxVERT
/ actualscorevalue= round(expressions.proportionscorevalue*values.scalemax)
/ actualscorevalue3= round(expressions.proportionscorevalue*values.scalemax)
/ actualscorevalue4= round(expressions.proportionscorevalue*values.scalemax)

/ modifiedma=values.MMA*0.90+values.lastlatency*0.10
/ incrementalvariance=values.IncVar*0.90+(0.10*(values.lastlatency-values.MMA))^2
/ nrpassedcheck= values.pass1+values.pass2+values.pass3+values.pass4
/ stricktnrpassedcheck= values.stricktpass1+values.stricktpass2+values.stricktpass3+values.stricktpass4
</expressions>


**Values that are set and changed during the trials
<values>
/ scalemax =2500
/ IncVar=40000
/ MMA = 300
/valuescalelastresponse=0
/ lastresponse = 0
/ hpositionAvalue = (-10)
/ vpositionAvalueVERT = (-10)
/ predtimer = 0
/errorcount=0
/tidsbruk=0
/trialcounter=0
/totaltid=0
/totaltid10=0
/lastlatency=0
/lastcorrect=0
/failedpract=0
/randnumber=0
/numberofmouseadjust=0
/numberofbuttonadjust=0
/valueoutcome=0
/valueprediction=0
/overunder=0
/fakecorrect=0
/currentexptelapsedtime=0
/stimulus=""
/lastresponsefixed=0
/check1=0
/check2=0
/check3=0
/check4=0
/pass1=0
/pass2=0
/pass3=0
/pass4=0
/pass5=0
/stricktpass1=0
/stricktpass2=0
/stricktpass3=0
/stricktpass4=0
/valuescaleresponsey=0
/valueScale3fakescore=0
/easyprobvalue=1
/difficultprobvalue=0
</values>


<defaults>
