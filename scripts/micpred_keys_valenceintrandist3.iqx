****PREDICTION TASK
*** Trials***
<trial startpredtimer>
/ ontrialbegin = [values.valuescalelastresponse=-20]

/ ontrialbegin = [values.lastresponse = 0]
/ ontrialbegin = [values.lastresponsefixed = -20]
/ ontrialbegin = [values.hpositionAvalue = -10]
/ ontrialbegin = [values.numberofmouseadjust = 0]
/ ontrialbegin = [values.numberofbuttonadjust = 0]
/ response = timeout(0)
</trial>


stop and start timer is moved to the visual analogue trial!

<trial VisualAnalogueScale>
/ ontrialbegin = [if (values.numberofbuttonadjust == 0 && values.numberofmouseadjust== 0) values.predtimer=script.elapsedtime]
/ stimulusframes = [1=Predtext2, question1, continuetxt, lastresponsevalue, line, X,
lefttune, righttune, lefttune2, righttune2, leftanchormin, rightanchormax]
/ inputdevice = mouse
/ validresponse = (line, continuetxt, lefttune, righttune, lefttune2, righttune2)
/ correctresponse= (continuetxt)
/ branch = [if (trial.VisualAnalogueScale.correct==0) trial.VisualAnalogueScale]
/ ontrialend = [if (trial.VisualAnalogueScale.response=="righttune") values.lastresponse=values.lastresponse+expressions.increment1]
/ ontrialend = [if (trial.VisualAnalogueScale.response=="lefttune") values.lastresponse=values.lastresponse-expressions.increment1]
/ ontrialend = [if (trial.VisualAnalogueScale.response=="righttune2") values.lastresponse=values.lastresponse+expressions.increment2]
/ ontrialend = [if (trial.VisualAnalogueScale.response=="lefttune2") values.lastresponse=values.lastresponse-expressions.increment2]
/ ontrialend = [if (trial.VisualAnalogueScale.response=="line") values.lastresponse=expressions.actualscore]
/ ontrialend = [if (trial.VisualAnalogueScale.correct==0) values.hpositionAvalue=expressions.tunepos]
/ ontrialend = [if (trial.VisualAnalogueScale.correct==0 && trial.VisualAnalogueScale.response=="line") values.numberofmouseadjust=values.numberofmouseadjust+1]
/ ontrialend = [if (trial.VisualAnalogueScale.correct==0 && trial.VisualAnalogueScale.response!="line") values.numberofbuttonadjust=values.numberofbuttonadjust+1]
/ ontrialend = [if (trial.VisualAnalogueScale.correct==1) values.predtimer= script.elapsedtime-values.predtimer]
</trial>



branch = [if (trial.VisualAnalogueScale.correct==1) trial.recordlastresponse]
trial recordlastresponse>
/ stimulusframes = [1=roundedvaluetxt]
/ timeout=1
</trial>

text roundedvaluetxt>
/ items = ("<%values.lastresponse%>")
</text>

