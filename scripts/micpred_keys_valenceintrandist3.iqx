/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>


*****SKEWED COND:
<expt skewedtestexpt>
/subjects = (1 of 2)
/ blocks = [
1=touchblock, alder, setprobblock, skewedpractletter, skewedpractpred;
2=write2slide, setmax;
3=skewedtestblokk1;
4=skewedtestblokk2;
5= skewedtestblokk3, attentioncheck;
6,7= skewedtestblokk4Vanlig;
8-15=skewedtestblokk4Value;
16=skewedtestblokk5Valuefake;
17-19= skewedtestblokk4Value;
20=skewedtestblokk5Valuefake;
21-23=skewedtestblokk4Value;
24=textboxlast]
</expt>


<expt skewedtestexptErrorCond>
/subjects = (2 of 2)
/ blocks = [
1=touchblock, alder, setprobblock, skewedpractletterErrorCond, skewedpractpredErrorCond;
2=write2slideErrorCond, setmax;
3=skewedtestblokk1ErrorCond;
4=skewedtestblokk2ErrorCond;
5= skewedtestblokk3ErrorCond, attentioncheckErrorCond;
6,7= skewedtestblokk4VanligErrorCond;
8-15=skewedtestblokk4ValueErrorCond;
16=skewedtestblokk5ValueErrorCondfake;
17-19= skewedtestblokk4ValueErrorCond;
20=skewedtestblokk5ValueErrorCondfake;
21-23=skewedtestblokk4ValueErrorCond;
24=textboxlast
]
</expt>

