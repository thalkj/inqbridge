**********************************************************************************************************
<block attentioncheck>
/trials=[1=attentioncheck0, attentioncheck1; 2= attentioncheck2]
/ postinstructions = (lastset)
</block>

<block attentioncheckErrorCond>
/trials=[1=attentioncheck0, attentioncheck1; 2= attentioncheck2]
/ postinstructions = (lastsetErrorCond)
</block>

<trial checkattcheck>
/ stimulusframes = [1=checkattcheck]
/ response = timeout(2000)
</trial>

<text checkattcheck>
/ items = ("antall riktig: <%expressions.nrpassedcheck%><%expressions.stricktnrpassedcheck%><%values.pass5%>")
/ color = darkblue
/ position = (50%, 50%)
</text>



<surveypage attentioncheck0>
/ showbackbutton = false
/ showpagenumbers = false
/ showquestionnumbers = false
/ questions = [1=attchkcaption]
/ ontrialend = [values.check1=0]
/ ontrialend = [values.check2=0]
/ ontrialend = [values.check3=0]
/ ontrialend = [values.check4=0]
</surveypage>

<caption attchkcaption>
/ caption = "Please answer a few questions about work-related attitudes."
/ subcaption = "These questions are included to test items that will be used in a different project on attitudes."
</caption>


<surveypage attentioncheck1>
/ showbackbutton = false
/ showpagenumbers = false
/ showquestionnumbers = false
/ subcaption = "To what extent do you consider the below situations as problematic/unacceptable versus unproblematic/acceptable?"
/ questions = [1=check1;2=check2;3=check3;4=check4]
/ ontrialend = [values.check1=dropdown.check1.response]
/ ontrialend = [values.check2=dropdown.check2.response]
/ ontrialend = [values.check3=dropdown.check3.response]
/ ontrialend = [values.check4=dropdown.check4.response]
</surveypage>

<surveypage attentioncheck2>
/ showbackbutton = false
/ showpagenumbers = false
/ showquestionnumbers = false
/ caption = ""
/ subcaption = "To what extent do you consider the below situations as problematic/unacceptable versus unproblematic/acceptable?"
/ questions = [1=check2b;2=check1b;3=check5b;4=check4b;4=check3b]
/ ontrialend = [if (dropdown.check1b.response>=values.check1) values.pass1=1] // Once a year more acceptable than 3-4 days a month 
/ ontrialend = [if (dropdown.check2b.response<=values.check2) values.pass2=1]  // two or three times a month less acceptable than once or twice a year
/ ontrialend = [if (dropdown.check3b.response>=values.check3) values.pass3=1]  //once a year more accpetable than once a month
/ ontrialend = [if (dropdown.check4b.response<=values.check4) values.pass4=1]  //twice a week less acceptable than once a week
/ ontrialend = [if (dropdown.check1b.response>values.check1) values.stricktpass1=1] // Once a year more acceptable than 3-4 days a month 
/ ontrialend = [if (dropdown.check2b.response<values.check2) values.stricktpass2=1]  // two or three times a month less acceptable than once or twice a year
/ ontrialend = [if (dropdown.check3b.response>values.check3) values.stricktpass3=1]  //once a year more accpetable than once a month
/ ontrialend = [if (dropdown.check4b.response<values.check4) values.stricktpass4=1]  //twice a week less acceptable than once a week
/ ontrialend = [values.pass5=dropdown.check5b.response]  
</surveypage>

***
<dropdown check1>
/ caption = "Once or twice a month, John is 20 minutes late for his work"
/ options = ("Totally unacceptable, he should be fired", "Unacceptable", "Slightly unacceptable", "Neutral", "Slightly acceptable", "Acceptable", "Perfectly Acceptable")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

<dropdown check2>
/ caption = "Once or twice a year, John calls in sick when he is tired and needs a day off"
/ options = ("Totally unacceptable, he should be fired", "Unacceptable", "Slightly unacceptable", "Neutral", "Slightly acceptable", "Acceptable", "Perfectly Acceptable")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

<dropdown check3>
/ caption = "Once or twice a month, John is somewhat unproductive due to a hangover (drinking alcohol the day before work)"
/ options = ("Totally unacceptable, he should be fired", "Unacceptable", "Slightly unacceptable", "Neutral", "Slightly acceptable", "Acceptable", "Perfectly Acceptable")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

<dropdown check4>
/ caption = "Once a week, John spends about 15 minutes doing his laundry during his regular work hours while working remotely from home"
/ options = ("Totally unacceptable, he should be fired", "Unacceptable", "Slightly unacceptable", "Neutral", "Slightly acceptable", "Acceptable", "Perfectly Acceptable")
/ optionvalues = ("1", "2", "3", "4", "5", "6", "7")
/ required = true
</dropdown>

