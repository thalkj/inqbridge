/response = free
/validresponse = (" ")
</trial>



<trial klarferdig>
/validresponse = (" ")
/stimulusframes = [1=erasescreen,instruktb, instrukt2b]
/response = free
/ recorddata = false
</trial>

<trial klarferdigpred>
/validresponse = (" ")
/stimulusframes = [1=erasescreen,instruktb, instrukt2b]
/response = free
/ recorddata = false
</trial>

************* EGENTLIGE TRYKKE LETTER TRIALS:
DEL 1: practice
<trial skewedletterpract>
/ validresponse = (anyresponse)
/ correctresponse = (text.skewedletterspractice.currentitem)
/ response = correct
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=skewedletterspractice]
/ ontrialend = [if (trial.skewedletterpract.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency= trial.skewedletterpract.latency]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.IncVar=expressions.incrementalvariance]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.MMA=expressions.modifiedma]
</trial>

DEL 2: skrive
<trial skewedletterskriveeasy>
/ validresponse = (anyresponse)
/ correctresponse = (text.easyletters.currentitem)
/ response = correct
/ stimulustimes = [1 = fixation, prevest; 1234 =blank; 1518=easyletters]
/ ontrialend = [if (trial.skewedletterskriveeasy.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterskriveeasy.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterskriveeasy.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[trial.lettertidsbruktestskrive]
</trial>

<trial skewedletterskrivedifficult>
/ validresponse = (anyresponse)
/ correctresponse = (text.difficultletters.currentitem)
/ response = correct
/ stimulustimes = [1 = fixation, prevest; 1234 =blank; 1518=difficultletters]
/ ontrialend = [if (trial.skewedletterskrivedifficult.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterskrivedifficult.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterskrivedifficult.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[trial.lettertidsbruktestskrive]
</trial>

**SElect between easy and difficult:
<list skrivetriallist>
/ items = (trial.skewedletterskriveeasy, trial.skewedletterskrivedifficult)
/ itemprobabilities = [values.easyprobvalue; values.difficultprobvalue]
/ poolsize = 100
/ resetinterval = 0
</list>


DEL 3: responsskala
<trial skewedlettereasy>
/ validresponse = (anyresponse)
/ correctresponse = (text.easyletters.currentitem)
/ response = correct
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=easyletters]
/ ontrialend = [if (trial.skewedlettereasy.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedlettereasy.latency]
/ ontrialend = [values.lastcorrect= trial.skewedlettereasy.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[trial.lettertidsbruktest]
</trial>

<trial skewedletterdifficult>
/ validresponse = (anyresponse)
/ correctresponse = (text.difficultletters.currentitem)
/ response = correct
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=difficultletters]
/ ontrialend = [if (trial.skewedletterdifficult.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterdifficult.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterdifficult.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[trial.lettertidsbruktest]
</trial>

<list triallist>
/ items = (trial.skewedlettereasy, trial.skewedletterdifficult)
/ itemprobabilities = [values.easyprobvalue; values.difficultprobvalue]
/ poolsize = 100
/ resetinterval = 0
</list>


***ERRORCONDTRIALS:
DEL 1: practice ERRORCOMD
<trial skewedletterpractErrorCond>
/ validresponse = (anyresponse)
/ correctresponse = (text.skewedletterspractice.currentitem)
/ response = correct
/ errormessage = true(wrong,200)
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=skewedletterspractice]
/ ontrialend = [if (trial.skewedletterpractErrorCond.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency= trial.skewedletterpractErrorCond.latency]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.IncVar=expressions.incrementalvariance]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.MMA=expressions.modifiedma]
</trial>

Del 2 skrive ERRORCOND
<trial skewedletterskriveErrorCondeasy>
/ validresponse = (anyresponse)
/ correctresponse = (text.easyletters.currentitem)
/ response = correct
/ errormessage = true(wrong,200)
/ stimulustimes = [1 = fixation, prevest; 1234 =blank; 1518=easyletters]
/ ontrialend = [if (trial.skewedletterskriveErrorCondeasy.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterskriveErrorCondeasy.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterskriveErrorCondeasy.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[if (trial.skewedletterskriveErrorCondeasy.correct==1) trial.lettertidsbruktestskrive]
/ branch=[if (trial.skewedletterskriveErrorCondeasy.correct==0) trial.lettertidsbruktestskriveErrorCondWrong]
</trial>

<trial skewedletterskriveErrorConddifficult>
/ validresponse = (anyresponse)
/ correctresponse = (text.difficultletters.currentitem)
/ response = correct
/ errormessage = true(wrong,200)
/ stimulustimes = [1 = fixation, prevest; 1234 =blank; 1518=difficultletters]
/ ontrialend = [if (trial.skewedletterskriveErrorConddifficult.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterskriveErrorConddifficult.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterskriveErrorConddifficult.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[if (trial.skewedletterskriveErrorConddifficult.correct==1) trial.lettertidsbruktestskrive]
/ branch=[if (trial.skewedletterskriveErrorConddifficult.correct==0) trial.lettertidsbruktestskriveErrorCondWrong]
</trial>

**SElect between easy and difficult skrive ErrorCond
<list skrivetriallistErrorCond>
/ items = (trial.skewedletterskriveErrorCondeasy, trial.skewedletterskriveErrorConddifficult)
/ itemprobabilities = [values.easyprobvalue; values.difficultprobvalue]
/ poolsize = 100
/ resetinterval = 0
</list>


DEL 3. Skala skewedcond
<trial skewedletterErrorCondeasy>
/ validresponse = (anyresponse)
/ correctresponse = (text.easyletters.currentitem)
/ response = correct
/ errormessage = true(wrong,200)
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=easyletters]
/ ontrialend = [if (trial.skewedletterErrorCondeasy.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterErrorCondeasy.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterErrorCondeasy.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[if (trial.skewedletterErrorCondeasy.correct==1) trial.lettertidsbruktest]
/ branch=[if (trial.skewedletterErrorCondeasy.correct==0) trial.lettertidsbruktestErrorCondWrong]
</trial>

<trial skewedletterErrorConddifficult>
/ validresponse = (anyresponse)
/ correctresponse = (text.difficultletters.currentitem)
/ response = correct
/ errormessage = true(wrong,200)
/ stimulustimes = [1 = fixation; 1234 =blank; 1518=difficultletters]
/ ontrialend = [if (trial.skewedletterErrorConddifficult.correct==0) values.errorcount = (values.errorcount+1)]
/ ontrialend = [values.lastlatency=trial.skewedletterErrorConddifficult.latency]
/ ontrialend = [values.lastcorrect= trial.skewedletterErrorConddifficult.correct]
/ ontrialend = [values.lastresponsefixed=values.lastresponse]
/ branch=[if (trial.skewedletterErrorConddifficult.correct==1) trial.lettertidsbruktest]
/ branch=[if (trial.skewedletterErrorConddifficult.correct==0) trial.lettertidsbruktestErrorCondWrong]
</trial>

<list triallistErrorCond>
/ items = (trial.skewedletterErrorCondeasy, trial.skewedletterErrorConddifficult)
/ itemprobabilities = [values.easyprobvalue; values.difficultprobvalue]
/ poolsize = 100
/ resetinterval = 0
</list>


<text wrong>
/ items = ("Wrong key, please press the correct key")
/ position = (50%, 55%)
/ color = red
</text>

******NYE FEEDBACK.    skriveestfeedback + skriveest når feil! Genrell feedback + feedback feil, 
**Feil er meir relevant i reactive task! Particularly causion, because errors are easy.

Del 2: FEEDBACK NÅR  RIKTIG OG ALLTID I NORMAL SKEWED BETINGELSE:
<trial lettertidsbruktestskrive>
/stimulustimes= [1=reactionfeedback, dittestimat]
/response = timeout(3000)
/validresponse = (noresponse)
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.IncVar=expressions.incrementalvariance]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.MMA=expressions.modifiedma]
/ branch = [trial.savedata]
</trial>

Del 2:  FEEDBACK NÅR skrive OG FEIL i errorcond
<trial lettertidsbruktestskriveErrorCondWrong>
/stimulustimes= [1=letterfeedbacktestskriveErrorCondWrong]
/response = timeout(3000)
/validresponse = (noresponse)
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.IncVar=expressions.incrementalvariance]
/ ontrialend = [if (values.lastlatency<7000 && values.lastlatency>40) values.MMA=expressions.modifiedma]
/ branch = [trial.savedata]
</trial>


Del 3 ****FEEBACK NÅR RESPONSESCALE alltid i normal bet og riktig i errorcond:
<trial lettertidsbruktest>
/stimulustimes= [1=reactionfeedback, dittestimat]
/response = timeout(2800)
/validresponse = (noresponse)
/ branch = [trial.savedata]
</trial>

Del 3 FEEDBACK NÅR RESPONSESCALE OG FEIL i errorcond
<trial lettertidsbruktestErrorCondWrong>
/stimulustimes= [1=letterfeedbacktestErrorCondWrong]
/response = timeout(2800)
/validresponse = (noresponse)
/ branch = [trial.savedata]
</trial>


