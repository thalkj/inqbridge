<trial ValueScale3fake>
/ ontrialbegin = [if (values.numberofmouseadjust==0) values.predtimer=script.elapsedtime]
/ stimulusframes = [1=bildeein, bildeto, bildetre, continuetxtVERT, lineVERT, XVERT,
valuepredictionoutcometxtestimatefake, valuepredictionoutcometxt2, valuepredictionoutcometxt3, feelingtxt3fake]
/ inputdevice = mouse
/ validresponse = (lineVERT, continuetxtVERT)
/ correctresponse= (continuetxtVERT)
/ontrialend = [values.valuescaleresponsey=trial.ValueScale3fake.responsey]
/ ontrialend = [if (trial.ValueScale3fake.response=="lineVERT") values.valuescalelastresponse=expressions.actualscorevalue]
/ ontrialend = [if (expressions.valueresponse01<0.2) values.valueScale3fakescore=values.valueScale3fakescore+1]
/ ontrialend = [values.valueoutcome=values.lastresponsefixed]
/ ontrialend = [values.valueprediction=values.lastlatency]
/ ontrialend = [if (trial.ValueScale3fake.correct==0) values.predtimer= script.elapsedtime-values.predtimer]
/ branch =[trial.savevaluedata3fake]
</trial>



**stimulus to ValueScale:
<shape lineVERT>
/ shape = rectangle
/ color	=black
/ size = (2%, 80%)
/ position = (75, 50)
/ erase = false
</shape>

<text XVERT>
/ fontstyle = ("Arial", 9%, false, false, false, false, 5, 0)
/ items = ("--")
/ txcolor = (0, 0, 255)
/ txbgcolor = (transparent)
/ hposition = shape.lineVERT.hposition
/ vposition = values.vpositionAvalueVERT
</text>

<text continuetxtVERT>
/ items= (" Continue ")
/ fontstyle = ("MS Shell Dlg 2", 2.81%, false, false, false, false, 5, 1)
/ position = (90, 50)
/ txbgcolor = lightgrey
</text>

<text valuepredictionoutcometxt>
/ items = ("How satisfied are you with the above result? ~nPlease indicate by using the scale on the line from very dissatisfied (sad face) to very satisfied (happy face). Click continue when you are done.")
/ size = (40%,30%)
/ position = (50%, 85%)
</text>



<text valuepredictionoutcometxt2>
/items = ("Estimate: <%values.lastresponsefixed%> ms")
/position = (50, 55)
/ fontstyle = ("Times New Roman", 5.5%, false, false, false, false, 5, 1)
/ txcolor = (0, 210, 0)
</text>

<text valuepredictionoutcometxt3>
/ items = ("Reaction time: <%values.lastlatency%> ms")
/ position = (50, 48)
/ fontstyle = ("Times New Roman", 5.5%, false, false, false, false, 5, 1)
/ txcolor = (0, 255, 0)
</text>

