//EXPERIENCE ONLY:
<trial revealtrial>
    / ontrialbegin = [values.randomvalue=expressions.randomvalue; values.actoutcome = expressions.outcomebin_current;
	if (values.modeANDcondition == 2) {values.actplacebooutcome = values.actoutcome;};
	values.finalshownvalue = expressions.finalshownvalue_current;]
