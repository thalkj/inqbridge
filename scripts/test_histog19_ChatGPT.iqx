*LEVEL1: EXPT
**LEVEL2: Demography, learning histogram, knowledge test of learninghistogram, learning prediction scale, learning_aboutrating_highgranu/_lowgranu, experience/experienceWhisto/placeboexperience, evaluationscale 
**LEVEL2_instructions:
***Level3: trials within blocks
____________________________________________Instruction EXPT-level
<page intro1>
Welcome to this experiment on ratings, predictions and estimation. Any questions about the study can be directed at torleif@simula.no 
^^The tasks can be experienced as highly repetitive, so you need to do you best paying attention.
</page>


//*********************************************************************
//****SETTINGS AND TECHINICAL STUFF *********************************
//********************************************************************

//Instruction (page) settings
<instruct>   
/ nextkey = (" ")
/ prevkey = (noresponse)
/ nextlabel = "Press spacebar to continue"
/ finishlabel = "Press spacebar to continue"
/ fontstyle = ("Times New Roman", 3.43%, false, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
/ windowsize = (70%, 70%)
</instruct>

//Values AND EXPRESSIONS: Variables to Store Data **
<values>
    /posskew=1     //expereimetnal condition, positive skew=1, negative=0, set by the blocks 
	/ modeANDcondition = 0 //set to 0 = learning, 1=experience, 2= placeboexperience; 3= experience with histogram
	/ showfine = 0 //0=show coarse bin value, 1= show fine (1000 or 600)
    / finalshownvalue = -99
	/ actoutcome = -99
    / actplacebooutcome = -99
	/ randomvalue = -99
	/ count0 = 0
	/ count1 = 0
	/ count2 = 0
	/ count3 = 0
	/ count4 = 0
	/ count5 = 0
	/ count6 = 0
	/ count7 = 0
	/ count8 = 0
	/ count9 = 0
	/ count10 = 0
	/ totaloutcome = 1
	/ histogincrement = 1.5
	/ binsize = 2.9
	/totalprob=0
	/ totalprobA=0  //are these used?
	/ totalprobB=0
	/ currentprediction=-99
	/ bintargetvalue=15 
	/ actoutcome1000 = -99
	/ actoutcome1000placebo = -99

//HERE AND BELOW ARE VALUES FOR THE VISUAL ANALOGUE SCALE     
/ activetasknr=1
/ scalemax =10000       
/ lastresponse = 0
/ hpositionAvalue = (-10)
/ predtimer = 0
/trialcounter=0
/totaltid=0
/totaltid10=0
/numberofmouseadjust=0
/numberofbuttonadjust=0
/valueoutcome=0
/valueprediction=0
/overunder=0
/fakecorrect=0
/currentexptelapsedtime=0
/randnumbersubmitcode=0
/responsexscore=0 //to record the horizontal response. used in expressions
/scalemaxdisplayed=10  //HERE YOU CAN CHANGE THE MAXIMUM OF THE SCALE THAT IS DISPLAYED
/displayvalue=""
/correcthistanswers=0 //Knoweldge test
</values>

<expressions>
    // Calculate cumulative probabilities in thousands for learning
    / cumulativeprobabilitiesL1 = list.probabilitieslearning.1 * 1000
    / cumulativeprobabilitiesL2 = (list.probabilitieslearning.1 + list.probabilitieslearning.2) * 1000
    / cumulativeprobabilitiesL3 = (list.probabilitieslearning.1 + list.probabilitieslearning.2 + list.probabilitieslearning.3) * 1000
    / cumulativeprobabilitiesL4 = (list.probabilitieslearning.1 + list.probabilitieslearning.2 + list.probabilitieslearning.3 + list.probabilitieslearning.4) * 1000
    / cumulativeprobabilitiesL5 = (list.probabilitieslearning.1 + list.probabilitieslearning.2 + list.probabilitieslearning.3 + list.probabilitieslearning.4 + list.probabilitieslearning.5) * 1000
    / cumulativeprobabilitiesL6 = (list.probabilitieslearning.1 + list.probabilitieslearning.2 + list.probabilitieslearning.3 + list.probabilitieslearning.4 + list.probabilitieslearning.5 + list.probabilitieslearning.6) * 1000
    // Calculate cumulative probabilities in thousands for PLACEBOEXPERIENCE (similar to learning)
    / cumulativeprobabilitiesPlacebo1 = list.probabilitiesplacebo.1 * 1000
    / cumulativeprobabilitiesPlacebo2 = (list.probabilitiesplacebo.1 + list.probabilitiesplacebo.2) * 1000
    / cumulativeprobabilitiesPlacebo3 = (list.probabilitiesplacebo.1 + list.probabilitiesplacebo.2 + list.probabilitiesplacebo.3) * 1000
    / cumulativeprobabilitiesPlacebo4 = (list.probabilitiesplacebo.1 + list.probabilitiesplacebo.2 + list.probabilitiesplacebo.3 + list.probabilitiesplacebo.4) * 1000
    / cumulativeprobabilitiesPlacebo5 = (list.probabilitiesplacebo.1 + list.probabilitiesplacebo.2 + list.probabilitiesplacebo.3 + list.probabilitiesplacebo.4 + list.probabilitiesplacebo.5) * 1000
    / cumulativeprobabilitiesPlacebo6 = (list.probabilitiesplacebo.1 + list.probabilitiesplacebo.2 + list.probabilitiesplacebo.3 + list.probabilitiesplacebo.4 + list.probabilitiesplacebo.5 + list.probabilitiesplacebo.6) * 1000

    // Calculate cumulative probabilities in thousands for positive skew
    / cumulativeprobabilitiesA1 = list.probabilitiesA.1 * 1000
    / cumulativeprobabilitiesA2 = (list.probabilitiesA.1 + list.probabilitiesA.2) * 1000
    / cumulativeprobabilitiesA3 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3) * 1000
    / cumulativeprobabilitiesA4 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4) * 1000
    / cumulativeprobabilitiesA5 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5) * 1000
    / cumulativeprobabilitiesA6 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6) * 1000
    / cumulativeprobabilitiesA7 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6 + list.probabilitiesA.7) * 1000
    / cumulativeprobabilitiesA8 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6 + list.probabilitiesA.7 + list.probabilitiesA.8) * 1000
    / cumulativeprobabilitiesA9 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6 + list.probabilitiesA.7 + list.probabilitiesA.8 + list.probabilitiesA.9) * 1000
    / cumulativeprobabilitiesA10 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6 + list.probabilitiesA.7 + list.probabilitiesA.8 + list.probabilitiesA.9 + list.probabilitiesA.10) * 1000
    / cumulativeprobabilitiesA11 = (list.probabilitiesA.1 + list.probabilitiesA.2 + list.probabilitiesA.3 + list.probabilitiesA.4 + list.probabilitiesA.5 + list.probabilitiesA.6 + list.probabilitiesA.7 + list.probabilitiesA.8 + list.probabilitiesA.9 + list.probabilitiesA.10 + list.probabilitiesA.11) * 1000
    // Calculate cumulative probabilities in thousands for negative skew
    / cumulativeprobabilitiesB1 = list.probabilitiesB.1 * 1000
    / cumulativeprobabilitiesB2 = (list.probabilitiesB.1 + list.probabilitiesB.2) * 1000
    / cumulativeprobabilitiesB3 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3) * 1000
    / cumulativeprobabilitiesB4 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4) * 1000
    / cumulativeprobabilitiesB5 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5) * 1000
    / cumulativeprobabilitiesB6 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6) * 1000
    / cumulativeprobabilitiesB7 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6 + list.probabilitiesB.7) * 1000
    / cumulativeprobabilitiesB8 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6 + list.probabilitiesB.7 + list.probabilitiesB.8) * 1000
    / cumulativeprobabilitiesB9 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6 + list.probabilitiesB.7 + list.probabilitiesB.8 + list.probabilitiesB.9) * 1000
    / cumulativeprobabilitiesB10 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6 + list.probabilitiesB.7 + list.probabilitiesB.8 + list.probabilitiesB.9 + list.probabilitiesB.10) * 1000
    / cumulativeprobabilitiesB11 = (list.probabilitiesB.1 + list.probabilitiesB.2 + list.probabilitiesB.3 + list.probabilitiesB.4 + list.probabilitiesB.5 + list.probabilitiesB.6 + list.probabilitiesB.7 + list.probabilitiesB.8 + list.probabilitiesB.9 + list.probabilitiesB.10 + list.probabilitiesB.11) * 1000
    // Random value generation
    / randomvalue = rand(0, 1000)  //in thousasnds
    // Assign outcome value based on random draw and cumulative probabilities
    / outcomevaluelearning = 
        if (values.randomvalue <= expressions.cumulativeprobabilitiesL1) list.outcomeslearning.1
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesL2) list.outcomeslearning.2
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesL3) list.outcomeslearning.3
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesL4) list.outcomeslearning.4
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesL5) list.outcomeslearning.5
        else list.outcomeslearning.6
		/ outcomevalueplacebo = 
        if (values.randomvalue <= expressions.cumulativeprobabilitiesPlacebo1) list.outcomeslearning.1  //USE SAME LIST AS LEARNING (it is the same scale I believe...for now)
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesPlacebo2) list.outcomeslearning.2
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesPlacebo3) list.outcomeslearning.3
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesPlacebo4) list.outcomeslearning.4
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesPlacebo5) list.outcomeslearning.5
        else list.outcomes.6
		/ outcomevalueA = 
        if (values.randomvalue <= expressions.cumulativeprobabilitiesA1) list.outcomes.1
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA2) list.outcomes.2
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA3) list.outcomes.3
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA4) list.outcomes.4
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA5) list.outcomes.5
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA6) list.outcomes.6
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA7) list.outcomes.7
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA8) list.outcomes.8
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA9) list.outcomes.9
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesA10) list.outcomes.10
        else list.outcomes.11
	/ outcomevalueB = 
        if (values.randomvalue <= expressions.cumulativeprobabilitiesB1) list.outcomes.1
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB2) list.outcomes.2
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB3) list.outcomes.3
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB4) list.outcomes.4
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB5) list.outcomes.5
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB6) list.outcomes.6
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB7) list.outcomes.7
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB8) list.outcomes.8
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB9) list.outcomes.9
        else if (values.randomvalue <= expressions.cumulativeprobabilitiesB10) list.outcomes.10
        else list.outcomes.11
/animationtargetbin = list.histogramlabpos.item(values.actoutcome + 1) //e.g., if actual outcome is 0 it is indexed 1 and the targetbin should be 1 (for outcome 0)	
//NOTE:USING THE SAME histogramlabpos but only the lower numbers in the list for placebo and learning, and the entire list for experience conditions
	/ scalemin = 0        //HERE AND BELOW ARE EXPRESSIONS FOR THE VISUAL ANALOGUE RESPONSE SCALE
/ increment1 = 1
/ increment2 = 2
/ increment3 = 5
/ linesize_in_px = ((shape.line.width) / 100 * display.canvasWidth)
/ linestart= (display.canvaswidth-expressions.linesize_in_px) / 2
/ proportionscore = (values.responsexscore - expressions.linestart) / expressions.linesize_in_px
/ actualscore= round(expressions.proportionscore*values.scalemax)
/ tunepos = expressions.linestart + ((values.lastresponse/values.scalemax)*expressions.linesize_in_px)
// displaydivisor = values.scalemax / values.scalemaxdisplayed
// lastresponsedisplayed = round(values.lastresponse / expressions.displaydivisor)
/ lastresponsedisplayed=round(values.lastresponse/1000) //This may be just used in the visual analogue? or saved as well?
/ fineoutcome1000 =
    if (values.actoutcome == 0) round(rand(1, 50))
    else if (values.actoutcome == 10) round(rand(951, 1000))
    else round(rand(values.actoutcome * 100 - 49, values.actoutcome * 100 + 50))  //note that I draw another value to get 1000 granularity I dont use the original draw from 1000 which is only used to allocate probabilities
/ fineoutcome600placebo =
    if (values.actplacebooutcome == 0) round(rand(1, 100))
    else if (values.actplacebooutcome == 5) round(rand(500, 600))
    else round(rand(values.actplacebooutcome * 100 + 1, (values.actplacebooutcome + 1) * 100))  //note that I draw another value to get higher granularity I dont use the original draw from 1000 which is only used to allocate probabilities

/ outcomebin_current =    //which distribution. Note: modeANDcondition 0 = learning, 1=experience, 2= placeboexperience; 3= experience with histogram
	if (values.modeANDcondition == 0) expressions.outcomevaluelearning 
    else if (values.modeANDcondition == 2) expressions.outcomevalueplacebo
    else if (values.posskew == 1) expressions.outcomevalueA
    else expressions.outcomevalueB

/ finalshownvalue_current =   //which value granularity
    if (values.showfine == 0) values.actoutcome
    else if (values.modeANDcondition == 2) expressions.fineoutcome600placebo    //so: if not fine granularity then placebofine is placebo and fine1000 if experience or exp+histo
    else expressions.fineoutcome1000
</expressions>

// *****************************************
// ** Text for debugging*
<text techdetails>
    / items = ("chosen randomvalue= <%values.randomvalue%> 
	~n cumulativeprobabilitiesA8=<%expressions.cumulativeprobabilitiesA8%>~n cumulativeprobabilitiesA1 =<%expressions.cumulativeprobabilitiesA1%> 
	~n listoutcomes 11 and 1= <%list.outcomes.11%> and <%list.outcomes.1%>
  	~n <%values.count0%> <%values.count1%> <%values.count2%> <%values.count3%> <%values.count4%> <%values.count5%> <%values.count6%> <%values.count7%> <%values.count8%> <%values.count9%> <%values.count10%>")
    / fontstyle = ("Arial", 12pt)
    / txcolor = (0, 30, 30)
    / position = (70%, 30%)
</text>


--------------DETECTS ERROR IN DISTRIBUTIONPROBABILITIES (not summing to 100)****************RUN FIRST IN EXPERIMENT
<text errorinscript>
    / items = ("Note to script: prob does not sum to 100 (but <%values.totalprob%> Press space to continue")
	/ fontstyle = ("Arial", 12pt)
    / txcolor = (0, 30, 30)
    / position = (50%, 50%)
</text>
<trial checkerrorpercentages>
	/ ontrialbegin = [values.totalprobA=100*(list.probabilitiesA.1+list.probabilitiesA.2+list.probabilitiesA.3+list.probabilitiesA.4+list.probabilitiesA.5+list.probabilitiesA.6+list.probabilitiesA.7+list.probabilitiesA.8+list.probabilitiesA.9+list.probabilitiesA.10+list.probabilitiesA.11)]
	/ ontrialbegin = [values.totalprobB=100*(list.probabilitiesB.1+list.probabilitiesB.2+list.probabilitiesB.3+list.probabilitiesB.4+list.probabilitiesB.5+list.probabilitiesB.6+list.probabilitiesB.7+list.probabilitiesB.8+list.probabilitiesB.9+list.probabilitiesB.10+list.probabilitiesB.11)]
	/ response = timeout(10)
	/ branch = [if ((values.totalprobA!=100) || (values.totalprobB!=100)) trial.errorpercentages]
</trial>
<trial errorpercentages>
    / stimulusframes = [1=errorinscript]
	/ response = correct
	/ correctresponse = (" ")
</trial>


