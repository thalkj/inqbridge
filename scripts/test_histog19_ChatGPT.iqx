//CHECK ATTENTION IN REVEAL-TRIALS
<openended PreviousOutcomeCheckPlacebo>
/ stimulusframes = [1=whatwastheprevious]
/ position = (50%, 50%)
/ mask = alphabetic
/ charlimit = 2
/ correctresponse= (values.actplacebooutcome)
/ correctmessage = true(correctprevious, 3000) 
/ errormessage = true(incorrectprevious, 7000)
/ linelength = 3
/ multiline = false
</openended>

<openended PreviousOutcomeCheck>
/ stimulusframes = [1=whatwastheprevious]
/ position = (50%, 50%)
/ correctresponse= (values.actoutcome)
/ mask = integer
/ charlimit = 2
/ correctmessage = true(correctprevious, 3000) 
/ errormessage = true(incorrectprevious, 7000)
/ linelength = 3
/ multiline = false
</openended>


<text whatwastheprevious>
    / items = ("What was the rating you just observed?")
    / fontstyle = ("Arial", 4%)
    / txcolor = (0, 0, 255)
    / position = (50%, 15%)
</text>


<text correctprevious>
    / items = ("Correct!")
    / fontstyle = ("Arial", 4%)
    / txcolor = (0, 0, 255)
    / position = (50%, 50%)
</text>

<text incorrectprevious>
    / items = ("Incorrect answer, please pay attention")
    / fontstyle = ("Arial", 4%)
    / txcolor = (0, 0, 255)
    / position = (50%, 50%)
</text>





