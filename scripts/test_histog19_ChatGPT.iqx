//******************** LEARNVISUALANALOGUE BLOCK ********************
//***********************************************************
*Trials
<trial reset_analogue>
/ ontrialbegin = [values.lastresponse = 0]
/ ontrialbegin = [values.hpositionAvalue = 0]
/ ontrialbegin = [values.displayvalue = ""]
/ ontrialbegin = [values.numberofmouseadjust = 0]
/ stimulusframes = [1=blank]
/ response= timeout(1)
</trial>
<shape blank>
/ shape = rectangle
/ color = (255,255,255)
/ position = (50%, 50%)
/ size = (100%, 100%)
</shape>

*VISUAL ANALOGUE, STIMULI. 
*Buttons
<text continuetxt>
/ items= (" Continue ")
/ fontstyle = ("Tahoma", 2.81%, false, false, false, false, 5, 1)
/ position = (50, 35)
/ txbgcolor = lightgrey
</text>
*Response line and scale
<shape line>
/ shape = rectangle
/ color	=black
/ size = (90%, 3.5%)
/ position = (50, 25)
/ erase = false
</shape>
<text leftanchormin>
/ items = ("<%expressions.scalemin%>")
/ position = (5%, 21%)
/ fontstyle = ("Tahoma", 2.81%, false, false, false, false, 5, 1)
/ erase = false
</text>
<text rightanchormax>
/ items = ("<%values.scalemaxdisplayed%>")
/ position = (95%, 21%)
/ fontstyle = ("Tahoma", 2.81%, false, false, false, false, 5, 1)
/ erase = false
</text>
*Indicator
<text X>
/ fontstyle = ("Arial", 3.4%, false, false, false, false, 5, 0)
/ items = ("|")
/ txcolor = (255, 0, 0)
/ txbgcolor = (transparent)
/ hposition = values.hpositionAvalue
/ vposition = shape.line.vposition
</text>

*Instructions to scale
<text question1>
/ items = ("You may adjust your response by clicking again")
/ fontstyle = ("Tahoma", 2.1%, false, false, false, false, 5, 1)
/ position = (50%, 11.5%)
/ erase = false
</text>
<text lastresponsevalue>
/ items = ("Your prediction: <%values.displayvalue%>")
/ fontstyle = ("Tahoma", 2.3%, true, false, false, false, 5, 1)
/ position = (50%, 20%)
</text>
<text Predtext1>
/ items = ("Please predict the next rating.")
/ position = (50%, 6%)
/ fontstyle = ("Tahoma", 2.1%, true, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
</text>

<text Task1>
/ onPrepare = [text.Task1.skip = (values.activetasknr!=1);]
/ items = ("Let's try to use the below response scale. Please use the scale to predict what is the next number in this series: 0  2  4  6  ...  
~nPlease provide your prediction by clicking on the black line. If needed, you can click multiple times to adjust your prediction")
/ position = (50%, 5%)
/ vAlign = top
/ fontstyle = ("Tahoma", 2.1%, false, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
</text>


<text Task2>
/ onPrepare = [text.Task2.skip = (values.activetasknr!=2);]
/ items = ("Ok, just to practice once more with the response scale. Please set the prediction to the value '2' by clicking the line below")
/ size = (98%, 10%)
/ position = (50%, 5%)
/ vAlign = top
/ fontstyle = ("Tahoma", 2.1%, false, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
</text>


<trial learnvisualanalogue>
/ ontrialbegin = [if (values.numberofmouseadjust== 0) values.predtimer=script.elapsedtime]
/ stimulusframes = [1= Task1, Task2, continuetxt, lastresponsevalue, line, X,
leftanchormin, rightanchormax]
/ inputdevice = mouse
/ validresponse = (line, continuetxt)
/ correctresponse= (continuetxt)
/ branch = [if (trial.learnvisualanalogue.correct==0) trial.learnvisualanalogue]
/ ontrialend = [values.responsexscore=trial.learnvisualanalogue.responsex]
/ ontrialend = [if (trial.learnvisualanalogue.response=="line") values.lastresponse=expressions.actualscore]
/ ontrialend = [if (trial.learnvisualanalogue.correct==0) values.hpositionAvalue=expressions.tunepos]
/ ontrialend = [if (trial.learnvisualanalogue.correct==0 && trial.learnvisualanalogue.response=="line") values.numberofmouseadjust=values.numberofmouseadjust+1]
/ ontrialend = [if (trial.learnvisualanalogue.correct==1) values.predtimer= script.elapsedtime-values.predtimer]
/ ontrialend = [values.currentprediction=expressions.lastresponsedisplayed]
/ ontrialend = [values.displayvalue= format("%d", values.currentprediction)]
/ ontrialend = [list.predictions.appenditem(values.currentprediction); list.actuals.appenditem(values.actoutcome)]
</trial>

<block learnvisualanalogueblock1>
/ onBlockBegin = [values.activetasknr = 1]
/ trials = [1=learnvisualanalogue; 2= reset_analogue]
</block>

<block learnvisualanalogueblock2>
/ onBlockBegin = [values.activetasknr = 2]
/ trials = [1=learnvisualanalogue]
</block>


