// *****************************************
// ** LEARNING HISTO TRIALS
<trial revealsimplyspace>
/ stimulustimes = [1=revealsimplyfirst, revealsimplyspace]
/ response = correct
/ correctresponse = (" ")
</trial>

<trial learnhistoanimate1>
    / ontrialbegin = [values.randomvalue=expressions.randomvalue; values.actoutcome = expressions.outcomevaluelearning;]
	/ ontrialbegin = [if(values.actoutcome == 0) values.count0 +=1; //mulig eg må bruke brackets eller tabort semicolon
	else if(values.actoutcome == 1) values.count1 +=1;
	else if(values.actoutcome == 2) values.count2 +=1;
	else if(values.actoutcome == 3) values.count3 +=1;
	else if(values.actoutcome == 4) values.count4 +=1;
	else if(values.actoutcome == 5) values.count5 +=1;]
    / stimulustimes = [1=revealsimplyfirst,revealsimplyb; 1000=dot1;1500=dot2;2000=dot3;
	2500=reveal2preclear, reveal2;5000=letskeep;
	6500= historicalinfo, freq_axis, value_axis, freq0, freq10, freq20, titlexaxis,
	bin0_label, bin1_label, bin2_label, bin3_label, bin4_label, bin5_label; 
	9500=animation1, animation1b, animation1c; 12500=bin0, bin1, bin2, bin3, bin4, bin5; 14000=letskeep2, press_space;]
    / response = correct
	/ correctresponse = (" ")
</trial>
<trial learnhistoanimate2>
    / ontrialbegin = [values.randomvalue=expressions.randomvalue; values.actoutcome = expressions.outcomevaluelearning]
	/ ontrialbegin = [if(values.actoutcome == 0) values.count0 +=1;
	else if(values.actoutcome == 1) values.count1 +=1;
	else if(values.actoutcome == 2) values.count2 +=1;
	else if(values.actoutcome == 3) values.count3 +=1;
	else if(values.actoutcome == 4) values.count4 +=1;
	else if(values.actoutcome == 5) values.count5 +=1]
    / stimulustimes = [1=revealsimply, revealsimplyb, historicalinfo, freq_axis, value_axis, freq0, freq10, freq20, titlexaxis,
	bin0_label, bin1_label, bin2_label, bin3_label, bin4_label, bin5_label;
	1000=dot1;1500=dot2;2000=dot3;
	2500=reveal2preclear, reveal2;3300=arrow1, arrow1b, arrow1c;3500=deletearrow;3700=arrow1, arrow1b, arrow1c;3900=deletearrow;4100=arrow1, arrow1b, arrow1c, bin0, bin1, bin2, bin3, bin4, bin5; 4100=press_space]
    / response = correct
	/ correctresponse = (" ")
</trial>


<block learning_histBlock>
/ onBlockBegin = [values.histogincrement=1.2;values.cond]
    / trials = [1=checkerrorpercentages;2=revealsimplyspace, learnhistoanimate1; 3-10=learnhistoanimate2]
	/ onblockend = [values.count0 = 0; values.count1 = 0;	values.count2 = 0; values.count3 = 0; values.count4 = 0; values.count5 = 0; values.count6 = 0; values.count7 = 0; values.count8 = 0; values.count9 = 0; values.count10 = 0]
	/ postinstructions = (afterhistostack)
</block>

_____________________________________Instructions for learning histogram:
<page noneed>
From now on the blocks will just pile up without the arrow indicating the stack that increased
^.
</page>

<page afterhistostack>
You got it, right? The counting of the ratings were made using a so-called histogram. Please try to answer a few questions regarding another histogram on the next page.
</page>







//***KNOWELDGE TEST FOR HISTOGRAM
<text learnhistogram>
/ items = ("The next task concerns the understanding of histograms. Like just shown to you, a histogram is a type of bar chart that can illustrate how many number of units one has when things differ in size or magnitude. For example one can show the distribution marks 
in a school or the distribution of height in a group of people.")
/ position = (50%, 50%)
/ size = (80%, 30%)
</text>


<text examplehistogram1>
/ items = ("The histogram to the right shows ~nthe number of marks in a school. ~n~nHow many tests are graded E in that school?")
/ position = (30%, 50%)
/ halign = center
/ fontstyle = ("Tahoma", 3%, false, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text examplehistogram2>
/ items = ("The histogram to the right shows the number of ~nindividuals for different categories of height, ~nfor example, there are ~n8 individuals between 150 and 155 cm and none ~nbetween 195 and 200.")
/ position = (30%, 25%)
/ halign = center
/ fontstyle = ("Tahoma", 2.5%, false, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text examplehistogram2b>
/ items = ("How many individuals are ~nbetween 160 and 165 centimeters tall?")
/ position = (30%, 57%)
/ halign = center
/ fontstyle = ("Tahoma", 3%, false, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<text examplehistogram2c>
/ items = ("And how many individuals ~nare between 170 and 175 centimeters tall?")
/ position = (30%, 57%)
/ halign = center
/ fontstyle = ("Tahoma", 3%, false, false, false, false, 5, 1)
/ size = (80%, 10%)
</text>

<picture histograde>
   / items = ("histogrammarks2.jpg")
   / position = (73%, 50%)
   / size = (50%, 50%)
</picture>

<picture histoheight>
   / items = ("heights_histogram_custom2.jpg")
   / position = (73%, 50%)
   / size = (50%, 50%)
</picture>

<openended gradeQ1>
/ stimulusframes = [1=examplehistogram1, histograde]
/ mask = integer
/ charlimit = 5
/ multiline = false
/ position = (30%, 70%)
/ size = (10%, 3.2%)
/ halign = center
/ ontrialend = [if (trial.gradeQ1.response == 25) values.correcthistanswers +=1]
</openended>

<openended heightQ1>
/ stimulusframes = [1=examplehistogram2, examplehistogram2b, histoheight]
/ mask = integer
/ charlimit = 5
/ multiline = false
/ position = (30%, 70%)
/ size = (10%, 3.2%)
/ halign = center
/ ontrialend = [if (trial.heightQ1.response == 25) values.correcthistanswers +=1]
/ ontrialend = [if (trial.heightQ1.response == 24) values.correcthistanswers +=1]
/ ontrialend = [if (trial.heightQ1.response == 26) values.correcthistanswers +=1]
</openended>

<openended heightQ2>
/ stimulusframes = [1=examplehistogram2c, histoheight]
/ mask = integer
/ charlimit = 5
/ multiline = false
/ position = (30%, 70%)
/ size = (10%, 3.2%)
/ halign = center
/ ontrialend = [if (trial.heightQ2.response == 40) values.correcthistanswers +=1]
</openended>

<block testlearn_histoBlock>
/ trials = [1=heightQ1, heightQ2]
/ branch = [
    if (values.correcthistanswers < 2) {
        return block.incorrect_learn_histoBlock;
    } else {
        return block.correct_learn_histoBlock;
    };
]
</block>

**branched + branched blocks
<block correct_learn_histoBlock>
/ preInstructions = (nicework)
</block>

<block incorrect_learn_histoBlock>
/ preInstructions = (failedknowledgetest)
/ branch = [block.learning_histBlock]
</block>

________________________________instructions testlearn_histo
<page nicework>
Great! You got all the answers right. 
</page>

<page failedknowledgetest>
Hmmm.. those were not the right answers. Let us try the basics again by looking at how the frequencies are counted using a histogram.
</page>



