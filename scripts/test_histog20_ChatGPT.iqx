<shape freq_axis>
    / shape = rectangle
    / color = (0, 0, 0) // Black line
    / size = (0.1%, 27%) // Thin vertical line, spanning most of the height
    / position = (7%, 90%) // Positioned near the left and centered vertically
    / valign = bottom
</shape>

<shape value_axis>
    / shape = rectangle
    / color = (0, 0, 0) // Black line
    / size = (20%, 0.1%) // Thin horizontal line for learning histogram (6 bins)
    / position = (7%, 90%)
    / halign = left
</shape>

