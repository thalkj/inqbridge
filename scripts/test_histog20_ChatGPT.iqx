/ response = timeout(2000)
</trial>

-----------------EXPERIENCE ONLY
<trial predictnextexp1VisAna>  
/ ontrialbegin = [if (values.showfine==0) values.scalemaxdisplayed=10 else values.scalemaxdisplayed=1000;
				values.randomvalue = expressions.randomvalue; 
				if (values.posskew == 1) { values.actoutcome = expressions.outcomevalueA; } else { values.actoutcome = expressions.outcomevalueB; };
				if (values.numberofmouseadjust== 0) values.predtimer=script.elapsedtime;]
/ stimulusframes = [1=restaurantInstructions_small, restaurantInstructions_small_placebo, hiddenactoutcome, whatnext, Predtext2, continuetxt, lastresponsevalue, line, X,
leftanchormin, rightanchormax]
/ inputdevice = mouse
/ validresponse = (line, continuetxt)
/ correctresponse= (continuetxt)
/ branch = [if (trial.predictnextexp1VisAna.correct==0) trial.predictnextexp1VisAna]
/ ontrialend = [values.responsexscore=trial.predictnextexp1VisAna.responsex]
/ ontrialend = [if (trial.predictnextexp1VisAna.response=="line") values.lastresponse=expressions.actualscore]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct==0) values.hpositionAvalue=expressions.tunepos]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct==0 && trial.predictnextexp1VisAna.response=="line") values.numberofmouseadjust=values.numberofmouseadjust+1]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct==1) values.predtimer= script.elapsedtime-values.predtimer]
// Display update during adjustment loop (runs every iteration where line was clicked)
/ ontrialend = [if (values.numberofmouseadjust > 0) {values.currentprediction = expressions.lastresponsedisplayed; values.displayvalue = format("%d", values.currentprediction);}]
// On final Continue: set -99 if no prediction was made, otherwise finalize value
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.numberofmouseadjust == 0) {values.currentprediction = -99; values.displayvalue = "N.A.";}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.numberofmouseadjust > 0) {values.currentprediction = expressions.lastresponsedisplayed; values.displayvalue = format("%d", values.currentprediction);}]
// Save to lists and numbered values (only on final Continue)
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1) {values.pred_counter = values.pred_counter + 1; list.predictions.appenditem(values.currentprediction); list.actuals.appenditem(values.actoutcome);}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.pred_counter == 1) {values.prediction1 = values.currentprediction; values.actual1 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.pred_counter == 2) {values.prediction2 = values.currentprediction; values.actual2 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.pred_counter == 3) {values.prediction3 = values.currentprediction; values.actual3 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.pred_counter == 4) {values.prediction4 = values.currentprediction; values.actual4 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextexp1VisAna.correct == 1 && values.pred_counter == 5) {values.prediction5 = values.currentprediction; values.actual5 = values.actoutcome;}]
</trial>
