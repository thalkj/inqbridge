/ ontrialend = [if (trial.predictnextdesc1VisAna.correct == 1 && values.pred_counter == 1) {values.prediction1 = values.currentprediction; values.actual1 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextdesc1VisAna.correct == 1 && values.pred_counter == 2) {values.prediction2 = values.currentprediction; values.actual2 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextdesc1VisAna.correct == 1 && values.pred_counter == 3) {values.prediction3 = values.currentprediction; values.actual3 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextdesc1VisAna.correct == 1 && values.pred_counter == 4) {values.prediction4 = values.currentprediction; values.actual4 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextdesc1VisAna.correct == 1 && values.pred_counter == 5) {values.prediction5 = values.currentprediction; values.actual5 = values.actoutcome;}]
</trial>

// Both condition (experience + histogram): same as description but with own self-references
<trial predictnextboth1VisAna>
/ ontrialbegin = [if (values.showfine==0) values.scalemaxdisplayed=10 else values.scalemaxdisplayed=1000;
					values.randomvalue = expressions.randomvalue; if (values.posskew == 1) { values.actoutcome = expressions.outcomevalueA; } else { values.actoutcome = expressions.outcomevalueB; };
					if (values.numberofmouseadjust== 0) values.predtimer=script.elapsedtime;]
/ stimulusframes = [1= restaurantInstructions_small, restaurantInstructions_small_placebo, hiddenactoutcome, whatnext, Predtext2, continuetxt, lastresponsevalue, line, X,
						leftanchormin, rightanchormax, historicalinfo, freq_axis_large, value_axis_large, freq0, freq10, freq20, freq30, bin0, bin1, bin2, bin3, bin4, bin5, bin6, bin7, bin8, bin9, bin10, bin0_label, bin1_label, bin2_label, bin3_label, bin4_label, bin5_label, bin6_label, bin7_label, bin8_label, bin9_label, bin10_label,
						bin0_label1000, bin1_label1000, bin2_label1000, bin3_label1000, bin4_label1000, bin5_label1000, bin6_label1000, bin7_label1000, bin8_label1000, bin9_label1000, bin10_label1000]
/ inputdevice = mouse
/ validresponse = (line, continuetxt)
/ correctresponse= (continuetxt)
/ branch = [if (trial.predictnextboth1VisAna.correct==0) trial.predictnextboth1VisAna]
/ ontrialend = [values.responsexscore=trial.predictnextboth1VisAna.responsex]
/ ontrialend = [if (trial.predictnextboth1VisAna.response=="line") values.lastresponse=expressions.actualscore]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct==0) values.hpositionAvalue=expressions.tunepos]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct==0 && trial.predictnextboth1VisAna.response=="line") values.numberofmouseadjust=values.numberofmouseadjust+1]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct==1) values.predtimer= script.elapsedtime-values.predtimer]
/ ontrialend = [if (values.numberofmouseadjust > 0) {values.currentprediction = expressions.lastresponsedisplayed; values.displayvalue = format("%d", values.currentprediction);}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.numberofmouseadjust == 0) {values.currentprediction = -99; values.displayvalue = "N.A.";}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.numberofmouseadjust > 0) {values.currentprediction = expressions.lastresponsedisplayed; values.displayvalue = format("%d", values.currentprediction);}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1) {values.pred_counter = values.pred_counter + 1; list.predictions.appenditem(values.currentprediction); list.actuals.appenditem(values.actoutcome);}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.pred_counter == 1) {values.prediction1 = values.currentprediction; values.actual1 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.pred_counter == 2) {values.prediction2 = values.currentprediction; values.actual2 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.pred_counter == 3) {values.prediction3 = values.currentprediction; values.actual3 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.pred_counter == 4) {values.prediction4 = values.currentprediction; values.actual4 = values.actoutcome;}]
/ ontrialend = [if (trial.predictnextboth1VisAna.correct == 1 && values.pred_counter == 5) {values.prediction5 = values.currentprediction; values.actual5 = values.actoutcome;}]
</trial>


---------------------------5 next prediction blocks
<block predictnext5expVisAna>
/ onblockbegin = [list.predictions.reset(); list.actuals.reset(); values.pred_counter = 0;
    values.prediction1 = -99; values.prediction2 = -99; values.prediction3 = -99; values.prediction4 = -99; values.prediction5 = -99;
    values.actual1 = -99; values.actual2 = -99; values.actual3 = -99; values.actual4 = -99; values.actual5 = -99]
/ preinstructions = (startingpred_exp)
/ trials = [
    1               = reset_analogue;
    2, 5, 8, 11, 14 = predictnextexp1VisAna;
    3, 6, 9, 12     = reset_analogue;
    4               = andthenextrating;
    7, 10, 13       = andthenext]
// postinstructions moved to predictionresultspage block (shown after survey)
</block>

<block predictnext5descVisAna>
/ onblockbegin = [list.predictions.reset(); list.actuals.reset(); values.pred_counter = 0;
    values.prediction1 = -99; values.prediction2 = -99; values.prediction3 = -99; values.prediction4 = -99; values.prediction5 = -99;
    values.actual1 = -99; values.actual2 = -99; values.actual3 = -99; values.actual4 = -99; values.actual5 = -99]
/ preinstructions = (startingpred_desc)
/ trials = [
    1               = reset_analogue;
    2, 5, 8, 11, 14 = predictnextdesc1VisAna;
    3, 6, 9, 12     = reset_analogue;
    4               = andthenextrating;
    7, 10, 13       = andthenext]
// postinstructions moved to predictionresultspage block (shown after survey)
</block>

<block predictnext5bothVisAna>
/ onblockbegin = [list.predictions.reset(); list.actuals.reset(); values.pred_counter = 0;
    values.prediction1 = -99; values.prediction2 = -99; values.prediction3 = -99; values.prediction4 = -99; values.prediction5 = -99;
    values.actual1 = -99; values.actual2 = -99; values.actual3 = -99; values.actual4 = -99; values.actual5 = -99]
/ preinstructions = (startingpred_both)
/ trials = [
    1               = reset_analogue;
    2, 5, 8, 11, 14 = predictnextboth1VisAna;
    3, 6, 9, 12     = reset_analogue;
    4               = andthenextrating;
    7, 10, 13       = andthenext]
// postinstructions moved to predictionresultspage block (shown after survey)
</block>


-------------------------------INSTRUCTIONS FOR PREDICTIONS
**************************************************************************************************

------------------prediction trial stimulus common to all below
<text hiddenactoutcome>
/ items = ("<%values.actoutcome%>")
/ position = (100%, 100%)
/ color =white 
</text>

<text whatnext>
/ items = ("What is your prediction of the next rating?")
/ position = (50%, 12%)
</text>

<text andthenextrating>
/ items = ("And your prediction of the next rating after that?")
/ position = (50%, 12%)
</text>

<text andthenext>
/ items = ("And the next?")
/ position = (50%, 12%)
</text>


<page startingpred_exp>
Now a short break. You have observed a series of customer ratings for Ristorante Italo.
~nOn the next page your task is to predict the next five ratings for this restaurant. The customers rate on a scale from 0 (worst) to 10 (best). Use the response scale to indicate each prediction.
</page>

<page startingpred_desc>
Now a short break. You have observed a series of ratings displayed in a histogram.
~nOn the next page you will use this histogram information to predict the next five ratings. The ratings are on a scale from 0 (worst) to 10 (best), and the histogram showing the frequency of past ratings will remain visible. Use the response scale to indicate each prediction.
</page>

<page startingpred_both>
Now a short break. You have observed a series of customer ratings for Ristorante Italo, along with a histogram showing the distribution of all ratings so far.
~nOn the next page your task is to predict the next five ratings. The customers rate on a scale from 0 (worst) to 10 (best), and the histogram will remain visible. Use the response scale to indicate each prediction.
</page>

**postinstruxctiorn
<page yourresults>
Thanks for your predictions. Here are your results compared with the customer ratings:~n~n

First prediction: <% values.displayprediction1 %>     —     Actual: <% values.actual1 %>~n
 Second prediction: <% values.displayprediction2 %>     —     Actual: <% values.actual2 %>~n
 Third prediction: <% values.displayprediction3 %>     —     Actual: <% values.actual3 %>~n
 Fourth prediction: <% values.displayprediction4 %>     —     Actual: <% values.actual4 %>~n
 Fifth prediction: <% values.displayprediction5 %>     —     Actual: <% values.actual5 %>~n
</page>

<block predictionresultspage>
/ preinstructions = (yourresults)
</block>

//**************************************************
//*************************************************
// EVALUATE BLOCK
// After each round of 5 predictions, participants evaluate each prediction error
// one by one. For each of the 5 predictions, they see their prediction vs actual
// and rate how happy they are with the result on a vertical VAS with smiley face anchors.
// This mirrors the evaluation pattern from micpred_keys.
//*************************************************

// --- Instruction page before evaluation ---
<page evaluateInstructions>
Now you will see how each of your predictions compared to the actual customer rating.~n~n
For each prediction, please indicate how satisfied you are with the accuracy of your prediction by clicking on the vertical line.~n~n
Press the spacebar to continue.
</page>

// --- Smiley face images for VAS anchors ---
<item bilder1>
/1="bilde1.jpg"
</item>
<item bilder2>
/1="bilde2.jpg"
</item>
<item bilder3>
/1="bilde3.jpg"
</item>

// --- Smiley face images for vertical satisfaction scale ---
// Sad face near bottom of vertical scale (dissatisfied)
<picture bildeein>
/ items = bilder1
/ position = (78%, 82%)
/ size = (8%, 8%)
</picture>

// Neutral face at middle of vertical scale
<picture bildeto>
/ items = bilder2
/ position = (78%, 50%)
/ size = (8%, 8%)
</picture>

// Happy face near top of vertical scale (satisfied)
<picture bildetre>
/ items = bilder3
/ position = (78%, 18%)
/ size = (8%, 8%)
</picture>

// --- Vertical VAS elements for satisfaction rating ---
// Vertical response line (right side of screen)
<shape lineVERT>
/ shape = rectangle
/ color = black
/ size = (2%, 60%)
/ position = (70%, 50%)
/ erase = false
</shape>

// Horizontal marker on the vertical line (shows current selection)
<text XVERT>
/ fontstyle = ("Arial", 7%, false, false, false, false, 5, 0)
/ items = ("--")
/ txcolor = (0, 0, 255)
/ txbgcolor = (transparent)
/ hposition = shape.lineVERT.hposition
/ vposition = values.eval_vpositionVERT
</text>

// Continue button for vertical VAS
<text continuetxtVERT>
/ items = (" Continue ")
/ fontstyle = ("Tahoma", 2.81%, false, false, false, false, 5, 1)
/ position = (92%, 50%)
/ txbgcolor = lightgrey
</text>

// --- Text elements for individual prediction error evaluation ---
// Ordinal label ("First prediction", "Second prediction", etc.) — shown 500ms before rest
<text eval_pe_ordinal>
/ items = ("<%values.eval_ordinal_label%>")
/ position = (30%, 15%)
/ fontstyle = ("Tahoma", 3.5%, true, false, false, false, 5, 1)
/ txcolor = (0, 0, 0)
</text>

// Shows current prediction vs actual (updated each iteration via eval_set_next)
<text eval_pe_display>
/ items = ("Your prediction:  <%values.eval_display_current%>~nActual rating:      <%values.eval_current_actual%>")
/ position = (30%, 35%)
/ size = (50%, 20%)
/ fontstyle = ("Tahoma", 3%, false, false, false, false, 5, 1)
</text>

<text eval_satisfactionquestion>
/ items = ("How satisfied are you with the accuracy of this prediction?~nPlease click the vertical line to indicate your satisfaction, then click Continue.")
/ size = (50%, 20%)
/ position = (30%, 65%)
/ fontstyle = ("Tahoma", 2%, false, false, false, false, 5, 1)
</text>

// --- Hidden text elements to record evaluation data in data file ---
<text eval_satisfaction01_record>
/ items = ("<%values.eval_satisfaction01%>")
/ position = (-10%, -10%)
/ fontstyle = ("Arial", 1%, false, false, false, false, 5, 1)
</text>

<text eval_round_record>
/ items = ("<%values.eval_round%>")
/ position = (-10%, -10%)
/ fontstyle = ("Arial", 1%, false, false, false, false, 5, 1)
</text>

<text eval_prednum_record>
/ items = ("<%values.eval_currentpred_num%>")
/ position = (-10%, -10%)
/ fontstyle = ("Arial", 1%, false, false, false, false, 5, 1)
</text>

// --- Trials ---

// 500ms blank screen between evaluations (gives visual separation)
<trial eval_blank_screen>
/ response = timeout(500)
</trial>

// Set up the next prediction error for evaluation: increments counter,
// loads current prediction/actual from numbered values, resets the vertical VAS,
// sets ordinal label and display string (handles -99 → "N.A.")
<trial eval_set_next>
/ ontrialbegin = [values.eval_currentpred_num = values.eval_currentpred_num + 1]
/ ontrialbegin = [if (values.eval_currentpred_num == 1) {
    values.eval_current_prediction = values.prediction1; values.eval_current_actual = values.actual1;
    values.eval_ordinal_label = "First prediction";
    if (values.prediction1 == -99) values.eval_display_current = "N.A." else values.eval_display_current = format("%d", values.prediction1);
}]
/ ontrialbegin = [if (values.eval_currentpred_num == 2) {
    values.eval_current_prediction = values.prediction2; values.eval_current_actual = values.actual2;
    values.eval_ordinal_label = "Second prediction";
    if (values.prediction2 == -99) values.eval_display_current = "N.A." else values.eval_display_current = format("%d", values.prediction2);
}]
/ ontrialbegin = [if (values.eval_currentpred_num == 3) {
    values.eval_current_prediction = values.prediction3; values.eval_current_actual = values.actual3;
    values.eval_ordinal_label = "Third prediction";
    if (values.prediction3 == -99) values.eval_display_current = "N.A." else values.eval_display_current = format("%d", values.prediction3);
}]
/ ontrialbegin = [if (values.eval_currentpred_num == 4) {
    values.eval_current_prediction = values.prediction4; values.eval_current_actual = values.actual4;
    values.eval_ordinal_label = "Fourth prediction";
    if (values.prediction4 == -99) values.eval_display_current = "N.A." else values.eval_display_current = format("%d", values.prediction4);
}]
/ ontrialbegin = [if (values.eval_currentpred_num == 5) {
    values.eval_current_prediction = values.prediction5; values.eval_current_actual = values.actual5;
    values.eval_ordinal_label = "Fifth prediction";
    if (values.prediction5 == -99) values.eval_display_current = "N.A." else values.eval_display_current = format("%d", values.prediction5);
}]
/ ontrialbegin = [values.eval_vpositionVERT = -10; values.eval_satisfaction_y = -10; values.eval_satisfaction_raw = 0; values.eval_numberofmouseadjustVERT = 0]
/ response = timeout(0)
</trial>

// Satisfaction rating on vertical VAS with smiley face anchors
// Shows ordinal label at 0ms, then PE display + VAS + smileys at 500ms
<trial eval_satisfaction_trial>
/ ontrialbegin = [if (values.eval_numberofmouseadjustVERT == 0) values.predtimer = script.elapsedtime]
/ stimulustimes = [0=eval_pe_ordinal; 500=eval_pe_display, eval_satisfactionquestion, continuetxtVERT, lineVERT, XVERT, bildeein, bildeto, bildetre]
/ inputdevice = mouse
/ validresponse = (lineVERT, continuetxtVERT)
/ correctresponse = (continuetxtVERT)
/ branch = [if (trial.eval_satisfaction_trial.correct == 0) trial.eval_satisfaction_trial]
/ ontrialend = [values.eval_satisfaction_y = trial.eval_satisfaction_trial.responsey]
/ ontrialend = [if (trial.eval_satisfaction_trial.response == "lineVERT") values.eval_satisfaction_raw = expressions.actualscoreVERT]
/ ontrialend = [if (trial.eval_satisfaction_trial.correct == 0) values.eval_vpositionVERT = expressions.tuneposVERT]
/ ontrialend = [if (trial.eval_satisfaction_trial.correct == 0 && trial.eval_satisfaction_trial.response == "lineVERT") values.eval_numberofmouseadjustVERT = values.eval_numberofmouseadjustVERT + 1]
/ ontrialend = [if (trial.eval_satisfaction_trial.correct == 1) values.eval_satisfaction01 = expressions.eval_satisfaction01_calc]
</trial>

// Save evaluation data for this single prediction error (timeout=0 records to data file)
<trial eval_save_single>
/ stimulusframes = [1=eval_satisfaction01_record, eval_round_record, eval_prednum_record]
/ response = timeout(0)
</trial>

// --- The evaluation block ---
// 5 iterations of: blank screen → set_next → satisfaction rating → save
<block evaluateBlock>
/ preinstructions = (evaluateInstructions)
/ onblockbegin = [values.eval_round = values.eval_round + 1; values.eval_currentpred_num = 0;
    // Format display predictions for N.A. handling (used by yourresults page)
    if (values.prediction1 == -99) values.displayprediction1 = "N.A." else values.displayprediction1 = format("%d", values.prediction1);
    if (values.prediction2 == -99) values.displayprediction2 = "N.A." else values.displayprediction2 = format("%d", values.prediction2);
    if (values.prediction3 == -99) values.displayprediction3 = "N.A." else values.displayprediction3 = format("%d", values.prediction3);
    if (values.prediction4 == -99) values.displayprediction4 = "N.A." else values.displayprediction4 = format("%d", values.prediction4);
    if (values.prediction5 == -99) values.displayprediction5 = "N.A." else values.displayprediction5 = format("%d", values.prediction5);]
/ trials = [
    1, 5, 9, 13, 17  = eval_blank_screen;
    2, 6, 10, 14, 18  = eval_set_next;
    3, 7, 11, 15, 19 = eval_satisfaction_trial;
    4, 8, 12, 16, 20 = eval_save_single]
</block>

//**************************************************
//*************************************************
// SURVEY: CHECK AVERAGE AND MOST FREQUENT:
*******************************************************************************************
************************************CHECK MODE AND MEAN ***********************************
******************************************************************************************
<surveypage distributionunderstandingcheck>
/ caption = "Before we give you the results of your predictions, think about the customer ratings again and answer the following questions:"
/ questions = [1=meanQ; 2=modeQ; 3=maxQ; 4=minQ]
/ showpagenumbers = false
/ showquestionnumbers = false
/ showbackbutton = false
/ fontstyle = ("Arial", 2.3%, false, false, false, false, 5, 1)
</surveypage>

<textbox meanQ>
/ caption = "What do you think was the **average rating** (the mean)?"
</textbox>

<textbox modeQ>
/ caption = "What do you think was the **most frequent rating** (the mode)?"
</textbox>

<textbox maxQ>
/ caption = "What was the **highest rating** you saw?"
</textbox>

<textbox minQ>
/ caption = "What was the **lowest rating** you saw?"
</textbox>

<block distributionunderstandingcheck>
/ trials = [1=distributionunderstandingcheck]
</block>





//*************************************************************************************************************
//************************************************************************************************************
//*********                SAVE STUFF                                                           **************
//***********************************************************************************************************
//***datasavetrial for things I am not sure gets saved:
<text actualvaluesave>
/items = ("<%values.actoutcome%>")
/ position = (100%, 100%)
</text>

<text actualvaluefinesave>
/items = ("<%expressions.fineoutcome1000%>")
/ position = (100%, 100%)
</text>

<text fullestimatsave>
/items = ("<%values.lastresponse%>")
/ position = (100%, 100%)
</text>
<text displayedestimatesave>
/items = ("<%expressions.lastresponsedisplayed%>") 
/ position = (100%, 100%)
</text>
<text numberofmouse>
/items = ("<%values.numberofmouseadjust%>")
/ position = (100%, 100%)
</text>

*Savestuff, trial
<trial savedata>
/ stimulusframes = [1=actualvaluesave, actualvaluefinesave, fullestimatsave, displayedestimatesave, numberofmouse]
/ timeout = 0
/ ontrialend = [values.actoutcome = -1] //reset outcome value
</trial>

********************************************************************************************************************************************************************************************************************************************************************
**************************************************************************************************************************************************************************************************************************************************************





*************************************************************************************************************
************************************************************************************************************
*********                FINAL BLOCK, codes and stufdf                                        **************
***********************************************************************************************************
<text savecode>
/ items = ("Do not save code. Anonymous data")
</text>
// <text savecode> //commented out for anonymous data collection
// / items = ("kode<%values.randnumber%><%values.fakecorrect%>")
// </text>
<surveypage textboxlast>
/questions = [1=textboxlast]
/showpagenumbers = FALSE
/showbackbutton = FALSE
/showquestionnumbers = FALSE
/ fontstyle = ("Arial", 2.11%, false, false, false, false, 5, 1)
/caption="You have completed all tasks! Many thanks for your participation!
The purpose of this study is to investigate how people form predictions about ratings when they have different types of information available — direct experience with individual ratings, a summary histogram showing the distribution of past ratings, or both.
Understanding how people use distributional information to make predictions can help improve how we present data and support better decision-making.
If you have any questions please contact Torleif Halkjelsvik, Adjunct Research Scientist at Simula Metropolitan Centre for Digital Engineering, e-mail: torleif@simula.no"
</surveypage>
<text visetidenA>
/ items = ("<%script.elapsedtime%>")
</text>

*Final block, trials
<trial visetiden>
/ stimulusframes = [1=visetidenA, savecode]
/ timeout = 0
</trial>
<textbox textboxlast>
/caption= "Your MTurk code for submitting the HIT is <%values.randnumbersubmitcode%><%values.fakecorrect%> 
If you have any comments please write in the field below."
/textboxsize = (80%, 30%)
/ size = (80%, 30%)
/ multiline = true
/required = FALSE
</textbox>

*Final block, block
<block textboxlastBlock>
/onblockbegin = [values.randnumbersubmitcode= floor(rand(700,999))]
/trials=[1=visetiden; 2= textboxlast]
</block> 
